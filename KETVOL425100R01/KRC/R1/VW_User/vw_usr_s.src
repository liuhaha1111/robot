&ACCESS R7
&REL 280
&COMMENT KS_26_01_0083 VW (Tech_Basic)
&PARAM EDITMASK = vw_usr_s
&PARAM TEMPLATE = C:\KRC\Roboter\Template\vw_usr_sv
&PARAM TPUSER_VERSION = 8.3.0
&PARAM SUPPRESS = LoosOfPrecision UnswitchedEnum UnusedFunctionParameter
&PARAM DISKPATH = KRC:\R1\VW_User
DEF VW_USR_S(USER_CMD :IN,CMD_SEL :IN,PARA1 :IN,PARA2 :IN,PARA3 :IN,PARA4 :IN,PARA5 :IN,PARA6 :IN,PARA7 :IN,PARA8 :IN,PARA9 :IN,PARA10 :IN )
;FOLD ;%{H}%MKUKATPVW
;VW_USER Call
DECL VW_USER_CMD USER_CMD
REAL PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9
BOOL PARA10
INT CMD_SEL
SWITCH  USER_CMD
CASE #USR_INIT
USER_INIT ()
CASE #USR_SAW
USER_SAW ()
CASE #USR_RESET
USER_RESET ()
CASE #USR_CANCEL
USER_CANCEL ()
CASE #USR_LOOP
USER_LOOP ()
CASE #USR_MAKRO_SPS
USER_MAKRO_SPS (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_SAW
USER_MAKRO_SAW (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_STEP
USER_MAKRO_STEP (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_TRIG
USER_MAKRO_TRIG (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_NEUSTART
USER_MAKRO_NEUSTART (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_INIT_SUB1
USER_INIT_SUB1 ()
CASE #USR_INIT_SUB2
USER_INIT_SUB2 ()
CASE #USR_INIT_SUB3
USER_INIT_SUB3 ()
CASE #USR_INIT_SUB4
USER_INIT_SUB4 ()
CASE #USR_INIT_SUB5
USER_INIT_SUB5 ()
CASE #USR_MAKRO_SUB1
USER_MAKRO_SUBMIT1 (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_SUB2
USER_MAKRO_SUBMIT2 (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_SUB3
USER_MAKRO_SUBMIT3 (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_SUB4
USER_MAKRO_SUBMIT4 (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO_SUB5
USER_MAKRO_SUBMIT5 (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
DEFAULT
ENDSWITCH
END
;ENDFOLD
;
;***************************************************
;FOLD Init
DEF  USER_INIT ()
;Aufruf beim Start des SPS.SUB
;
;***************************************************
; Technologiepaket Basic                           *
;*                                                 *
;*Konzernstandard                                  *
;*Bearbeiter: C. Eisenknappl AUDI AG I/PG-C61      *
;*                                                 *
;* Aenderungsjournal:                              *
;* 07.08.2018 CE Palettier-Modus implementiert     *
;* 23.09.2019 CE Ruecksetzen Tool_Corr Base_corr   *
;*            angepasst.                           *
;* 10.01.2019 CE Modul NZ geändert                 *
;*                                                 *
;***************************************************
;
INT i
BOOL bRet
;
;Version Techpaket
Tech_Basic.Name[]="KS26.01.083_20191111"
;
;Vorbesetzung Meldungsausgabe
FOR i=1 TO 100
  n_USRS_Handle[i]=-1
  n_USRR_Handle[i]=-1
ENDFOR
bRet=Clear_KrlMsg(-99)
WAIT SEC 0.1
;
;TimerInit
Timer_USR_S=$ROB_TIMER
HM_Timer_USR_S=$ROB_TIMER
;
;Anlauf-Merker (Kaltstart)
B_Anlauf=TRUE
;
;Vorbesetzung MyOldTime ist MyNewTime (Kaltstart)
MyNewTime=$DATE
MyOldTime=MyNewTime
;
;Peripherie Sharing
IF PERI_GATEW1 THEN
  $OUT[3905]=FALSE
ENDIF
IF PERI_GATEW2 THEN
  $OUT[3937]=FALSE
ENDIF
;
;Hilfsflag fuer USER-Aufrufueberwachung ausschalten
USER_AKTIV=FALSE
;POT-Timer zuruecksetzen
$TIMER[TimerNr_POT]=0
;Hilfsflag fuer FRG Positionieren ausschalten
$FLAG[F_Frg_Servo]=FALSE
;
;Aufruf INIT Module
;G
G_INIT()  
;SZ
SZ_INIT()  
;STP
STP_INIT()
;SK 
SK_INIT()
;BZ
BZ_INIT()
;BZ
OE_INIT()
;LR
LR_INIT()
;CZ 
CZ_INIT()
;DS 
DS_INIT()
;FD
FD_INIT()
;KL
KL_INIT()
;MS
MS_INIT()
;BM
BM_INIT()
;NZ 
NZ_INIT()
;RW
RW_INIT()
;SFR
SFR_INIT()
;RE
RE_INIT()
;SR
SR_INIT()
;NK
NK_INIT()
;SM
SM_INIT()
;BU
BU_INIT()
;POT
POT_INIT()
;IPO
IPO_INIT()
;PGR
PGR_INIT()
;PR
PR_INIT()
;TR
TR_INIT()
;EKI
A_EKI_INIT()
;VW FE
VW_FE_INIT()
;VW_WA
VW_WA_INIT()
;PRC
PRC_INIT()
;INOS
INO_INIT()
;ZAI
ZAI_INIT()
;ISRA
ISR_INIT()
;VMT
VMT_INIT()
;VA
VA_INIT()
;MOD1
MOD1_INIT()
;MOD2
MOD2_INIT()
;MOD3
MOD3_INIT()
;RZ 
RZ_INIT(1)
;
;CONV
CONV_INIT()
;
END
;ENDFOLD
;
;***************************************************
;FOLD Satzanwahl
DEF  USER_SAW ()
;Aufruf bei Verlust der Satzkoinzidenz (z.B. Satzanwahl)
INT i
;
;Tool_corr + Base_corr ruecksetzen
IF NOT TouchupSaw_Active THEN
  Tool_Corr=$NULLFRAME
  Base_Corr=$NULLFRAME
ENDIF
;
;Hilfsflag fuer USER-Aufrufueberwachung ausschalten
USER_AKTIV=FALSE
;
;Hilfsflag fuer FRG Positionieren ausschalten
$FLAG[F_Frg_Servo]=FALSE
;
;Aufruf SAW Module
;G
G_SAW()  
;BZ
FOR i=1 TO 2
  IF MIT_BZ[i] THEN
    BZ_SAW(i)
  ENDIF  
ENDFOR
;OE
FOR i=1 TO 2
  IF MIT_OE[i] THEN
    OE_SAW(i)
  ENDIF  
ENDFOR
;LR
IF MIT_LR THEN
  LR_SAW( )
ENDIF  
;CZS
FOR i=1 TO 2
  IF MIT_CZS[i] OR MIT_CZP[i] THEN
    CZ_SAW(i)
  ENDIF
ENDFOR
;FD
FOR i=1 TO 2
  IF MIT_FD[i] THEN
    FD_SAW(i)
  ENDIF
ENDFOR  
;KL
FOR i=1 TO 3
  IF MIT_KL[i] THEN
    KL_SAW(i)
  ENDIF
ENDFOR  
;MS
FOR i=1 TO 2
  IF MIT_MS[i] THEN
    MS_SAW(i)
  ENDIF
ENDFOR  
;BM
FOR i=1 TO 3
  IF MIT_BM[i] THEN
    BM_SAW(i)
  ENDIF
ENDFOR  
;NZ
FOR i=1 TO 2
  IF MIT_NZS[i] OR MIT_NZH[i] THEN
    NZ_SAW(i)
  ENDIF
ENDFOR  
;RW
FOR i=1 TO 2
  IF MIT_RW[i] THEN
    RW_SAW(i)
  ENDIF
ENDFOR
;SFR
IF $SR_SAFEMON_ACTIVE THEN
  SFR_SAW( )
ENDIF
;SR
IF MIT_SR THEN
  SR_SAW( )
ENDIF
;RE
IF MIT_RE THEN
  RE_SAW( )
ENDIF
;NK
IF MIT_NK THEN
  NK_SAW( )
ENDIF
;SM
FOR i=1 TO 2
  IF MIT_SM[i] THEN
    SM_SAW(i)
  ENDIF
ENDFOR
;BU
IF MIT_BU THEN
  BU_SAW()
ENDIF
;STP
IF MIT_STP THEN
  STP_SAW( )
ENDIF  
;VA
IF MIT_VA THEN
  VA_SAW( )
ENDIF
;PR
IF MIT_PR THEN
  PR_SAW( )
ENDIF
;TR
TR_SAW( )
;PGR
PGR_SAW( )
;POT
POT_SAW( )
;SZ
FOR i=1 TO 3
  IF MIT_EZ[i] OR MIT_KE[i] THEN
    SZ_SAW(i)
  ENDIF
ENDFOR
;DS
IF MIT_DS THEN
  DS_SAW()
ENDIF
;EKI
IF MIT_EKI THEN
  A_EKI_SAW()
ENDIF
;PRC
IF B_MIT_PRC THEN
  PRC_SAW()
ENDIF
;ZAI
IF B_MIT_ZAI THEN
  ZAI_SAW()
ENDIF
;INOS
IF B_MIT_INOS THEN
  INO_RstIO()
ENDIF
;ISRA
IF B_MIT_ISR THEN
  IS_ResetSignals()
ENDIF
;VMT
IF B_MIT_VMT THEN
  VMT_BK_SAW()
ENDIF
;MOD1
MOD1_SAW()
;MOD2
MOD2_SAW()
;MOD3
MOD3_SAW()
;RZ
IF MIT_RZ THEN
  RZ_SAW( )
ENDIF
;CONV
IF B_MIT_CONV THEN
  CONV_SAW()
ENDIF
;
;Merker-Init
B_Merker_Init=TRUE
;
END
;ENDFOLD
