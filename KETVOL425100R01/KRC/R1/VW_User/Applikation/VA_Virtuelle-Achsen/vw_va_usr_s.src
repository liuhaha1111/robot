;
;***************************************************
;FOLD LOOP Servo-Zangen
GLOBAL DEF VA_LOOP( )
INT i 
;
;Behandlung Override beim Single-Step
IF ($PRO_MODE1==#BSTEP) AND $COULD_START_MOTION AND $OUT[O_R_bewegt] AND schleppfehler THEN
  IF NOT OV_RUECK THEN
    OV_PRO_Old=$OV_PRO
    OV_RUECK=TRUE
  ENDIF
  $OV_PRO=0
ELSE
  IF $OUT[O_R_Hand] AND $OUT[O_R_bewegt] AND NOT schleppfehler AND OV_RUECK THEN
    $OV_PRO=OV_PRO_Old
    OV_RUECK=FALSE
  ENDIF
ENDIF
;
;Behandlung Schleppfehler
IF schleppfehler THEN
  Behandlung_schleppfehler()
ELSE
  SetSollPos(TRUE) ;Trockenlauf
  sg_fehler()
ENDIF
;
;Zustand SoftPLC
PlcState()    
;
IF $COULD_START_MOTION THEN
  GunNotReady()
  IF ($MODE_OP==#T1) OR ($MODE_OP==#T2) THEN
    SubManDriveOn()
  ENDIF
  IF $EXT AND NOT $softplcbool[5] AND NOT $softplcbool[6] THEN
    ANTEIN_MERKER=FALSE
  ENDIF 
ELSE  ;PERI_RDY
  IF $EXT AND NOT $softplcbool[5] AND $softplcbool[6] AND NOT $power_fail THEN
    SF_Vorwarnung=TRUE
  ENDIF 
  ANTEIN_MERKER=TRUE
  $softplcbool[109]=FALSE
ENDIF ;PERI_RDY
;
$H_POS.E1=$AXIS_ACT.E1
$H_POS.E2=$AXIS_ACT.E2
$H_POS.E3=$AXIS_ACT.E3
$H_POS.E4=$AXIS_ACT.E4
$H_POS.E5=$AXIS_ACT.E5
$H_POS.E6=$AXIS_ACT.E6
;
$softplcbool[11]=$OUT[SZ_BASE_MA[1]+O_SZ_FRG]
$softplcbool[12]=$OUT[SZ_BASE_MA[2]+O_SZ_FRG]
$softplcbool[13]=$OUT[SZ_BASE_MA[3]+O_SZ_FRG]
$softplcbool[14]=$OUT[NZS_BASE_MA[1]+O_NZS_FRG]
$softplcbool[15]=$OUT[NZS_BASE_MA[2]+O_NZS_FRG]
$softplcbool[16]=$OUT[CZS_BASE_MA[1]+O_CZS_FRG]
$softplcbool[17]=$OUT[CZS_BASE_MA[2]+O_CZS_FRG]
IF ($MODE_OP<>#EX) THEN
  Handbetrieb=TRUE
ELSE
  Handbetrieb=FALSE
ENDIF
;
END
;ENDFOLD
;
;***************************************************
;FOLD ExtSg_init()
DEF ExtSg_init()
INT i, RobTimer
BOOL bRet
$softplcint[20]=0
$softplcreal[20]=max_sf
RobTimer=$ROB_TIMER
ErrPlcIntNr=-1
;
IF NOT EZ1_DOCK AND (EZ1_ExAx>0) THEN
  SysBusDelay[(EZ1_ExAx-6)]=Delay_EZ1[1]
ENDIF
IF NOT EZ2_DOCK AND (EZ2_ExAx>0) THEN
  SysBusDelay[(EZ2_ExAx-6)]=Delay_EZ2[1]
ENDIF
IF NOT EZ3_DOCK AND (EZ3_ExAx>0) THEN
  SysBusDelay[(EZ3_ExAx-6)]=Delay_EZ3[1]
ENDIF
IF Mit_NZS[1] AND NOT NZ1_DOCK AND (NZ1_ExAx>0) THEN
  SysBusDelay[(NZ1_ExAx-6)]=Delay_NZ1[1]
ENDIF
IF Mit_NZS[2] AND NOT NZ2_DOCK AND (NZ2_ExAx>0) THEN
  SysBusDelay[(NZ2_ExAx-6)]=Delay_NZ2[1]
ENDIF
IF Mit_RW[1] AND NOT RW1_DOCK AND (RW1_ExAx>0) THEN
  SysBusDelay[(RW1_ExAx-6)]=Delay_RW1[1]
ENDIF
IF Mit_RW[2] AND NOT RW2_DOCK AND (RW2_ExAx>0) THEN
  SysBusDelay[(RW2_ExAx-6)]=Delay_RW2[1]
ENDIF
IF NOT CZ1_DOCK AND (CZ1_ExAx>0) THEN
  SysBusDelay[(CZ1_ExAx-6)]=Delay_CZ1[1]
ENDIF
IF NOT CZ2_DOCK AND (CZ2_ExAx>0) THEN
  SysBusDelay[(CZ2_ExAx-6)]=Delay_CZ2[1]
ENDIF
;
FOR i=1 TO 7
  $softplcint[7+i]=SysBusDelay[i]
ENDFOR
;
$OV_ASYNC=100
;
SZConfig()
;
async_active=FALSE
pos_outofsoftend=FALSE
$softplcbool[18]=proconos_msg
schleppfehler=FALSE
SetSollpos(TRUE)
sf_prog_status=#SZ_io
;Meldungen zuruecknehmen
bRet=Clear_KrlMsg(-99)
IF (($ASYNC_MODE B_AND 'B1')==0) THEN
  MsgState(i, "SynchroMove: $ASYNC_MODE Bit1 falsch konfiguriert", "vw_usr_s",,, 110)
ENDIF
END
;ENDFOLD
;
;***************************************************
;FOLD Behandlung Schleppfehler
DEF  Behandlung_schleppfehler()
BOOL bRet
;
IF (async_active==FALSE) AND NOT $power_fail THEN
  SWITCH sf_prog_status
    CASE #man_motion
      Fahrt_SG_Istpos()
    CASE #prg_motion
      IF $ROB_STOPPED THEN
        IF $EXT==FALSE THEN
          SetSollPos(FALSE)
          IF $softplcbool[6] THEN
            Fahrt_SG_Istpos()
          ELSE
            schleppfehler=FALSE
			   sf_prog_status=#SZ_io
          ENDIF
        ELSE
          IF $COULD_START_MOTION THEN
            SetSollPos(TRUE)
            IF $softplcbool[6]==FALSE THEN
              schleppfehler=FALSE
			     sf_prog_status=#SZ_io
            ENDIF
          ENDIF
        ENDIF
      ENDIF
    CASE #driveoff_motion
      IF $EXT==FALSE THEN
        SetSollPos(FALSE)
        Fahrt_SG_Istpos()
      ELSE
        IF $COULD_START_MOTION THEN
          SetSollPos(TRUE)
          IF $softplcbool[6]==FALSE THEN
            schleppfehler=FALSE
			   sf_prog_status=#SZ_io
          ENDIF
        ENDIF
      ENDIF
    CASE #dest_invalid
      Fahrt_SG_Istpos()
    CASE #user_act
      Fahrt_SG_Istpos()
    CASE #SZ_io
      IF NOT $softplcbool[5] AND NOT $softplcbool[6] THEN
        schleppfehler=FALSE
		ENDIF
  ENDSWITCH
ENDIF
SWITCH $ASYNC_STATE
  CASE #BUSY
    async_active=TRUE
  CASE #IDLE ;asynchron-Bewegung abgeschlossen
    IF async_active THEN
      schleppfehler = FALSE
	   sf_prog_status=#SZ_io
      SetSollPos(TRUE)
      async_active=FALSE	
    ENDIF
  CASE #CANCELLED
    async_active=FALSE
ENDSWITCH
END
;ENDFOLD
;
;***************************************************
;FOLD PlcState *** Fehler SoftPLC
DEF PlcState()
;*** Fehler SoftPLC
BOOL bRet
INT i,MsgNrOffSet,actState,tmpInt
BOOL MsgNum[3]
;
MsgNrOffSet=0
tmpInt=0
actState=cIoCtl($Soft_Plc_Cmd,1005,0," ",tmpInt)
;
IF (actState==2) OR ($ROB_TIMER<pcoBootTime) THEN
  pcoBootTime=$ROB_TIMER
ENDIF
;
;Verzoegerung Bootphase um 1000ms
IF  (($ROB_TIMER-pcoBootTime)>1000) AND NOT $softplcbool[1] THEN
  $OV_PRO=0
  MsgNum[1]=TRUE ;ProConOs in stop
ELSE
  MsgNum[1]=FALSE
ENDIF
IF $softplcbool[2] THEN
  $OV_PRO=0
  MsgNum[2]=TRUE ;SoftPLC ungueltige Zangenkonfiguration
ELSE
  MsgNum[2]=FALSE
ENDIF
IF $softplcbool[3] THEN
  $OV_PRO=0
  MsgNum[3]=TRUE ;SoftPLC Ueberlauf der Sollposition
ELSE
  MsgNum[3]=FALSE
ENDIF
;
FOR i=1 TO 3
  IF (MsgNum[i]==TRUE) THEN	
    VA_Msg(MsgNrOffSet+i,#StateMsg)
  ELSE
    IF (n_VAS_Handle[MsgNrOffSet+i]>-1) THEN
      bRet=Clear_KrlMsg(n_VAS_Handle[MsgNrOffSet+i])
      n_VAS_Handle[MsgNrOffSet+i]=-1
    ENDIF
  ENDIF
ENDFOR
;
END
;ENDFOLD
;
;***************************************************
;FOLD SubManDriveOn
DEF SubManDriveOn()
IF ANTEIN_MERKER THEN
  ANTEIN_MERKER=FALSE
  ;Fahrt auf Istposition bei Antriebe Ein in Hand
  schleppfehler=ManDriveOn()
ENDIF ;Antein_Merker
IF ($PRO_STATE1<>#P_ACTIVE) AND $PRO_MOVE THEN
  ManualMove()
ENDIF
END
;ENDFOLD
;
;***************************************************
;FOLD GunNotReady
DEF GunNotReady()
INT i,PlcIntNr,MsgNrOffSet
BOOL SZNotRdy[7]
BOOL FrgSZ,SZRdy,bRet
;
MsgNrOffSet=13
;
FOR PlcIntNr=1 TO 7
  SZNotRdy[PlcIntNr]=FALSE
ENDFOR
;
FOR PlcIntNr=1 TO 7
  FrgSZ=FctFrgSZ(PlcIntNr)
  IF (FrgSZ==FALSE) AND ($softplcint[PlcIntNr]<>0) THEN
    SZRdy=FctSZRdy(PlcIntNr)
    IF NOT SZRdy THEN
      SZNotRdy[PlcIntNr]=TRUE
    ENDIF
  ENDIF
  IF (SZNotRdy[PlcIntNr]==TRUE) THEN
    VA_Msg((MsgNrOffSet+PlcIntNr),#StateMsg)
  ELSE
    IF (n_VAS_Handle[MsgNrOffSet+PlcIntNr]>-1) THEN
      bRet=Clear_KrlMsg(n_VAS_Handle[MsgNrOffSet+PlcIntNr])
      n_VAS_Handle[MsgNrOffSet+PlcIntNr]=-1
    ENDIF
  ENDIF
ENDFOR
;
END
;ENDFOLD
;
;***************************************************
;FOLD sg_fehler
DEF sg_fehler ()
INT i,PlcIntNr,MsgNrOffSet
BOOL MsgNum[3]
BOOL FrgSZ,InvDestPos,bRet
;
MsgNrOffSet=24
;
FOR i=1 TO 3
  MsgNum[i]=FALSE
ENDFOR
;
IF $softplcbool[5] THEN
  FOR PlcIntNr=1 TO 7
    FrgSZ=FctFrgSZ(PlcIntNr)
    IF ($softplcint[PlcIntNr]<>0) AND NOT FrgSZ AND NOT $power_fail THEN
      schleppfehler=TRUE
      IF $PRO_STATE1==#P_ACTIVE THEN
        sf_prog_status=#prg_motion
      ELSE ;$PRO_STATE1<>#P_ACTIVE
        IF NOT $EXT THEN
          SetSollPos(FALSE)
        ENDIF
        IF NOT $COULD_START_MOTION THEN
          IF NOT $power_fail THEN
            sf_prog_status=#driveoff_motion
            ErrPlcIntNr=PlcIntNr
            MsgNum[2]=TRUE ;Zange auf unzulaessiger Position
          ENDIF
        ELSE
          IF NOT $power_fail THEN
            sf_prog_status=#man_motion
            MsgNum[1]=TRUE ;Schleppfehler im Handbetrieb
	       ENDIF
        ENDIF
      ENDIF
      InvDestPos=FctDestPos(PlcIntNr)
      IF InvDestPos THEN
        ErrPlcIntNr=PlcIntNr
        MsgNum[3]=TRUE ;Zielposition ungueltig
        sf_prog_status=#dest_invalid
      ENDIF ;Zielposition_ungueltig
    ENDIF
  ENDFOR
ENDIF
;
FOR i=1 TO 3
  IF (MsgNum[i]==TRUE) THEN	
    VA_Msg(MsgNrOffSet+i,#StateMsg,ErrPlcIntNr)
  ELSE
    IF (n_VAS_Handle[MsgNrOffSet+i]>-1) THEN
      bRet=Clear_KrlMsg(n_VAS_Handle[MsgNrOffSet+i])
      n_VAS_Handle[MsgNrOffSet+i]=-1
    ENDIF
  ENDIF
ENDFOR
;
END
;ENDFOLD
;
;***************************************************
;FOLD Asynchronfahrt auf Istposition
DEF Fahrt_SG_Istpos()
BOOL B_SZ_SoftEnd,B_NZS_SoftEnd,B_CZS_SoftEnd
INT PlcIntNr, i
E6AXIS zielpos
;***************************************************
;*    Asynchronfahrt auf aktuelle Istposition      *
;***************************************************
;
pos_outofsoftend=FALSE
;
IF $COULD_START_MOTION AND $ROB_STOPPED THEN
  FOR PlcIntNr=1 To 7
    B_SZ_SoftEnd=FALSE
    B_NZS_SoftEnd=FALSE
    B_CZS_SoftEnd=FALSE
    IF ($softplcint[PlcIntNr]<>0) THEN
      SWITCH $softplcint[PlcIntNr]
        CASE 7
          IF ((PlcIntNr==1) AND (EZ1_DOCK==FALSE)) OR ((EZ1_DOCK==TRUE) AND NOT $OUT[SZ_BASE_MA[1]+O_SZ_Re_aus]) THEN
            B_SZ_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==4) AND (NZ1_DOCK==FALSE)) OR ((NZ1_DOCK==TRUE) AND NOT $OUT[NZS_BASE_MA[1]+O_NZS_Re_aus]) THEN
            B_NZS_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==6) AND (CZ1_DOCK==FALSE)) OR ((CZ1_DOCK==TRUE) AND NOT $OUT[CZS_BASE_MA[1]+O_CZS_Re_aus]) THEN
            B_CZS_SoftEnd=TRUE
          ENDIF
          IF (B_SZ_SoftEnd==TRUE) OR (B_NZS_SoftEnd==TRUE) OR (B_CZS_SoftEnd==TRUE) THEN        
            zielpos.E1=IstPosCalc(PlcIntNr)
            pos_outofsoftend=Outofsoftend(zielpos.E1,7)
          ENDIF
        CASE 8
          IF ((PlcIntNr==1) AND (EZ1_DOCK==FALSE)) OR ((EZ1_DOCK==TRUE) AND NOT $OUT[SZ_BASE_MA[1]+O_SZ_Re_aus]) THEN
            B_SZ_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==4) AND (NZ1_DOCK==FALSE)) OR ((NZ1_DOCK==TRUE) AND NOT $OUT[NZS_BASE_MA[1]+O_NZS_Re_aus]) THEN
            B_NZS_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==6) AND (CZ1_DOCK==FALSE)) OR ((CZ1_DOCK==TRUE) AND NOT $OUT[CZS_BASE_MA[1]+O_CZS_Re_aus]) THEN
            B_CZS_SoftEnd=TRUE
          ENDIF
          IF (B_SZ_SoftEnd==TRUE) OR (B_NZS_SoftEnd==TRUE) OR (B_CZS_SoftEnd==TRUE) THEN 
            zielpos.E2=IstPosCalc(PlcIntNr)
            pos_outofsoftend=Outofsoftend(zielpos.E2,8)
          ENDIF
        CASE 9
          IF ((PlcIntNr==1) AND (EZ1_DOCK==FALSE)) OR ((EZ1_DOCK==TRUE) AND NOT $OUT[SZ_BASE_MA[1]+O_SZ_Re_aus]) THEN
            B_SZ_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==4) AND (NZ1_DOCK==FALSE)) OR ((NZ1_DOCK==TRUE) AND NOT $OUT[NZS_BASE_MA[1]+O_NZS_Re_aus]) THEN
            B_NZS_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==6) AND (CZ1_DOCK==FALSE)) OR ((CZ1_DOCK==TRUE) AND NOT $OUT[CZS_BASE_MA[1]+O_CZS_Re_aus]) THEN
            B_CZS_SoftEnd=TRUE
          ENDIF
          IF (B_SZ_SoftEnd==TRUE) OR (B_NZS_SoftEnd==TRUE) OR (B_CZS_SoftEnd==TRUE) THEN  
            zielpos.E3=IstPosCalc(PlcIntNr)
            pos_outofsoftend=Outofsoftend(zielpos.E3,9)
          ENDIF
        CASE 10
          IF ((PlcIntNr==1) AND (EZ1_DOCK==FALSE)) OR ((EZ1_DOCK==TRUE) AND NOT $OUT[SZ_BASE_MA[1]+O_SZ_Re_aus]) THEN
            B_SZ_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==4) AND (NZ1_DOCK==FALSE)) OR ((NZ1_DOCK==TRUE) AND NOT $OUT[NZS_BASE_MA[1]+O_NZS_Re_aus]) THEN
            B_NZS_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==6) AND (CZ1_DOCK==FALSE)) OR ((CZ1_DOCK==TRUE) AND NOT $OUT[CZS_BASE_MA[1]+O_CZS_Re_aus]) THEN
            B_CZS_SoftEnd=TRUE
          ENDIF
          IF (B_SZ_SoftEnd==TRUE) OR (B_NZS_SoftEnd==TRUE) OR (B_CZS_SoftEnd==TRUE) THEN 
            zielpos.E4=IstPosCalc(PlcIntNr)
            pos_outofsoftend=Outofsoftend(zielpos.E4,10)
          ENDIF
        CASE 11
          IF ((PlcIntNr==1) AND (EZ1_DOCK==FALSE)) OR ((EZ1_DOCK==TRUE) AND NOT $OUT[SZ_BASE_MA[1]+O_SZ_Re_aus]) THEN
            B_SZ_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==4) AND (NZ1_DOCK==FALSE)) OR ((NZ1_DOCK==TRUE) AND NOT $OUT[NZS_BASE_MA[1]+O_NZS_Re_aus]) THEN
            B_NZS_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==6) AND (CZ1_DOCK==FALSE)) OR ((CZ1_DOCK==TRUE) AND NOT $OUT[CZS_BASE_MA[1]+O_CZS_Re_aus]) THEN
            B_CZS_SoftEnd=TRUE
          ENDIF
          IF (B_SZ_SoftEnd==TRUE) OR (B_NZS_SoftEnd==TRUE) OR (B_CZS_SoftEnd==TRUE) THEN  
            zielpos.E5=IstPosCalc(PlcIntNr)
            pos_outofsoftend=Outofsoftend(zielpos.E5,11)
          ENDIF
        CASE 12
          IF ((PlcIntNr==1) AND (EZ1_DOCK==FALSE)) OR ((EZ1_DOCK==TRUE) AND NOT $OUT[SZ_BASE_MA[1]+O_SZ_Re_aus]) THEN
            B_SZ_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==4) AND (NZ1_DOCK==FALSE)) OR ((NZ1_DOCK==TRUE) AND NOT $OUT[NZS_BASE_MA[1]+O_NZS_Re_aus]) THEN
            B_NZS_SoftEnd=TRUE
          ENDIF
          IF ((PlcIntNr==6) AND (CZ1_DOCK==FALSE)) OR ((CZ1_DOCK==TRUE) AND NOT $OUT[CZS_BASE_MA[1]+O_CZS_Re_aus]) THEN
            B_CZS_SoftEnd=TRUE
          ENDIF
          IF (B_SZ_SoftEnd==TRUE) OR (B_NZS_SoftEnd==TRUE) OR (B_CZS_SoftEnd==TRUE) THEN 
            zielpos.E6=IstPosCalc(PlcIntNr)
            pos_outofsoftend=Outofsoftend(zielpos.E6,12)
          ENDIF
        DEFAULT
        HALT
      ENDSWITCH
    ENDIF
    IF pos_outofsoftend THEN
      goto FctEnd
    ENDIF
  ENDFOR
  FOR i=1 TO 6
    $ACC_EXTAX[i]=100
    $VEL_EXTAX[i]=100
  ENDFOR
  IF $ROB_CAL THEN
    asyptp zielpos
  ENDIF
  FctEnd:
ENDIF
END
;ENDFOLD
;
;***************************************************
;FOLD SZ Konfiguration
GLOBAL DEF SZConfig()
INT i
;
$softplcbool[20]=FALSE
;
SetPlcIntNull(0)
IF (EZ_PlcInt[1]<>0) THEN
  $softplcint[EZ_PlcInt[1]]=EZ1_ExAx
ENDIF
IF (EZ_PlcInt[2]<>0) THEN
  $softplcint[EZ_PlcInt[2]]=EZ2_ExAx
ENDIF
IF (EZ_PlcInt[3]<>0) THEN
  $softplcint[EZ_PlcInt[3]]=EZ3_ExAx
ENDIF
IF (NZ_PlcInt[1]<>0) THEN
  $softplcint[NZ_PlcInt[1]]=NZ1_ExAx
ENDIF
IF (NZ_PlcInt[2]<>0) THEN
  $softplcint[NZ_PlcInt[2]]=NZ2_ExAx
ENDIF
IF (CZ_PlcInt[1]<>0) THEN
  $softplcint[CZ_PlcInt[1]]=CZ1_ExAx
ENDIF
IF (CZ_PlcInt[2]<>0) THEN
  $softplcint[CZ_PlcInt[2]]=CZ2_ExAx
ENDIF
IF (RW_PlcInt[1]<>0) THEN
  $softplcint[RW_PlcInt[1]]=RW1_ExAx
ENDIF
IF (RW_PlcInt[2]<>0) THEN
  $softplcint[RW_PlcInt[2]]=RW2_ExAx
ENDIF
;
END
;
;***************************************************
GLOBAL DEF SetPlcIntNull(StartVal : IN)
INT i, StartVal
IF (StartVal==0) THEN
  FOR i=1 TO 7
    $softplcint[i]=0
  ENDFOR
ELSE
  $softplcint[StartVal]=0
ENDIF
END
;
;***************************************************
;FOLD SetSollpos
DEF SetSollpos(SollState : IN)
BOOL SollState
IF SollState THEN
  IF MIT_EZ[1] OR MIT_KE[1] THEN
    $OUT[SZ_BASE_MA[1]+O_SZ_SPos_g]=TRUE
  ENDIF
  IF MIT_EZ[2] OR MIT_KE[2] THEN
    $OUT[SZ_BASE_MA[2]+O_SZ_SPos_g]=TRUE
  ENDIF
  IF MIT_EZ[3] OR MIT_KE[3] THEN
    $OUT[SZ_BASE_MA[3]+O_SZ_SPos_g]=TRUE
  ENDIF
  IF MIT_NZS[1] THEN
    $OUT[NZS_BASE_MA[1]+O_NZS_SPos_g]=TRUE
  ENDIF  
  IF MIT_NZS[2] THEN
    $OUT[NZS_BASE_MA[2]+O_NZS_SPos_g]=TRUE
  ENDIF
  IF MIT_CZS[1] THEN
    $OUT[CZS_BASE_MA[1]+O_CZS_SPos_g]=TRUE
  ENDIF
  IF MIT_CZS[2] THEN
    $OUT[CZS_BASE_MA[2]+O_CZS_SPos_g]=TRUE
  ENDIF  
ELSE
  IF MIT_EZ[1] OR MIT_KE[1] THEN
    $OUT[SZ_BASE_MA[1]+O_SZ_SPos_g]=FALSE
  ENDIF
  IF MIT_EZ[2] OR MIT_KE[2] THEN
    $OUT[SZ_BASE_MA[2]+O_SZ_SPos_g]=FALSE
  ENDIF
  IF MIT_EZ[3] OR MIT_KE[3] THEN
    $OUT[SZ_BASE_MA[3]+O_SZ_SPos_g]=FALSE
  ENDIF
  IF MIT_NZS[1] THEN
    $OUT[NZS_BASE_MA[1]+O_NZS_SPos_g]=FALSE
  ENDIF 
  IF MIT_NZS[2] THEN
    $OUT[NZS_BASE_MA[2]+O_NZS_SPos_g]=FALSE
  ENDIF
  IF MIT_CZS[1] THEN
    $OUT[CZS_BASE_MA[1]+O_CZS_SPos_g]=FALSE
  ENDIF
  IF MIT_CZS[2] THEN
    $OUT[CZS_BASE_MA[2]+O_CZS_SPos_g]=FALSE
  ENDIF  
ENDIF
END
;ENDFOLD
;
;***************************************************
;FOLD ManualMove
DEF ManualMove()
INT PlcIntNr
BOOL FrgSZ,SollPosVal,IstPosVal,DestPosVal
BOOL RemFrgSZ,RemSollPos,RemIstPos,RemDestPos
;
RemFrgSZ=FALSE
RemSollPos=FALSE
RemIstPos=FALSE
RemDestPos=FALSE
;
IF ($PRO_STATE1<>#P_ACTIVE) AND $PRO_MOVE THEN
  FOR PlcIntNr=1 TO 7
    IF ($softplcint[PlcIntNr]<>0) THEN
      $softplcint[13]=PlcIntNr
      FrgSZ=FctFrgSZ(PlcIntNr)
      IF FrgSZ THEN
        RemFrgSZ=TRUE
        EXIT
      ENDIF
      SollPosVal=FctSollPos(PlcIntNr)
      IF NOT SollPosVal THEN
        RemSollPos=TRUE
        EXIT
      ENDIF
      IstPosVal=FctIstPos(PlcIntNr)
      IF NOT IstPosVal THEN
        RemIstPos=TRUE
        EXIT
      ENDIF
      DestPosVal=FctDestPos(PlcIntNr)
      IF DestPosVal THEN
        RemDestPos=TRUE
        EXIT
      ENDIF
    ENDIF
  ENDFOR
  ;
  IF RemFrgSZ==TRUE THEN
    VA_Msg(21,#NotifyMsg,PlcIntNr) ;Freigabe gesetzt
  ELSE
    IF RemSollPos==TRUE THEN
      VA_Msg(22,#NotifyMsg,PlcIntNr) ;Sollposition ungueltig
    ELSE
      IF RemIstPos==TRUE THEN
        VA_Msg(23,#NotifyMsg,PlcIntNr) ;Istposition ungueltig
      ELSE
        IF RemDestPos==TRUE THEN
          VA_Msg(24,#NotifyMsg,PlcIntNr) ;Zielposition ungueltig
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  ;
ENDIF
END
;ENDFOLD
;
;***************************************************
;FOLD FctManDriveOn
DEFFCT BOOL ManDriveOn()
INT PlcIntNr
BOOL FrgSZ, FctSchleppfehler
FctSchleppfehler=FALSE
FOR PlcIntNr=1 TO 7
  IF ($softplcint[PlcIntNr]<>0) THEN
    FrgSZ=FctFrgSZ(PlcIntNr)
    IF NOT FrgSZ THEN
      IF ABS($softplcreal[PlcIntNr])>1 THEN
        FctSchleppfehler=TRUE
        sf_prog_status=#user_act
        SetSollPos(FALSE)
      ENDIF
    ENDIF
  ENDIF
ENDFOR
RETURN(FctSchleppfehler)
ENDFCT
;ENDFOLD
