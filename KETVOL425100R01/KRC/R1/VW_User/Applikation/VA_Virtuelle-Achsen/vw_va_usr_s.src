;FOLD INIT VirtualAxis 
GLOBAL DEF VA_INIT( )
INT i
;
;Version Techpaket
Tech_VA.Name[]="KS26.01.000_20170424"
;
;Vorbesetzung Meldungsausgabe
FOR i=1 TO 100
  n_VAS_Handle[i]=-1
  n_VAR_Handle[i]=-1
ENDFOR
;
pos_outofsoftend=FALSE
;
;ExtSg_init
IF (ExtServoDev==TRUE) THEN
  ExtSg_init()
ELSE
  sf_prog_status=#SZ_io  
ENDIF
;
;Vorbesetzung Visu Werte
Visu_Speed_EZ1=0
Visu_Speed_EZ2=0
Visu_Speed_EZ3=0
Visu_Speed_NZ1=0
Visu_Speed_NZ2=0
Visu_Speed_CZ1=0
Visu_Speed_CZ2=0
Visu_Speed_RW1=0
Visu_Speed_RW2=0
Visu_EZ1_ExAx=0
Visu_EZ2_ExAx=0
Visu_EZ3_ExAx=0
Visu_NZ1_ExAx=0
Visu_NZ2_ExAx=0
Visu_CZ1_ExAx=0
Visu_CZ2_ExAx=0
Visu_RW1_ExAx=0
Visu_RW2_ExAx=0
;
END
;ENDFOLD
