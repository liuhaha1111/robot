; End Port - Configuration

; Timeout Zeiten nach Angabe des Kamerasystems 

DECL GLOBAL INT EKI_TimerIns[5]
EKI_TimerIns[1]=25000 ; [ms] SYS 1 TimeOut END "Calibrieren, Referenzieren, Validieren" 
EKI_TimerIns[2]=5000 ; [ms] SYS 2 TimeOut END "Calibrieren, Referenzieren, Validieren" 
EKI_TimerIns[3]=5000 ; [ms] SYS 3 TimeOut END "Calibrieren, Referenzieren, Validieren" 
EKI_TimerIns[4]=5000 ; [ms] SYS 4 TimeOut END "Calibrieren, Referenzieren, Validieren" 
EKI_TimerIns[5]=5000 ; [ms] SYS 5 TimeOut END "Calibrieren, Referenzieren, Validieren" 

DECL GLOBAL INT EKI_TimerClc[5]
EKI_TimerClc[1]=25000 ; [ms] SYS 1 TimeOut Reaktionszeit fuer "Messpunkt usw."
EKI_TimerClc[2]=10000 ; [ms] SYS 2 TimeOut Reaktionszeit fuer "Messpunkt usw."
EKI_TimerClc[3]=10000 ; [ms] SYS 3 TimeOut Reaktionszeit fuer "Messpunkt usw."
EKI_TimerClc[4]=20000 ; [ms] SYS 4 TimeOut Reaktionszeit fuer "Messpunkt usw."
EKI_TimerClc[5]=10000 ; [ms] SYS 5 TimeOut Reaktionszeit fuer "Messpunkt usw."

DECL GLOBAL INT EKI_Pingtime[5]
EKI_Pingtime[1]=5000 ; [ms] SYS 1 TimeOut Reaktionszeit fuer "Ping"
EKI_Pingtime[2]=5000 ; [ms] SYS 2 TimeOut Reaktionszeit fuer "Ping"
EKI_Pingtime[3]=5000 ; [ms] SYS 3 TimeOut Reaktionszeit fuer "Ping"
EKI_Pingtime[4]=5000 ; [ms] SYS 4 TimeOut Reaktionszeit fuer "Ping"
EKI_Pingtime[5]=1000 ; [ms] SYS 5 TimeOut Reaktionszeit fuer "Ping"
; 
; Kamera Stationaer (TRUE) oder am Roboter (FALSE)

DECL GLOBAL BOOL B_EKI_KASTAT[5]
B_EKI_KASTAT[1]=FALSE ; FALSE Kam 1 robotergefuehrt = BASE, TRUE stationaer = TOOL Korrektur
B_EKI_KASTAT[2]=FALSE ; FALSE Kam 2 robotergefuehrt = BASE, TRUE stationaer = TOOL Korrektur
