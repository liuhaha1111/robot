&PARAM TPVW_VERSION = 8.3.0
&REL 88
DEFDAT  vw_xml_usr_conf PUBLIC

; Port - Konfigurations Test fuer die IBN der Kamerasysteme

GLOBAL INT EKI_ETH_VERS=28
;EKI_ETH_VERS = 21  ; KUKA EthernetKRL Version V2.1 = 21 default

GLOBAL BOOL B_EKI_INITSY[5]
B_EKI_INITSY[1]=TRUE
B_EKI_INITSY[2]=FALSE
B_EKI_INITSY[3]=FALSE
B_EKI_INITSY[4]=FALSE
B_EKI_INITSY[5]=FALSE

; Konfiguration fuer eine Einport -Datenuebertragung

GLOBAL BOOL B_One_Port[5]
B_One_Port[1]=FALSE
B_One_Port[2]=FALSE
B_One_Port[3]=FALSE
B_One_Port[4]=FALSE
B_One_Port[5]=FALSE

; Konfiguration fuer eine Zweiport -Datenuebertragung

