B_Two_Port[1]=TRUE
B_Two_Port[2]=FALSE
B_Two_Port[3]=FALSE
B_Two_Port[4]=FALSE
B_Two_Port[5]=FALSE

; Konfiguration fuer getrennte XML- Datenempfangsstruktur

