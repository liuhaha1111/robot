;FOLD ACHSWINKEL SENDEN
CASE IS_FnctID_IMT_SendAxis1
	IF (IS_iExternErrors>0) THEN
		IF ((IS_iExternErrors b_and 8)==8) THEN
			IS_MSG_ERR(IS_MSG_ERR_IMT_PREPARE1, IS_SUBTYP)
			IS_iFnctID = 0
			RETURN
		ENDIF
		IF (IS_iErrorSource==3) AND (IS_iExternErrors==16) THEN
		  IF (($MODE_OP==#T2) OR ($MODE_OP==#T1)) THEN
        ;MsgNotify("Achswinkel werden uebertragen", "ISRA")
      ENDIF
		ELSE
		  IF (IS_iErrorSource==3) AND (IS_iExternErrors==32) THEN
        IF (($MODE_OP==#T2) OR ($MODE_OP==#T1)) THEN
           ;MsgNotify("Basedaten werden uebertragen", "ISRA")
        ENDIF
			ELSE
			 IF (IS_iErrorSource==3) AND (IS_iExternErrors==48) THEN
         IF (($MODE_OP==#T2) OR ($MODE_OP==#T1)) THEN
            ;MsgNotify("Basedaten und Achswinkel werden uebertragen", "ISRA")
         ENDIF
			 ELSE
					IS_MSG_ERR(IS_MSG_ERR_AXIS1)
				ENDIF
			ENDIF
		ENDIF
	ELSE
		SWITCH IS_iInternErrors
			CASE IS_Err_ID_Drain
				IS_MSG_ERR(IS_MSG_ERR_AXIS1C)
			CASE IS_Err_ID_Timeout
				IS_MSG_ERR(IS_MSG_ERR_AXIS1D)
			DEFAULT
				IS_MSG_ERR(IS_MSG_ERR_AXIS1)
		ENDSWITCH
	ENDIF
