	ch_KXRKey[] = "IS_MSG_PP_WARN"
CASE IS_MSG_PP_MOVEMODE
	ch_KXRKey[] = "IS_MSG_PP_MOVEMODE"
CASE IS_MSG_PP_TOL
	ch_KXRKey[] = "IS_MSG_PP_TOL"
CASE IS_MSG_PP_INVERSE
	ch_KXRKey[] = "IS_MSG_PP_INVERSE"
