CASE IS_MSG_ERR_SERV_TOOL_T
	ch_KXRKey[] = "IS_MSG_ERR_SERV_TOOL_T"
	IS_UserInstruction = IS_Instr_TolChk
CASE IS_MSG_ERR_SERV_ROB
	ch_KXRKey[] = "IS_MSG_ERR_SERV_ROB"
	IS_UserInstruction = 0
CASE IS_MSG_ERR_SERV_ROB_T
	ch_KXRKey[] = "IS_MSG_ERR_SERV_ROB_T"
	IS_UserInstruction = IS_Instr_TolChk
CASE IS_MSG_ERR_SERV_SENSIMT
	ch_KXRKey[] = "IS_MSG_ERR_SERV_SENSIMT"
CASE IS_MSG_ERR_SERVICE1A
	ch_KXRKey[] = "IS_MSG_ERR_SERVICE1A"
	IS_UserInstruction = IS_Instr_Response
CASE IS_MSG_ERR_SERVICE1B
	ch_KXRKey[] = "IS_MSG_ERR_SERVICE1B"
	IS_UserInstruction = IS_Instr_Response
CASE IS_MSG_ERR_SERVICE1C
	ch_KXRKey[] = "IS_MSG_ERR_SERVICE1C"
	IS_UserInstruction = IS_Instr_Response
CASE IS_MSG_ERR_SERVICE1D
	ch_KXRKey[] = "IS_MSG_ERR_SERVICE1D"
	IS_UserInstruction = IS_Instr_Response
