;FOLD Service
CASE IS_FnctID_IMT_Service
	IF (IS_iInternErrors == IS_Err_ID_Timeout) THEN
		SWITCH IS_iServiceMode
			CASE IS_iSENSOR_CHANGE
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1a)
			CASE IS_iTOOL_CHANGE
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1b)
			CASE IS_iROBOT_CHANGE
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1c)
			CASE IS_iSENSOR_CHANGE_IMT
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1d)
		ENDSWITCH
	ELSE
		SWITCH IS_iServiceMode
			CASE IS_iSENSOR_CHANGE
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1e)
			CASE IS_iTOOL_CHANGE
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1f)
			CASE IS_iROBOT_CHANGE
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1g)
			CASE IS_iSENSOR_CHANGE_IMT
				IS_MSG_ERR(IS_MSG_ERR_SERVICE1h)
		ENDSWITCH
	ENDIF
;ENDFOLD (Service)
;
;FOLD ProcessState
CASE IS_FnctID_IMT_GetExtStat
	IS_MSG_ERR(IS_MSG_ERR_IMT_APPLY, IS_SUBTYP)
;ENDFOLD (ProcessState)
;
ENDSWITCH
;
IS_iFnctID = 0
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Ergebnis-Zustand abfragen
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_IMT_GetExternState (iStateResult:OUT, iStateWarning:OUT)
DECL INT iStateResult
DECL INT iStateWarning
DECL BOOL b_RetVal
;
IS_iFnctID = IS_FnctID_IMT_GetExtStat
;
IS_TX8_DATA_ID 				= 58			;Zustandsabfrage
IS_TX1_DATA_REQUEST 	= TRUE
IS_TX1_HANDSHAKE 			= IS_ToggleHandshake()
;
IF (IS_Wait(#IS_ERROR_ID, TRUE, 0) == FALSE) THEN
	$FLAG[IS_FLAG_ERROR] = TRUE
	IS_SetInternError(IS_IntErr_StReq1)
	RETURN FALSE
ENDIF
;
IS_iErrorSource  	= IS_RX8_ERR_SYS_ID
IS_iExternErrors 	= IS_RX8_ERRORS
iStateResult  		= IS_RX8_STATE_RESULT
iStateWarning 		= IS_RX8_STATE_WARNING
;
IS_TX1_DATA_REQUEST 	= FALSE
IS_TX1_DATA_ACCEPTED 	= TRUE
IS_TX1_HANDSHAKE 			= IS_ToggleHandshake()
;
b_RetVal = IS_Wait(#IS_ERROR_ID, FALSE, 0)
;
IF (b_RetVal == FALSE) THEN
	$FLAG[IS_FLAG_ERROR] = TRUE
	IS_SetInternError(IS_IntErr_StReq2)
ENDIF
;
IS_TX8_DATA_ID 				= 0
IS_TX1_DATA_ACCEPTED 	= FALSE
;
RETURN b_RetVal
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Ergebniszustand auf Roboter Flags abbilden
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_IMT_ProcessExtState (iExternStateResult:IN, iExternStateWarning:IN)
DECL INT iExternStateResult
DECL INT iExternStateWarning
;
IF (iExternStateResult B_AND IS_STATE_RESULT_OK) == IS_STATE_RESULT_OK THEN
	$FLAG[IS_FLAG_RESULT_OK]  = TRUE
	$FLAG[IS_FLAG_RESULT_NOK] = FALSE
ELSE
	$FLAG[IS_FLAG_RESULT_OK]	= FALSE
ENDIF
;
IF (iExternStateResult B_AND IS_STATE_RESULT_NOK) == IS_STATE_RESULT_NOK THEN
	$FLAG[IS_FLAG_RESULT_NOK] = TRUE
	$FLAG[IS_FLAG_RESULT_OK]  = FALSE
  IS_MSG_ERR(IS_MSG_RESULT_NOK)
  RETURN FALSE
ELSE
	$FLAG[IS_FLAG_RESULT_NOK]	= FALSE
  $FLAG[IS_FLAG_RESULT_OK]  = TRUE
ENDIF
;
IF (iExternStateWarning B_AND IS_STATE_WARN_TOL) == IS_STATE_WARN_TOL THEN
 	$FLAG[IS_FLAG_WARN_TOL] = TRUE
ELSE
  $FLAG[IS_FLAG_WARN_TOL] = FALSE
ENDIF
;
RETURN TRUE
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Systemdiagnose durchfuehren
;---------------------------------------------------------------------------------------------
DEF  IS_SYSTEM_DIAG ()
DECL BOOL bFlag
;
IF (IS_SYS_TYPE == IS_SYS_TYPE_IMT) THEN
	IF $IS_LIVE_SIGNAL THEN
		IS_MSG(IS_MSG_I_SYS_DIAG_1, IS_MSG_TYPE_NOTIFY)
	ELSE
		IS_MSG(IS_MSG_I_SYS_DIAG_2, IS_MSG_TYPE_NOTIFY)
		RETURN
	ENDIF
	;
	IF $IS_COMMUNICATE THEN
		IS_MSG(IS_MSG_I_SYS_DIAG_3, IS_MSG_TYPE_NOTIFY)
	ELSE
		IS_MSG(IS_MSG_I_SYS_DIAG_4, IS_MSG_TYPE_NOTIFY)
	ENDIF
	;
	;IS_MSG(0,7)
	IS_MSG(IS_MSG_I_SYNC, IS_MSG_TYPE_DIALOG)
	;
	IF (IS_ANSWER==1) THEN
		$IS_COMMUNICATE = TRUE
		IF IS_IMT_SyncHandshake() THEN
			IS_MSG(IS_MSG_I_SYS_DIAG_5, IS_MSG_TYPE_NOTIFY)
		ELSE
			IS_MSG(IS_MSG_I_SYS_DIAG_6, IS_MSG_TYPE_NOTIFY)
		ENDIF
	ELSE
		IS_MSG(IS_MSG_I_SYS_DIAG_7, IS_MSG_TYPE_NOTIFY)
	ENDIF
	;
ENDIF
;
IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
	IF $IS_COMMUNICATE THEN
		IS_MSG(IS_MSG_I_SYS_DIAG_3, IS_MSG_TYPE_NOTIFY)
	ELSE
		IS_MSG(IS_MSG_I_SYS_DIAG_4, IS_MSG_TYPE_NOTIFY)
	ENDIF
	;
	;IS_MSG (0,7)
	IS_MSG(IS_MSG_I_SYNC, IS_MSG_TYPE_DIALOG)
	;
	IF (IS_ANSWER==1) THEN
		$IS_COMMUNICATE = TRUE
		;
		ISRA_PG_INIT()
		;
		IF IS_State_OK() THEN
			IS_MSG(IS_MSG_I_SYS_DIAG_5, IS_MSG_TYPE_NOTIFY)
		ELSE
			IS_MSG(IS_MSG_I_SYS_DIAG_6, IS_MSG_TYPE_NOTIFY)
		ENDIF
	ELSE
		IS_MSG(IS_MSG_I_SYS_DIAG_7, IS_MSG_TYPE_NOTIFY)
	ENDIF
ENDIF
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;
;FOLD HW über separate Messung prüfen
;---------------------------------------------------------------------------------------------
DEF IS_CheckHW()
	IF ((NOT IS_STATE_OK()) AND (NOT IS_bHWCheckMode) AND $IS_LIVE_SIGNAL) THEN
		;MsgNotify("IS_CheckHW", "Executing")
		; Fehlerflags speichern
		IS_SaveErrorFlags()
		;
		ISRA_PG_INIT()
		IS_bHWCheckMode = TRUE
		;
    IS_RF_Prepare(99, 0, 0)
    IS_RF_Apply(0)
    IS_RF_EndPose()
		;
		IF (NOT IS_STATE_OK()) AND (IS_RX1_RF_ERR_FEAT == TRUE) THEN
			$FLAG[IS_FLAG_ERR_ACQ] = TRUE
			$FLAG[IS_FLAG_ERROR] = TRUE
			IS_bHWCheckMode = FALSE
			IS_MSG_ERR(IS_MSG_ERR_RF_APPLY3E)
			;MsgNotify("IS_CheckHW","HW Error detected")
		ELSE
			IS_RestoreErrorFlags()
		ENDIF
	ENDIF
	IS_bHWCheckMode = FALSE
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Speichern der Fehlerflags
;---------------------------------------------------------------------------------------------
DEF IS_SaveErrorFlags()
;
IS_FLAGS_SAVED[1] = $FLAG[IS_FLAG_ERR_SPS]
IS_FLAGS_SAVED[2] = $FLAG[IS_FLAG_ERR_ROBOT]
IS_FLAGS_SAVED[3] = $FLAG[IS_FLAG_ERR_PREPARE]
IS_FLAGS_SAVED[4] = $FLAG[IS_FLAG_ERR_ACQ]
IS_FLAGS_SAVED[5] = $FLAG[IS_FLAG_ERR_FEATURE]
IS_FLAGS_SAVED[6] = $FLAG[IS_FLAG_ERR_EVAL]
IS_FLAGS_SAVED[7] = $FLAG[IS_FLAG_ERR_TOL]
IS_FLAGS_SAVED[8] = $FLAG[IS_FLAG_WARN_TOL]
IS_FLAGS_SAVED[9] = $FLAG[IS_FLAG_KAL1_HLP]
IS_FLAGS_SAVED[10] = $FLAG[IS_FLAG_KAL2_HLP]
IS_FLAGS_SAVED[11] = $FLAG[IS_FLAG_RESULT_OK]
IS_FLAGS_SAVED[12] = $FLAG[IS_FLAG_RESULT_NOK]
IS_FLAGS_SAVED[13] = $FLAG[IS_FLAG_ERROR]
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Wiederherstellen der Fehlerflags
;---------------------------------------------------------------------------------------------
DEF IS_RestoreErrorFlags()
;
$FLAG[IS_FLAG_ERR_SPS] 		= IS_FLAGS_SAVED[1] 
$FLAG[IS_FLAG_ERR_ROBOT] 	= IS_FLAGS_SAVED[2] 
$FLAG[IS_FLAG_ERR_PREPARE]= IS_FLAGS_SAVED[3]
$FLAG[IS_FLAG_ERR_ACQ]		= IS_FLAGS_SAVED[4] 
$FLAG[IS_FLAG_ERR_FEATURE]= IS_FLAGS_SAVED[5] 
$FLAG[IS_FLAG_ERR_EVAL]		= IS_FLAGS_SAVED[6] 
$FLAG[IS_FLAG_ERR_TOL]		= IS_FLAGS_SAVED[7] 
$FLAG[IS_FLAG_WARN_TOL]		= IS_FLAGS_SAVED[8] 
$FLAG[IS_FLAG_KAL1_HLP]		= IS_FLAGS_SAVED[9] 
$FLAG[IS_FLAG_KAL2_HLP]		= IS_FLAGS_SAVED[10] 
$FLAG[IS_FLAG_RESULT_OK]	= IS_FLAGS_SAVED[11]
$FLAG[IS_FLAG_RESULT_NOK]	= IS_FLAGS_SAVED[12] 
$FLAG[IS_FLAG_ERROR]			= IS_FLAGS_SAVED[13]
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;
;FOLD Fehlermeldungen deutsch
;---------------------------------------------------------------------------------------------
DEF  IS_MSG_ERR (iMsgNr:IN, iParam1:IN, iParam2:IN)
; Meldung die in allen Betriebsarten ausgegeben wird.
DECL INT iMsgNr
DECL INT MSG_QUIT_FLAG  ;Messages muessen quittiert werden.
DECL INT nHandle
DECL INT OFFSET
DECL STATE_T STATE
DECL CHAR MELDUNG[80]
DECL CHAR PARAM[10]
DECL INT IS_UserInstruction
CHAR ch_KXRKey[100]
CHAR ch_KXRKey_Btn1[10]
CHAR ch_KXRKey_Btn2[10]
DECL INT iParam1, iParam2
DECL KRLMSGPAR_T par1, par2

IS_UserInstruction=-1
;
IF IS_bHWCheckMode THEN
	RETURN
ENDIF
;
IF ($MODE_OP==#T1) OR ($MODE_OP==#T2) OR ((iMsgNr>=IS_IntErr_Param1) AND (iMsgNr<=IS_IntErr_Param6)) THEN
	MSG_QUIT_FLAG = 1
ELSE
	MSG_QUIT_FLAG = 2 ;Keine Quittierung in Automatik
ENDIF
;
;For Testing:
;MSG_QUIT_FLAG = 2
;
; Prepare the additional parameters
par1.par_type = #value
par2.par_type = #value
;
IF NOT (Varstate ("iParam1")==#initialized) then
   iParam1 = 0;
ENDIF
;
IF NOT (Varstate ("iParam2")==#initialized) then
   iParam2 = 0;
ENDIF
;
SWITCH iMsgNr
;Sync
CASE IS_MSG_ERR_SYNC1A
	ch_KXRKey[] = "IS_MSG_ERR_SYNC1A"
CASE IS_MSG_ERR_SYNC1B
	ch_KXRKey[] = "IS_MSG_ERR_SYNC1B"
	IS_UserInstruction = IS_Instr_Response
CASE IS_MSG_ERR_SYNC2A
	ch_KXRKey[] = "IS_MSG_ERR_SYNC2A"
CASE IS_MSG_ERR_SYNC2B
	ch_KXRKey[] = "IS_MSG_ERR_SYNC2B"
	IS_UserInstruction = IS_Instr_Response
;
;Select
CASE IS_MSG_ERR_SELECT1
	ch_KXRKey[] = "IS_MSG_ERR_SELECT1"
	IS_UserInstruction = IS_Instr_ModelCmp
CASE IS_MSG_ERR_SELECT1A
	ch_KXRKey[] = "IS_MSG_ERR_SELECT1A"
	IS_UserInstruction = IS_Instr_ModelChk
CASE IS_MSG_ERR_SELECT1B
	ch_KXRKey[] = "IS_MSG_ERR_SELECT1B"
	IS_UserInstruction = IS_Instr_DeadlyErr
CASE IS_MSG_ERR_SELECT1C
	ch_KXRKey[] = "IS_MSG_ERR_SELECT1C"
	IS_UserInstruction = IS_Instr_Response
CASE IS_MSG_ERR_SELECT2
	ch_KXRKey[] = "IS_MSG_ERR_SELECT2"
	IS_UserInstruction = IS_Instr_Response
CASE IS_MSG_ERR_SELECT2A
	ch_KXRKey[] = "IS_MSG_ERR_SELECT2A"
	IS_UserInstruction = IS_Instr_DeadlyErr
CASE IS_MSG_ERR_SELECT2B
