	ch_KXRKey[] = "IS_MSG_PP_TEST_POSA"
CASE IS_MSG_PP_TEST_POSK
	ch_KXRKey[] = "IS_MSG_PP_TEST_POSK"
CASE IS_MSG_DEBUG
	ch_KXRKey[] = "IS_MSG_DEBUG"
;
;Zustand/Warnung
CASE IS_MSG_RESULT_OK
  ch_KXRKey[] = "IS_MSG_RESULT_OK"
CASE IS_MSG_RESULT_NOK
  ch_KXRKey[] = "IS_MSG_RESULT_NOK"
CASE IS_MSG_WARN_TOL
  ch_KXRKey[] = "IS_MSG_WARN_TOL"
;
; Fehler und Meldungen von intern
CASE IS_IntErr_Param1
  ch_KXRKey[] = "IS_IntErr_Param1"
CASE IS_IntErr_Param2
  ch_KXRKey[] = "IS_IntErr_Param2"
CASE IS_IntErr_Param3
  ch_KXRKey[] = "IS_IntErr_Param3"
CASE IS_IntErr_Param4
  ch_KXRKey[] = "IS_IntErr_Param4"
CASE IS_IntErr_Param5
  ch_KXRKey[] = "IS_IntErr_Param5"
CASE IS_IntErr_Param6
  ch_KXRKey[] = "IS_IntErr_Param6"
;
CASE IS_IntErr_Com
	ch_KXRKey[] = "IS_IntErr_Com"
CASE IS_IntErr_ERequest
 ch_KXRKey[] = "IS_IntErr_ERequest"
CASE IS_IntErr_Meas
  ch_KXRKey[] = "IS_IntErr_Meas"
CASE IS_IntErr_Retry
  ch_KXRKey[] = "IS_IntErr_Retry"
CASE IS_IntErr_Data
  ch_KXRKey[] = "IS_IntErr_Data"
CASE IS_IntErr_Base
  ch_KXRKey[] = "IS_IntErr_Base"
CASE IS_IntErr_Tool
  ch_KXRKey[] = "IS_IntErr_Tool"
CASE IS_IntErr_ESendBit
 ch_KXRKey[] = "IS_IntErr_ESendBit"
CASE IS_IntErr_Specif
  ch_KXRKey[] = "IS_IntErr_Specif"
CASE IS_IntErr_SrvcExp
 	ch_KXRKey[] = "IS_IntErr_SrvcExp"
CASE IS_IntErr_StReq1
  ch_KXRKey[] = "IS_IntErr_StReq1"
CASE IS_IntErr_StReq2
  ch_KXRKey[] = "IS_IntErr_StReq2"
CASE IS_IntErr_ESend
 	ch_KXRKey[] = "IS_IntErr_ESend"
CASE IS_IntErr_IQRWait
 	ch_KXRKey[] = "IS_IntErr_IQRWait"
 	MSG_QUIT_FLAG = 3
CASE IS_IntErr_PCWait
 	ch_KXRKey[] = "IS_IntErr_PCWait"
 	MSG_QUIT_FLAG = 3
CASE IS_IntErr_TolRob
 	ch_KXRKey[] = "IS_IntErr_TolRob"
CASE IS_IntErr_RFAState
  ch_KXRKey[] = "IS_IntErr_RFAState"
CASE IS_IntErr_MeasPosNo
  ch_KXRKey[] = "IS_IntErr_MeasPosNo"
CASE IS_IntErr_RFGCSt
	ch_KXRKey[] = "IS_IntErr_RFGCSt"
CASE IS_IntErr_RFEPSt
	ch_KXRKey[] = "IS_IntErr_RFEPSt"
;
DEFAULT
   ch_KXRKey[] = "IS_MSG_ERR_DEFAULT"
ENDSWITCH
;
;Set Parameters:
par1.par_int = iParam1
par2.par_int = iParam2
;
SWITCH MSG_QUIT_FLAG
CASE 1
	IF (iMsgNr == IS_IntErr_Com) THEN
		;Dauerschleife bis Verbindung wieder da ist und der Ablauf normal weiter geht oder Option zum simulieren:
		IS_RF_ReconnectLoop()
	ELSE
 		OFFSET = 0
 		;
 		;Liegt eine Handlungsanweisung vor?
 		IF (IS_UserInstruction <> -1) THEN
	 	  REPEAT
	 	  	; Solange wiederholen bis Dialog mit OK/Weiter bestätigt wird.
	 	  	IF (IS_iServiceMode == IS_iSERVICE_NONE) THEN
	 	  		; Wenn nicht in Serviceprogramm, dann Button Info&Weiter, da Frage nach Messwiederholung folgt
	 	  		ch_KXRKey_Btn1[]="INFO"
					ch_KXRKey_Btn2[]="FORWARD"
	 	  		IS_ShowDialog(IS_ANSWER,ch_KXRKey_Btn1[],ch_KXRKey_Btn2[]," "," "," "," "," ",ch_KXRKey[], "vw_isr_usr_r", TRUE, par1, par2)
	 	  	ELSE
	 	  		; Wenn in Serviceprogramm, dann Button Info&OK
	 	  		ch_KXRKey_Btn1[]="INFO"
					ch_KXRKey_Btn2[]="OK"
	 	  		IS_ShowDialog(IS_ANSWER,ch_KXRKey_Btn1[],ch_KXRKey_Btn2[]," "," "," "," "," ",ch_KXRKey[], "vw_isr_usr_r", TRUE, par1, par2)
	 	  	ENDIF
		 		IS_ANSWER = 8-IS_ANSWER
				IF (IS_ANSWER == 1) THEN
					;'Info': Handlungsanweisung anzeigen
					IS_GetUserInstruction(IS_UserInstruction)
				ELSE
					;'OK': Beenden ohne Handlungsanweisung
				ENDIF
			UNTIL (IS_ANSWER <> 1)
 		ELSE
 			; Dialog ohne Info-Button anzeigen
 			ch_KXRKey_Btn2[]="OK"
 			IS_ShowDialog(IS_ANSWER," ",ch_KXRKey_Btn2[]," "," "," "," "," ",ch_KXRKey[], "vw_isr_usr_r", TRUE, par1, par2)
 		ENDIF
	ENDIF
CASE 2
  IS_ShowMessage(nHandle, #notify, ch_KXRKey[], "vw_isr_usr_r", iMsgNr, TRUE, par1, par2)
ENDSWITCH
;
END ;of IS_MSG_ERR
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Meldungsausgabe (Info, Quittierung und Dialog)
;---------------------------------------------------------------------------------------------
DEF  IS_MSG(iMsgNr: IN, iMsgType: IN, iParam: IN)
DECL INT iMsgNr, iMsgType, iParam
DECL KRLMSGPAR_T par1
DECL INT nHandle
CHAR ch_KXRKey[100]
CHAR ch_KXRKey_btn1[10]
CHAR ch_KXRKey_btn2[10]
;
; Prepare the additional parameter
par1.par_type = #value

IF NOT (Varstate ("iParam")==#initialized) then
   iParam = 0;
ENDIF
;
IF (($MODE_OP==#T2) OR ($MODE_OP==#T1) OR (IS_iServiceMode <> IS_iSERVICE_NONE)) THEN
	SWITCH iMsgNr
	CASE IS_MSG_I_SERV_SENS_CHK
 	  ch_KXRKey[] = "IS_Info_Serv_Sens_Chk"
 	CASE IS_MSG_I_SERV_SENS
 		ch_KXRKey[] = "IS_Info_Serv_Sens"
 	CASE IS_MSG_I_SERV_TOOL
		ch_KXRKey[] = "IS_Info_Serv_Tool"
 	CASE IS_MSG_I_SERV_TOOL_PATH1
 		ch_KXRKey[] = "IS_Info_Serv_Tool_Path"
 	CASE IS_MSG_I_SERV_ROB
 	  ch_KXRKey[] = "IS_Info_Serv_Rob"
 	CASE IS_MSG_I_SERV_ROB_PATH1
 	  ch_KXRKey[] = "IS_Info_Serv_Rob_Path"
 	CASE IS_MSG_I_SERV_SENSIMT
 		ch_KXRKey[] = "IS_Info_Serv_Sens_IMT"
 	CASE IS_MSG_I_TRANS_AXES
 		ch_KXRKey[] = "IS_Info_Transfer_Axes"
	CASE IS_MSG_I_TRANS_BASE
		ch_KXRKey[] = "IS_Info_Transfer_Base"
	CASE IS_MSG_I_SYS_DIAG_1
		ch_KXRKey[] = "IS_Info_Sys_Diag_1"
	CASE IS_MSG_I_SYS_DIAG_2
		ch_KXRKey[] = "IS_Info_Sys_Diag_2"
	CASE IS_MSG_I_SYS_DIAG_3
		ch_KXRKey[] = "IS_Info_Sys_Diag_3"
	CASE IS_MSG_I_SYS_DIAG_4
		ch_KXRKey[] = "IS_Info_Sys_Diag_4"
	CASE IS_MSG_I_SYS_DIAG_5
		ch_KXRKey[] = "IS_Info_Sys_Diag_5"
  CASE IS_MSG_I_SYS_DIAG_6
		ch_KXRKey[] = "IS_Info_Sys_Diag_6"
	CASE IS_MSG_I_SYS_DIAG_7
 		ch_KXRKey[] = "IS_Info_Sys_Diag_7"
	CASE IS_MSG_I_SYNC
	  IF (IS_SYS_TYPE == IS_SYS_TYPE_IMT) THEN
	  	ch_KXRKey[] = "IS_Info_Sync_IMT"
	  ENDIF
	  IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
	  	ch_KXRKey[] = "IS_Info_Sync_RF"
	  ENDIF  
		ch_KXRKey_btn1[]= "YES"
		ch_KXRKey_btn2[]= "NO"
	CASE IS_MSG_I_MEAS_FAILED
	  IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
			ch_KXRKey[] = "IS_Info_Meas_Failed"
			ch_KXRKey_btn1[]= "REPEAT"
			ch_KXRKey_btn2[]= "CANCEL"
		ENDIF
	CASE IS_MSG_I_SERV_TOOL_PATH2
	  IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
			ch_KXRKey_btn1[]= "OK"
			ch_KXRKey_btn2[]= " "
			ch_KXRKey[] = "IS_Info_Tool_Path_2"
	  ENDIF
	CASE IS_MSG_I_SERV_ROB_PATH2
	  IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
			ch_KXRKey_btn1[]= "OK"
			ch_KXRKey_btn2[]= " "
			ch_KXRKey[] = "IS_Info_Tool_Path_2"
	  ENDIF  
	ENDSWITCH
	;
	; Set parameter
	par1.par_int = iParam
	;	
	SWITCH iMsgType
		CASE IS_MSG_TYPE_DIALOG
			IS_ShowDialog(IS_ANSWER,ch_KXRKey_btn1[],ch_KXRKey_btn2[]," "," "," "," "," ",ch_KXRKey[], "vw_isr_usr_r", TRUE, par1)
			IS_ANSWER = 8-IS_ANSWER
		CASE IS_MSG_TYPE_NOTIFY
			IS_ShowMessage(nHandle, #notify, ch_KXRKey[], "vw_isr_usr_r", iMsgNr, TRUE, par1)
		CASE IS_MSG_TYPE_QUIT
			IS_ShowMessage(nHandle, #quit, ch_KXRKey[], "vw_isr_usr_r", iMsgNr, TRUE, par1)
		CASE IS_MSG_TYPE_STATE
			IS_ShowMessage(nHandle, #state, ch_KXRKey[], "vw_isr_usr_r", iMsgNr, TRUE, par1)
		DEFAULT
			IS_ShowMessage(nHandle, #notify, ch_KXRKey[], "vw_isr_usr_r", iMsgNr, TRUE, par1)
	ENDSWITCH
ENDIF
;
END ;of IS_MSG
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Framemessage
;---------------------------------------------------------------------------------------------
DEF IS_MSG_FRAME2 (TYPE:IN, NR:IN, INFRAME:IN)
DECL FRAME INFRAME
DECL INT TYPE, NR
DECL INT OFFSET
DECL STATE_T STATE
DECL INT nHandle
DECL CHAR NAME[20]
DECL CHAR MELDUNG[80]
DECL CHAR ch_KXRkey[100]
DECL CHAR ABS[20]
;
SWITCH TYPE
  CASE 1
    NAME[]="Baseoffset"
    ABS[]="Differenz Basedaten"
  CASE 2
    NAME[]="Tooloffset"
    ABS[]="Differenz Tooldaten"
  CASE 3	;
    NAME[]="Base"
    ABS[]="Alte Basedaten"
  CASE 4
    NAME[]="Base"
    ABS[]="Neue Basedaten"
  CASE 5
    NAME[]="Tool"
    ABS[]="Alte Tooldaten"
  CASE 6
    NAME[]="Tool"
    ABS[]="Neue Tooldaten"
  CASE 7 
    NAME[]="Base"
    ABS[]="Korrekturdaten"
  CASE 8
    NAME[]="Tool"
    ABS[]="Korrekturdaten"
  CASE 9
    NAME[]="Grenzwert"
    ABS[]="Korrekturdaten"
ENDSWITCH
;
	OFFSET=0
	IF (NR>0) THEN
  	SWRITE(MELDUNG[],STATE,OFFSET,"%s%d: X:%.1f,Y:%.1f,Z:%.1f,A:%.3f,B:%.3f,C:%.3f",NAME[],NR,INFRAME.x,INFRAME.y,INFRAME.z,INFRAME.a,INFRAME.b,INFRAME.c)
  	;SWRITE(MELDUNG[],STATE,OFFSET,"X:%.1f,Y:%.1f,Z:%.1f,A:%.3f,B:%.3f,C:%.3f",INFRAME.x,INFRAME.y,INFRAME.z,INFRAME.a,INFRAME.b,INFRAME.c)
  ELSE
  	SWRITE(MELDUNG[],STATE,OFFSET,"%s: X:%.1f,Y:%.1f,Z:%.1f,A:%.3f,B:%.3f,C:%.3f",NAME[],INFRAME.x,INFRAME.y,INFRAME.z,INFRAME.a,INFRAME.b,INFRAME.c)
 	ENDIF
;
  ;MsgState(nHandle, MELDUNG[], ABS[])
  IS_ShowMessage(nHandle, #state, MELDUNG[], ABS[], 1, TRUE)
;
END ;of IS_MSG_FRAME2()
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD ShowDialog
DEF IS_ShowDialog(nAnswer:OUT, sDialogSK1[]:IN,sDialogSK2[]:IN,sDialogSK3[]:IN,sDialogSK4[]:IN,sDialogSK5[]:IN,sDialogSK6[]:IN,sDialogSK7[]:IN,sText[]:IN, sModul[]:IN, bLog:IN, Par1:IN,Par2:IN,Par3:IN) 
;************************************************************
;Function: Executes a dialog
;************************************************************
DECL KrlMsg_T Msg
DECL KrlMsgDlgSK_T Msg_SOFTKEY[7]
DECL INT nHandle,nMsgSel,nApplNum,nMsgTNr,count, len, nAnswer, nMsgNr
DECL BOOL bLog,Clear
DECL KrlMsgPar_T Par1,Par2,Par3, MsgPar[3]
DECL EKrlMsgType MsgType
DECL KrlMsgOpt_T MsgOpt
DECL CHAR sModul[], sText[], sDialogSK1[], sDialogSK2[], sDialogSK3[], sDialogSK4[], sDialogSK5[], sDialogSK6[], sDialogSK7[]

;set Parameter (if existent (otherwise "empty"))
ERR_CLEAR($Err)
ON_ERROR_PROCEED
MsgPar[1]=Par1
IF ($Err.Number<>0)THEN
  MsgPar[1].par_type=#empty
ENDIF
ERR_CLEAR($Err)
ON_ERROR_PROCEED
MsgPar[2]=Par2
IF ($Err.Number<>0)THEN
  MsgPar[2].par_type=#empty
ENDIF
ERR_CLEAR($Err)
ON_ERROR_PROCEED
MsgPar[3]=Par3
IF ($Err.Number<>0)THEN
  MsgPar[3].par_type=#empty
ENDIF

;set Option
;Vorlaufstopp
MsgOpt.Vl_Stop=FALSE		
;Clear message on program reset
MsgOpt.Clear_P_Reset=TRUE	
;Clear message on block selection
MsgOpt.Clear_p_SAW=FALSE	
;Log message
MsgOpt.Log_To_DB=bLog	

;Standard aus MSGLIB
Msg.Nr=1
ERR_CLEAR($Err)
ON_ERROR_PROCEED
Msg.Nr=nMsgNr
len=Strlen(sText[])
IF len>0 THEN
  IF len>80 THEN
    len=80
  ENDIF
  FOR count=1 TO len
    Msg.Msg_txt[count]=sText[count]
  ENDFOR
ELSE
  Msg.Msg_txt[]="parameter sText[] is missing"
ENDIF

len=Strlen(sModul[])
IF len>0 THEN
  IF len>24 THEN
    len=24
  ENDIF
  FOR count=1 TO len
    Msg.Modul[count]=sModul[count]
  ENDFOR
ELSE
  Msg.Modul[]="Appl" 
ENDIF

;Set softkey text (1)
ERR_CLEAR($Err)
ON_ERROR_PROCEED
len=Strlen(sDialogSK1[])
IF $Err.Number==0 THEN
  IF len > 0 THEN
    IF len>24 THEN
      len=24
    ENDIF
    Msg_SOFTKEY[7].Sk_Type = #KEY
    FOR count=1 TO len
      Msg_SOFTKEY[7].Sk_txt[count] = sDialogSK1[count]
    ENDFOR
  ENDIF
ELSE
  FOR count=1 TO 24
    Msg_SOFTKEY[7].Sk_txt[count] = " "
  ENDFOR
ENDIF

;Set softkey text (2)
ERR_CLEAR($Err)
ON_ERROR_PROCEED
len=Strlen(sDialogSK2[])
IF $Err.Number==0 THEN
  len=Strlen(sDialogSK2[])
  IF len > 0 THEN
    IF len>24 THEN
      len=24
    ENDIF
    Msg_SOFTKEY[6].Sk_Type = #KEY
    FOR count=1 TO len
      Msg_SOFTKEY[6].Sk_txt[count] = sDialogSK2[count]
    ENDFOR
  ENDIF
ELSE
  FOR count=1 TO 24
    Msg_SOFTKEY[6].Sk_txt[count] = " "
  ENDFOR
ENDIF

;Set softkey text (3)
ERR_CLEAR($Err)
ON_ERROR_PROCEED
len=Strlen(sDialogSK3[])
IF $Err.Number==0 THEN
  len=Strlen(sDialogSK3[])
  IF len > 0 THEN
    IF len>24 THEN
      len=24
    ENDIF
    Msg_SOFTKEY[5].Sk_Type = #KEY
    FOR count=1 TO len
      Msg_SOFTKEY[5].Sk_txt[count] = sDialogSK3[count]
    ENDFOR
  ENDIF
ELSE
  FOR count=1 TO 24
    Msg_SOFTKEY[5].Sk_txt[count] = " "
  ENDFOR
ENDIF

;Set softkey text (4)
ERR_CLEAR($Err)
ON_ERROR_PROCEED
len=Strlen(sDialogSK4[])
IF $Err.Number==0 THEN
  len=Strlen(sDialogSK4[])
  IF len > 0 THEN
    IF len>24 THEN
      len=24
    ENDIF
    Msg_SOFTKEY[4].Sk_Type = #KEY
    FOR count=1 TO len
      Msg_SOFTKEY[4].Sk_txt[count] = sDialogSK4[count]
    ENDFOR
  ENDIF
ELSE
  FOR count=1 TO 24
    Msg_SOFTKEY[4].Sk_txt[count] = " "
  ENDFOR
ENDIF

;Set softkey text (5)
ERR_CLEAR($Err)
ON_ERROR_PROCEED
len=Strlen(sDialogSK5[])
IF $Err.Number==0 THEN
  len=Strlen(sDialogSK5[])
  IF len > 0 THEN
    IF len>24 THEN
      len=24
    ENDIF
    Msg_SOFTKEY[3].Sk_Type = #KEY
    FOR count=1 TO len
      Msg_SOFTKEY[3].Sk_txt[count] = sDialogSK5[count]
    ENDFOR
  ENDIF
ELSE
  FOR count=1 TO 24
    Msg_SOFTKEY[3].Sk_txt[count] = " "
  ENDFOR
ENDIF

;Set softkey text (6)
ERR_CLEAR($Err)
ON_ERROR_PROCEED
len=Strlen(sDialogSK6[])
IF $Err.Number==0 THEN
  len=Strlen(sDialogSK6[])
  IF len > 0 THEN
    IF len>24 THEN
      len=24
    ENDIF
    Msg_SOFTKEY[2].Sk_Type = #KEY
    FOR count=1 TO len
      Msg_SOFTKEY[2].Sk_txt[count] = sDialogSK6[count]
    ENDFOR
  ENDIF
ELSE
  FOR count=1 TO 24
    Msg_SOFTKEY[2].Sk_txt[count] = " "
  ENDFOR
ENDIF

;Set softkey text (7)
ERR_CLEAR($Err)
ON_ERROR_PROCEED
len=Strlen(sDialogSK7[])
IF $Err.Number==0 THEN
  len=Strlen(sDialogSK7[])
  IF len > 0 THEN
    IF len>24 THEN
      len=24
    ENDIF
    Msg_SOFTKEY[1].Sk_Type = #KEY
    FOR count=1 TO len
      Msg_SOFTKEY[1].Sk_txt[count] = sDialogSK7[count]
    ENDFOR
  ENDIF
ELSE
  FOR count=1 TO 24
    Msg_SOFTKEY[1].Sk_txt[count] = " "
  ENDFOR
ENDIF

CONTINUE
nHandle=SET_KRLDLG(Msg, MsgPar[], Msg_SOFTKEY[], MsgOpt)

If (nHandle > 0) THEN
  REPEAT
  CONTINUE
  WAIT SEC 0.5
  UNTIL((NOT Exists_KrlDlg(nHandle, nAnswer)))
  Clear=Clear_KrlMsg(nHANDLE)
ENDIF
;
END
;
;
DEF IS_ShowMessage(nHandle:OUT, MsgType:IN, sText[]:IN, sModul[]:IN, nMsgNr:IN, bLog:IN, Par1:IN, Par2:IN, Par3:IN)
;************************************************************
;Function: Executes a Message Send of the notify message
;************************************************************
DECL CHAR sText[], sModul[]  
DECL KrlMsg_T Msg
DECL EKrlMsgType MsgType
DECL KrlMsgPar_T Par1, Par2, Par3, MsgPar[3]
DECL KrlMsgOpt_T MsgOpt
DECL BOOL bLog
DECL INT count, len, nHandle, nMsgNr

;set Parameter (if existent (otherwise "empty"))
ERR_CLEAR($Err)
ON_ERROR_PROCEED
MsgPar[1]=Par1
if ($Err.Number<>0)Then
  MsgPar[1].par_type=#empty
endif
ERR_CLEAR($Err)
ON_ERROR_PROCEED
  MsgPar[2]=Par2
if ($Err.Number<>0)Then
MsgPar[2].par_type=#empty
endif
ERR_CLEAR($Err)
ON_ERROR_PROCEED
  MsgPar[3]=Par3
if ($Err.Number<>0)Then
  MsgPar[3].par_type=#empty
endif

;set Option
;Vorlaufstopp
MsgOpt.Vl_Stop=FALSE		
;Clear message on program reset
MsgOpt.Clear_P_Reset=TRUE	
;Clear message on block selection
MsgOpt.Clear_p_SAW=FALSE	
;Log message
MsgOpt.Log_To_DB=bLog		

;set MessagNumber
Msg.Nr=nMsgNr
;set Msgtext
len=Strlen(sText[])
if len>0 then
	if len>80 then
		len=80
	endif
	for count=1 to len
		Msg.Msg_txt[count]=sText[count]
	endfor
else
	Msg.Msg_txt[]="Message text is missing"
endif
;setMsg-Modul
len=Strlen(sModul[])
if len>0 then
	if len>24 then
		len=24
	endif
	for count=1 to len
		Msg.Modul[count]=sModul[count]
	endfor
else
	Msg.Modul[]="Module name missing" 
endif

CONTINUE
nHandle=Set_KrlMsg (MsgType, Msg, MsgPar[], MsgOpt)

END 
;
;ENDFOLD (ISRA)