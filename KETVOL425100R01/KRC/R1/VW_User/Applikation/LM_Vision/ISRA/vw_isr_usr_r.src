;
; FOLD Handlungsanweisung bestimmen
;---------------------------------------------------------------------------------------------
DEF IS_GetUserInstruction(iInstruction:IN)
DECL INT iInstruction
;DECL CHAR MELDUNG[80]
DECL INT OFFSET
DECL INT iAnswer
CHAR ch_KXRKey[100]
CHAR ch_KXRKey_btn[10]
	iAnswer=0
	
	IF (iInstruction==-1) THEN
		RETURN
	ENDIF

	SWITCH(iInstruction)
	CASE 0
		IF $FLAG[IS_FLAG_ERR_PREPARE] THEN
			ch_KXRKey[]="IS_Instr_Flag_Prep"
		ELSE
			IF $FLAG[IS_FLAG_ERR_ACQ] THEN
				ch_KXRKey[]="IS_Instr_Flag_Prep"
			ELSE
				IF $FLAG[IS_FLAG_ERR_FEATURE] THEN
					ch_KXRKey[]="IS_Instr_Flag_Feat"
				ELSE
					IF $FLAG[IS_FLAG_ERR_EVAL] THEN
						ch_KXRKey[]="IS_Instr_Flag_Eval"
					ELSE
						IF $FLAG[IS_FLAG_ERR_TOL] THEN
							ch_KXRKey[]="IS_Instr_Flag_Tol"
						ELSE
							ch_KXRKey[]="IS_Instr_Flag_Default"
						ENDIF						
					ENDIF				
				ENDIF			
			ENDIF	
		ENDIF
	CASE IS_Instr_Response
		ch_KXRKey[] = "IS_Instr_Response"
	CASE IS_Instr_ModelCmp
		ch_KXRKey[] = "IS_Instr_ModelCmp"
	CASE IS_Instr_ModelChk
		ch_KXRKey[] = "IS_Instr_ModelChk"
	CASE IS_Instr_DeadlyErr
		ch_KXRKey[] = "IS_Instr_DeadlyErr"
	CASE IS_Instr_RoutCheck
		ch_KXRKey[] = "IS_Instr_RoutCheck"
	CASE IS_Instr_PntChk
    ch_KXRKey[] = "IS_Instr_PntChk"
	CASE IS_Instr_TolChk
		ch_KXRKey[] = "IS_Instr_TolChk"
	CASE IS_Instr_CalChk
		ch_KXRKey[] = "IS_Instr_CalChk"
	CASE IS_Instr_ImgMsgChk
		ch_KXRKey[] = "IS_Instr_ImgMsgChk"
	CASE IS_Instr_RobTol
    ch_KXRKey[] = "IS_Instr_RobTol"
	CASE IS_Instr_TypeChk
		ch_KXRKey[] = "IS_Instr_TypeChk"
	CASE IS_Instr_HWChk
		ch_KXRKey[] = "IS_Instr_HWChk"
	CASE IS_Instr_MsgChk
		ch_KXRKey[] = "IS_Instr_MsgChk"
	CASE IS_Instr_RobProg
		ch_KXRKey[] = "IS_Instr_RobProg"
	ENDSWITCH
	;
 	ch_KXRKey_btn[] = "BACK"
 	;
	IS_ShowDialog(iAnswer," ",ch_KXRKey_btn[]," "," "," "," "," ",ch_KXRKey[], "vw_isr_usr_r", TRUE)
	;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Fehler nach Aussen melden
;---------------------------------------------------------------------------------------------
DEF IS_SetError(iError:IN)
DECL INT  iError
DECL BOOL bRetVal
;
;IS_Log("SetError",1,FALSE)
;
IS_strErrorSource[ ] = "VW-User"
IS_strErrorSource[8] = 0
;
IS_iCurrentUserError = iError
;
IF (iError>0) AND (iError<7) THEN
	IS_TX1_ERROR_STATE = TRUE
	IS_TX1_HANDSHAKE = IS_ToggleHandshake()
	;
	IF (IS_WAIT(#IS_ERROR_ID, FALSE,0)==FALSE) THEN
		$FLAG[IS_FLAG_ERROR] = TRUE
		IS_SetInternError(IS_IntErr_ESendBit) 					;Fehleruebertragung schlug fehl
		;IS_MSG_ERR(IS_MSG_ERR_BIT_TRNS)
		;IS_iFnctID = 0
	ENDIF
	;
	IF (IS_RX8_DATA_ID==9) AND ($FLAG[IS_FLAG_ERROR]==FALSE) THEN
		IS_TX8_DATA_ID  			= 9
		IS_TX8_ERROR_ID1 			= 0
		IS_TX8_ERROR_ID2			= iError
		IS_TX1_DATA_END_TRANS	= TRUE
		IS_TX1_DATA_VALID			= TRUE
		IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
;
		IF (IS_WAIT(#IS_ERROR_ID, FALSE,0)==FALSE) THEN
			$FLAG[IS_FLAG_ERROR] = TRUE
			IS_SetInternError(IS_IntErr_ESend) 				;Fehleruebertragung schlug fehl
			;IS_MSG_ERR(IS_MSG_ERR_TRANSM)
			;IS_iFnctID = 0
		ENDIF
;
		IS_TX8_DATA_ID  			= 0
		IS_TX8_ERROR_ID1 			= 0
		IS_TX8_ERROR_ID2			= 0
		IS_TX1_DATA_END_TRANS	= FALSE
		IS_TX1_DATA_VALID			= FALSE
;
		SWITCH iError
			CASE 2,3,4
				$FLAG[IS_FLAG_ERR_ROBOT] = TRUE	 ;Verbindungsfehler
			CASE 6
				$FLAG[IS_FLAG_ERR_TOL] = TRUE 	 ;Korrektur ausser Toleranz
		ENDSWITCH
;
		$FLAG[IS_FLAG_ERROR] = TRUE
;
	ENDIF
;
ENDIF
;
IS_iInternErrors = iError
IS_ProcessErrors()
IS_iInternErrors = 0
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Internen Fehler signalisieren
;---------------------------------------------------------------------------------------------
DEF IS_SetInternError(iError:IN, iParam1: IN, iParam2: IN)
DECL INT iError
DECL INT iParam1,iParam2
;
IF NOT (Varstate ("iParam1")==#initialized) then
   iParam1 = 0;
ENDIF
;
IF NOT (Varstate ("iParam2")==#initialized) then
   iParam2 = 0;
ENDIF
;
IS_strErrorSource[] = "VW-User"
IS_strErrorSource[8] = 0
;
IF (iError>=1010) AND (iError<=1018) THEN
;
	SWITCH iError
		CASE IS_IntErr_Com
		 	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE 									;Fehler ISRA LiveSignal
	 	CASE 1011
		 	$FLAG[IS_FLAG_ERR_PREPARE]= TRUE  								;Model_ID Abgleich mit ISRA-System fehlgeschlagen
		CASE 1012
	   	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Reintialisieren der Signale fehlgeschlagen
	  CASE IS_IntErr_ERequest
	   	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Fehlerabfrage schlug fehl
	  CASE 1016
	    $FLAG[IS_FLAG_ERR_PREPARE]= TRUE									;Daten holen NIO. Typ ,SubTyp
	  CASE IS_IntErr_Base
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Base ID n out of range (1-31)
	  CASE IS_IntErr_Tool
	    $FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Tool ID %d out of range (1-31)
	  CASE IS_IntErr_ESendBit
	   	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Fehleruebertragung schlug fehl
	  CASE IS_IntErr_Specif
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Specifier nicht erlaubt
	  CASE IS_IntErr_SrvcExp
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;
	  CASE IS_IntErr_StReq1
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;
	  CASE IS_IntErr_StReq2
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;
	  CASE 1025
	  	$FLAG[IS_FLAG_ERR_FEATURE]= TRUE							  	;Fehler beim Uebertragen der Tooldaten
		CASE IS_IntErr_ESend
	   	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Fehleruebertragung schlug fehl
	  CASE IS_IntErr_MeasPosNo
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;Fehler am Messpunkt
	  CASE IS_IntErr_IQRWait
	  	;
	  CASE IS_IntErr_PCWait
	  	;
	  CASE IS_IntErr_TolRob
	  	$FLAG[IS_FLAG_ERR_TOL] 		= TRUE									;Toleranzueberschreitung
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;
	  CASE IS_IntErr_RFAState
	  	$FLAG[IS_FLAG_ERR_ROBOT] 	= TRUE									;
	  	
	  DEFAULT
	    ;
	  ENDSWITCH
 ;
ENDIF
;
IS_bInternError = TRUE
;
$FLAG[IS_FLAG_ERROR] = TRUE
;
;
IS_MSG_ERR(iError, iParam1, iParam2)
;
IS_iFnctID = 0
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Externen Fehler vom Bus abfragen
;---------------------------------------------------------------------------------------------
DEF IS_IMT_GetExternErrors ()
DECL BOOL b_RetVal
;
IF (IS_RX1_ERROR_STATE == FALSE) THEN
	RETURN
ENDIF
;
IS_TX1_DATA_END_TRANS = FALSE
IS_TX1_DATA_VALID			= FALSE
IS_TX1_DATA_ACCEPTED	= FALSE
IS_TX8_DATA_ID 				= 9			;Fehlerabfrage
IS_TX1_DATA_REQUEST 	= TRUE
IS_TX1_HANDSHAKE 			= IS_ToggleHandshake()
;
WAIT SEC 0.1
;
IF (IS_Wait(#IS_ERROR_ID, TRUE, IS_FnctID_IMT_GetExtErr) == FALSE) THEN
	$FLAG[IS_FLAG_ERROR] 			= TRUE
	IS_SetInternError(IS_IntErr_ERequest)				;Fehlerabfrage schlug fehl
	IS_MSG_ERR(IS_MSG_ERR_REQUEST)
	IS_iFnctID = 0
	RETURN
ENDIF
;
IS_iErrorSource 			= IS_RX8_ERR_SYS_ID
IS_iExternErrors 			= IS_RX8_ERRORS
IS_TX1_DATA_REQUEST 	= FALSE
IS_TX1_DATA_ACCEPTED 	= TRUE
IS_TX1_HANDSHAKE = IS_ToggleHandshake()
;
IF (IS_Wait(#IS_ERROR_ID, FALSE, 0) == FALSE) THEN
	$FLAG[IS_FLAG_ERROR] = TRUE
	IS_SetInternError(IS_IntErr_ERequest)				;Fehlerabfrage schlug fehl
	IS_MSG_ERR(IS_MSG_ERR_REQUEST)
	IS_iFnctID = 0
	RETURN
ENDIF
;
IS_TX1_DATA_ACCEPTED = FALSE
;
;Synchronisieren der ISRA Flags mit Roboter Flags.
b_RetVal = IS_SyncErrors(IS_iErrorSource, IS_iExternErrors)
;
IS_ProcessErrors()
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;
;FOLD Externen Fehler für RF vom Bus abfragen
;---------------------------------------------------------------------------------------------
DEF IS_RF_GetExternErrors (iFnctID:IN)
DECL INT iFnctID
DECL BOOL bVal
;
IS_iExternErrors = 0
;
; Auslesen und in internes Mapping ueberfuehren
IF IS_RX1_RF_ERR_DEADLY THEN
	IS_iExternErrors = IS_iExternErrors B_OR IS_ErrBit_Deadly
ENDIF
;
IF IS_RX1_RF_ERR_PREP THEN
	IS_iExternErrors = IS_iExternErrors B_OR IS_ErrBit_Prepare
ENDIF
;
IF IS_RX1_RF_ERR_FEAT THEN
	IS_iExternErrors = IS_iExternErrors B_OR IS_ErrBit_Feature
ENDIF
;
IF IS_RX1_RF_ERR_TOL THEN
	IS_iExternErrors = IS_iExternErrors B_OR IS_ErrBit_Tol
ENDIF
;
IF IS_iExternErrors <> 0 THEN
	;Synchronisieren der ISRA Fehler mit Roboter Flags
  bVal = IS_SyncErrors(1, IS_iExternErrors)
	;
	IS_ProcessErrors()
ENDIF
;
IS_iExternErrors = 0
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;	
;FOLD Externen Fehler für RF vom Bus abfragen
;---------------------------------------------------------------------------------------------
DEF IS_RF_GetExternWarn (iFncID:IN, MSGOUT:IN)
DECL INT iFncID
DECL BOOL MSGOUT
DECL BOOL bVal
;
IS_iExternWarns_RF = 0
;
; Auslesen und in internes Mapping ueberfuehren
IF IS_RX1_RF_W_MAN THEN
	IS_iExternWarns_RF = IS_iExternWarns_RF B_OR IS_STATE_WARN_MANMEAS
ENDIF
;
IF IS_RX1_RF_W_TOL THEN
	IS_iExternWarns_RF = IS_iExternWarns_RF B_OR IS_STATE_WARN_TOL
ENDIF
;
IF IS_RX1_RF_W_EVAL THEN
	IS_iExternWarns_RF = IS_iExternWarns_RF B_OR IS_STATE_WARN_EVAL
ENDIF
;
IF IS_iExternWarns_RF <> 0 THEN
	; Synchronisieren der ISRA Warnungen mit Roboter Flags
	; TODO: ErrSourceRoVis = 1
	bVal = IS_RF_SyncWarns(1, IS_iExternWarns_RF, TRUE)
	;
	; Meldungsausgabe: TODO: ProcessWarns --> Funktioniert das?
ENDIF
;
IS_iExternWarns_RF = 0
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Abbilden der externen Fehler auf Roboter Flags
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_SyncErrors (iErrorSource:IN, iExternErrors:IN)
DECL INT  iErrorSource
DECL INT  iExternErrors
DECL BOOL b_OK
;
;FOLD Reset Flags
IF (iErrorSource==0) AND (iExternErrors==0) THEN
	$FLAG[IS_FLAG_ERR_SPS] 				= FALSE
	$FLAG[IS_FLAG_ERR_ROBOT] 			= FALSE
	$FLAG[IS_FLAG_ERR_PREPARE] 		= FALSE
	$FLAG[IS_FLAG_ERR_ACQ]		 		= FALSE
	$FLAG[IS_FLAG_ERR_FEATURE] 		= FALSE
	$FLAG[IS_FLAG_ERR_EVAL] 			= FALSE
	$FLAG[IS_FLAG_ERR_TOL] 				= FALSE
	$FLAG[IS_FLAG_WARN_TOL]			 	= FALSE
	$FLAG[IS_FLAG_RESULT_OK] 			= FALSE
	$FLAG[IS_FLAG_RESULT_NOK] 		= FALSE
	$FLAG[IS_FLAG_ERROR] 					= FALSE
	;
	IS_iErrorSource = 0
	IS_iExternErrors = 0
	;	
	IS_strErrorSource[] = "VW-User"
	IS_strErrorSource[8] = 0
	;
	RETURN TRUE
ENDIF
;ENDFOLD (Reset Flags)
;
b_OK = TRUE
;	
;Bit 1
IF (iExternErrors B_AND 1)==IS_ErrBit_SPS THEN 				;Fehler SPS-Kommunikation
  $FLAG[IS_FLAG_ERR_SPS] = TRUE
  $FLAG[IS_FLAG_ERROR]   = TRUE
  b_OK = FALSE
ELSE
  $FLAG[IS_FLAG_ERR_SPS]=FALSE
ENDIF
;
;Bit 2
IF (iExternErrors B_AND 2)==IS_ErrBit_Rob THEN						;Fehler Roboter-Kommunikation
  $FLAG[IS_FLAG_ERR_ROBOT]=TRUE
  $FLAG[IS_FLAG_ERROR]=TRUE
  b_OK = FALSE
ELSE
  $FLAG[IS_FLAG_ERR_ROBOT]=FALSE
ENDIF
;
;Bit 3
IF (iExternErrors B_AND 4)==IS_ErrBit_Command THEN 			;Fehler bei Messbeauftragung
	$FLAG[IS_FLAG_RESULT_NOK] = TRUE
	$FLAG[IS_FLAG_RESULT_OK]  = FALSE
  $FLAG[IS_FLAG_ERROR]=TRUE
  b_OK = FALSE
ENDIF
;
;Bit 4
IF (iExternErrors B_AND 8)==IS_ErrBit_Prepare THEN 			;Fehler Typanmeldung
	$FLAG[IS_FLAG_RESULT_NOK] = TRUE
	$FLAG[IS_FLAG_RESULT_OK]  = FALSE
  $FLAG[IS_FLAG_ERR_PREPARE]=TRUE
  $FLAG[IS_FLAG_ERROR]=TRUE
  b_OK = FALSE
ELSE
  $FLAG[IS_FLAG_ERR_PREPARE]=FALSE
ENDIF
;
;Bit 5
IF (iExternErrors B_AND 16)==IS_ErrBit_ACQ THEN 					;Fehler Bildaufnahme
	$FLAG[IS_FLAG_RESULT_NOK] = TRUE
	$FLAG[IS_FLAG_RESULT_OK]  = FALSE
  $FLAG[IS_FLAG_ERR_ACQ]=TRUE
  $FLAG[IS_FLAG_ERROR]=TRUE
  b_OK = FALSE
ELSE
  $FLAG[IS_FLAG_ERR_ACQ]=FALSE
ENDIF
;
;Bit 6
IF (iExternErrors B_AND 32)==IS_ErrBit_Feature THEN			;Fehler Merkmalerkennung
	$FLAG[IS_FLAG_RESULT_NOK] = TRUE
	$FLAG[IS_FLAG_RESULT_OK]  = FALSE
  $FLAG[IS_FLAG_ERR_FEATURE]=TRUE
  $FLAG[IS_FLAG_ERROR]=TRUE
  b_OK = FALSE
ELSE
  $FLAG[IS_FLAG_ERR_FEATURE]=FALSE
ENDIF
;
;Bit 7
IF (iExternErrors B_AND 64)==IS_ErrBit_Eval THEN 				;Fehler bei Auswertung
	$FLAG[IS_FLAG_RESULT_NOK] = TRUE
	$FLAG[IS_FLAG_RESULT_OK]  = FALSE
  $FLAG[IS_FLAG_ERR_EVAL]=TRUE
  $FLAG[IS_FLAG_ERROR]=TRUE
  b_OK = FALSE
ELSE
  $FLAG[IS_FLAG_ERR_EVAL]=FALSE
ENDIF
;
;Bit 8
IF (iExternErrors B_AND 128)==IS_ErrBit_Tol THEN 			;Fehler Toleranzueberschreitung
	$FLAG[IS_FLAG_RESULT_NOK] = TRUE
	$FLAG[IS_FLAG_RESULT_OK]  = FALSE
  $FLAG[IS_FLAG_ERR_TOL]=TRUE
  $FLAG[IS_FLAG_ERROR]=TRUE
  b_OK = FALSE
ELSE
  $FLAG[IS_FLAG_ERR_TOL]=FALSE
ENDIF
;
RETURN b_OK
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Abbilden der externen Fehler auf Roboter Flags für RF
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_RF_SyncWarns (iErrorSource:IN, iExternWarns:IN, MSGOUT:IN)
DECL INT  iErrorSource
DECL INT  iExternWarns
DECL BOOL MSGOUT ; flag zur ausgabe von meldungen
DECL BOOL bOk
;
IF (iErrorSource == 0) AND (iExternWarns == 0) THEN
	;
	$FLAG[IS_FLAG_WARN_TOL]=FALSE
	
	IS_iErrorSource = 0
	IS_iExternWarns_RF = 0
	IS_strErrorSource[] = "VW-User"
	RETURN TRUE
ENDIF
bOk = TRUE
;
; 1: Manuelle Messunganmeldung wurde verwendet
IF (iExternWarns B_AND IS_STATE_WARN_MANMEAS) == IS_STATE_WARN_MANMEAS THEN
	;bisher gibt es kein Flag
	bOk = FALSE 
ENDIF
;
; 2: bei Ergebnissimulation
IF (iExternWarns B_AND IS_STATE_WARN_EVAL) == IS_STATE_WARN_EVAL THEN
	;bisher gibt es kein Flag
	bOk = FALSE 
ENDIF
;
; 3: Toleranzverletzung
IF (iExternWarns B_AND IS_STATE_WARN_TOL) == IS_STATE_WARN_TOL THEN
	$FLAG[IS_FLAG_WARN_TOL] = TRUE
	bOk = FALSE 
ENDIF
;
RETURN bOK
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Zentrale Funktion zur Fehlerbehandlung
;---------------------------------------------------------------------------------------------
DEF IS_ProcessErrors()
DECL CHAR strErrorSource[10]
DECL INT OFFSET
DECL STATE_T STATE
CHAR ch_tempString[300]
;
IF (IS_iExternErrors==0) AND (IS_iInternErrors==0) THEN
	RETURN
ENDIF
;
IF (IS_iExternErrors <> 0) THEN
	SWITCH IS_iErrorSource
	CASE 1
		strErrorSource[] = "RoVis"
		strErrorSource[6] = 0
	CASE 2
		strErrorSource[] = "Genesis"
		strErrorSource[8] = 0
	CASE 3
		strErrorSource[] = "IQRob"
		strErrorSource[6] = 0
	CASE 4
		strErrorSource[] = "ISRob"
		strErrorSource[6] = 0
	CASE 5
		strErrorSource[] = "Dynalog"
		strErrorSource[8] = 0
		SWITCH IS_iExternErrors
			CASE 1
				IS_MSG_ERR(IS_MSG_ERR_RTC_CALIB)
			CASE 2
				SWITCH IS_iServiceMode
				CASE IS_iTOOL_CHANGE
					IS_MSG_ERR(IS_MSG_ERR_RTC_CALC_TOOL)
				CASE IS_iROBOT_CHANGE
					IS_MSG_ERR(IS_MSG_ERR_RTC_CALC_BASE)
				CASE IS_iSENSOR_CHANGE_IMT
					IS_MSG_ERR(IS_MSG_ERR_SERV_SENSIMT)
				DEFAULT
					IS_MSG_ERR(IS_MSG_ERR_RTC)
				ENDSWITCH
			DEFAULT
				IS_MSG_ERR(IS_MSG_ERR_RTC)
			ENDSWITCH
		RETURN
	DEFAULT
		strErrorSource[] = "ISRA"
		strErrorSource[5] = 0
	ENDSWITCH
;
	OFFSET=0
	SWRITE(IS_strErrorSource[], STATE, OFFSET, "%s%d", strErrorSource[], IS_iExternErrors)
ENDIF
;
IF (IS_iInternErrors <> 0) THEN
	strErrorSource[] = "VW-User"
	strErrorSource[8]= 0
	OFFSET=0
	SWRITE(IS_strErrorSource[], STATE, OFFSET, "%s%d", strErrorSource[], IS_iInternErrors)
ENDIF
;
IF (IS_iInternErrors == IS_Err_ID_Tolerance) THEN
	OFFSET=0
	SWRITE(ch_tempString[], STATE, OFFSET, "Max = {X %.2f, Y %.2f, Z %.2f, A %.2f, B %.2f, C %.2f}", IS_CORR_ACCEPT_FRAME.X, IS_CORR_ACCEPT_FRAME.Y, IS_CORR_ACCEPT_FRAME.Z, IS_CORR_ACCEPT_FRAME.A, IS_CORR_ACCEPT_FRAME.B, IS_CORR_ACCEPT_FRAME.C)
	IS_MSG_ERR(IS_MSG_ERR_TOL_EXCEEDED)
	RETURN
ENDIF
;
SWITCH IS_iServiceMode
	CASE IS_iSENSOR_CHANGE
		IF (IS_iErrorSource==3) AND (IS_iExternErrors==16) THEN
			;IS_MSG_ERR(IS_MSG_ERR_SERV_SENS2)
			IS_MSG(IS_MSG_I_TRANS_AXES, IS_MSG_TYPE_NOTIFY) ;Achswinkel werden uebertragen
			IS_iFnctID = 0
		ELSE
		  ;IS_MSG_ERR(IS_MSG_ERR_SERV_SENS2)
		ENDIF
		RETURN
	CASE IS_iTOOL_CHANGE
		IF (IS_iErrorSource==3) AND (IS_iExternErrors==16) THEN
			;IS_MSG_ERR(IS_MSG_ERR_AXIS1A)
			IS_MSG(IS_MSG_I_TRANS_AXES, IS_MSG_TYPE_NOTIFY) ;Achswinkel werden uebertragen
			IS_iFnctID = 0
		ELSE
		  IS_MSG_ERR(IS_MSG_ERR_SERV_TOOL)
		ENDIF
		RETURN
	CASE IS_iROBOT_CHANGE
		IF (IS_iErrorSource==3) AND (IS_iExternErrors==16) THEN
			;IS_MSG_ERR(IS_MSG_ERR_AXIS1A)
			IS_MSG(IS_MSG_I_TRANS_AXES, IS_MSG_TYPE_NOTIFY) ;Achswinkel werden uebertragen
			IS_iFnctID = 0
		ELSE
		  IF (IS_iErrorSource==3) AND (IS_iExternErrors==32) THEN
		  	;IS_MSG_ERR(IS_MSG_ERR_AXIS1B)
				IS_MSG(IS_MSG_I_TRANS_BASE, IS_MSG_TYPE_NOTIFY) ;Basedaten werden uebertragen
				IS_iFnctID = 0
			ELSE
			  IF (IS_iErrorSource==3) AND (IS_iExternErrors==48) THEN
					;IS_MSG_ERR(IS_MSG_ERR_AXIS1B)
					;IS_MSG_ERR(IS_MSG_ERR_AXIS1A)
					IS_MSG(IS_MSG_I_TRANS_BASE, IS_MSG_TYPE_NOTIFY) ;Basedaten werden uebertragen)
					IS_MSG(IS_MSG_I_TRANS_AXES, IS_MSG_TYPE_NOTIFY) ;Achswinkel werden uebertragen
					IS_iFnctID = 0
			  ELSE
				  IS_MSG_ERR(IS_MSG_ERR_SERV_ROB)
				ENDIF
			ENDIF
		ENDIF
		RETURN
   CASE IS_iSENSOR_CHANGE_IMT
		IS_MSG_ERR(IS_MSG_ERR_SERV_SENSIMT)
		IS_iFnctID = 0
		RETURN
ENDSWITCH
;
SWITCH IS_iFnctID
;
;FOLD SNYC
CASE IS_FnctID_IMT_Sync1
	IF (IS_iExternErrors>0) THEN
		IS_MSG_ERR(IS_MSG_ERR_SYNC1A)
	ELSE
		IS_MSG_ERR(IS_MSG_ERR_SYNC1B)
	ENDIF
CASE IS_FnctID_IMT_Sync2
	IF (IS_iExternErrors>0) THEN
		IS_MSG_ERR(IS_MSG_ERR_SYNC2A)
	ELSE
		IS_MSG_ERR(IS_MSG_ERR_SYNC2B)
	ENDIF
;ENDFOLD (SYNC)
;
;FOLD SELECT
CASE IS_FnctID_IMT_SelectUp1
IF (IS_iExternErrors>0) THEN
	IF (IS_iErrorSource==3) AND ((IS_iExternErrors b_and 4)==4) THEN
		IS_MSG_ERR(IS_MSG_ERR_SELECT1A, IS_MODEL)
	ELSE
		IS_MSG_ERR(IS_MSG_ERR_SELECT1, IS_MODEL)
	ENDIF
ELSE
	SWITCH IS_iInternErrors
		CASE IS_Err_ID_Drain 																;Ablauffehler
			IS_MSG_ERR(IS_MSG_ERR_SELECT1B, IS_MODEL)
		CASE IS_Err_ID_Timeout 															;Timeout
			IS_MSG_ERR(IS_MSG_ERR_SELECT1C)
		DEFAULT
