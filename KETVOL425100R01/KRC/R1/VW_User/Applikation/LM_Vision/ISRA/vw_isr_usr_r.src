CASE IS_MSG_ERR_IMT_PREPARE1A
	ch_KXRKey[] = "IS_MSG_ERR_IMT_PREPARE1A"
	IS_UserInstruction = IS_Instr_PntChk
CASE IS_MSG_ERR_IMT_PREPARE1B
	ch_KXRKey[] = "IS_MSG_ERR_IMT_PREPARE1B"
