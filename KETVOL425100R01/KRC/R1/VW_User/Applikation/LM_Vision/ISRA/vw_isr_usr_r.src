&ACCESS RVEO
&COMMENT KS26
&REL 59
&PARAM DISKPATH = VW_User/Applikation/LM_Vision/Isra
&PARAM TPUSER_VERSION = 8.3.0
&PARAM EDITMASK = VW_ISR_USR_R
DEF VW_ISR_USR_R( )
;
;***************************************************
;* ISRA                                            *
;* Version 1.30  / VKRC 4                          *
;* Bearbeitet am:                                  *
;* 27.11.2014 JHo                                  *
;***************************************************
;
;FOLD ISRA
;FOLD ISRA RF Messsystem ansteuern
;***************************************************
END

GLOBAL DEF ISRA_RF_Interface(USER_CMD:IN,CMD_SEL:IN,MODUS:IN,TYP:IN,SUBTYP:IN,SPECIFIER:IN,TOOLNR:IN,WIEDERHOLUNG:IN,PAR7:IN,PAR8:IN,PAR9:IN)
	DECL VW_USER_CMD USER_CMD
	DECL INT CMD_SEL, MODUS,TYP,SUBTYP,SPECIFIER,TOOLNR,WIEDERHOLUNG,PAR7,PAR8,PAR9
	DECL INT iCounter, iServiceCounter
	DECL BOOL bRepeatMeasurement
;
	iCounter = 1
	iServiceCounter = 1
	bRepeatMeasurement=FALSE
;
	IS_MODUS				= MODUS
	IS_TYP					= TYP
	IS_SUBTYP				= SUBTYP
	IS_SPECIFIER		= SPECIFIER
	IS_TOOLNR				= TOOLNR
	IS_WIEDERHOLUNG	= WIEDERHOLUNG
;
	; Ueberprufung der Eingabeparameter
	IF (IS_CheckParams(CMD_SEL,MODUS,TYP,SUBTYP,SPECIFIER,TOOLNR,WIEDERHOLUNG)==FALSE) THEN
		RETURN
	ENDIF
;
  SWITCH USER_CMD
  ;-- Advance
	CASE #USR_ADV
   	;FOLD Advance: Messung anmelden
   	;
 		iCounter = 1
 		iServiceCounter = 1
 		;
 		REPEAT ;Im Fehlerfall wiederholen
   		SWITCH IS_MODUS
   			CASE 1,3,6						; RF Messung anmelden
   			  ; Nur anmelden wenn noch keine Messung laeuft
   				IF ((IS_iMeasStateRF <> IS_iMS_STARTED) AND (IS_iMeasStateRF <> IS_iMS_RUNNING) AND (NOT $FLAG[IS_FLAG_ERROR])) THEN
   					IS_RF_Prepare(IS_TYP, IS_SUBTYP, IS_SPECIFIER)
   				ENDIF
   			CASE 21								; Base/Tool-Korrektur anwenden
   				;
   			CASE 22								; Base oder Tool zuruecksetzen
   				IS_ResetBaseOrTool(IS_SPECIFIER)
   			CASE 23								; Base und Tool zuruecksetzen
   				IS_ResetBaseOrTool(1)
   				IS_ResetBaseOrTool(2)
   			CASE 24								; ServiceErgebnis anwenden auf Base/Tool
   				;
   			CASE 31								; RF Sensortausch
   			  ; moved to TRIG
   			CASE 32 							; RF Tooltausch
   			  ; moved to TRIG
        CASE 33 							; RF Robotertausch
          ; moved to TRIG
   			CASE 36								; Fehlerdiagnose
   				;
   		  DEFAULT ;modus nicht vorhanden
   		ENDSWITCH
   	;
   	 	iCounter = iCounter+1
 	  UNTIL ((iCounter>=IS_WIEDERHOLUNG) OR ($FLAG[IS_FLAG_ERROR]==FALSE))
 		;
   	;ENDFOLD (Advance)
  ;-- Trig
	CASE #USR_TRIG
   ;FOLD Trig
   		iCounter = 1
   		iServiceCounter = 1
   		;
   		REPEAT ;Im Fehlerfall wiederholen
   		;
   		  SWITCH IS_MODUS
   			CASE 1,6								; RF Messung ausführen (1) und Komplett ausfuehren (6)
   				IS_iMeasPoint = IS_iMeasPoint + 1
   				IF (IS_iMeasPoint == IS_TOOLNR) THEN
   					IS_RF_Apply(0)
   				ELSE
   					IS_SetInternError(IS_IntErr_MeasPosNo, IS_iMeasPoint, IS_TOOLNR)
   				ENDIF
   			CASE 3							; RF Messung m. Korrektur (3)
   				IF ($MODE_OP==#T1) OR ($MODE_OP==#T2) THEN
   					;Teach-Modus
   					REPEAT
   					  IF (bRepeatMeasurement==TRUE) THEN
   					  	ISRA_PG_INIT()
   							; Nur anmelden wenn noch keine Messung laeuft
				   			IF ((IS_iMeasStateRF <> IS_iMS_STARTED) AND (IS_iMeasStateRF <> IS_iMS_RUNNING) AND (NOT $FLAG[IS_FLAG_ERROR])) THEN
				   				IS_RF_Prepare(IS_TYP, IS_SUBTYP, IS_SPECIFIER)
				   			ENDIF
				   		ENDIF
				   		;
   						IS_RF_Apply(0)
   						IS_RF_EndPose()
   						;
	            IF IS_STATE_OK() THEN
	            	$FLAG[IS_FLAG_RESULT_OK]=TRUE
	   					ELSE
	   						;Abfrage an User, ob die Messung wiederholt werden soll
	   						IS_MSG(IS_MSG_I_MEAS_FAILED, IS_MSG_TYPE_DIALOG)
   							IF (IS_ANSWER == 1) THEN
									;'Wiederholen': Prepare und erneute Messung
   								bRepeatMeasurement=TRUE	
				   			ELSE
				   				;'Abbrechen': Schleife beenden
				   				RETURN
   							ENDIF
	   					ENDIF
	   				UNTIL ($FLAG[IS_FLAG_ERROR]==FALSE)
	   			ELSE
	   				;Automatik
	 					IS_RF_Apply(0)
						IS_RF_EndPose()
						IF IS_STATE_OK() THEN
							$FLAG[IS_FLAG_RESULT_OK]=TRUE
						ENDIF
	   			ENDIF		
   			CASE 21								; Base/Tool-Korrektur anwenden
   				;
   			CASE 22								; Base oder Tool zuruecksetzen
   				;
   			CASE 23								; Base und Tool zuruecksetzen
   				;
        CASE 24               ; ServiceErgebnis anwenden auf Base/Tool
					;
   			CASE 31								; RF Sensortausch
   			  ; Die Schleife darf nur verlassen werden, wenn der Sensortausch erfolgreich abgeschlossen ist.
   			  REPEAT
   			  	; Wenn in Wdh, erneutes ProgramInit durchführen
   			  	IF iServiceCounter > 1 THEN
               ISRA_PG_INIT()
   			  	ENDIF
   			  	;
	          ; Prepare Sensorpruefung
	   				IF ((IS_iMeasStateRF <> IS_iMS_STARTED) AND (IS_iMeasStateRF <> IS_iMS_RUNNING) AND (NOT $FLAG[IS_FLAG_ERROR])) THEN
	   					IS_RF_Prepare(IS_TYP, IS_SUBTYP, IS_SPECIFIER)
	   				ENDIF
	   				;
	   				; Hier schon Service anmelden, damit keine Fehlermeldungen für eine normale Messung erscheinen
	   				IS_Apply_Service(3) ;3
	   				;
	   			  ; Sensorpruefung ausfuehren
	   			  IS_RF_Apply(0)
	   			  IS_RF_EndPose()
	   				SWITCH IS_SPECIFIER
	   				 CASE 1
	   				 	IS_RF_GetCorrection(1,31)
	   				 CASE 2
	   				 	IS_RF_GetCorrection(2,31)
	   				ENDSWITCH
	   				;
	   				IF NOT IS_State_OK() THEN
	   		  	  IS_MSG_ERR(IS_MSG_ERR_SERV_SENS1)
	   				ELSE
	   		  		IS_MSG(IS_MSG_I_SERV_SENS_CHK, IS_MSG_TYPE_NOTIFY)
							;
	   		  		IS_Apply_Service(3) ;3
	   		  		; Start Sensortausch, wenn keine Messung laueft
		   			  IF ((IS_iMeasStateRF <> IS_iMS_STARTED) AND (IS_iMeasStateRF <> IS_iMS_RUNNING) AND (NOT $FLAG[IS_FLAG_ERROR])) THEN
		   					IS_RF_Prepare(IS_iRM_Calib,0,0)
		   				ENDIF
		   				;
		   				IS_RF_Apply(1)				; ControlID 1 = Flaechenbildaufnahme
		   				IS_RF_Apply(2)				; ControlID 2 = Streifenbildaufnahme
	   		  		IS_RF_EndPose()
	   					;
   						IF IS_State_OK() THEN
		   		  		IS_MSG(IS_MSG_I_SERV_SENS, IS_MSG_TYPE_NOTIFY)
		   		  	ELSE
	  	 		  		IS_MSG_ERR(IS_MSG_ERR_SERV_SENS2)
		   			  ENDIF
	   		  	ENDIF
	   		  	;
	   		  	iServiceCounter = iServiceCounter+1
	   		  	;
	   		  UNTIL ($FLAG[IS_FLAG_ERROR]==FALSE)
	   		  ;
	   		  IF IS_STATE_OK() THEN
	   		  	$FLAG[IS_FLAG_RESULT_OK] = TRUE
	   			ENDIF
   				;
   			CASE 32 							; RF Tooltausch
   			  ; Die Schleife darf nur verlassen werden, wenn der Tooltausch erfolgreich abgeschlossen ist.
   			  REPEAT
   			  	; Wenn in Wdh, erneutes ProgramInit durchführen
   			  	IF iServiceCounter > 1 THEN
            	ISRA_PG_INIT()
   			  	ENDIF
   			  	;
	          IS_Apply_Service (1) ;1
	   				IF ((IS_iMeasStateRF <> IS_iMS_STARTED) AND (IS_iMeasStateRF <> IS_iMS_RUNNING) AND (NOT $FLAG[IS_FLAG_ERROR])) THEN
	   					IS_RF_Prepare(IS_TYP, IS_SUBTYP, 0)
	   				ENDIF
	   				IS_RF_Apply(0)
   					IS_RF_EndPose()
   					IS_RF_GetCorrection(2,IS_TOOLNR)
	   				;
	   				IF (NOT IS_CheckCorrFrame($ISRA_TOOL_OFFSET,$NULLFRAME)) THEN
	   					$FLAG[IS_FLAG_ERROR] = TRUE
	   					IS_MSG_ERR(IS_MSG_ERR_TOL_EXCEEDED)
	   				ENDIF
		   			;
	   				iServiceCounter = iServiceCounter+1
	   				;
   				UNTIL ($FLAG[IS_FLAG_ERROR]==FALSE)
   			CASE 33						;RF Robotertausch
   				IF ((IS_iMeasStateRF == IS_iMS_STARTED) OR (IS_iMeasStateRF == IS_iMS_RUNNING) AND (NOT $FLAG[IS_FLAG_ERROR])) THEN
   					; Letzter Messpunkt eines bewegten Robotertauschs, darum kein Eintritt in Dauerschleife
   					IS_RF_Apply(0)
   					IS_RF_EndPose()
   					;
   					IS_Apply_Service (2) ;2
   					IS_RF_GetCorrection(1,IS_TOOLNR)
   					;
   				ELSE
   					; stationärer Robotertausch
   					; Die Schleife darf nur verlassen werden, wenn der Robotertausch erfolgreich abgeschlossen ist.
	   			  REPEAT
	   			  	; Wenn in Wdh, erneutes ProgramInit durchführen
	   			  	IF iServiceCounter > 1 THEN
	               ISRA_PG_INIT()
	   			  	ENDIF
	   			  	;
		   				IS_Apply_Service (2) ;2
		   				IF ((IS_iMeasStateRF <> IS_iMS_STARTED) AND (IS_iMeasStateRF <> IS_iMS_RUNNING) AND (NOT $FLAG[IS_FLAG_ERROR])) THEN
		   					IS_RF_Prepare(IS_TYP, IS_SUBTYP, 0)
		   				ENDIF
		   				IS_RF_Apply(0)
		   				IS_RF_EndPose()
		   				IS_RF_GetCorrection(1,IS_TOOLNR)
				   		;
				   		IF (NOT IS_CheckCorrFrame($ISRA_BASE_OFFSET,$NULLFRAME)) THEN
		   					$FLAG[IS_FLAG_ERROR] = TRUE
		   					IS_MSG_ERR(IS_MSG_ERR_TOL_EXCEEDED)
					   	ENDIF
				   		;
		   				iServiceCounter = iServiceCounter+1
		   				;
	   				UNTIL ($FLAG[IS_FLAG_ERROR]==FALSE)
	   			ENDIF
	   			;
	   			IF IS_STATE_OK() THEN
	   				$FLAG[IS_FLAG_RESULT_OK]=TRUE
	   			ENDIF
   			CASE 36								; Fehlerdiagnose
   				;
   	    DEFAULT ;modus nicht vorhanden
   		  ENDSWITCH
   			;
   	 	iCounter = iCounter+1
   		;
   	  UNTIL ((iCounter>=IS_WIEDERHOLUNG) OR ($FLAG[IS_FLAG_ERROR]==FALSE))
   		;
   	;ENDFOLD (Trig)
	;-- Main
	CASE #USR_MAIN
   ;FOLD Main
   ;
   		iCounter = 1
   		REPEAT  ;Im Fehlerfall wiederholen
   ;
   		  SWITCH IS_MODUS
				CASE 1									; RF Messen
					;
   			CASE 3									; RF Messung mit Korrektur
   				IS_RF_GetCorrection(IS_SPECIFIER,31)
   				IS_ApplyCorrection(IS_SPECIFIER,31)
   				IF (IS_iMaxNumIterations > 1) THEN
   					IS_RF_Apply_Iterative()
   				ENDIF
   			CASE 6									; RF Messung Komplett
   				IS_RF_EndPose()
   				;
   				IF IS_STATE_OK() THEN
   					$FLAG[IS_FLAG_RESULT_OK]=TRUE
   				ENDIF
   				;
   				SWITCH IS_SPECIFIER
   				 CASE 1
   				 	IS_RF_GetCorrection(1,31)
   				 CASE 2
   				 	IS_RF_GetCorrection(2,31)
   				ENDSWITCH
   			CASE 21									; Base/Tool-Korrektur anwenden
   				IS_ApplyCorrection(IS_SPECIFIER,31)
   			CASE 22									; Base oder Tool zuruecksetzen
   				;
   			CASE 23									; Base und Tool zuruecksetzen
   				;
   			CASE 24									; ServiceErgebnis anwenden auf Base/Tool
   			  ; Den entsprechenden ServiceMode anmelden und Service anwenden
					SWITCH IS_SPECIFIER
   				CASE 1
   					REPEAT
	   					IS_Apply_Service (2) ; RF Robotertausch
	   					IS_Apply_RobotChange(IS_TOOLNR)
	   				UNTIL ($FLAG[IS_FLAG_ERROR]==FALSE)
   				CASE 2
   					REPEAT
	   					IS_Apply_Service (1) ; RF Tooltausch
	   					IS_Apply_ToolChange(IS_TOOLNR)
						UNTIL ($FLAG[IS_FLAG_ERROR]==FALSE)
   				DEFAULT
   					IS_Apply_Service (0) ; IS_SERVICE_NONE
   					IS_SetInternError(IS_IntErr_SrvcExp)
   				ENDSWITCH
   			CASE 31									; RF Sensortausch
   				;
   			CASE 32 								; Tooltausch
   			  ; moved to TRIG
   			CASE 33 								; Robotortausch
   			  ; moved to TRIG
   			CASE 36 								; Fehlerdiagnose
   				IS_System_Diag()
   			DEFAULT ;modus nicht vorhanden
   			ENDSWITCH
   ;
   	 	iCounter = iCounter+1
   ;
   	  UNTIL ((iCounter>=IS_WIEDERHOLUNG) OR ($FLAG[IS_FLAG_ERROR]==FALSE))
   ;
   ;ENDFOLD (Main)
;
	ENDSWITCH
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD ISRA IMT Messsystem ansteuern
;---------------------------------------------------------------------------------------------
GLOBAL DEF ISRA_IMT_Interface(USER_CMD:IN,CMD_SEL:IN,MODUS:IN,TYP:IN,SUBTYP:IN,SPECIFIER:IN,TOOLNR:IN,WIEDERHOLUNG:IN,PAR7:IN,PAR8:IN,PAR9:IN)
	DECL VW_USER_CMD USER_CMD
	DECL INT CMD_SEL,MODUS,TYP,SUBTYP,SPECIFIER,TOOLNR,WIEDERHOLUNG,PAR7,PAR8,PAR9
;
	;IS_Log("ISRA_IMT_Interface",1,TRUE)
;
	IS_MODUS				= MODUS
	IS_TYP					= TYP
	IS_SUBTYP				= SUBTYP
	IS_SPECIFIER		= SPECIFIER
	IS_TOOLNR				= TOOLNR
	IS_WIEDERHOLUNG	= WIEDERHOLUNG
;
	; Ueberprufung der Eingabeparameter
	IF (IS_CheckParams(CMD_SEL, MODUS,TYP,SUBTYP,SPECIFIER,TOOLNR,WIEDERHOLUNG)==FALSE) THEN
		RETURN
	ENDIF
;
  SWITCH USER_CMD
  ;-- Advance
	CASE #USR_ADV
   ;FOLD Advance: Messung anmelden
   	  SWITCH MODUS
   		CASE 13,14,15 			;IMT Messung anmelden
   			;IS_IMT_Prepare(TYP, SUBTYP, SPECIFIER)
   			IS_IMT_Prepare(SUBTYP)
   		CASE 22						;Base oder Tool zuruecksetzen
   			IS_ResetBaseOrTool(SPECIFIER)
   		CASE 23						; Base und Tool zuruecksetzen
   			IS_ResetBaseOrTool(1)
   			IS_ResetBaseOrTool(2)
   		CASE 32 					;Tooltausch
   			IS_Apply_Service (1)
   		CASE 33 					;Robotertausch
   			IS_Apply_Service (2)
   		CASE 34 					;Sensortausch
   			IS_Apply_Service (4)
   		CASE 35 					;Vollkalib
   			IS_Apply_Service (5)
   	  DEFAULT ;modus nicht vorhanden
   	  ENDSWITCH
   	;ENDFOLD (Advance)
  ;-- Trig
	CASE #USR_TRIG
   ;FOLD Trig
   	  SWITCH MODUS
   		CASE 13,14,15						;IMT Messung ausfuehren
   			;IS_IMT_Apply(SPECIFIER)
   			IS_IMT_Apply(TRUE)
    DEFAULT ;modus nicht vorhanden
   	  ENDSWITCH
   	;ENDFOLD (Trig)
	;-- Main
	CASE #USR_MAIN
   ;FOLD Main
   	  SWITCH MODUS
   		CASE 14				;IMT Messung Komplett
   			IF NOT $FLAG[950] THEN
   				IS_IMT_EndPose()
   				SWITCH SPECIFIER
   				CASE 1,2,3,4
   					IS_IMT_GetCorrection(SPECIFIER,TOOLNR) ; AB 2010-11-28 (auch Faelle 3 und 4 behandelt)
   				DEFAULT ; wrong specifier
   				ENDSWITCH
   			ENDIF
   		CASE 15				;IMT Messung mit Korrektur
   			IS_IMT_EndPose()
   			IS_IMT_GetCorrection(SPECIFIER,TOOLNR)
   			IS_ApplyCorrection(SPECIFIER,TOOLNR)
   		CASE 16
   			IS_IMT_EndPose()
   	  CASE 12
   			REPEAT ; Full calib?, measurement, split calib?
   				IS_SelectUP(TYP)
   			UNTIL ((IS_bRepeatUpSel<>TRUE) OR ($FLAG[IS_FLAG_ERROR]) OR NOT IS_State_OK())
   		CASE 21						;Base/Tool-Korrektur anwenden
   			IS_ApplyCorrection(SPECIFIER,TOOLNR)
   		CASE 24						;ServiceErgebnis anwenden auf Base/Tool
   			SWITCH IS_iServiceMode
   			CASE IS_iTOOL_CHANGE
   				IS_IMT_GetCorrection(2,TOOLNR)
   				IS_Apply_ToolChange(TOOLNR)
   			CASE IS_iROBOT_CHANGE
   				IS_IMT_GetCorrection(1,TOOLNR)
   				IS_Apply_RobotChange(TOOLNR)
   			DEFAULT
   				IS_SetInternError(IS_IntErr_SrvcExp)
   			ENDSWITCH
   		CASE 36 					;Fehlerdiagnose
   			IS_System_Diag()
   		 ENDSWITCH
   ;ENDFOLD (Main)
	ENDSWITCH
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Programm Init wird beim Start eines Motion TP aufgerufen
;---------------------------------------------------------------------------------------------
GLOBAL DEF ISRA_PG_INIT()
DECL BOOL bVal
	IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) AND $IS_COMMUNICATE THEN
		; Init
		IS_ResetSignals()
		IS_ResetFlags()
		IS_iErrorSource		= 0
		IS_iInternErrors	= 0
		IS_iMeasPoint			= 0
		IS_iServiceMode 	= IS_iSERVICE_NONE
		IS_bInternError 	= FALSE
		IS_strErrorSource[]	= "VW-User"
		;
		IS_iQuitFlag			= 0
		;
		IS_iCurrentUserError	= 0
		;
		IS_iMeasStateRF			= IS_iMS_PREP_NOK
		;
		IS_bMeasurementOK = FALSE
		;
		IS_bHWCheckMode = FALSE
		;
		; Jetzt sollte alles initialisiert sein, so dass auf eine funktionierende Gegenstelle geschaut werden kann
		IS_iExternErrors = IS_RX8_RF_ERR_SUM
		;
		IF (IS_iExternErrors <> 0) THEN
			;IS_Log("ISRA_PG_INIT: EReset required",1,TRUE)
			IS_TX1_RF_ERESET = TRUE
			bVal = IS_RF_WAIT(#IS_RF_ERESET, FALSE, 0, IS_FnctID_RF_Init1)
			IS_TX1_RF_ERESET = FALSE
		ENDIF
		;
		IS_iExternErrors = IS_RX8_RF_ERR_SUM
		;
		; Ohne Livesignal auch kein Ready...
		IF $IS_LIVE_SIGNAL THEN
			; Falls nicht betriebsbereit, muss hier noch der Ablauf zurueckgesetzt werden
			IF NOT IS_RX1_RF_READY THEN
				;IS_Log("ISRA_PG_INIT: SReset required",1,TRUE)
				IS_TX1_RF_SRESET = TRUE
				bVal = IS_RF_WAIT(#IS_RF_READY, TRUE, 0, IS_FnctID_RF_Init2)
				IS_TX1_RF_SRESET = FALSE			
			ENDIF
			;
		ENDIF
		;
	ENDIF
	;
	; System synchronisieren
	IF (IS_SYS_TYPE == IS_SYS_TYPE_IMT) AND $IS_COMMUNICATE THEN
		;IS_Log("ISRA_PG_INIT: Sync start...",1,TRUE)
		bVal = IS_IMT_SyncHandshake()
	ENDIF
	;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD ISRA Messsystem initialisieren und Handshake synchronisieren
;---------------------------------------------------------------------------------------------
GLOBAL DEFFCT BOOL IS_IMT_SyncHandshake()
;
$IS_iHandshakeCounter = 0
;
IS_ResetFlags()
;
IS_TX1_ERROR_STATE		= FALSE
IS_iErrorSource 			= 0
IS_iExternErrors 			= 0
IS_iInternErrors 			= 0
IS_bInternError 			= FALSE
IS_strErrorSource[] 	= "VW-User"
IS_strErrorSource[8] 	= 0
IS_iCurrentUserError	= 0
;
IS_bSendBase 					= FALSE
IS_bSendAxes          = FALSE
;
IS_iServiceMode				= IS_iSERVICE_NONE ;TH
;
IS_iQuitFlag 					= 1
;
IS_bRepeatUpSel 			= FALSE
;
IS_ResetSignals()
;
IS_TX1_INIT_SIGNALS			= TRUE
IS_bHandshake 					= TRUE
IS_TX1_HANDSHAKE				= IS_bHandshake
$IS_iHandshakeCounter		= $IS_iHandshakeCounter + 1
;
IF (IS_WaitForEnd(IS_FnctID_IMT_Sync1)==FALSE) THEN
	RETURN FALSE
ENDIF
;
CONTINUE
IS_TX1_INIT_SIGNALS		= FALSE
IS_bHandshake         = FALSE
;
IS_TX1_HANDSHAKE			= IS_bHandshake
$IS_iHandshakeCounter = $IS_iHandshakeCounter + 1
;
IF (IS_WaitForEnd(IS_FnctID_IMT_Sync2)==FALSE) THEN
	RETURN FALSE
ENDIF
;
RETURN TRUE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Alle Flags zuruecksetzen
DEF IS_ResetFlags()
;
$FLAG[IS_FLAG_ERR_SPS] 				= FALSE
$FLAG[IS_FLAG_ERR_ROBOT] 			= FALSE
$FLAG[IS_FLAG_ERR_PREPARE] 		= FALSE
$FLAG[IS_FLAG_ERR_ACQ]		 		= FALSE
$FLAG[IS_FLAG_ERR_FEATURE] 		= FALSE
$FLAG[IS_FLAG_ERR_EVAL] 			= FALSE
$FLAG[IS_FLAG_ERR_TOL] 				= FALSE
$FLAG[IS_FLAG_WARN_TOL]			 	= FALSE
$FLAG[IS_FLAG_KAL1_HLP]				= FALSE
$FLAG[IS_FLAG_KAL2_HLP]				= FALSE
$FLAG[IS_FLAG_RESULT_OK] 			= FALSE
$FLAG[IS_FLAG_RESULT_NOK] 		= FALSE
$FLAG[IS_FLAG_ERROR] 					= FALSE
;
END
;ENDFOLD
;
;FOLD Handshake umschalten
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_ToggleHandshake()
;
CONTINUE
IF IS_bHandshake THEN
	CONTINUE
	IS_bHandshake = FALSE
	CONTINUE
	$IS_iHandshakeCounter = 0
	CONTINUE
	IS_TX1_HANDSHAKE = FALSE
	CONTINUE
	RETURN FALSE
ELSE
	CONTINUE
	IS_bHandshake = TRUE
	CONTINUE
	$IS_iHandshakeCounter = 1
	CONTINUE
	IS_TX1_HANDSHAKE = TRUE
	CONTINUE
	RETURN TRUE
ENDIF
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Timer starten
;---------------------------------------------------------------------------------------------
DEF IS_StartTimer(TNR:IN, TIME:IN)
DECL INT 	TNR
DECL REAL TIME
;
$TIMER_STOP[TNR]	= TRUE
$TIMER[TNR]				= -1000*TIME
$TIMER_STOP[TNR]	= FALSE
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Timer stoppen
;---------------------------------------------------------------------------------------------
DEF IS_StopTimer(TNR:IN)
DECL INT 	TNR
DECL REAL TIME
;
CONTINUE
$TIMER_STOP[TNR]	= TRUE
CONTINUE
$TIMER[TNR]				= -1
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Eingabeparamter auf Korrektheit ueberpruefen
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_CheckParams (CMD_SEL:IN,MODUS:IN,TYP:IN,SUBTYP:IN,SPECIFIER:IN,TOOLNR:IN,WIEDERHOLUNG:IN)
DECL INT CMD_SEL,MODUS,TYP,SUBTYP,SPECIFIER,TOOLNR,WIEDERHOLUNG
DECL INT Idx
DECL BOOL bValid
DECL INT iMsgNr
DECL INT iparam1, iparam2
FRAME aModeParamType[23]
;
;IS_Log("CheckParams",1,FALSE)
;
;ParamType:	0	nicht belegt fuer diesen Modus, also 0
;						1 Alle Werte erlaubt
;						2	Alle Werte ausser 0 erlaubt
;											P1		P2	 P3		P4	 P5		P6
aModeParamType[ 1] = {X  1, Y 1, Z 1, A 0, B 2, C 0}	;RF Messen
aModeParamType[ 2] = {X  2, Y 1, Z 1, A 1, B 0, C 2}	;obsolet: RF Messen, Beenden, Korrektur holen (optional) = RF Messung Ges. o. Korr.
aModeParamType[ 3] = {X  3, Y 1, Z 1, A 2, B 0, C 2}	;RF Messen; Beenden; Korrektur holen und anwenden = RF Messung Ges. m. Korr.
aModeParamType[ 4] = {X  4, Y 2, Z 1, A 1, B 0, C 2}	;obsolet
aModeParamType[ 5] = {X  5, Y 2, Z 1, A 0, B 0, C 0}	;obsolet
aModeParamType[ 6] = {X  6, Y 2, Z 1, A 2, B 2, C 1}	;RF Messen.Komplett und Korrektur holen (nicht anwenden)
aModeParamType[ 7] = {X 11, Y 1, Z 2, A 0, B 0, C 1}	;IMT MessungUPAuswahl
aModeParamType[ 8] = {X 12, Y 2, Z 0, A 0, B 0, C 1}	;IMT UpAuswahl
aModeParamType[ 9] = {X 13, Y 2, Z 1, A 0, B 0, C 1}	;IMT Messen
aModeParamType[10] = {X 14, Y 2, Z 1, A 1, B 0, C 1}	;IMT Messen, Beenden, Korrektur holen (optional)
aModeParamType[11] = {X 15, Y 2, Z 1, A 2, B 2, C 1}	;IMT Messen, Beenden, Korrektur holen und anwenden
aModeParamType[12] = {X 16, Y 0, Z 0, A 0, B 0, C 1}	;IMT Messung Beenden
aModeParamType[13] = {X 21, Y 0, Z 0, A 2, B 0, C 0}	;Korrektur anwenden auf Base/Tool
aModeParamType[14] = {X 22, Y 0, Z 0, A 2, B 0, C 0}	;Base oder Tool reseten
aModeParamType[15] = {X 23, Y 0, Z 0, A 0, B 0, C 0}	;Alle Base/Tool reseten
aModeParamType[16] = {X 24, Y 0, Z 0, A 2, B 2, C 0}	;Serivceergebnis anwenden auf Base/Tool	
aModeParamType[17] = {X 31, Y 2, Z 2, A 0, B 0, C 0}	;RF Sensortausch
IF (CMD_SEL == 1007) THEN ;RF
aModeParamType[18] = {X 32, Y 2, Z 0, A 0, B 2, C 0}	;RF Tooltausch 
aModeParamType[19] = {X 33, Y 2, Z 0, A 0, B 0, C 0}	;RF Robotertausch 
ELSE
aModeParamType[18] = {X 32, Y 0, Z 0, A 0, B 0, C 1}	;IMT Tooltausch 
aModeParamType[19] = {X 33, Y 0, Z 0, A 0, B 0, C 1}	;IMT Robotertausch 
ENDIF
aModeParamType[20] = {X 34, Y 1, Z 1, A 0, B 0, C 1}	;IMT Sensortausch 
aModeParamType[21] = {X 35, Y 0, Z 0, A 0, B 0, C 1}	;IMT Vollkalibrierung 
aModeParamType[22] = {X 36, Y 0, Z 0, A 0, B 0, C 0}	;Systemdiagnose
aModeParamType[23] = {X 40, Y 0, Z 0, A 2, B 2, C 0}	;obsolet Korrektur holen
;
bValid = FALSE
;
FOR Idx = 1 TO 23
	IF (aModeParamType[Idx].x == MODUS) THEN
		bValid = TRUE
	ENDIF
ENDFOR
;
IF (bValid==FALSE) THEN
	IS_MSG_ERR(IS_IntErr_Param1, IS_MODUS)	;Falscher Modus
	RETURN FALSE
ENDIF
;
Idx=1
;
WHILE (Idx<24) AND (bValid)
	IF (aModeParamType[Idx].x == MODUS) THEN
		IF (IS_CheckModusParam(aModeParamType[Idx], Typ, Subtyp, SPECIFIER, TOOLNR, WIEDERHOLUNG, iMsgNr, iparam1, iparam2) == FALSE) THEN
			bValid = FALSE
		ENDIF
	ENDIF
	Idx = Idx+1
ENDWHILE
;
IF (bValid==FALSE) THEN
	IS_MSG_ERR(iMsgNr,iparam1,iparam2) ; Falscher Parameter-Wert
	RETURN FALSE
ENDIF
;
RETURN TRUE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;-----------------------------------------------------------
;-- Hilfsfunktion fuer IS_CheckParams
;-----------------------------------------------------------
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_CheckParam(iType:IN, iValue:IN)
;FOLD
	DECL INT iType
	DECL INT iValue

		SWITCH iType
		CASE 0
			IF (iValue == 0) THEN
				RETURN TRUE
			ELSE
				RETURN FALSE
			ENDIF

		CASE 1
			RETURN TRUE

		CASE 2
			IF (iValue <> 0) THEN
				RETURN TRUE
			ELSE
				RETURN FALSE
			ENDIF

		DEFAULT
			RETURN FALSE
		ENDSWITCH

ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD

;-----------------------------------------------------------
;-- Hilfsfunktion fuer IS_CheckParams
;-----------------------------------------------------------
DEFFCT BOOL IS_CheckModusParam(ParamType:IN, P2:IN, P3:IN, P4:IN, P5:IN, P6:IN, iMsgNr:OUT, iparam1:OUT, iparam2:OUT)
;FOLD
	DECL FRAME ParamType
	DECL INT P2,P3,P4,P5,P6
	DECL INT iMsgNr
	DECL INT iparam1, iparam2

	IF (IS_CheckParam(ParamType.y, P2) == FALSE) THEN
			iMsgNr = IS_IntErr_Param2
			iparam1 = IS_TYP
			iparam2 = IS_MODUS
			RETURN FALSE
	ENDIF

	IF (IS_CheckParam(ParamType.z, P3) == FALSE) THEN
			iMsgNr = IS_IntErr_Param3
			iparam1 = IS_SUBTYP
			iparam2 = IS_MODUS
			RETURN FALSE
	ENDIF

	IF (IS_CheckParam(ParamType.a, P4) == FALSE) THEN
			iMsgNr = IS_IntErr_Param4
			iparam1 = IS_SPECIFIER
			iparam2 = IS_MODUS
			RETURN FALSE
	ENDIF

	IF (IS_CheckParam(ParamType.b, P5) == FALSE) THEN
			iMsgNr = IS_IntErr_Param5
			iparam1 = IS_TOOLNR
			iparam2 = IS_MODUS
			RETURN FALSE
	ENDIF

	IF (IS_CheckParam(ParamType.c, P6) == FALSE) THEN
			iMsgNr = IS_IntErr_Param6
			iparam1 = IS_WIEDERHOLUNG
			iparam2 = IS_MODUS
			RETURN FALSE
	ENDIF
	
	IF NOT (Varstate ("iparam1")==#initialized) then
	   iparam1 = 0;
	ENDIF
	;
	IF NOT (Varstate ("iparam2")==#initialized) then
	   iparam2 = 0;
	ENDIF

	RETURN TRUE

ENDFCT
;ENDFOLD

;ENDFOLD
;
;FOLD Komm-Zustand ueberpruefen
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_State_OK ()
;
IF (IS_SYS_TYPE == IS_SYS_TYPE_IMT) THEN
	CONTINUE
	IF IS_bSkipFlag THEN
		RETURN FALSE
	ENDIF
	CONTINUE
	IF $IS_LIVE_SIGNAL AND $IS_COMMUNICATE AND NOT IS_TX1_ERROR_STATE AND NOT IS_RX1_ERROR_STATE THEN
		RETURN TRUE
	ELSE
		CONTINUE
		IF $IS_LIVE_SIGNAL == FALSE THEN
			IF NOT $FLAG[IS_FLAG_ERROR] THEN ;Noch keinen Fehlerflag gesetzt ?
				IS_SetInternError(IS_IntErr_Com)			; Fehler ISRA Livesignal
			ENDIF
			RETURN FALSE
		ENDIF
		IF IS_RX1_ERROR_STATE THEN
			IF NOT $FLAG[IS_FLAG_ERROR] THEN ;Noch keinen Fehlerflag gesetzt ?
				IS_IMT_GetExternErrors()
			ENDIF
		  RETURN FALSE
		ENDIF
		RETURN FALSE
	ENDIF
	;
ENDIF
;
IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
	; Da die Fehlerbehandlung nach jedem Kommunikationsschritt zuschlaegt sind bei Fehlern auch die Flags gesetzt
	IF ($FLAG[IS_FLAG_ERROR]==FALSE) AND ($IS_COMMUNICATE==TRUE) AND ($IS_LIVE_SIGNAL==TRUE) THEN
		RETURN TRUE
	ELSE
		IF ($IS_LIVE_SIGNAL == FALSE) THEN
			; Noch keinen Fehlerflag gesetzt ?
			IF (NOT $FLAG[IS_FLAG_ERROR]) THEN
				IS_SetInternError(IS_IntErr_Com) ;Fehler ISRA Livesignal
				;
				IF $IS_LIVE_SIGNAL ==TRUE THEN
					IS_ResetFlags()
					IS_bInternError = FALSE
					RETURN TRUE
				ENDIF
			ENDIF
			RETURN FALSE
		ENDIF
		RETURN FALSE
	ENDIF
	;
ENDIF
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
; FOLD Schleife zum Wiederaufbau der Verbindung zum ISRA-System
;---------------------------------------------------------------------------------------------
DEF IS_RF_ReconnectLoop()
INT nHandle
BOOL retVal
BOOL bISRALive
DECL CHAR ch_KXRKey[100]
;
nHandle = -1
;
;Existiert eine Wartemeldung bereits?
IF (Exists_KrlMsg (nHandle) == FALSE) THEN
	retVal = Clear_KrlMsg (nHandle)
ENDIF
;
; Wartemeldung ausgeben
ch_KxrKey[]= "IS_Wait_Connection"
IS_ShowMessage(nHandle, #waiting, ch_KxrKey[], "vw_isr_usr_r", 1, TRUE)
;
IF (nHandle > 0) THEN
	; Solange wiederholen, bis Kommunikation wieder laeuft oder Benutzer 'Simuliere' drueckt
	REPEAT
		IF $IS_LIVE_SIGNAL==TRUE THEN
			bISRALive = TRUE
		ELSE
			bISRALive = FALSE
		ENDIF
		;
		;Abfrage, ob Benutzer 'Simuliere' gedrueckt hat
		IF (Exists_KrlMsg (nHandle) == FALSE) THEN
			bISRALive = TRUE
 		ENDIF
 		;
 		WAIT SEC 0.2
 		;
	UNTIL (bISRALive==TRUE)
	;
	; Ablöschen einer noch anstehenden Wartemeldung
	IF (Exists_KrlMsg (nHandle) == TRUE) THEN
	  retVal = Clear_KrlMsg (nHandle)
	ENDIF
ENDIF
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Auf Handshake warten, Datenkennung abgleichen, Fehlerbehandlung
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_Wait(iWaitType:IN, bCompareDataID:IN, iFnctID:IN)
DECL ISWaitType iWaitType
DECL BOOL				bCompareDataID
DECL INT				iFnctID 
;
;Skip-Message-Box
DECL KrlMsg_T msg
DECL KrlMsgPar_T par[3]
DECL KrlMsgOpt_T opt
INT nHandle, validPgNo
BOOL retVal
;
msg = {modul[] "ISRA_COM", Nr 1, msg_txt[] "Skip?"}
;
nHandle = -1
;
IS_bSkipFlag		= FALSE
IS_bTimeoutFlag	= FALSE
;
IF (iWaitType <> #IS_ERROR_ID) THEN
	IS_iFnctID = iFnctID
ENDIF
;
IS_StartTimer (IS_iWaitTimerID, IS_rWaitTimeout)
;
; In case of already known error only wait for handshake change
IF (iWaitType == #IS_ERROR_ID) THEN
  ;WAIT FOR ((IS_RX1_HANDSHAKE<>IS_bHandshake) OR $TIMER_FLAG[IS_iWaitTimerID])
  WHILE (TRUE)
		IF (IS_RX1_HANDSHAKE == IS_bHandshake) THEN      
			EXIT
		ENDIF
		;
		;Has there a Skip-Messagebox been created?
		IF (IS_bTimeoutFlag == TRUE) THEN
			IF (Exists_KrlMsg (nHandle) == FALSE) THEN
				;The user must have skipped, since there is a handle and the messagebox doesnt exist anymore!
				retVal = Clear_KrlMsg (nHandle)
				IS_bSkipFlag = TRUE
			ENDIF
		ENDIF
		;
		IF ((IS_RX1_SKIP == TRUE) OR (IS_bSkipFlag == TRUE)) THEN
			IS_bSkipFlag = TRUE
			EXIT
		ENDIF
		;
		IF (($TIMER_FLAG[IS_iWaitTimerID]) AND (NOT (IS_bSkipFlag==TRUE)) AND (IS_bTimeoutFlag == FALSE)) THEN
			IS_TX1_TIMEOUT = TRUE
			nHandle = Set_KrlMsg (#waiting, msg, par[], opt)
			IS_bTimeoutFlag = TRUE
		ENDIF
		;
  	WAIT SEC 0.005
  ENDWHILE
ELSE
	;WAIT FOR ((IS_RX1_HANDSHAKE==IS_bHandshake) OR IS_RX1_ERROR_STATE OR $TIMER_FLAG[IS_iWaitTimerID])
	WHILE (TRUE)
		IF (IS_RX1_HANDSHAKE == IS_bHandshake) OR (IS_RX1_ERROR_STATE==TRUE) THEN      
			EXIT
		ENDIF
		;
		;Has there a Skip-Messagebox been created?
		IF (IS_bTimeoutFlag == TRUE) THEN
			IF (Exists_KrlMsg (nHandle) == FALSE) THEN
				;The user must have skipped, since there is a handle and the messagebox doesnt exist anymore!
				retVal = Clear_KrlMsg (nHandle)
				IS_bSkipFlag = TRUE
			ENDIF
		ENDIF
		;
		IF ((IS_RX1_SKIP == TRUE) OR (IS_bSkipFlag == TRUE)) THEN
			IS_bSkipFlag = TRUE
			EXIT
		ENDIF
		;
		IF (($TIMER_FLAG[IS_iWaitTimerID]) AND (NOT (IS_bSkipFlag==TRUE)) AND (IS_bTimeoutFlag == FALSE)) THEN
			IS_TX1_TIMEOUT = TRUE
			nHandle = Set_KrlMsg (#waiting, msg, par[], opt)
			IS_bTimeoutFlag = TRUE
		ENDIF
  	WAIT SEC 0.005
  ENDWHILE
ENDIF
;
; Clearing a potential Skip-Messagebox
IF (Exists_KrlMsg (nHandle) == TRUE) THEN
  retVal = Clear_KrlMsg (nHandle)
ENDIF
;
; Resetting the timeout-signal on leave
IF IS_bTimeoutFlag == TRUE THEN
  IS_TX1_TIMEOUT = FALSE
ENDIF
;
;Skip
IF IS_bSkipFlag == TRUE THEN
  IS_ResetSignals()
  IS_TX1_SKIP = TRUE
  RETURN FALSE
ENDIF
;
;Fehler
IF IS_RX1_ERROR_STATE AND (iWaitType <> #IS_ERROR_ID) THEN
	IS_IMT_GetExternErrors()
  IS_StopTimer(IS_iWaitTimerID)
  RETURN FALSE
ENDIF
;
IS_StopTimer(IS_iWaitTimerID)
;
;IF bCompareDataID THEN
;	CONTINUE
;	IF (IS_RX8_DATA_ID <> IS_TX8_DATA_ID) THEN
;		IS_MSG_ERR(IS_MSG_I_SERV_SENS_CHK)
;		wait SEC 0.5
;		IF (IS_RX8_DATA_ID <> IS_TX8_DATA_ID) THEN
;			IS_MSG_ERR(4002,0,0)
;			IS_MSG_ERR(4003,0,0)
;			IS_SetError(IS_Err_ID_Drain) ;Kommandoablauf
;			return FALSE
;		endif
;	endif
;ENDIF
;
RETURN TRUE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Auf Handshake warten, Datenkennung abgleichen, Fehlerbehandlung, Vorlaufzeiger nicht verzoegern
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_WaitInMotion(iWaitType:IN, bCompareDataID:IN, iFnctID:IN)
DECL ISWaitType iWaitType
DECL BOOL				bCompareDataID
DECL INT				iFnctID
;
;Skip-Message-Box
DECL KrlMsg_T msg
DECL KrlMsgPar_T par[3]
DECL KrlMsgOpt_T opt
INT nHandle, validPgNo
BOOL retVal
;
CONTINUE
msg = {modul[] "ISRA_COM", Nr 1, msg_txt[] "Skip?"}
CONTINUE
nHandle = -1
;
CONTINUE
IS_bTimeoutFlag = FALSE
CONTINUE
IS_bSkipFlag    = FALSE
;
CONTINUE
IF (iWaitType <> #IS_ERROR_ID) THEN
	CONTINUE
	IS_iFnctID = iFnctID
ENDIF
;
CONTINUE
IS_StartTimer (IS_iWaitTimerID, IS_rWaitTimeout)
;
IF (iWaitType == #IS_ERROR_ID) THEN
	CONTINUE
	;WAIT FOR ((IS_RX1_HANDSHAKE==IS_bHandshake) OR $TIMER_FLAG[IS_iWaitTimerID])
	;
	CONTINUE
	WHILE (TRUE)
		CONTINUE
		IF(IS_RX1_HANDSHAKE==IS_bHandshake) THEN
			CONTINUE
			EXIT
		ENDIF
		
		CONTINUE
		;
		;Has there a Skip-Messagebox been created?
    CONTINUE
    ;
    IF (IS_bTimeoutFlag == TRUE) THEN
      CONTINUE
      IF (Exists_KrlMsg (nHandle) == FALSE) THEN
        CONTINUE
        ;The user must have skipped, since there is a handle and the messagebox doesnt exist anymore!
        CONTINUE
        retVal = Clear_KrlMsg (nHandle)
        CONTINUE
        IS_bSkipFlag = TRUE
        CONTINUE
      ENDIF
      CONTINUE
    ENDIF
    ;
    CONTINUE
    IF ((IS_RX1_SKIP == TRUE) OR (IS_bSkipFlag == TRUE)) THEN
      CONTINUE
      IS_bSkipFlag = TRUE
      CONTINUE
      EXIT
      CONTINUE
    ENDIF
    ;
    CONTINUE
    IF (($TIMER_FLAG[IS_iWaitTimerID]) AND (NOT (IS_bSkipFlag==TRUE)) AND (IS_bTimeoutFlag == FALSE)) THEN
      CONTINUE
      IS_TX1_TIMEOUT = TRUE
      CONTINUE
      nHandle = Set_KrlMsg (#waiting, msg, par[], opt)
      CONTINUE
      IS_bTimeoutFlag = TRUE
      CONTINUE
    ENDIF
    ;
    CONTINUE
    WAIT SEC 0.005
    CONTINUE
	ENDWHILE
	;
	CONTINUE
	;
ELSE
	;CONTINUE
	;WAIT FOR ((IS_RX1_HANDSHAKE==IS_bHandshake) OR IS_RX1_ERROR_STATE OR $TIMER_FLAG[IS_iWaitTimerID])
	;
	WHILE (TRUE)
		IF(IS_RX1_HANDSHAKE==IS_bHandshake) OR (IS_RX1_ERROR_STATE==TRUE) THEN
			CONTINUE
			EXIT
		ENDIF
		;
		;Has there a Skip-Messagebox been created?
    IF (IS_bTimeoutFlag == TRUE) THEN
      IF (Exists_KrlMsg (nHandle) == FALSE) THEN
        ;The user must have skipped, since there is a handle and the messagebox doesnt exist anymore!
        retVal = Clear_KrlMsg (nHandle)
        IS_bSkipFlag = TRUE
      ENDIF
    ENDIF
    ;
    IF ((IS_RX1_SKIP == TRUE) OR (IS_bSkipFlag == TRUE)) THEN
      IS_bSkipFlag = TRUE
      EXIT
    ENDIF
    ;
    IF (($TIMER_FLAG[IS_iWaitTimerID]) AND (NOT (IS_bSkipFlag==TRUE)) AND (IS_bTimeoutFlag == FALSE)) THEN
      IS_TX1_TIMEOUT = TRUE
      nHandle = Set_KrlMsg (#waiting, msg, par[], opt)
      IS_bTimeoutFlag = TRUE
    ENDIF
    ;
		WAIT SEC 0.005
	ENDWHILE
	;
ENDIF
;
; Clearing a potential Skip-Messagebox
IF (Exists_KrlMsg (nHandle) == TRUE) THEN
  retVal = Clear_KrlMsg (nHandle)
ENDIF
;
; Resetting the timeout-signal on leave
IF IS_bTimeoutFlag == TRUE THEN
  IS_TX1_TIMEOUT = FALSE
ENDIF
;
;Skip
IF IS_bSkipFlag == TRUE THEN
  IS_ResetSignals()
  IS_TX1_SKIP = TRUE
  RETURN FALSE
ENDIF
;
;Fehler
IF IS_RX1_ERROR_STATE AND (iWaitType <> #IS_ERROR_ID) THEN
	IS_IMT_GetExternErrors()
  IS_StopTimer(IS_iWaitTimerID)
  RETURN FALSE
ENDIF
;
IS_StopTimer(IS_iWaitTimerID)
RETURN TRUE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Auf Handshake warten, Fehlerbehandlung, Vorlaufzeiger nicht verzoegern
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_WaitForEnd(iFnctID:IN)
DECL INT iFnctID
DECL BOOL bInit
;
;Skip-Message-Box
DECL KrlMsg_T msg
DECL KrlMsgPar_T par[3]
DECL KrlMsgOpt_T opt
INT nHandle, validPgNo
BOOL retVal
;
CONTINUE
msg = {modul[] "ISRA_COM", Nr 1, msg_txt[] "Skip?"}
CONTINUE
nHandle = -1
;
CONTINUE
IS_bTimeoutFlag = FALSE
CONTINUE
IS_bSkipFlag    = FALSE
;
IS_iFnctID = iFnctID
CONTINUE
IS_StartTimer (IS_iWaitTimerID, IS_rWaitTimeout)
CONTINUE
;
IF (IS_TX1_INIT_SIGNALS) THEN
	CONTINUE
  ; WAIT FOR ((IS_RX1_HANDSHAKE==TRUE) AND (IS_RX1_INIT_SIGNALS==TRUE)) OR ($TIMER_FLAG[IS_iWaitTimerID])
  CONTINUE
  WHILE (TRUE)
  	IF(IS_RX1_HANDSHAKE==IS_bHandshake) AND (IS_RX1_INIT_SIGNALS==TRUE) THEN
  		CONTINUE
  		EXIT
  	ENDIF	
  	;
    CONTINUE
    ;Has there a Skip-Messagebox been created?
    CONTINUE
    IF (IS_bTimeoutFlag == TRUE) THEN
      CONTINUE
      IF (Exists_KrlMsg (nHandle) == FALSE) THEN
        CONTINUE
        ;The user must have skipped, since there is a handle and the messagebox doesnt exist anymore!
        CONTINUE
        retVal = Clear_KrlMsg (nHandle)
        CONTINUE
        IS_bSkipFlag = TRUE
        CONTINUE
      ENDIF
      CONTINUE
    ENDIF
    ;
    CONTINUE
    IF ((IS_RX1_SKIP == TRUE) OR (IS_bSkipFlag == TRUE)) THEN
      CONTINUE
      IS_bSkipFlag = TRUE
      CONTINUE
      EXIT
      CONTINUE
    ENDIF
    ;
    CONTINUE
    IF (($TIMER_FLAG[IS_iWaitTimerID]) AND (NOT (IS_bSkipFlag==TRUE)) AND (IS_bTimeoutFlag == FALSE)) THEN
      CONTINUE
      IS_TX1_TIMEOUT = TRUE
      CONTINUE
      nHandle = Set_KrlMsg (#waiting, msg, par[], opt)
      CONTINUE
      IS_bTimeoutFlag = TRUE
      CONTINUE
    ENDIF
    ;
    CONTINUE
    WAIT SEC 0.005
    CONTINUE
  ENDWHILE
	CONTINUE
ELSE
	CONTINUE
	; WAIT FOR ((IS_RX1_HANDSHAKE==IS_bHandshake) OR (IS_RX1_ERROR_STATE==TRUE) OR $TIMER_FLAG[IS_iWaitTimerID])
  WHILE (TRUE)
    CONTINUE
    IF (IS_RX1_HANDSHAKE == IS_bHandshake) OR (IS_RX1_ERROR_STATE==TRUE) THEN
      CONTINUE
      EXIT
    ENDIF
    ;
    CONTINUE
    ;Has there a Skip-Messagebox been created?
    CONTINUE
    IF (IS_bTimeoutFlag == TRUE) THEN
      CONTINUE
      IF (Exists_KrlMsg (nHandle) == FALSE) THEN
        CONTINUE
        ;The user must have skipped, since there is a handle and the messagebox doesnt exist anymore!
        CONTINUE
        retVal = Clear_KrlMsg (nHandle)
        CONTINUE
        IS_bSkipFlag = TRUE
        CONTINUE     
      ENDIF
      CONTINUE
    ENDIF
    ;
    CONTINUE
    IF ((IS_RX1_SKIP == TRUE) OR (IS_bSkipFlag == TRUE)) THEN
      CONTINUE
      IS_bSkipFlag = TRUE
      CONTINUE
      EXIT
    ENDIF
    ;
    CONTINUE
    IF (($TIMER_FLAG[IS_iWaitTimerID]) AND (NOT (IS_bSkipFlag==TRUE)) AND (IS_bTimeoutFlag == FALSE)) THEN
      CONTINUE
      IS_TX1_TIMEOUT = TRUE
      CONTINUE
      nHandle = Set_KrlMsg (#waiting, msg, par[], opt)
      CONTINUE
      IS_bTimeoutFlag = TRUE
      CONTINUE
    ENDIF
    ;
    CONTINUE
    WAIT SEC 0.005
    CONTINUE
  ENDWHILE
  ;
  CONTINUE
ENDIF
;
CONTINUE
; Clearing a potential Skip-Messagebox
CONTINUE
IF (Exists_KrlMsg (nHandle) == TRUE) THEN
  CONTINUE
  retVal = Clear_KrlMsg (nHandle)
  CONTINUE
ENDIF
;
CONTINUE
; Resetting the timeout-signal on leave
CONTINUE
IF IS_bTimeoutFlag == TRUE THEN
  CONTINUE
  IS_TX1_TIMEOUT = FALSE
  CONTINUE
ENDIF
;
CONTINUE
;Skip
CONTINUE
IF IS_bSkipFlag == TRUE THEN
  CONTINUE
  IS_ResetSignals()
  CONTINUE
  IS_TX1_SKIP = TRUE
  CONTINUE
  RETURN FALSE
ENDIF
;
CONTINUE
;Fehler
CONTINUE
IF IS_RX1_ERROR_STATE THEN
  CONTINUE
	IS_IMT_GetExternErrors()
  CONTINUE
  IS_StopTimer(IS_iWaitTimerID)
  CONTINUE
  RETURN FALSE
ENDIF
;
CONTINUE
IS_StopTimer(IS_iWaitTimerID)
CONTINUE
;
RETURN TRUE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Service-Ergebnis Tooltausch auf Tool anwenden
;---------------------------------------------------------------------------------------------
DEF IS_Apply_ToolChange (iCorrID:IN)
DECL INT iCorrID
DECL FRAME tmpToolData
;
IF NOT IS_State_OK() OR (IS_iExternErrors<>0) OR IS_bInternError THEN
	IS_MSG_ERR(IS_MSG_ERR_SERV_TOOL)
	IS_iServiceMode = IS_iSERVICE_NONE
	RETURN
ENDIF
;
IF (iCorrID < 1) OR (iCorrID > 31) THEN
	IS_SetInternError(IS_IntErr_Tool, iCorrID)
	IS_MSG_ERR(IS_MSG_ERR_SERV_TOOL)
	IS_iServiceMode = IS_iSERVICE_NONE
	RETURN
ENDIF
;
tmpToolData = TOOL_DATA[iCorrID]
;
IS_MSG_FRAME2 (2, iCorrID, $ISRA_TOOL_OFFSET)													;Abweichung zum aktuellen Tool
IS_MSG_FRAME2 (5, iCorrID, tmpToolData) 															;Altes Tool
IS_MSG_FRAME2 (6, iCorrID, $ISRA_TOOL_OFFSET : tmpToolData) 					;Neues Tool
;
IF NOT IS_SetRobFrame(iCorrID) THEN
	$FLAG[IS_FLAG_ERROR]=TRUE
	IS_MSG_ERR(IS_MSG_ERR_SERV_TOOL_T)
	IS_iServiceMode = IS_iSERVICE_NONE
	RETURN
ENDIF
;
IF IS_State_OK() THEN
	IS_MSG(IS_MSG_I_SERV_TOOL, IS_MSG_TYPE_NOTIFY)
	;IS_MSG(0,12)
	IS_MSG(IS_MSG_I_SERV_TOOL_PATH2, IS_MSG_TYPE_DIALOG, iCorrID)
	IS_MSG(IS_MSG_I_SERV_TOOL_PATH1, IS_MSG_TYPE_NOTIFY)
ELSE
	IS_MSG_ERR(IS_MSG_ERR_SERV_TOOL)
ENDIF
;
;IS_iServiceMode = IS_iSERVICE_NONE
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Service-Ergebnis Robotertausch auf Base anwenden
;---------------------------------------------------------------------------------------------
DEF IS_Apply_RobotChange (iCorrID:IN)
DECL INT iCorrID
FRAME tmpBaseData
;
IF NOT IS_State_OK() OR (IS_iExternErrors <> 0) OR IS_bInternError THEN
	IS_MSG_ERR(IS_MSG_ERR_SERV_ROB)
	IS_iServiceMode = IS_iSERVICE_NONE
	RETURN
ENDIF
;
IF (iCorrID < 1) OR (iCorrID > 31) THEN
	IS_SetInternError(IS_IntErr_Base,iCorrID)	 ;Base ID out of range
	IS_MSG_ERR(IS_MSG_ERR_SERV_ROB)
	IS_iServiceMode = IS_iSERVICE_NONE
	RETURN
ENDIF 
;
tmpBaseData = BASE_DATA[iCorrID]
;
IS_MSG_FRAME2 (1, iCorrID, $ISRA_BASE_OFFSET)  								;Offset
IS_MSG_FRAME2 (3, iCorrID, tmpBaseData) 											;Alte Base 
IS_MSG_FRAME2 (4, iCorrID, $ISRA_BASE_OFFSET : tmpBaseData)		;Neue Base
;
IF NOT IS_SetRobFrame(iCorrID) THEN
	$FLAG[IS_FLAG_ERROR]=TRUE
	IS_MSG_ERR(IS_MSG_ERR_SERV_ROB_T)
	IS_iServiceMode = IS_iSERVICE_NONE
	RETURN
ENDIF
;
IF IS_State_OK() THEN
	IS_MSG(IS_MSG_I_SERV_ROB, IS_MSG_TYPE_NOTIFY)
	;IS_MSG(0,13)
	IS_MSG(IS_MSG_I_SERV_ROB_PATH2, IS_MSG_TYPE_DIALOG, iCorrID)
	IS_MSG(IS_MSG_I_SERV_ROB_PATH1, IS_MSG_TYPE_NOTIFY)
ELSE
	IS_MSG_ERR(IS_MSG_ERR_SERV_ROB)
ENDIF
;
;IS_iServiceMode = IS_iSERVICE_NONE
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Tool-/Robotertausch-Ergebnis anwenden
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_SetRobFrame(iFrameID:IN)
DECL INT iFrameID
DECL FRAME tmpTool
;
SWITCH IS_iServiceMode
CASE IS_iTOOL_CHANGE
	tmpTool = TOOL_DATA[iFrameID]
	;
   ;IF IS_CheckCorrFrame($ISRA_TOOL_OFFSET,$NULLFRAME) THEN
		;
		IF (IS_SYS_TYPE == IS_SYS_TYPE_IMT) THEN
			TOOL_DATA[iFrameID] = $ISRA_TOOL_OFFSET : TOOL_DATA[iFrameID]
			RETURN TRUE
		ENDIF
		;
		IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
			TOOL_DATA[iFrameID] = $ISRA_TOOL_OFFSET : TOOL_DATA[iFrameID]
			RETURN TRUE
		ENDIF
		;
	;ELSE
		;RETURN FALSE
	;ENDIF
	;
CASE IS_iROBOT_CHANGE
   ;IF IS_CheckCorrFrame($ISRA_BASE_OFFSET,$NULLFRAME) THEN
		;
		IF (IS_SYS_TYPE == IS_SYS_TYPE_IMT) THEN
			BASE_DATA[iFrameID] = $ISRA_BASE_OFFSET : BASE_DATA[iFrameID]
			RETURN TRUE
		ENDIF
		;
		IF (IS_SYS_TYPE == IS_SYS_TYPE_RF) THEN
			BASE_DATA[iFrameID] = $ISRA_BASE_OFFSET : BASE_DATA[iFrameID]
			RETURN TRUE
		ENDIF
		;
	;ELSE
		;RETURN FALSE
	;ENDIF
DEFAULT
	;IS_Log("IS_SetRobFrame: Unknown Servicemode",1,TRUE)
	RETURN FALSE
ENDSWITCH
;
RETURN FALSE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Korrekturwert auf Toleranz ueberpruefen und Fehlerflag setzen
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_CheckCorrFrame(fr_Frame1:IN,fr_Frame2:IN)
DECL FRAME fr_Frame1
DECL FRAME fr_Frame2
DECL REAL r_DeltaX
DECL REAL r_DeltaY
DECL REAL r_DeltaZ
DECL REAL r_DeltaA
DECL REAL r_DeltaB
DECL REAL r_DeltaC
;
r_DeltaX=ABS(fr_Frame1.X-fr_Frame2.X)
r_DeltaY=ABS(fr_Frame1.Y-fr_Frame2.Y)
r_DeltaZ=ABS(fr_Frame1.Z-fr_Frame2.Z)
r_DeltaA=ABS(fr_Frame1.A-fr_Frame2.A)
r_DeltaB=ABS(fr_Frame1.B-fr_Frame2.B)
r_DeltaC=ABS(fr_Frame1.C-fr_Frame2.C)
;
IF (r_DeltaX > IS_CORR_ACCEPT_FRAME.X) OR (r_DeltaY > IS_CORR_ACCEPT_FRAME.Y) THEN
	;IS_SetError(IS_Err_ID_Tolerance) ;Toleranzueberschreitung
	RETURN FALSE
ENDIF
;
IF (r_DeltaZ > IS_CORR_ACCEPT_FRAME.Z) OR (r_DeltaA > IS_CORR_ACCEPT_FRAME.A) THEN
	;IS_SetError(IS_Err_ID_Tolerance) ;Toleranzueberschreitung
	RETURN FALSE
ENDIF
;
IF (r_DeltaB > IS_CORR_ACCEPT_FRAME.B) OR (r_DeltaC > IS_CORR_ACCEPT_FRAME.C) THEN
	;IS_SetError(IS_Err_ID_Tolerance) ;Toleranzueberschreitung
	RETURN FALSE
ENDIF
;
RETURN TRUE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD ISRA Base/Tool-Offset zuruecksetzen
;---------------------------------------------------------------------------------------------
DEF IS_ResetBaseOrTool (iType:IN)
DECL INT iType
;
;IS_Log("ResetBaseOrTool",1,TRUE)
;
SWITCH iType
	CASE 1
		$ISRA_BASE_OFFSET = $NULLFRAME
	CASE 2
		$ISRA_TOOL_OFFSET = $NULLFRAME
ENDSWITCH
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD ModellNr Abgleich, RountinenNr Abfrage, UP-Select
;---------------------------------------------------------------------------------------------
DEF IS_SelectUP(iModelID:IN)
DECL INT  iModelID
DECL INT  SEL_RES
DECL BOOL bRetVal
;
IS_MODEL = iModelID
;
IF IS_STATE_OK() THEN
;
	;Model-ID Abgleich
	IS_TX8_MODEL_ID 			= IS_MODEL
	IS_TX8_DATA_ID				= 8					; Model-ID
	IS_TX1_DATA_END_TRANS = TRUE
	IS_TX1_DATA_VALID 		= TRUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
;
	IF (IS_Wait(#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SelectUp1) == FALSE) THEN
		RETURN
	ENDIF
;
	;Abfrage UP-Nr
	IS_TX1_DATA_END_TRANS	= FALSE
	IS_TX1_DATA_VALID			= FALSE
	IS_TX8_DATA_ID 				= 51 				;Prog-ID
	IS_TX1_DATA_REQUEST 	= TRUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
;
  IF (IS_Wait(#IS_VALID, TRUE, IS_FnctID_IMT_SelectUp2) == TRUE) THEN
		IF (IS_RX8_PROG_ID < 1) THEN
			IS_SetError(IS_Err_ID_ProgID) 	;Fehler ProgID
			RETURN
		ENDIF
		;
		IS_PROGID	= IS_RX8_PROG_ID
		IS_iCurrentSub = IS_PROGID
		;
		IF (UPNR[iModelID, IS_PROGID]>0)  THEN
			IS_TX8_DATA_ID 				= 51
			IS_TX1_DATA_REQUEST 	= FALSE
			IS_TX1_DATA_ACCEPTED 	= TRUE
			IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
			;
			bRetVal = IS_Wait(#IS_ACCEPTED, FALSE, IS_FnctID_IMT_SelectUp3)
			SEL_RES=SELECT(#UP,UPNR[iModelID, IS_PROGID],TRUE) 							;UP selektieren
		ELSE
			IS_SetError(IS_Err_ID_ProgID) ;Fehler ProgID
			RETURN
		ENDIF
 	ENDIF
ENDIF
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Messergebnis holen
;---------------------------------------------------------------------------------------------
DEF IS_IMT_GetCorrection(iSpecifier:IN, iToolNr:IN)
DECL INT 		iSpecifier
DECL INT 		iToolNr
DECL FRAME 	CORR_FRAME
DECL INT 		ID1, ID2, ID3
DECL INT 		iStateResult
DECL INT 		iStateWarning
;
IF IS_STATE_OK() THEN
	;
	IF (IS_IMT_GetExternState (iStateResult, iStateWarning)==FALSE) THEN
		RETURN ;Fehler beim Zustandholen
	ENDIF
	;
	CORR_FRAME = $NULLFRAME
	;
	SWITCH iSpecifier
	CASE 1,3		;Base
		ID1 = 52
		ID2 = 53
		ID3 = 54
	CASE 2,4		;Tool
		ID1 = 55
		ID2 = 56
		ID3 = 57
	DEFAULT
		IS_SetInternError(IS_IntErr_Specif, IS_SPECIFIER)
		RETURN
	ENDSWITCH
	;
	;XY-Korrektur erfragen
	IS_TX1_DATA_ACCEPTED	= FALSE		;Fuer RF
	IS_TX8_DATA_ID				= ID1
	IS_TX1_DATA_REQUEST		= TRUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
	;
	IF (IS_Wait(#IS_VALID, TRUE, IS_FnctID_IMT_GetCorr1) == FALSE) THEN
		RETURN
	ENDIF
	;
	CORR_FRAME.X = IS_RX32_CORR_X / IS_IMT_rScaleXYZ
  CORR_FRAME.Y = IS_RX32_CORR_Y / IS_IMT_rScaleXYZ
	;
	IS_TX8_DATA_ID				= ID1
	IS_TX1_DATA_ACCEPTED	= TRUE
	IS_TX1_DATA_REQUEST		= FALSE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
	;
	IF (IS_Wait(#IS_VALID, FALSE, IS_FnctID_IMT_GetCorr2) == FALSE) THEN
		RETURN
	ENDIF
	;
	IF (IS_RX8_DATA_ID <> ID2) THEN
		IS_SetError(IS_Err_ID_Drain)
		RETURN
	ENDIF
	;
	CORR_FRAME.Z = IS_RX32_CORR_Z / IS_IMT_rScaleXYZ
  CORR_FRAME.A = IS_RX32_CORR_A / IS_IMT_rScaleABC
	;
	IS_TX8_DATA_ID 				= ID2
	IS_TX1_DATA_ACCEPTED	= TRUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
	;
	IF (IS_Wait(#IS_VALID, FALSE, IS_FnctID_IMT_GetCorr3) == FALSE) THEN
		RETURN
	ENDIF
	;
	IF (IS_RX8_DATA_ID <> ID3) THEN
		IS_SetError(IS_Err_ID_Drain) ;Kommandoablauf
		RETURN
	ENDIF
	;
	CORR_FRAME.B = IS_RX32_CORR_B / IS_IMT_rScaleABC
  CORR_FRAME.C = IS_RX32_CORR_C / IS_IMT_rScaleABC
	;
	IS_TX8_DATA_ID 				= ID3
	IS_TX1_DATA_END_TRANS = TRUE
	IS_TX1_DATA_ACCEPTED	= TRUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
	;
	IF (IS_Wait(#IS_ACCEPTED, FALSE, IS_FnctID_IMT_GetCorr4)==FALSE) THEN
		RETURN
	ENDIF
	;
	IS_TX8_DATA_ID 				= 0
	IS_TX1_DATA_END_TRANS = FALSE
	IS_TX1_DATA_ACCEPTED	= FALSE
	;
	IS_iFnctID = 0 ;keine irrefuehrende Fehlermeldung erzeugen
	;
	IF (IS_SyncErrors(IS_iErrorSource, IS_iExternErrors)==FALSE) THEN
		IS_iFnctID = IS_FnctID_IMT_GetExtStat
		IS_ProcessErrors()
		RETURN
	ENDIF
	;
	IF (IS_IMT_ProcessExtState (iStateResult, iStateWarning)==FALSE) THEN
		;Meldung
		RETURN
	ENDIF
	;
	;--- write Corr_Frame ---
	;
	SWITCH IS_iServiceMode
	CASE IS_iTOOL_CHANGE
			$ISRA_TOOL_OFFSET	= CORR_FRAME
	CASE IS_iROBOT_CHANGE
			$ISRA_BASE_OFFSET	= CORR_FRAME
	DEFAULT
		IF IS_CheckCorrFrame(CORR_FRAME, $NULLFRAME) THEN
			SWITCH (iSpecifier)
			CASE 1
				$ISRA_BASE_OFFSET	= CORR_FRAME
			CASE 2
				$ISRA_TOOL_OFFSET	= CORR_FRAME
			CASE 3
				;Achtung Offset wird akkumuliert
				$ISRA_BASE_OFFSET	= $ISRA_BASE_OFFSET : CORR_FRAME
			CASE 4
				;Achtung Offset wird akkumuliert
				$ISRA_TOOL_OFFSET	= $ISRA_TOOL_OFFSET : CORR_FRAME
			ENDSWITCH
	  ENDIF
	ENDSWITCH
;
ENDIF ;State_OK
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Messergebnis für RF holen
;---------------------------------------------------------------------------------------------
DEF IS_RF_GetCorrection(iSpecifier:IN, iToolNr:IN)
DECL INT 		iSpecifier
DECL INT 		iToolNr
DECL FRAME 	CORR_FRAME
;
IF IS_State_OK()THEN
	;Zuerst Messpunktnummer zurücksetzen:
	IS_iMeasPoint = 0
	;
	;IS_Log("IS_RF_GetCorrection: Executing",1,TRUE)
	;
   IF (IS_iMeasStateRF <> IS_iMS_ENDED) THEN
		;IS_Log("IS_RF_GetCorrection: Wrong state to get results",1,TRUE)
		;
		IS_bInternError = TRUE
		;
		$FLAG[IS_FLAG_ERROR]=TRUE
		$FLAG[IS_FLAG_ERR_ROBOT]=TRUE
		;
		IS_iFnctID = IS_FnctID_RF_GCorr3
		;
		IS_SetInternError(IS_IntErr_RFGCSt)
		;
		IS_bInternError = FALSE
		IS_iFnctID = 0
		;
		RETURN
	ENDIF
	;
	; Warten auf Messende, falls noch nicht gesetzt
	IF IS_RF_Wait(#IS_RF_RESRUN, FALSE, 0, IS_FnctID_RF_GCorr1) THEN
	  ; Read 16-bit Integer
		IS_RX16_DATA[1] = IS_RX16_RF_RES_X
	  IF (IS_RX16_DATA[1] > 32767) THEN
	    CORR_FRAME.X= ((IS_RX16_DATA[1] b_or 'HFFFF0000') / IS_RF_rScaleXYZ)
	  ELSE
	    CORR_FRAME.X = IS_RX16_DATA[1] / IS_RF_rScaleXYZ
	  ENDIF
	  ;
	  IS_RX16_DATA[2] = IS_RX16_RF_RES_Y
	  IF (IS_RX16_DATA[2] > 32767) THEN
	    CORR_FRAME.Y= ((IS_RX16_DATA[2] b_or 'HFFFF0000') / IS_RF_rScaleXYZ)
	  ELSE
	    CORR_FRAME.Y = IS_RX16_DATA[2] / IS_RF_rScaleXYZ
	  ENDIF
		;
	  IS_RX16_DATA[3] = IS_RX16_RF_RES_Z
	  IF (IS_RX16_DATA[3] > 32767) THEN
	    CORR_FRAME.Z= ((IS_RX16_DATA[3] b_or 'HFFFF0000') / IS_RF_rScaleXYZ)
	  ELSE
	    CORR_FRAME.Z = IS_RX16_DATA[3] / IS_RF_rScaleXYZ
	  ENDIF
		;		
	  IS_RX16_DATA[4] = IS_RX16_RF_RES_RZ
	  IF (IS_RX16_DATA[4] > 32767) THEN
	    CORR_FRAME.A= ((IS_RX16_DATA[4] b_or 'HFFFF0000') / IS_RF_rScaleABC)
	  ELSE
	    CORR_FRAME.A = IS_RX16_DATA[4] / IS_RF_rScaleABC
	  ENDIF
		;		
	  IS_RX16_DATA[5] = IS_RX16_RF_RES_RY
	  IF (IS_RX16_DATA[5] > 32767) THEN
	    CORR_FRAME.B= ((IS_RX16_DATA[5] b_or 'HFFFF0000') / IS_RF_rScaleABC)
	  ELSE
	    CORR_FRAME.B = IS_RX16_DATA[5] / IS_RF_rScaleABC
	  ENDIF
		;		
	  IS_RX16_DATA[6] = IS_RX16_RF_RES_RX
	  IF (IS_RX16_DATA[6] > 32767) THEN
	    CORR_FRAME.C= ((IS_RX16_DATA[6] b_or 'HFFFF0000') / IS_RF_rScaleABC)
	  ELSE
	    CORR_FRAME.C = IS_RX16_DATA[6] / IS_RF_rScaleABC
	  ENDIF
		;						
		SWITCH IS_iSERVICEMODE
			CASE IS_iTOOL_CHANGE
				$ISRA_TOOL_OFFSET = CORR_FRAME
			CASE IS_iROBOT_CHANGE
				$ISRA_BASE_OFFSET = CORR_FRAME
			DEFAULT
				IF IS_CheckCorrFrame(CORR_FRAME, $NULLFRAME) THEN
					;
					SWITCH iSpecifier
						CASE 1
							; Achtung Offset wird akkumuliert
							$ISRA_BASE_OFFSET = CORR_FRAME
						CASE 2
							; Achtung Offset wird akkumuliert
							$ISRA_TOOL_OFFSET = CORR_FRAME
            DEFAULT
							;
          ENDSWITCH
					;
				ELSE
					IS_iFnctID = IS_FnctID_RF_GCorr2
					IS_SetInternError(IS_IntErr_TolRob) 		; Toleranzueberschreitung
				ENDIF
				;
		ENDSWITCH
		;
   ENDIF
	;
ELSE
	;IS_Log("IS_RF_GetCorrection: Skipping",1,TRUE)
ENDIF
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Korrektur auf Base/Tool anwenden
;---------------------------------------------------------------------------------------------
DEF IS_ApplyCorrection (iCorrType:IN, iCorrID:IN)
DECL INT iCorrType
DECL INT iCorrID
;
IF (IS_State_OK()==FALSE) THEN
	RETURN
ENDIF
;
;IS_Log("ApplyCorrection",1,TRUE)
;
SWITCH iCorrType
	CASE 1
		IF (iCorrID>=1) AND (iCorrID <= 31) THEN
      BASE_DATA[iCorrID] = BASE_DATA[VW_MPARA_ACT.BASE_NO] : $ISRA_BASE_OFFSET
		ELSE
			IS_SetInternError(IS_IntErr_Base, iCorrID) ;Base ID out of range
		ENDIF
	CASE 2
		IF (iCorrID>=1) AND (iCorrID <= 31) THEN
      TOOL_DATA[iCorrID] = TOOL_DATA[VW_MPARA_ACT.TOOL_NO] : $ISRA_TOOL_OFFSET
		ELSE
			IS_SetInternError(IS_IntErr_Tool, iCorrID) ;Tool ID out of range
		ENDIF
	DEFAULT
		IS_SetInternError(IS_IntErr_Specif, IS_SPECIFIER) ;Specifier nicht erlaubt
ENDSWITCH
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Serviceprogramm anmelden
;---------------------------------------------------------------------------------------------
DEF IS_Apply_Service(iServiceID:IN)
DECL INT  iServiceID
DECL BOOL	bRetVal
;
IF NOT IS_State_OK() THEN
	RETURN
ENDIF
;
IS_ResetFlags()
IS_iExternErrors = 0
IS_bInternError = FALSE
;
;IS_Log("Apply Service",1,TRUE)
;
SWITCH iServiceID
	CASE 0
		IS_iServiceMode=IS_iSERVICE_NONE
	CASE 1
		IS_iServiceMode=IS_iTOOL_CHANGE
	CASE 2
		IS_iServiceMode=IS_iROBOT_CHANGE
	CASE 3
		IS_iServiceMode=IS_iSENSOR_CHANGE
	CASE 4
		IS_iServiceMode=IS_iSENSOR_CHANGE_IMT
	CASE 5
		IS_iServiceMode=IS_iFULL_CALIB
	DEFAULT
		IS_iServiceMode=IS_iSERVICE_NONE
ENDSWITCH
;
IF (IS_SYS_TYPE == IS_SYS_TYPE_IMT) THEN		;Extra anmelden des Servicemode ist fuer RF nicht notwendig
	CONTINUE
	IS_TX8_DATA_ID				= 10
	CONTINUE
	IS_TX16_SERVICE_ID		= iServiceID
	CONTINUE
	IS_TX1_DATA_END_TRANS	= TRUE
	CONTINUE
	IS_TX1_DATA_VALID			= TRUE
	CONTINUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
	;
	IF (IS_Wait(#IS_ACCEPTED, TRUE, IS_FnctID_IMT_Service)==FALSE) THEN
		IS_iServiceMode=IS_iSERVICE_NONE
	ENDIF
	;
	CONTINUE
	IS_TX1_DATA_END_TRANS	= FALSE
	CONTINUE
	IS_TX1_DATA_VALID = FALSE
ENDIF
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD RF Messung vorbereiten
;---------------------------------------------------------------------------------------------
DEF IS_RF_Prepare(iType:IN, iSubType:IN, iColor:IN)
DECL INT iType
DECL INT iSubType
DECL INT iColor
DECL BOOL bVal
DECL INT iDesiredRM
;
IF (IS_iMeasStateRF <> IS_iMS_PREP_ADV) THEN
  IS_iMeasStateRF = IS_iMS_PREP_NOK
ENDIF
;
IF (IS_STATE_OK()) THEN
	;
	; Ready?
	IF (IS_iMeasStateRF == IS_iMS_PREP_ADV) THEN
		bVal = TRUE
	ELSE
		bVal = IS_RF_Wait(#IS_RF_READY, TRUE, 0, IS_FnctID_RF_Prepare1)
	ENDIF
	;
	IF bVal THEN
		;IS_Log("RF Prepare: ROVIS signals ready",1,TRUE)
		; Betriebsart setzen
		IF (IS_iServiceMode == IS_iSENSOR_CHANGE) THEN
			iDesiredRM = 5  ; Kalibrierung
		ELSE
			iDesiredRM = 2	; Automatik
		ENDIF
		;
		IS_TX4_RF_RM = iDesiredRM
		;
		IF IS_RF_Wait(#IS_RF_RM, FALSE, iDesiredRM, IS_FnctID_RF_Prepare2) THEN
			;IS_Log("RF Prepare: ROVIS signals desired Runmode",1,TRUE)
			; Typinformation setzen
			IS_TX8_RF_TYP 			= iType
			IS_TX8_RF_SUB_TYP 	= iSubType
			IS_TX8_RF_COLOR_ID 	= iColor
			IS_TX1_RF_TYP_STR 	= TRUE
			;
			IF IS_RF_Wait(#IS_RF_PREP, TRUE, 0, IS_FnctID_RF_Prepare3) THEN
				;IS_Log("RF Prepare: ROVIS signals prepare OK",1,TRUE)
				IS_iMeasStateRF = IS_iMS_PREP_OK
			ENDIF
			;
			IS_TX1_RF_TYP_STR 	= FALSE
			;
			; RETURN
		ENDIF
		;
	ENDIF
ELSE
	;IS_Log("RF Prepare: Skipping",1,TRUE)
;
ENDIF
;
; RETURN
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD RF Messung ausfuehren
;---------------------------------------------------------------------------------------------
DEF IS_RF_Apply(iColor:IN)
DECL INT iColor
;
IF (IS_STATE_OK()) THEN
	;
	IF (IS_iMeasStateRF == IS_iMS_PREP_OK) THEN
		;
		;Ist das Signal vor der ersten Messung aus?
		IF IS_RF_WAIT(#IS_RF_MESRUN, FALSE, 0, IS_FnctID_RF_Apply1) THEN
			IS_iMeasStateRF = IS_iMS_STARTED
		ELSE
			IS_iMeasStateRF = IS_iMS_NONE
		ENDIF
		;
	ENDIF
	;
	WAIT SEC IS_rSettlingTime
	;
	IF  ((IS_iMeasStateRF == IS_iMS_STARTED) OR (IS_iMeasStateRF == IS_iMS_RUNNING)) THEN
		;
		; Vor Eintritt darf keine Bildaufnahme laufen
		IF IS_RF_WAIT(#IS_RF_IMGACQ, FALSE, 0, IS_FnctID_RF_Apply4) THEN
			;MsgNotify("RF Apply: ROVIS signals image acquisition is not running")
			;
			; Falls Sensortausch (=Kalibrierung) muss noch die Controlgroup auf ROVIS-Seite klar sein
			IF (IS_iServiceMode == IS_iSENSOR_CHANGE) THEN
				IS_TX8_RF_COLOR_ID = iColor
			ENDIF
			;
			IS_TX1_RF_START = TRUE
			;
			; Messung laeuft  ist Grundvoraussetzung
			IF IS_RF_WAIT(#IS_RF_MESRUN, TRUE, 0, IS_FnctID_RF_Apply2) THEN
				;MsgNotify("RF Apply: ROVIS signals measurement runnning")
				;
				; Bildaufnahme laeuft
				IF IS_RF_WAIT(#IS_RF_IMGACQ, TRUE, 0, IS_FnctID_RF_Apply5) THEN
					;MsgNotify("RF Apply: ROVIS signals image acqusition started")
					;
					IS_TX1_RF_START = FALSE
					;
					IF IS_RF_WAIT(#IS_RF_IMGACQ, FALSE, 0, IS_FnctID_RF_Apply3) THEN
						;MsgNotify("RF Apply: ROVIS signals image acquisition finished")
						IS_iMeasStateRF = IS_iMS_RUNNING
					ELSE
						IS_iMeasStateRF = IS_iMS_NONE
					ENDIF
				ENDIF
			ENDIF
		ENDIF
	ELSE
		;IS_Log("RF Apply: Wrong state to apply a measurement",1,TRUE)
		;
		IS_bInternError = TRUE
		;
		$FLAG[IS_FLAG_ERROR] = TRUE
		$FLAG[IS_FLAG_ERR_ROBOT] = TRUE
		;
		IS_iFnctID = IS_FnctID_RF_Apply6
		;
		IS_SetInternError(IS_IntErr_RFAState)
		;
		IS_bInternError = FALSE
		IS_iFnctID = 0
	ENDIF
	;
	IS_TX1_RF_START = FALSE
	;
ELSE
	;MsgNotify("RF Apply: Skipping")
ENDIF
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD RF Messung beenden
;---------------------------------------------------------------------------------------------
DEF IS_RF_EndPose()
;
IF IS_State_OK() THEN
;
	;MsgNotify("Executing","IS_RF_EndPose")
	;
	; Warten auf Messende, falls noch nicht gesetzt
	IF IS_RF_WAIT(#IS_RF_MESRUN, FALSE, 0, IS_FnctID_RF_End1) THEN
		;
		IF IS_RF_WAIT(#IS_RF_RESRUN, FALSE, 0, IS_FnctID_RF_End2) THEN
			;
			;IS_Log("IS_RF_EndPose: ROVIS signals results available",1,TRUE)
			IF (IS_iMeasStateRF == IS_iMS_RUNNING) THEN
				IS_iMeasStateRF = IS_iMS_ENDED
			ELSE
				;
				;MsgNotify("IS_RF_EndPose","Wrong state to end a measurement")
				;
				IS_bInternError = TRUE
				;
				$FLAG[IS_FLAG_ERROR] = TRUE
				$FLAG[IS_FLAG_ERR_ROBOT] = TRUE
				;
				IS_iFnctID = IS_FnctID_RF_End3
				;
				IS_SetInternError(IS_IntErr_RFEPSt)
  			;
  			IS_bInternError = FALSE
  			;
  			IS_iFnctID = 0
			ENDIF
			;
		ENDIF
		;
	ENDIF
;
ELSE
	;IS_Log("IS_RF_EndPose: Skipping",1,TRUE)
ENDIF
;
;Hardware OK?
IS_CheckHW()
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD RF Iterative Messung ausfuehren
;---------------------------------------------------------------------------------------------
DEF IS_RF_Apply_Iterative()
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD RF Warten auf Systemantworten (RoVis)
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_RF_Wait(WaitType:IN, bWaitingVal:IN, iWaitingVal:IN, iFnctID:IN)
DECL ISWaitType WaitType
DECL BOOL bWaitingVal
DECL INT iWaitingVal
DECL INT iFnctID
;
IF IS_STATE_OK() THEN
	IS_StartTimer (IS_iWaitTimerID, IS_rWaitTimeout)
	
	IS_iFnctID = iFnctID
	 ;MsgNotify("Starting...", "IS_RF_Wait")
   SWITCH WaitType 

   CASE #IS_RF_READY       ; Warten auf Ready
   	WAIT FOR ((IS_RX1_RF_READY == bWaitingVal) OR ($TIMER_FLAG[IS_iWaitTimerID]))
   CASE #IS_RF_RM          ; Warten auf Gleichheit der Runmodes
   	WAIT FOR ((IS_RX4_RF_RM == iWaitingVal) OR ($TIMER_FLAG[IS_iWaitTimerID]))
   CASE #IS_RF_PREP        ; Warten auf Prepare OK
   	WAIT FOR ((IS_RX1_RF_PREP_OK == bWaitingVal) OR ($TIMER_FLAG[IS_iWaitTimerID]))
   CASE #IS_RF_IMGACQ      ; Warten auf Bildaufnahme läuft -- Achtung: Nicht abgesichert!
    WAIT FOR ((IS_RX1_RF_IMG_ACQ == bWaitingVal) OR ($TIMER_FLAG[IS_iWaitTimerID]))
   CASE #IS_RF_MESRUN      ; Warten auf Messung läuft
   	WAIT FOR ((IS_RX1_RF_MEAS_RUN == bWaitingVal) OR ($TIMER_FLAG[IS_iWaitTimerID]))
   CASE #IS_RF_RESRUN      ; Warten auf Ergebnisuebertragung "noch nicht fertig"
    WAIT FOR ((IS_RX1_RF_RES_RUN == bWaitingVal) OR ($TIMER_FLAG[IS_iWaitTimerID]))
   CASE #IS_RF_ERESET      ; Warten auf Ruecksetzen der Fehlerbits
    WAIT FOR ((IS_RX8_RF_ERR_SUM == 0) OR ($TIMER_FLAG[IS_iWaitTimerID]))
	DEFAULT
    ;IS_Log("IS_RF_Wait: Case not available",1,TRUE)
  ENDSWITCH
  ;
 	;
  ;Hinweis zu Prioritaeten:
	; Ein Fehler von ROVIS ist immer als höchste Meldung zu beruecksichtigen
	; Ein Timeout ist eine Art "unbekannter" Fehler, der nicht von der Gegenstelle gemeldet wird 
	; und kann daher nur ueber die "Stelle" des Auftretens im Ablauf vom VW-User/ISRA-Comm klassifiziert werden
	; Ein Timeout ist daher für die Meldungsausgabe von zweithöchster Prioritaet
	; Eine Warnung von ROVIS hat niedrigste Priorität und wird nur dann gemeldet, wenn ansonsten alles ok ist
	
	; 1. Fehler von RoVis
	IS_RF_GetExternErrors(iFNCTID)
	;
	;Fehlerzustand bei GetExtErrRF festgestellt
	IF NOT IS_STATE_OK() THEN
	  IS_StopTimer(IS_iWaitTimerID)
	  RETURN FALSE
	ENDIF
	
	; 2. TimeOut-Fehler, hier kommt man nur herein, wenn ROVIS sich gar nicht aeussert...
	; ...
  IF ($TIMER_FLAG[IS_iWaitTimerID]) THEN
  	;
  	; Das "kleine" SetInternErr fuer RF
  	IS_iInternErrors = IS_Err_ID_Timeout
  	IS_bInternError = TRUE
  	$FLAG[IS_FLAG_ERROR] = TRUE
  	;
  	IS_ProcessErrors()
  	;
  	;Reset
  	IS_iInternErrors = 0
  	IS_bInternError = FALSE
  	;
  	;Hinweis: Das FLG[FL_ERR] bleibt gesetzt, so dass IS_STATE_OK weiterhin "nicht ok" ist
  	;
  	IS_StopTimer(IS_iWaitTimerID)
  	RETURN FALSE
  	;
	ENDIF
	;
	; 3. Warnungen von ROVIS
	IS_RF_GetExternWarn(iFNCTID, TRUE)
	; Keine Fehlerbehandlung, weil Ablauf durch Warnungen nicht beeinflusst wird
	;
	IS_StopTimer(IS_iWaitTimerID)
	;
	;MsgNotify("End of", "IS_RF_Wait")
	RETURN TRUE
	;
ELSE
	;IS_Log("IS_RF_Wait: Skipping",1,TRUE)
ENDIF
;
RETURN FALSE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD

;FOLD IMT Messpunkt anmelden
;---------------------------------------------------------------------------------------------
DEF IS_IMT_Prepare(iPoseId:IN)
;
DECL INT iPoseID
DECL BOOL b_RetVal
;
IF IS_State_OK() THEN
;
	;IS_Log("IMT_Prepare",1,TRUE)
;
	CONTINUE
	IS_TX8_MODEL_ID 			= 0
	CONTINUE
	IS_TX1_DATA_END_TRANS	= FALSE
	CONTINUE
	IS_TX1_DATA_VALID			= FALSE
	CONTINUE
	IS_TX1_DATA_ACCEPTED	= FALSE
	CONTINUE
	IS_TX8_POSE_ID 				= iPoseID
	CONTINUE
	IS_TX1_APPROACH_POSE	= TRUE
	CONTINUE
	IS_TX1_IN_POSE				= FALSE
	CONTINUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
;
	b_RetVal = IS_WaitForEnd(IS_FnctID_IMT_Prepare)
;
ENDIF ;State_OK
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD IMT Messpunkt messen
;---------------------------------------------------------------------------------------------
DEF IS_IMT_Apply(b_Active:IN)
DECL INT  iSendBase
DECL INT  iFrameID
DECL BOOL bRetVal
DECL BOOL b_Active
;
IF NOT (Varstate ("b_Active")==#initialized) then
   b_Active = TRUE;
ENDIF
;
WAIT SEC 0.0 ;stop advance pointer
;
IF ((b_Active==FALSE) OR ($IS_COMMUNICATE==FALSE)) THEN
   RETURN
ENDIF
;
IF IS_State_OK() THEN
;
	IF NOT IS_WaitForEnd(IS_FnctID_IMT_Prepare) THEN
		RETURN
	ENDIF
;
	;current work object can already be sent, before the robot stands still at the measurement feature
	IF $ISRA_SEND_BASE THEN
		IF NOT IS_IMT_SendBase() THEN
			RETURN
		ENDIF
		IF NOT IS_IMT_SendTool() THEN
			RETURN
		ENDIF
	ENDIF
;
	IF NOT IS_IMT_CheckAxisState() THEN
		RETURN
	ENDIF
;
	IF IS_bSendBase THEN
		IF NOT IS_IMT_SendBase() THEN
			RETURN
		ENDIF
		IF NOT IS_IMT_SendTool() THEN
			RETURN
		ENDIF		
		IF ($ISRA_SEND_AXES==FALSE) AND (IS_bSendAxes==FALSE) THEN
			IF NOT IS_IMT_CheckAxisState() THEN
				RETURN
			ENDIF
		ENDIF
	ENDIF
;
	WAIT FOR $ROB_STOPPED
	WAIT SEC IS_rSettlingTime
	;WAIT SEC IS_rMeasurementDelay
;
	IF $ISRA_SEND_AXES OR IS_bSendAxes THEN
		IF NOT IS_IMT_SendAxes() THEN
			RETURN
		ENDIF
		IF NOT IS_IMT_SendPose() THEN ;if axis angles are required, send Cartesian pose as well
			RETURN
		ENDIF
	ENDIF
;
	;IS_Log("IS_IMT_Apply",1,TRUE)
	IS_TX8_DATA_ID				= 0
	IS_TX1_DATA_UNCHANGED	= FALSE
	IS_TX1_DATA_END_TRANS	= FALSE
	IS_TX1_DATA_VALID			= FALSE
	IS_TX1_APPROACH_POSE	=	FALSE
	IS_TX1_IN_POSE				= TRUE
	IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
;
	bRetVal = IS_Wait(#IS_CONTINUE, FALSE, IS_FnctID_IMT_Apply)
;
ENDIF
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Ende des IMT Messzyklus signalisieren
;---------------------------------------------------------------------------------------------
DEF IS_IMT_EndPose(b_Active:IN)
DECL BOOL b_Active, b_RetVal
;
IF NOT (Varstate ("b_Active")==#initialized) then
   b_Active = TRUE;
ENDIF
;
IF ((b_Active==FALSE) OR ($IS_COMMUNICATE==FALSE)) THEN
   RETURN
ENDIF
;
;IF $FLAG[950] THEN 
;   RETURN
;ENDIF
;
IS_bRepeatUpSel = FALSE
;
IF IS_State_OK() THEN
	IS_TX1_IN_POSE		= FALSE
	IS_TX1_IN_ENDPOSE	= TRUE
	IS_TX1_HANDSHAKE	= IS_ToggleHandshake()
;
	IF (IS_WaitForEnd(IS_FnctID_IMT_EndPose1)==FALSE)THEN
		RETURN
	ENDIF
;
	IF IS_RX1_CONTINUE THEN
	  IS_bRepeatUpSel = TRUE
	ELSE
	  IS_bRepeatUpSel = FALSE
	ENDIF
;
	IS_TX1_IN_ENDPOSE	= FALSE
	IS_TX1_HANDSHAKE	= IS_ToggleHandshake()
;
	b_RetVal= IS_WaitForEnd(IS_FnctID_IMT_EndPose2)
;
	SWITCH IS_iServiceMode
		CASE IS_iSENSOR_CHANGE_IMT
			IF IS_STATE_OK() THEN
				IS_MSG(IS_MSG_I_SERV_SENS, IS_MSG_TYPE_NOTIFY)
			ELSE
				IS_MSG_ERR(IS_MSG_ERR_SERV_SENSIMT)
			ENDIF
	      IS_iServiceMode=IS_iSERVICE_NONE
		CASE IS_iFULL_CALIB
			IF IS_STATE_OK() THEN
				IS_MSG(IS_MSG_I_TRANS_AXES, IS_MSG_TYPE_NOTIFY)
			ENDIF
			IS_iServiceMode=IS_iSERVICE_NONE
	ENDSWITCH
;
ENDIF
;
END
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Signalisiert, ob Achsen gesendet werden oder nicht
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_IMT_CheckAxisState()
DECL BOOL b_RetVal
;
IS_bSendBase = FALSE
IS_bSendAxes = FALSE
;
IF $ISRA_SEND_AXES THEN
	RETURN TRUE
ENDIF
;
IF (IS_State_OK()==FALSE) THEN
	RETURN FALSE
ENDIF
;
IS_TX8_DATA_ID 				= 1
IS_TX1_DATA_UNCHANGED = TRUE
IS_TX1_DATA_END_TRANS = TRUE
IS_TX1_DATA_VALID 		= TRUE
IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
;
IF IS_WaitInMotion(#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SendAxis1) THEN
	RETURN TRUE
ENDIF

IF (IS_iErrorSource==3) AND (IS_iExternErrors == 16) THEN ;Achsen
	b_RetVal=IS_SyncErrors(0,0)
	IS_TX1_DATA_UNCHANGED = FALSE
	IS_TX1_DATA_END_TRANS = FALSE
	IS_TX1_DATA_VALID 		= FALSE
	IS_bSendAxes 					= TRUE
	RETURN TRUE
ENDIF

IF (IS_iErrorSource==3) AND (IS_iExternErrors == 32) THEN ;Base
	b_RetVal=IS_SyncErrors(0,0)
	IS_TX1_DATA_UNCHANGED = FALSE
	IS_TX1_DATA_END_TRANS = FALSE
	IS_TX1_DATA_VALID 		= FALSE
	IS_bSendBase 					= TRUE
	RETURN TRUE
ENDIF

IF (IS_iErrorSource==3) AND (IS_iExternErrors == 48) THEN ;Achsen+Base
	b_RetVal=IS_SyncErrors(0,0)
	IS_TX1_DATA_UNCHANGED = FALSE
	IS_TX1_DATA_END_TRANS = FALSE
	IS_TX1_DATA_VALID 		= FALSE
	IS_bSendBase 					= TRUE
	IS_bSendAxes 					= TRUE
	RETURN TRUE
ENDIF
;
RETURN FALSE
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Achsen senden
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_IMT_SendAxes()
DECL BOOL b_RetVal
;
IF (IS_State_OK()==FALSE) THEN
	RETURN FALSE
ENDIF
;
IS_TX8_DATA_ID		= 1
IS_TX32_AXIS_1 		= IS_IMT_rScaleAXIS*$AXIS_ACT.A1
IS_TX32_AXIS_2		= IS_IMT_rScaleAXIS*$AXIS_ACT.A2
IS_TX1_DATA_VALID = TRUE
IS_TX1_HANDSHAKE	= IS_ToggleHandshake()
;
IF (IS_Wait(#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SendAxis2)==FALSE) THEN
	IF (IS_iErrorSource==3) AND (IS_iExternErrors==32) THEN  ;Basedaten ungueltig, senden
		b_RetVal=IS_SyncErrors(0,0)
		IS_TX8_DATA_ID 		= 0
		IS_TX32_AXIS_1 		= 0
		IS_TX32_AXIS_2 		= 0
		IS_TX1_DATA_VALID = FALSE
		RETURN TRUE
	ENDIF
	RETURN FALSE
ENDIF
;
IS_TX8_DATA_ID 		= 2
IS_TX32_AXIS_3 		= IS_IMT_rScaleAXIS*$AXIS_ACT.A3
IS_TX32_AXIS_4 		= IS_IMT_rScaleAXIS*$AXIS_ACT.A4
IS_TX1_DATA_VALID = TRUE
IS_TX1_HANDSHAKE	= IS_ToggleHandshake()
;
IF (IS_Wait (#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SendAxis3)==FALSE) THEN
	RETURN FALSE
ENDIF
;
IS_TX8_DATA_ID 				= 3
IS_TX32_AXIS_5 				= IS_IMT_rScaleAXIS*$AXIS_ACT.A5
IS_TX32_AXIS_6 				= IS_IMT_rScaleAXIS*$AXIS_ACT.A6
IS_TX1_DATA_END_TRANS = TRUE
IS_TX1_DATA_VALID 		= TRUE
IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
;
b_RetVal = IS_Wait (#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SendAxis4)
;
IS_TX32_AXIS_1 = 0
IS_TX32_AXIS_2 = 0
IS_TX32_AXIS_3 = 0
IS_TX32_AXIS_4 = 0
IS_TX32_AXIS_5 = 0
IS_TX32_AXIS_6 = 0
IS_TX1_DATA_END_TRANS = FALSE
IS_TX1_DATA_VALID 		= FALSE
;
RETURN b_RetVal
;
ENDFCT
;---------------------------------------------------------------------------------------------
;ENDFOLD
;
;FOLD Base senden
;---------------------------------------------------------------------------------------------
DEFFCT BOOL IS_IMT_SendBase()
DECL BOOL b_RetVal
;
IF (IS_State_OK()==FALSE)THEN
	RETURN FALSE
ENDIF
;
IS_TX8_DATA_ID		= 4
IS_TX32_BASE_X		= IS_IMT_rScaleXYZ*$BASE.X
IS_TX32_BASE_Y		= IS_IMT_rScaleXYZ*$BASE.Y
IS_TX1_DATA_VALID	= TRUE
IS_TX1_HANDSHAKE	= IS_ToggleHandshake()
;
IF (IS_Wait (#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SendBase1)==FALSE) THEN
	RETURN FALSE
ENDIF
;
IS_TX8_DATA_ID 		= 5
IS_TX32_BASE_Z 		= IS_IMT_rScaleXYZ*$BASE.Z
IS_TX32_BASE_A 		= IS_IMT_rScaleABC*$BASE.A
IS_TX1_DATA_VALID = TRUE
IS_TX1_HANDSHAKE	= IS_ToggleHandshake()
;
IF (IS_Wait (#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SendBase2)==FALSE) THEN
	RETURN FALSE
ENDIF
;
IS_TX8_DATA_ID 				= 6
IS_TX32_BASE_B 				= IS_IMT_rScaleABC*$BASE.B
IS_TX32_BASE_C 				= IS_IMT_rScaleABC*$BASE.C
IS_TX1_DATA_END_TRANS = TRUE
IS_TX1_DATA_VALID 		= TRUE
IS_TX1_HANDSHAKE			= IS_ToggleHandshake()
b_RetVal = IS_Wait (#IS_ACCEPTED, TRUE, IS_FnctID_IMT_SendBase3)
;
IS_TX8_DATA_ID 				= 0
IS_TX32_BASE_X 				= 0
IS_TX32_BASE_Y 				= 0
IS_TX32_BASE_Z 				= 0
IS_TX32_BASE_A 				= 0
IS_TX32_BASE_B 				= 0
IS_TX32_BASE_C 				= 0
IS_TX1_DATA_END_TRANS = FALSE
IS_TX1_DATA_VALID 		= FALSE
;
RETURN b_RetVal
;
ENDFCT
