VMT_MESSAGES[44]={FLAG_NR 0,PAR 6,QUIT_MSG FALSE,OP_MODE #T2,TXT[] "X %1.1F mm, Y %1.1F mm, Z %1.1F mm, A %.2F, B %.2F, C %.2F"}
VMT_MESSAGES[45]={FLAG_NR 0,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Hintergrund-Task nicht fertig innerhalb von %1.0F ms!"}
VMT_MESSAGES[46]={FLAG_NR 500,PAR 2,QUIT_MSG TRUE,OP_MODE #T1,TXT[] "Messfahrt fuer Typ %1.0F / Bahn %1.0F war nicht erfolgreich !"}
VMT_MESSAGES[47]={FLAG_NR 503,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Keine Korrekturen vorhanden! Bitte Programm abwaehlen !"}
VMT_MESSAGES[48]={FLAG_NR 0,PAR 0,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Sensortausch erfolgreich durchgefuehrt !"}
