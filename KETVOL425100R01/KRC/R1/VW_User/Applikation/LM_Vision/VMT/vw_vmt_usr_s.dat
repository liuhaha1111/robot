GLOBAL CONST INT BK_E_LIMIT=16 ;das 5. Bit gesetzt
GLOBAL CONST INT BK_E_COLLIS=32 ;das 6. Bit gesetzt
GLOBAL CONST INT BK_E_DETECT=64 ;das 7. Bit gesetzt
GLOBAL CONST INT BK_E_GENERAL=128 ;das 8. Bit gesetzt

; Interne Variablen, die den Inhalt 
; der EA-Signalgruppen wiederspiegeln
GLOBAL INT N_VMT_TYPE=20
GLOBAL INT N_VMT_PATH=1
GLOBAL INT N_VMT_ROB_ID=1

; Index fuer die aktuelle Messung/Korrektur
; ergibt sich aus N_VMT_TYPE und N_VMT_PATH
GLOBAL INT N_VMT_PATHIX=1

; Die aktuelle Betriebsart
GLOBAL INT N_VMT_BKMODE=99
; Die verschiedenen Betriebsarten
GLOBAL CONST INT BK_M_MEASURE=1
GLOBAL CONST INT BK_M_CORRECT=2
GLOBAL CONST INT BK_M_TCP=4
GLOBAL CONST INT BK_M_CHECK=5
GLOBAL CONST INT BK_M_MEASREF=11
GLOBAL CONST INT BK_M_CORRREF=12
GLOBAL CONST INT BK_M_TCP_REF=14
