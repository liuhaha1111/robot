;FOLD VMT MESSAGES

; Messages & Errorhandling

;Messages - Struktur enthaelt :
;- Flag, das bei der Ausgabe gesetzt wird
;- Anzahl der Ausgabeparameter (meistens 1)
;- Quittierung erfoderlich
;- Mindest OP-Mode zur Anzeige der Meldung
;- Ausgabetext mit Formatangabe fuer die Parameter
GLOBAL STRUC MESSAGE_TYPE INT FLAG_NR,INT PAR,BOOL QUIT_MSG,MODE_OP OP_MODE,CHAR TXT[80]
GLOBAL INT VMT_MESSAGES_COUNT=60

; Diese Flags werden bei der Textausgabe ggfs. gesetzt
GLOBAL CONST INT F_VMT_IO=495
GLOBAL CONST INT F_VMT_NIO=496
GLOBAL CONST INT F_VMT_ERROR=497

GLOBAL CONST INT F_VMT_FIRST=498
GLOBAL CONST INT F_VMT_LAST=505

DECL MESSAGE_TYPE VMT_MESSAGES[60]
;Allgemeine Fehler
VMT_MESSAGES[1]={FLAG_NR 498,PAR 0,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Allgemeiner Fehler !"}
VMT_MESSAGES[2]={FLAG_NR 498,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Ungueltige Fehlernummer %1.0F!"}
VMT_MESSAGES[3]={FLAG_NR 498,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Korrektur in Base 0 nicht erlaubt, da es nicht moeglich ist."}
VMT_MESSAGES[4]={FLAG_NR 498,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Aktuelles Tool ist nicht 0! Fuer TCP Bestimmung muss in Flansch gefahren werden!"}
VMT_MESSAGES[5]={FLAG_NR 499,PAR 1,QUIT_MSG FALSE,OP_MODE #T2,TXT[] "Timeout beim Senden von Daten (%1.0F)"}
VMT_MESSAGES[6]={FLAG_NR 499,PAR 1,QUIT_MSG FALSE,OP_MODE #T2,TXT[] "Timeout beim Empfangen von Daten (%1.0F)"}
VMT_MESSAGES[7]={FLAG_NR 498,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Kommunikationsproblem! Bitte Verbindung zum VMT-PC pruefen!"}
VMT_MESSAGES[8]={FLAG_NR 500,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "VMT BK nicht bereit! Evtl. kein Automatikberieb?"}

; Auswahl Fehler
VMT_MESSAGES[9]={FLAG_NR 498,PAR 1,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Ungueltiges Base/Tool %1.0F! Bitte anderes Base/Tool auswaehlen."}
VMT_MESSAGES[10]={FLAG_NR 498,PAR 1,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Ungueltiger Modus %1.0F! Bitte User-Aufruf korrigieren."}
VMT_MESSAGES[11]={FLAG_NR 498,PAR 1,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Ungueltiger Typ %1.0F! Bitte richtigen Typ auswaehlen."}
VMT_MESSAGES[12]={FLAG_NR 498,PAR 2,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Ungueltige Bahn %1.0F/%1.0F! Bitte richtige Bahn auswaehlen."}
VMT_MESSAGES[13]={FLAG_NR 498,PAR 3,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Ungueltiger Punkt %1.0F/%1.0F/%1.0F! Bitte richtigen Punkt auswaehlen."}
VMT_MESSAGES[14]={FLAG_NR 0,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Korrektur bereits aktiv : %1.0F !"}
VMT_MESSAGES[15]={FLAG_NR 500,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Berechtigung fehlt! Bitte am VMT System anmelden."}
VMT_MESSAGES[16]={FLAG_NR 500,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Mess-Speicher ist voll! Bitte Messungen anwenden oder Typ wechseln."}
VMT_MESSAGES[17]={FLAG_NR 0,PAR 3,QUIT_MSG FALSE,OP_MODE #T2,TXT[] "X %1.1F mm, Y %1.1F mm, Z %1.1F mm"}
VMT_MESSAGES[18]={FLAG_NR 0,PAR 3,QUIT_MSG FALSE,OP_MODE #T2,TXT[] "A %1.1F Grad, B %1.1F Grad, C %1.1F Grad"}
VMT_MESSAGES[19]={FLAG_NR 0,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Neuer TCP fuer Sensor in TOOL %2d :"}
;Messfehler Korrekturen
VMT_MESSAGES[20]={FLAG_NR 500,PAR 2,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Punktanzahl Soll %1.0F <> Ist %1.0F! Parameter Punkt bitte anpassen."}
VMT_MESSAGES[21]={FLAG_NR 503,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Min. eine Messung zur Berechnung der Korrektur %1.0F war ungueltig."}
VMT_MESSAGES[22]={FLAG_NR 502,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Kollisionsgefahr im Bereich der Korrektur %1.0F!"}
VMT_MESSAGES[23]={FLAG_NR 503,PAR 2,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Keine Korrekturen fuer Typ %1.0F / Bahn %1.0F! Evtl. Konfiguration fehlerhaft?"}
VMT_MESSAGES[24]={FLAG_NR 504,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Toleranzueberschreitung bei Korrektur %1.0F."}
VMT_MESSAGES[25]={FLAG_NR 505,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Allgemeiner Fehler bei Korrektur %1.0F"}
VMT_MESSAGES[26]={FLAG_NR 505,PAR 1,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Korrektur %1.0F nicht vorhanden oder nicht gueltig!"}
VMT_MESSAGES[27]={FLAG_NR 501,PAR 0,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Sensorproblem! Bitte am VMT-System pruefen"}

VMT_MESSAGES[28]={FLAG_NR 503,PAR 1,QUIT_MSG TRUE,OP_MODE #T1,TXT[] "Messfehler bei Messpunkt %1.0F"}
