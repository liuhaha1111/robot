VMT_MESSAGES[32]={FLAG_NR 501,PAR 1,QUIT_MSG TRUE,OP_MODE #T1,TXT[] "Sensorproblem am Messpunkt %1.0F"}


VMT_MESSAGES[33]={FLAG_NR 504,PAR 0,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Abweichung zu gross!"}
VMT_MESSAGES[34]={FLAG_NR 0,PAR 0,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "VMT in Simulationsbetrieb ! Es werden keine Befehle ausgefuehrt !"}
VMT_MESSAGES[35]={FLAG_NR 0,PAR 7,QUIT_MSG FALSE,OP_MODE #T2,TXT[] "Korr %1.0F : X %1.1F mm, Y %1.1F mm, Z %1.1F mm, A %.2F, B %.2F, C %.2F"}
VMT_MESSAGES[36]={FLAG_NR 501,PAR 0,QUIT_MSG FALSE,OP_MODE #EX,TXT[] "VMT Verbindung verloren !"}
VMT_MESSAGES[37]={FLAG_NR 0,PAR 0,QUIT_MSG FALSE,OP_MODE #EX,TXT[] "VMT Verbindung wiederhergestellt !"}
VMT_MESSAGES[38]={FLAG_NR 498,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Ungueltige Gruppennummer! Bitte User-Aufruf korrigieren."}
VMT_MESSAGES[39]={FLAG_NR 0,PAR 0,QUIT_MSG FALSE,OP_MODE #AUT,TXT[] "Referenzfahrt erfolgreich! Bitte am VMT System Auswertungen parametrieren !"}
VMT_MESSAGES[40]={FLAG_NR 0,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Referenzfahrt NICHT erfolgreich! Bitte Kontrollieren und nochmals durchfuehren !"}
VMT_MESSAGES[41]={FLAG_NR 496,PAR 0,QUIT_MSG TRUE,OP_MODE #AUT,TXT[] "Abbruch durch Benutzer. Tooldaten nicht veraendert !"}

VMT_MESSAGES[42]={FLAG_NR 0,PAR 1,QUIT_MSG FALSE,OP_MODE #T2,TXT[] "Tooldaten (%1.0F) erfolgreich gesetzt."}
