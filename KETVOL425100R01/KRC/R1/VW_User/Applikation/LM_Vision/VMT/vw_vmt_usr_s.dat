; Interne Variablen, die den Inhalt 
; der EA-Signalgruppen wiederspiegeln
INT BK_SCALE_T=10000
INT BK_SCALE_R=10000

; Interne Variablen, die den Inhalt 
; der EA-Signalgruppen wiederspiegeln
INT N_VMT_TYPEID=20
INT N_VMT_PATHID=1
INT N_VMT_PT_ID=0

; Interne Variablen, die den Inhalt
; der EA-Signalgruppen wiederspiegeln
GLOBAL REAL R_VMT_CORR_X=0.0
GLOBAL REAL R_VMT_CORR_Y=0.0
GLOBAL REAL R_VMT_CORR_Z=0.0
GLOBAL REAL R_VMT_CORR_C=0.0
GLOBAL REAL R_VMT_CORR_B=0.0
GLOBAL REAL R_VMT_CORR_A=0.0
GLOBAL INT N_VMT_BKSTAT=8

; Vordergrundzaehler 
GLOBAL INT N_VMT_MESCNT=0
; Hintergrundzaehler
GLOBAL INT N_VMT_REQCNT=0

; Die momentan aktive Korrektur
GLOBAL INT N_VMT_CORACT=0
GLOBAL FRAME FR_VMT_CORACT={X 0.0,Y 0.0,Z 0.0,A 0.0,B 0.0,C 0.0}


; Timer
GLOBAL REAL R_VMT_BKWAIT=0.00999999978
GLOBAL INT N_VMT_RETRY=2
GLOBAL INT N_VMT_SENDTO=5000 ;Timeout [ms] Senden
GLOBAL INT N_VMT_RECVTO=5000 ;Timeout [ms] Empfangen

GLOBAL INT NA_VMT_TIMER[5]
NA_VMT_TIMER[1]=0
NA_VMT_TIMER[2]=442727491
