;ENDFOLD (PGR Interface)
;
;***************************************************
;FOLD Fertigmeldung
DEF Fertigmeldung(FM_Nr :IN)
INT FM_Nr,RobTimerStart,BMS_FM_QUIT
;
IF $FLAG[F_o_Proz_SStep] THEN
  PGR_Msg(8,#QuitMsg)
ELSE
  RobTimerStart=$Rob_Timer          
  SO_PGR_FM_Nr=FM_Nr
  WAIT FOR ((SI_PGR_FM_Nr==SO_PGR_FM_Nr) OR (($Rob_Timer-RobTimerStart)>2000))  
  IF (($Rob_Timer- RobTimerStart)>=2000) THEN
    PGR_Msg(10,#QuitMsg)
  ENDIF
ENDIF
FM_Nr=0
SO_PGR_FM_Nr=FM_Nr
;
END
;
;***************************************************
;FOLD PGR Meldungen
;
DEF PGR_Msg(msg_nr :IN, MsgTyp :IN)
INT msg_nr
DECL PGRR_MsgType MsgTyp
DECL KrlMsg_T USER_MSG
DECL KrlMsgPar_T Par[3]
DECL KrlMsgOpt_T Opt
DECL STATE_T Stat 
;
USER_MSG = { Modul[] "PGR_R_Msg", Nr -1, Msg_txt[] " "}
Opt = { VL_Stop True, Clear_P_Reset True, Log_To_DB False }
Par[1] = { Par_type #Value, Par_txt[] " " }
;
IF ((n_PGRR_Handle[msg_nr]<0) OR (MsgTyp==#NotifyMsg) OR (MsgTyp==#QuitMsg)) THEN
  USER_MSG.Nr = msg_nr
  SWITCH msg_nr
    CASE 1
      USER_MSG.MSG_TXT[]="PGR: Greifer-Nr ungueltig"
    CASE 2
      USER_MSG.MSG_TXT[]="PGR: Zangen-Nr ungueltig"
    CASE 3
      USER_MSG.MSG_TXT[]="PGR: Pistolen-Nr ungueltig"
    CASE 4
      USER_MSG.MSG_TXT[]="PGR: Spindel-Nr ungueltig"
    CASE 5
      USER_MSG.MSG_TXT[]="PGR: Buegel-Nr ungueltig"
    CASE 6
      USER_MSG.MSG_TXT[]="PGR: Kopf-Nr ungueltig"
    CASE 7
      USER_MSG.MSG_TXT[]="PGR: Brenner-Nr ungueltig"
    CASE 8
      USER_MSG.MSG_TXT[]="PGR: Anwahl ohne Prozess aktiv (F525), Fertigmeldung wurde nicht gesetzt"
    CASE 9
      USER_MSG.MSG_TXT[]="PGR: Anwahl ohne Prozess aktiv (BMS), Fertigmeldung wurde nicht gesetzt"
    CASE 10
      USER_MSG.MSG_TXT[]="PGR: Fertigmeldung wurde von BMS nicht quittiert"
    CASE 11
      USER_MSG.MSG_TXT[]="PGR: Fehlende Teilfertigmeldung(en), Gesamtfertigmeldung wurde nicht gesetzt"
    CASE 12
      USER_MSG.MSG_TXT[]="PGR: Prozess n.i.O., Fertigmeldung wurde nicht gesetzt"
    CASE 13
	   USER_MSG.MSG_TXT[]=" "
    CASE 14
	   USER_MSG.MSG_TXT[]=" "
    CASE 15
	   USER_MSG.MSG_TXT[]="PGR: Konfiguration -EZ/SP/KE1 2EZ/SP an 1SK- ungueltig"
    CASE 16
	   USER_MSG.MSG_TXT[]="PGR: Konfiguration -KF2 2EZ/SP an 1SK- ungueltig"
    CASE 17
	   USER_MSG.MSG_TXT[]=" "
    CASE 18
	   USER_MSG.MSG_TXT[]=" "
    CASE 19
	   USER_MSG.MSG_TXT[]="PGR: Konfiguration -KF Ausblasen- muss bei allen KF identisch sein"
    CASE 20
	   USER_MSG.MSG_TXT[]=" "
    CASE 21
	   USER_MSG.MSG_TXT[]="PGR: Konfiguration -CZ2 Flat- ungueltig (nur CZ1 Flat moeglich)"
    CASE 22
	   USER_MSG.MSG_TXT[]="PGR: PGR: Konfiguration -KF Ermittlung- muss bei allen EZ/SP/KE identisch sein"
    CASE 23
	   USER_MSG.MSG_TXT[]="PGR: Konfiguration -Ausgleich- muss bei allen EZ/SP/KE identisch sein"
	CASE 24
	   USER_MSG.MSG_TXT[]="PGR: Konfiguration -RIP2- ungueltig"
    CASE 25
	   USER_MSG.MSG_TXT[]="PGR: Konfiguration -RIP3- ungueltig"	
    CASE 91
      USER_MSG.MSG_TXT[]="PGR: Fraesmesserdicke nicht eingegeben"
    DEFAULT
      USER_MSG.MSG_TXT[]="unbekannte Meldung"   
  ENDSWITCH
  SWITCH MsgTyp
    CASE #StateMsg
      n_PGRR_Handle[msg_nr] = Set_KrlMsg (#State, USER_MSG, Par[], Opt) ;Ausgabe Statusmeldung
    CASE #QuitMsg
      n_PGRR_Handle[msg_nr] = Set_KrlMsg (#Quit, USER_MSG, Par[], Opt) ;Ausgabe Quittierungsmeldung
      While ( Exists_KrlMsg(n_PGRR_Handle[msg_nr]) )  ;Warten bis der Anwender quittiert
        Wait Sec 0.1
      Endwhile
    CASE #NotifyMsg
      n_PGRR_Handle[msg_nr] = Set_KrlMsg (#Notify, USER_MSG, Par[], Opt) ;Ausgabe Hinweismeldung
    DEFAULT
      n_PGRR_Handle[msg_nr] = Set_KrlMsg (#Quit, USER_MSG, Par[], Opt) ;Ausgabe Quittierungsmeldung
  ENDSWITCH
ENDIF
END
;
;ENDFOLD (PGR Meldungen)

