          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[OE_BASE_SL[Steu_Nr]+I_OE_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 20  ;Prozessgeraet Buersten(BU)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-50)
        IF (Wkzg_Nr<>1) THEN
          PGR_Msg(4,#QuitMsg)
        ENDIF
         ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((BU_BASE_SL-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[BU_BASE_SL+I_BU_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 21  ;Prozessgeraet Sonstige
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=PAR5
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          Hilf2_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            Fertigmeldung(FM_Nr)
          ENDIF
        ENDIF
	 ENDSWITCH   
    ;
    ;ENDFOLD (Trig)
;
;***************************************************
  CASE #USR_MAIN
    ;FOLD Main
    ;
    Proz_Nr=0
    Wkzg_Nr=0
    Steu_Nr=0
    FM_Nr=0
    ;
    ;Fertigmeldung an BMS zuruecksetzen
    SO_PGR_FM_Nr=FM_Nr
    ;Prozessgeraete-Nr an BMS zuruecksetzen
    SO_PGR_Geraete_Nr=Proz_Nr
    ;
    ;ENDFOLD (Main)
;
;***************************************************
  CASE #USR_MAKRO
    ;FOLD Makro
    ;
    SWITCH PAR1
      CASE 2100 ; Alle Variablen zuruecksetzen
        CF_BU_BASE_SL=449
        CF_LR_BASE_SL=449
        CF_RE_BASE_SL=449
        CF_STP_BASE_SL[1]=449
        CF_CZF_BASE_SL[1]=449
        MIT_STP=FALSE
        MIT_RZ=FALSE
        $FLAG[F_m_RZKOPF]=FALSE
        $FLAG[F_m_RZ1]=FALSE
        $FLAG[F_m_RZ2]=FALSE
        $FLAG[F_m_RZ3]=FALSE
        $FLAG[F_Mit_STP]=FALSE
        $FLAG[F_KL_MS_o_FRG]=FALSE 
		$FLAG[F_MIT_WDHFRS]=FALSE
        MIT_Auto_KF=FALSE
        MIT_2SZ_an_SK1=FALSE
        SZ1_PAR4=0
        SZ1_PAR5=0
        KF_ausbl_SZ_ZU=FALSE
        KF_ausbl_SZ_Kraft=FALSE
        KF_ausbl_SZ_AUF=FALSE
        KF1_PAR4=0
        KW_Braeuer=FALSE
        KW_Lutz=FALSE
        KW_AEG=FALSE
        KW_Sintherleghe=FALSE
        MIT_CZF[1]=FALSE
        MIT_MS_SUCH=FALSE
        MIT_BU=FALSE
        MIT_SR=FALSE
        MIT_LR=FALSE
        MIT_RE=FALSE
        MIT_NK=FALSE
        MIT_DS=FALSE
        MIT_DS_Cod=FALSE
        MIT_erw_B_Ve=FALSE
        B_KW_MIN_MAX=FALSE
        B_KW_ALU=FALSE
		  B_KW_VE_MONO=FALSE
		  B_KW_VE_BI=FALSE
        B_MIT_KW_VW=FALSE
        B_MIT_VIS=FALSE
        B_MIT_ISR=FALSE
        B_MIT_PRC=FALSE
        B_MIT_VMT=FALSE
        B_MIT_INOS=FALSE
        B_MIT_ZAI=FALSE
        MIT_EKI=FALSE
        B_G_o_Abblasen=FALSE
        V_TYP_SMC=FALSE
        V_TYP_Festo=FALSE
        MIT_SPM=FALSE
        MIT_PR=FALSE
        B_Rob_Pal=FALSE
        B_MIT_CONV=FALSE
        B_MIT_DZ=FALSE
        FOR i=1 TO 2
          CF_NZS_BASE_SL[i]=449
          CF_NZH_BASE_SL[i]=449
          CF_CZS_BASE_SL[i]=449
          CF_CZP_BASE_SL[i]=449
          CF_RW_BASE_SL[i]=449
          CF_BZ_BASE_SL[i]=449
          CF_MS_BASE_SL[i]=449
          CF_SM_BASE_SL[i]=449
          CF_FD_BASE_SL[i]=449
          CF_OE_BASE_SL[i]=449
          MIT_NZS[i]=FALSE
          MIT_NZH[i]=FALSE
          NZ_mit_Ausgleich[i]=FALSE
          NZ_V2[i]=FALSE
          MIT_CZS[i]=FALSE
          MIT_CZP[i]=FALSE
          MIT_RW[i]=FALSE
          MIT_BZ[i]=FALSE      
          MIT_MS[i]=FALSE   
          MS_KS_pneum[i]=FALSE
          MS_mit_SP[i]=FALSE
          SP_Ventil_an_MS[i]=FALSE
          MS_KS_mit_VE[i]=FALSE
          MIT_SM[i]=FALSE
          MIT_FD[i]=FALSE
          MIT_OE[i]=FALSE
        ENDFOR
        FOR i=1 TO 3
          CF_SZ_BASE_SL[i]=449
          CF_SK_BASE_SL[i]=449
          CF_KW_BASE_SL[i]=449
          CF_BM_BASE_SL[i]=449
          CF_KL_BASE_SL[i]=449
          MIT_EZ[i]=FALSE
          MIT_KE[i]=FALSE
          MIT_SZAusgleich[i]=FALSE
          MIT_SK_WdhFraesen[i]=FALSE
          KE_Ref_AUF[i]=FALSE
          MIT_SK[i]=FALSE
          MIT_EK_Vorz[i]=FALSE
          KF_NF_2Huebe[i]=FALSE
          KF_NF_2Kraft[i]=FALSE
          KF_mit_VE[i]=FALSE
          MIT_KW[i]=FALSE
          MIT_BM[i]=FALSE
          MIT_KL[i]=FALSE
          KL_robotergefuehrt[i]=FALSE
          KL_stat[i]=FALSE
          MIT_KL_SPUELEN[i]=FALSE
          KL_o_Nachtrig[i]=FALSE
          KL_Rob_Dos[i]=FALSE
          KL_pneum_KS[i]=TRUE
          KL_elektr_KS[i]=FALSE
          KL_ohne_KS[i]=FALSE
          G_VST[i]=FALSE
          B_OHNE_ND[i]=FALSE
          MIT_ND_Abfr_V[i]=FALSE
        ENDFOR
        FOR i=1 TO 4
          CF_SR_BASE_SL[i]=449
        ENDFOR
      CASE 2201 ;KL1
        IF (PAR2==1) THEN
          KL_robotergefuehrt[1]=TRUE
        ENDIF
        IF (PAR2==2) THEN
          KL_stat[1]=TRUE
        ENDIF
        IF (PAR3==1) THEN
          IF $IN[I_FT_o_BT] THEN
            MIT_KL_SPUELEN[1]=FALSE
          ELSE
            MIT_KL_SPUELEN[1]=TRUE
          ENDIF
        ENDIF
        IF (PAR4==2) THEN
          KL_o_Nachtrig[1]=TRUE
        ENDIF
        IF (PAR5==1) THEN
          KL_Rob_Dos[1]=TRUE
        ENDIF
        IF (PAR6==1) THEN
          KL_pneum_KS[1]=TRUE
          KL_elektr_KS[1]=FALSE
          KL_ohne_KS[1]=FALSE
        ENDIF
        IF (PAR6==2) THEN
          KL_pneum_KS[1]=FALSE
          KL_elektr_KS[1]=TRUE
          KL_ohne_KS[1]=FALSE
        ENDIF
        IF (PAR6==3) THEN
          KL_pneum_KS[1]=FALSE
          KL_elektr_KS[1]=FALSE
          KL_ohne_KS[1]=TRUE
        ENDIF
        IF (PAR7==1) THEN
          $FLAG[F_KL_MS_o_FRG]=TRUE
        ENDIF
        IF (PAR9==0) THEN
          CF_KL_BASE_SL[1]=Default_KL_BASE_SL[1]
        ELSE
          CF_KL_BASE_SL[1]=PAR9
        ENDIF
        MIT_KL[1]=TRUE
      CASE 2202 ;KL2
        IF (PAR2==1) THEN
          KL_robotergefuehrt[2]=TRUE
        ENDIF
        IF (PAR2==2) THEN
          KL_stat[2]=TRUE
        ENDIF
        IF (PAR3==1) THEN
          IF $IN[I_FT_o_BT] THEN
            MIT_KL_SPUELEN[2]=FALSE
          ELSE
            MIT_KL_SPUELEN[2]=TRUE
          ENDIF
        ENDIF
        IF (PAR4==2) THEN
          KL_o_Nachtrig[2]=TRUE
        ENDIF
        IF (PAR5==1) THEN
          KL_Rob_Dos[2]=TRUE
        ENDIF
        IF (PAR6==1) THEN
          KL_pneum_KS[2]=TRUE
          KL_elektr_KS[2]=FALSE
          KL_ohne_KS[2]=FALSE
        ENDIF
        IF (PAR6==2) THEN
          KL_pneum_KS[2]=FALSE
          KL_elektr_KS[2]=TRUE
          KL_ohne_KS[2]=FALSE
        ENDIF
        IF (PAR6==3) THEN
          KL_pneum_KS[2]=FALSE
          KL_elektr_KS[2]=FALSE
          KL_ohne_KS[2]=TRUE
        ENDIF
        IF (PAR7==1) THEN
          $FLAG[F_KL_MS_o_FRG]=TRUE
        ENDIF
        IF (PAR9==0) THEN
          CF_KL_BASE_SL[2]=Default_KL_BASE_SL[2]
        ELSE
          CF_KL_BASE_SL[2]=PAR9
        ENDIF
        MIT_KL[2]=TRUE
      CASE 2203 ;KL3
        IF (PAR2==1) THEN
          KL_robotergefuehrt[3]=TRUE
        ENDIF
        IF (PAR2==2) THEN
          KL_stat[3]=TRUE
        ENDIF
        IF (PAR3==1) THEN
          IF $IN[I_FT_o_BT] THEN
            MIT_KL_SPUELEN[3]=FALSE
          ELSE
            MIT_KL_SPUELEN[3]=TRUE
          ENDIF
        ENDIF
        IF (PAR4==2) THEN
          KL_o_Nachtrig[3]=TRUE
        ENDIF
        IF (PAR5==1) THEN
          KL_Rob_Dos[3]=TRUE
        ENDIF
        IF (PAR6==1) THEN
          KL_pneum_KS[3]=TRUE
          KL_elektr_KS[3]=FALSE
          KL_ohne_KS[3]=FALSE
        ENDIF
        IF (PAR6==2) THEN
          KL_pneum_KS[3]=FALSE
          KL_elektr_KS[3]=TRUE
          KL_ohne_KS[3]=FALSE
        ENDIF
        IF (PAR6==3) THEN
          KL_pneum_KS[3]=FALSE
          KL_elektr_KS[3]=FALSE
          KL_ohne_KS[3]=TRUE
        ENDIF
        IF (PAR7==1) THEN
          $FLAG[F_KL_MS_o_FRG]=TRUE
        ENDIF
        IF (PAR9==0) THEN
          CF_KL_BASE_SL[3]=Default_KL_BASE_SL[3]
        ELSE
          CF_KL_BASE_SL[3]=PAR9
        ENDIF
        MIT_KL[3]=TRUE
      CASE 2301 ;EZ/SP/KE1
        IF (PAR3==1) THEN
          MIT_EK_Vorz[1]=TRUE
        ENDIF
        IF (PAR5==1) THEN
          SZ1_PAR5=1
          MIT_Auto_KF=TRUE
        ENDIF
        IF (PAR5==2) THEN
          SZ1_PAR5=2
          MIT_Auto_KF=FALSE
        ENDIF
        IF (PAR6==2) THEN
          MIT_SZAusgleich[1]=TRUE
        ENDIF
        IF (PAR8==2) THEN
          MIT_SK_WdhFraesen[1]=TRUE
		  $FLAG[F_MIT_WDHFRS]=TRUE
        ELSE
          MIT_SK_WdhFraesen[1]=FALSE
		  $FLAG[F_MIT_WDHFRS]=FALSE
        ENDIF
        IF (PAR9==0) THEN
          CF_SZ_BASE_SL[1]=Default_SZ_BASE_SL[1]
          CF_SK_BASE_SL[1]=Default_SK_BASE_SL[1]
        ELSE
          CF_SZ_BASE_SL[1]=PAR9
          CF_SK_BASE_SL[1]=PAR9+16
        ENDIF
        IF (PAR2==1) THEN
          MIT_EZ[1]=TRUE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[1]=TRUE
          MIT_KE[1]=FALSE
        ENDIF
        IF (PAR2==2) THEN
          MIT_EZ[1]=TRUE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[1]=TRUE
          MIT_KE[1]=FALSE
          PGR_Msg (15,#QuitMsg)
        ENDIF
        IF (PAR2==3) THEN
          MIT_EZ[1]=FALSE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[1]=TRUE
          MIT_KE[1]=TRUE
          IF (PAR7==1) THEN
            KE_Ref_AUF[1]=TRUE
          ENDIF
        ENDIF
      CASE 2302 ;EZ/SP/KE2
        IF (PAR3==1) THEN
          MIT_EK_Vorz[2]=TRUE
        ENDIF
        IF (PAR5==1) AND (SZ1_PAR5==1)THEN
          MIT_Auto_KF=TRUE
        ELSE
          IF (PAR5==1) AND (SZ1_PAR5<>1) OR (PAR5==2) AND (SZ1_PAR5<>2)THEN
            PGR_Msg (22,#QuitMsg)
          ELSE
            MIT_Auto_KF=FALSE
          ENDIF
        ENDIF
        IF (PAR6==2) THEN
          MIT_SZAusgleich[2]=TRUE
        ENDIF
        IF (PAR8==2) THEN
          MIT_SK_WdhFraesen[2]=TRUE
		  $FLAG[F_MIT_WDHFRS]=TRUE
        ELSE
          MIT_SK_WdhFraesen[2]=FALSE
		  $FLAG[F_MIT_WDHFRS]=FALSE
        ENDIF
        IF (PAR9==0) THEN
          CF_SZ_BASE_SL[2]=Default_SZ_BASE_SL[2]
          CF_SK_BASE_SL[2]=Default_SK_BASE_SL[2]
        ELSE
          CF_SZ_BASE_SL[2]=PAR9
          CF_SK_BASE_SL[2]=PAR9+16
        ENDIF
        IF (PAR2==1) THEN
          MIT_EZ[2]=TRUE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[2]=TRUE
          MIT_KE[2]=FALSE
        ENDIF
        IF (PAR2==2) THEN
          MIT_EZ[2]=TRUE
          MIT_2SZ_an_SK1=TRUE
          MIT_SK[2]=FALSE
          MIT_KE[2]=FALSE
        ENDIF
        IF (PAR2==3) THEN
          MIT_EZ[2]=FALSE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[2]=TRUE
          MIT_KE[2]=TRUE
          IF (PAR7==1) THEN
            KE_Ref_AUF[2]=TRUE
          ENDIF
        ENDIF
      CASE 2303 ;EZ/SP/KE3
        IF (PAR3==1) THEN
          MIT_EK_Vorz[3]=TRUE
        ELSE
          MIT_EK_Vorz[3]=FALSE
        ENDIF
        IF (PAR5==1) AND (SZ1_PAR5==1) THEN
          MIT_Auto_KF=TRUE
        ELSE
          IF (PAR5==1) AND (SZ1_PAR5<>1) OR (PAR5==2) AND (SZ1_PAR5<>2)THEN
            PGR_Msg (22,#QuitMsg)
          ELSE
            MIT_Auto_KF=FALSE
          ENDIF
        ENDIF
        IF (PAR6==2) THEN
          MIT_SZAusgleich[3]=TRUE
        ENDIF
        IF (PAR8==2) THEN
          MIT_SK_WdhFraesen[3]=TRUE
		  $FLAG[F_MIT_WDHFRS]=TRUE
        ELSE
          MIT_SK_WdhFraesen[3]=FALSE
		  $FLAG[F_MIT_WDHFRS]=FALSE
        ENDIF        
        IF (PAR9==0) THEN
          CF_SZ_BASE_SL[3]=Default_SZ_BASE_SL[3]
          CF_SK_BASE_SL[3]=Default_SK_BASE_SL[3]
        ELSE
          CF_SZ_BASE_SL[3]=PAR9
          CF_SK_BASE_SL[3]=PAR9+16
        ENDIF
        IF (PAR2==1) THEN
          MIT_EZ[3]=TRUE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[3]=TRUE
          MIT_KE[3]=FALSE
        ENDIF
        IF (PAR2==2) THEN
          MIT_EZ[3]=TRUE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[3]=TRUE
          MIT_KE[3]=FALSE
          PGR_Msg (16,#QuitMsg)
        ENDIF
        IF (PAR2==3) THEN
          MIT_EZ[3]=FALSE
          MIT_2SZ_an_SK1=FALSE
          MIT_SK[3]=TRUE
          MIT_KE[3]=TRUE
          IF (PAR7==1) THEN
            KE_Ref_AUF[3]=TRUE
          ENDIF
        ENDIF
      CASE 2401 ;KF1
        IF (PAR2==2) OR (PAR2==3) OR (PAR2==4) OR (PAR2==5) THEN
          MIT_KW[1]=TRUE
        ENDIF
        SWITCH PAR2
          CASE 1
          CASE 2
            KW_Braeuer=TRUE
          CASE 3
            KW_Lutz=TRUE
          CASE 4
            KW_AEG=TRUE
          CASE 5
            KW_Sintherleghe=TRUE
        ENDSWITCH
        IF (PAR3==1) THEN
          KF_NF_2Huebe[1]=FALSE
          KF_NF_2Kraft[1]=FALSE
        ENDIF
        IF (PAR3==2) THEN
          KF_NF_2Huebe[1]=TRUE
          KF_NF_2Kraft[1]=FALSE
        ENDIF
        IF (PAR3==3) THEN
          KF_NF_2Huebe[1]=TRUE
          KF_NF_2Kraft[1]=TRUE
        ENDIF
        IF (PAR4==1) THEN
          KF1_PAR4=1
          KF_ausbl_SZ_ZU=TRUE
          KF_ausbl_SZ_Kraft=FALSE
          KF_ausbl_SZ_AUF=FALSE
        ENDIF
        IF (PAR4==2) THEN
          KF1_PAR4=2
          KF_ausbl_SZ_ZU=FALSE
          KF_ausbl_SZ_Kraft=TRUE
          KF_ausbl_SZ_AUF=FALSE
        ENDIF
        IF (PAR4==3) THEN
          KF1_PAR4=3
          KF_ausbl_SZ_ZU=FALSE
          KF_ausbl_SZ_Kraft=FALSE
          KF_ausbl_SZ_AUF=TRUE
        ENDIF
        IF (PAR5==1) THEN
          KF_mit_VE[1]=TRUE
        ELSE
          KF_mit_VE[1]=FALSE
        ENDIF
        IF (PAR9==0) OR (PAR2==1) THEN
          CF_KW_BASE_SL[1]=Default_KW_BASE_SL[1]
        ELSE
          CF_KW_BASE_SL[1]=PAR9
        ENDIF
      CASE 2402 ;KF2
        IF (PAR2==1) THEN
          MIT_KW[2]=FALSE
        ENDIF
        IF (PAR2==2) OR (PAR2==3) OR (PAR2==4) OR (PAR2==5) THEN
          MIT_KW[2]=TRUE
        ENDIF
        IF (PAR3==1) THEN
          KF_NF_2Huebe[2]=FALSE
          KF_NF_2Kraft[2]=FALSE
        ENDIF
        IF (PAR3==2) THEN
          KF_NF_2Huebe[2]=TRUE
          KF_NF_2Kraft[2]=FALSE
        ENDIF
        IF (PAR3==3) THEN
          KF_NF_2Huebe[2]=TRUE
          KF_NF_2Kraft[2]=TRUE
        ENDIF
        IF (PAR4==1) AND (KF1_PAR4==1) THEN
          KF_ausbl_SZ_ZU=TRUE
          KF_ausbl_SZ_Kraft=FALSE
          KF_ausbl_SZ_AUF=FALSE
        ELSE
          IF (PAR4==1) AND (KF1_PAR4<>1) THEN
            PGR_Msg (19,#QuitMsg)
          ENDIF
        ENDIF
        IF (PAR4==2) AND (KF1_PAR4==2) THEN
          KF_ausbl_SZ_ZU=FALSE
          KF_ausbl_SZ_Kraft=TRUE
          KF_ausbl_SZ_AUF=FALSE
          IF (PAR4==2) AND (KF1_PAR4<>2) THEN
            PGR_Msg (19,#QuitMsg)
          ENDIF
        ENDIF
        IF (PAR4==3) AND (KF1_PAR4==3) THEN
          KF_ausbl_SZ_ZU=FALSE
          KF_ausbl_SZ_Kraft=FALSE
          KF_ausbl_SZ_AUF=TRUE
        ELSE
          IF (PAR4==3) AND (KF1_PAR4<>3) THEN
            PGR_Msg (19,#QuitMsg)
          ENDIF
        ENDIF
        IF (PAR5==1) THEN
          KF_mit_VE[2]=TRUE
        ELSE
          KF_mit_VE[2]=FALSE
        ENDIF
        IF (PAR9==0) OR (PAR2==1) THEN
          CF_KW_BASE_SL[2]=Default_KW_BASE_SL[2]
        ELSE
          CF_KW_BASE_SL[2]=PAR9
        ENDIF
      CASE 2403 ;KF3
        IF (PAR2==1) THEN
          MIT_KW[3]=FALSE
        ENDIF
        IF (PAR2==2) OR (PAR2==3) OR (PAR2==4) OR (PAR2==5) THEN
          MIT_KW[3]=TRUE
        ENDIF
        IF (PAR3==1) THEN
          KF_NF_2Huebe[3]=FALSE
          KF_NF_2Kraft[3]=FALSE
        ENDIF
        IF (PAR3==2) THEN
          KF_NF_2Huebe[3]=TRUE
          KF_NF_2Kraft[3]=FALSE
        ENDIF
        IF (PAR3==3) THEN
          KF_NF_2Huebe[3]=TRUE
          KF_NF_2Kraft[3]=TRUE
        ENDIF
        IF (PAR4==1) AND (KF1_PAR4==1) THEN
          KF_ausbl_SZ_ZU=TRUE
          KF_ausbl_SZ_Kraft=FALSE
          KF_ausbl_SZ_AUF=FALSE
        ELSE
          IF (PAR4==1) AND (KF1_PAR4<>1) THEN
            PGR_Msg (19,#QuitMsg)
          ENDIF
        ENDIF
        IF (PAR4==2) AND (KF1_PAR4==2) THEN
          KF_ausbl_SZ_ZU=FALSE
          KF_ausbl_SZ_Kraft=TRUE
          KF_ausbl_SZ_AUF=FALSE
        ELSE
          IF (PAR4==2) AND (KF1_PAR4<>2) THEN
            PGR_Msg (19,#QuitMsg)
          ENDIF
        ENDIF
        IF (PAR4==3) AND (KF1_PAR4==3) THEN
          KF_ausbl_SZ_ZU=FALSE
          KF_ausbl_SZ_Kraft=FALSE
          KF_ausbl_SZ_AUF=TRUE
        ELSE
          IF (PAR4==3) AND (KF1_PAR4<>3) THEN
            PGR_Msg (19,#QuitMsg)
          ENDIF
        ENDIF
        IF (PAR5==1) THEN
          KF_mit_VE[3]=TRUE
        ELSE
          KF_mit_VE[3]=FALSE
        ENDIF
        IF (PAR9==0) OR (PAR2==1) THEN
          CF_KW_BASE_SL[3]=Default_KW_BASE_SL[3]
        ELSE
          CF_KW_BASE_SL[3]=PAR9
        ENDIF
      CASE 2501 ;STP
        MIT_STP=TRUE
        MIT_SK[1]=TRUE
        $FLAG[F_Mit_STP]=TRUE
        IF (PAR9==0) THEN
          CF_STP_BASE_SL[1]=Default_STP_BASE_SL[1]
          CF_SK_BASE_SL[1]=Default_SK_BASE_SL[1]
        ELSE
          CF_STP_BASE_SL[1]=PAR9
          CF_SK_BASE_SL[1]=PAR9+16
        ENDIF
      CASE 2601 ;NZ1
        IF (PAR9==0) THEN
          IF (PAR2==1) THEN
            CF_NZS_BASE_SL[1]=Default_NZS_BASE_SL[1]
          ELSE
            CF_NZH_BASE_SL[1]=Default_NZH_BASE_SL[1]
          ENDIF
        ELSE
          IF (PAR2==1) THEN
            CF_NZS_BASE_SL[1]=PAR9
          ELSE
            CF_NZH_BASE_SL[1]=PAR9
          ENDIF
        ENDIF
        IF (PAR2==1) THEN
          MIT_NZS[1]=TRUE
          MIT_NZH[1]=FALSE
        ENDIF
        IF (PAR2==2) THEN
          MIT_NZS[1]=FALSE
          MIT_NZH[1]=TRUE
        ENDIF
        IF (PAR3==1) THEN
          NZ_mit_Ausgleich[1]=TRUE
        ENDIF
        IF (PAR4==1) THEN
          NZ_V2[1]=TRUE
        ENDIF
      CASE 2602 ;NZ2
        IF (PAR9==0) THEN
          IF (PAR2==1) THEN
            CF_NZS_BASE_SL[2]=Default_NZS_BASE_SL[2]
          ELSE
            CF_NZH_BASE_SL[2]=Default_NZH_BASE_SL[2]
          ENDIF
        ELSE
          IF (PAR2==1) THEN
            CF_NZS_BASE_SL[2]=PAR9
          ELSE
            CF_NZH_BASE_SL[2]=PAR9
          ENDIF
        ENDIF
        IF (PAR2==1) THEN
          MIT_NZS[2]=TRUE
          MIT_NZH[2]=FALSE
        ENDIF
        IF (PAR2==1) THEN
          MIT_NZS[2]=FALSE
          MIT_NZH[2]=TRUE
        ENDIF
        IF (PAR3==1) THEN
          NZ_mit_Ausgleich[2]=TRUE
        ENDIF
        IF (PAR4==1) THEN
          NZ_V2[2]=TRUE
        ENDIF
      CASE 2701 ;CZ1
        IF (PAR9==0) THEN
          IF (PAR2==1) THEN
            CF_CZS_BASE_SL[1]=Default_CZS_BASE_SL[1]
          ENDIF
          IF (PAR2==2) THEN
            CF_CZP_BASE_SL[1]=Default_CZP_BASE_SL[1]
          ENDIF
          IF (PAR2==3) THEN
            CF_CZF_BASE_SL[1]=Default_CZF_BASE_SL[1]
          ENDIF
        ELSE
          IF (PAR2==1) THEN
            CF_CZS_BASE_SL[1]=PAR9
          ENDIF
          IF (PAR2==2) THEN
            CF_CZP_BASE_SL[1]=PAR9
          ENDIF
          IF (PAR2==3) THEN
            CF_CZF_BASE_SL[1]=PAR9
          ENDIF
        ENDIF
        IF (PAR2==1) THEN
          MIT_CZS[1]=TRUE
          MIT_CZP[1]=FALSE
        ENDIF
        IF (PAR2==2) THEN
          MIT_CZS[1]=FALSE
          MIT_CZP[1]=TRUE
        ENDIF
        IF (PAR2==3) THEN
          MIT_CZF[1]=TRUE
        ENDIF
      CASE 2702 ;CZ2
        IF (PAR9==0) THEN
          IF (PAR2==1) THEN
            CF_CZS_BASE_SL[2]=Default_CZS_BASE_SL[2]
          ENDIF
          IF (PAR2==2) THEN
            CF_CZP_BASE_SL[2]=Default_CZP_BASE_SL[2]
          ENDIF
        ELSE
          IF (PAR2==1) THEN
            CF_CZS_BASE_SL[2]=PAR9
          ENDIF
          IF (PAR2==2) THEN
            CF_CZP_BASE_SL[2]=PAR9
          ENDIF
        ENDIF
        IF (PAR2==1) THEN
          MIT_CZS[2]=TRUE
          MIT_CZP[2]=FALSE
        ENDIF
        IF (PAR2==2) THEN
          MIT_CZS[2]=FALSE
          MIT_CZP[2]=TRUE
        ENDIF
        IF (PAR2==3) THEN
          MIT_CZF[2]=FALSE  ;nicht vorgesehen
