        ENDIF
        IF (PAR2==5) THEN
          B_MIT_INOS=TRUE
        ENDIF
        IF (PAR2==6) THEN
          B_MIT_ZAI=TRUE
        ENDIF
        IF (PAR2==7) THEN
          MIT_EKI=TRUE
        ENDIF
        IF (PAR3==1) THEN
          B_One_Port[1]=TRUE
          B_New_XML[1]=FALSE
          B_Two_Port[1]=FALSE
          B_EKI_ASCII[1]=FALSE
          B_EKI_INITSY[1]=TRUE
        ENDIF
        IF (PAR3==2) THEN
          B_Two_Port[1]=TRUE
          B_One_Port[1]=FALSE
          B_New_XML[1]=FALSE
          B_EKI_ASCII[1]=FALSE
          B_EKI_INITSY[1]=TRUE
        ENDIF
