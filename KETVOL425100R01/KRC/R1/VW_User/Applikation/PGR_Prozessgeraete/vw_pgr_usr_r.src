		    B_KW_VE_BI=TRUE
		    B_MIT_KW_VW=TRUE
		    B_DFW2anRIP1=FALSE
		  ENDIF
          IF (PAR3==3) THEN
		    B_KW_VE_BI=TRUE
		    B_MIT_KW_VW=TRUE
		    B_DFW2anRIP1=TRUE
		  ENDIF
	       IF (PAR4==1) THEN
          B_OHNE_ND[1]=TRUE
		  ENDIF
		  IF (PAR4==2) THEN
          B_OHNE_ND[1]=FALSE
		  ENDIF
		CASE 4702 ;RIP2
		  IF (PAR1==4702) THEN
		    B_MIT_RIP[2]=TRUE
		  ENDIF
		  IF (PAR2==1) THEN
          B_KW_MIN_MAX=FALSE
          B_KW_ALU=FALSE   
          ENDIF 			
        IF (PAR2==2) THEN
          B_KW_MIN_MAX=TRUE
          B_KW_ALU=FALSE          
          ENDIF 			
        IF (PAR2==4) THEN
          B_KW_MIN_MAX=FALSE
          B_KW_ALU=TRUE      
        ENDIF		
		  IF (PAR3==1) THEN
		    B_KW_VE_MONO=TRUE
          ENDIF 		  
		  IF (PAR3==2) THEN
		    B_KW_VE_BI=TRUE
		    B_MIT_KW_VW=TRUE
		  ENDIF
		  IF (PAR4==1) THEN
