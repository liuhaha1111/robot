		  ENDIF
      CASE 4801 ;Roboter
        IF (PAR2==2) THEN
          B_Rob_Pal=TRUE
		  ELSE
          B_Rob_Pal=FALSE
        ENDIF
        IF (PAR3==2) THEN
          MIT_erw_B_Ve=TRUE
		ELSE
          MIT_erw_B_Ve=FALSE
        ENDIF
        IF (PAR9==1) THEN
          B_MIT_DZ=TRUE
        ENDIF
      CASE 4901 ;RZ1
        MIT_RZ=TRUE
        $FLAG[F_m_RZ1]=TRUE
        IF PAR2==1 THEN
	       $FLAG[F_m_RZKOPF]=TRUE
        ENDIF
        IF PAR2==2 THEN
	       $FLAG[F_m_RZKOPF]=FALSE
          IF PAR5==0 THEN
            PGR_Msg (91,#QuitMsg)
          ELSE
            PROCPAR[111]=PAR5
          ENDIF
        ENDIF
      CASE 4902 ;RZ2
        MIT_RZ=TRUE
        $FLAG[F_m_RZ2]=TRUE
        IF PAR2==2 THEN
	       $FLAG[F_m_RZKOPF]=FALSE
          IF PAR5==0 THEN
            PGR_Msg (91,#QuitMsg)
          ELSE
            PROCPAR[112]=PAR5
          ENDIF
        ENDIF
      CASE 4903 ;RZ3
        MIT_RZ=TRUE
        $FLAG[F_m_RZ3]=TRUE
        IF PAR2==2 THEN
	       $FLAG[F_m_RZKOPF]=FALSE
          IF PAR5==0 THEN
            PGR_Msg (91,#QuitMsg)
          ELSE
            PROCPAR[113]=PAR5
          ENDIF
        ENDIF
      CASE 5101 ;Roboter
        B_MIT_CONV=TRUE
      ENDSWITCH
    ;
    ;ENDFOLD (Makro)
;
;***************************************************
  DEFAULT
;
  ENDSWITCH
END
