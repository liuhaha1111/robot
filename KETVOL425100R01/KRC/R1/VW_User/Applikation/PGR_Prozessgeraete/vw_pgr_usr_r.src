&ACCESS R
&COMMENT KS26
&REL 200
&PARAM DISKPATH = VW_User/Applikation/PGR_Prozessgeraete
&PARAM TPUSER_VERSION = 8.3.0
DEF VW_PGR_USR_R( )
;
;***************************************************
;*Technologiepaket PGR Prozessgeraete              *
;*                                                 *
;*Konzernstandard                                  *
;*Bearbeiter: C. Eisenknappl AUDI AG I/PG-C61      *
;*                                                 *
;* Aenderungsjournal:                              *
;* 16.08.2017 FM Sonstige angepasst                *
;* 26.04.2018 Konfiguration RIP neu hinzu          *
;* 30.07.2018 Proz_Nr Greifer angepasst            *
;* 10.01.2019 KG-XML integriert                    *
;*                                                 *
;***************************************************
;
END
;
;FOLD PGR Interface
GLOBAL DEF PGR_Interface(USER_CMD:IN,CMD_SEL:IN,PAR1:IN,PAR2:IN,PAR3:IN,PAR4:IN,PAR5:IN,PAR6:IN,PAR7:IN,PAR8:IN,PAR9:IN)
DECL VW_USER_CMD USER_CMD
INT CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9
INT i,BitOffset,Byte,IdentNr,Proz_Nr,Wkzg_Nr,Steu_Nr,FM_Nr
;
;***************************************************
SWITCH USER_CMD
;
;***************************************************
  CASE #USR_INIT
    ;FOLD Init
    ;
    Proz_Nr=0
    Wkzg_Nr=0
    Steu_Nr=0
    FM_Nr=0
    ;
    ;Fertigmeldung an BMS zuruecksetzen
    SO_PGR_FM_Nr=FM_Nr
    ;Prozessgeraete-Nr an BMS zuruecksetzen
    SO_PGR_Geraete_Nr=Proz_Nr
    ;
    ;ENDFOLD (Init)
;
;***************************************************
  CASE #USR_ADV
    ;FOLD Advance
    ;
    ;
    ;ENDFOLD (Advance)
;
;***************************************************
  CASE #USR_TRIG
    ;FOLD Trig
    ;
    Proz_Nr=0
    Wkzg_Nr=0
    Steu_Nr=0
    FM_Nr=0
    ;
    BitOffset=1
    Byte=8
    IdentNr=10
    ;
   SWITCH PAR1
      CASE 0  ;Ohne Prozessgeraet
        ;Gesamtfertigmeldung an BMS
        IF (PAR4==15) THEN
          FM_Nr=PAR4
          FOR i=1 TO 30
            IF (Hilf1_FM[i]<>Hilf2_FM[i]) THEN
              Sperre_FM15=TRUE
            ENDIF
          ENDFOR        
          IF (Sperre_FM15==FALSE) THEN
            Fertigmeldung(FM_Nr)
          ELSE
            PGR_Msg(11,#QuitMsg)
          ENDIF
        ENDIF
      CASE 1  ;Prozessgeraet Greifer
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-10)
        IF ( Wkzg_Nr<1) OR ( Wkzg_Nr>8) THEN
          PGR_Msg(1,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            Hilf2_FM[PAR1]=TRUE
            Fertigmeldung(FM_Nr)
          ENDIF
        ENDIF          
      CASE 2  ;Prozessgeraet Dockingsystem
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-50)
        IF (Wkzg_Nr<>1) THEN
          PGR_Msg(6,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((DS_BASE_SL-BitOffset)/Byte)-15)*IdentNr)+ Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            Hilf2_FM[PAR1]=TRUE
            Fertigmeldung(FM_Nr)
          ENDIF
        ENDIF
      CASE 3  ;Prozessgeraet Zangensteuerung(EZ/SP/KE)
        Steu_Nr=PAR2
        Wkzg_Nr=PAR3
        IF  (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(2,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((SZ_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+ Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[SZ_BASE_SL[Steu_Nr]+I_SZ_o_Kra] AND NOT $IN[SK_BASE_SL[Steu_Nr]+I_SK_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 4  ;Prozessgeraet Kleben(KL)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-20)
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(3,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((KL_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[KL_BASE_SL[Steu_Nr]+I_KL_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 5  ;Prozessgeraet Clinchen-Servo(CZS)
        Steu_Nr=PAR2
        Wkzg_Nr=PAR3
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(2,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((CZS_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[CZS_BASE_SL[Steu_Nr]+I_CZS_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 6  ;Prozessgeraet Clinchen-Pneumo(CZP)
        Steu_Nr=PAR2
        Wkzg_Nr=PAR3
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(2,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((CZP_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[CZP_BASE_SL[Steu_Nr]+I_CZP_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 7  ;Prozessgeraet Clinchen-Flat(CZF)
        Steu_Nr=PAR2
        Wkzg_Nr=PAR3
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(2,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((CZF_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[CZF_BASE_SL[Steu_Nr]+I_CZF_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 8  ;Prozessgeraet Nieten-Servo(NZS)
        Steu_Nr=PAR2
        Wkzg_Nr=PAR3
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(2,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((NZS_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[NZS_BASE_SL[Steu_Nr]+I_NZS_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 9  ;Prozessgeraet Nieten-Hydr(NZS)
        Steu_Nr=PAR2
        Wkzg_Nr=PAR3
        IF  (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(2,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((NZH_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[NZH_BASE_SL[Steu_Nr]+I_NZH_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 10  ;Prozessgeraet Reibelementschweissen(RW)
        Steu_Nr=PAR2
        Wkzg_Nr=PAR3
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(2,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((RW_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[RW_BASE_SL[Steu_Nr]+I_RW_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 11  ;Prozessgeraet Bolzenschweissen(BZ)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-50)
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>5) THEN
          PGR_Msg(6,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((BZ_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[BZ_BASE_SL[Steu_Nr]+I_BZ_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ENDIF
          ENDIF
        ENDIF
      CASE 12  ;Prozessgeraet Stanzen(SM)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-40)
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(5,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((SM_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[SM_BASE_SL[Steu_Nr]+I_SM_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 13  ;Prozessgeraet Buckeln(BM)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-40)
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(5,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((BM_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[BM_BASE_SL[Steu_Nr]+I_BM_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 14  ;Prozessgeraet MIG/MAG(MS)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-60)
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(7,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((MS_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[MS_BASE_SL[Steu_Nr]+I_MS_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 15  ;Prozessgeraet FlowDrill(FD)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-30)
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>4) THEN
          PGR_Msg(4,#QuitMsg)
        ENDIF
         ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((FD_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[FD_BASE_SL[Steu_Nr]+I_FD_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 16  ;Prozessgeraet Schrauben(SR)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-30)
        IF (Wkzg_Nr<1) OR (Wkzg_Nr>5) THEN
          PGR_Msg(4,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((SR_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[SR_BASE_SL[Steu_Nr]+I_SR_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 17  ;Prozessgeraet Laserreinigung(LR)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-50)
        IF (Wkzg_Nr<>1) THEN
          PGR_Msg(6,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((LR_BASE_SL-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[LR_BASE_SL+I_LR_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 18  ;Prozessgeraet Wischkopf(RE)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-50)
        IF (Wkzg_Nr<>1) THEN
          PGR_Msg(6,#QuitMsg)
        ENDIF
        ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((RE_BASE_SL-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
          SO_PGR_Geraete_Nr=Proz_Nr
        ENDIF
        ;Fertigmeldung an BMS
        IF (PAR4>=1) AND (PAR4<=14) THEN
          FM_Nr=PAR4
          Hilf1_FM[PAR1]=TRUE
          IF (FM_Nr>=1) AND (FM_Nr<=14) THEN
            IF NOT $IN[RE_BASE_SL+I_RE_o_Proz] THEN
              Hilf2_FM[PAR1]=TRUE
              Fertigmeldung(FM_Nr)
            ELSE
              PGR_Msg(9,#NotifyMsg)
            ENDIF
          ENDIF
        ENDIF
      CASE 19  ;Prozessgeraet Objekterkennung(OE)
        Steu_Nr=PAR2
        Wkzg_Nr=(PAR3-50)
        IF (Wkzg_Nr<>1) THEN
          PGR_Msg(4,#QuitMsg)
        ENDIF
         ;Prozessgeraete-Nr an BMS
        IF (PAR4==20) OR (PAR4==21) THEN
          Proz_Nr=((((OE_BASE_SL[Steu_Nr]-BitOffset)/Byte)-15)*IdentNr)+Wkzg_Nr
