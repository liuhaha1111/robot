          B_KW_MIN_MAX=TRUE
          B_KW_ALU=FALSE 
          ENDIF 			
        IF (PAR2==4) THEN
          B_KW_MIN_MAX=FALSE
          B_KW_ALU=TRUE      
        ENDIF		
	     IF (PAR3==1) THEN
		    B_KW_VE_MONO=TRUE
          ENDIF 		  
