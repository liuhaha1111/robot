          B_EKI_RELABS[1]=FALSE
          B_EKI_KASTAT[1]=FALSE
        ENDIF
        IF (PAR4==2) THEN
          B_EKI_RELABS[1]=FALSE
          B_EKI_KASTAT[1]=TRUE
        ENDIF
        IF (PAR4==3) THEN
          B_EKI_RELABS[1]=TRUE
          B_EKI_KASTAT[1]=FALSE
        ENDIF
        IF (PAR4==4) THEN
          B_EKI_RELABS[1]=TRUE
          B_EKI_KASTAT[1]=TRUE
        ENDIF
      CASE 4302 ;LM2
