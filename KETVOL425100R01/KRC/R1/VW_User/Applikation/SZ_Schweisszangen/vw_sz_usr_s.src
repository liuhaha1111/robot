;ENDFOLD  
;
;***************************************************
;FOLD Zangenfunktion
DEF CheckZangenfunktion(SZNr :IN)
INT SZNr
;
IF ($Pro_state1==#P_Free) THEN
  IF $OUT[O_SZ_D_Teach] OR $OUT[O_SZ_D_Auf] OR $OUT[O_SZ_D_Zu] THEN
    $OUT[O_SZ_D_Teach]=FALSE
    $OUT[O_SZ_D_Auf]=FALSE
    $OUT[O_SZ_D_Zu]=FALSE
    SZ_Msg(21,#NotifyMsg)
  ENDIF
  RETURN
ENDIF
IF ($Pro_state1==#P_Reset) THEN
  IF $OUT[O_SZ_D_Teach] OR $OUT[O_SZ_D_Auf] OR $OUT[O_SZ_D_Zu] THEN
    $OUT[O_SZ_D_Teach]=FALSE
    $OUT[O_SZ_D_Auf]=FALSE
    $OUT[O_SZ_D_Zu]=FALSE
    SZ_Msg(22,#NotifyMsg)
  ENDIF
  RETURN
ENDIF
IF NOT($ON_Path) THEN
  IF $OUT[O_SZ_D_Teach] OR $OUT[O_SZ_D_Auf] OR $OUT[O_SZ_D_Zu] THEN
    $OUT[O_SZ_D_Teach]=FALSE
    $OUT[O_SZ_D_Auf]=FALSE
    $OUT[O_SZ_D_Zu]=FALSE
    SZ_Msg(24,#NotifyMsg)
  ENDIF
ENDIF
IF $OUT[O_SZ_D_Teach] AND ($Pro_mode1<>#MSTEP) THEN
  ;Teachfunktion nicht wenn kein SStep
  $OUT[O_SZ_D_Teach]=FALSE
  SZ_Msg(23,#NotifyMsg)
  RETURN
ENDIF
IF R1AusgleichFunktion==0 THEN
  IF $OUT[O_SZ_D_Teach] THEN
    ;teachen SZ1 EIN
    R1AusgleichFunktion=1
    $OUT[O_SZ_D_Teach]=FALSE
    SZ_Msg(31,#NotifyMsg)
  ENDIF
  IF $OUT[O_SZ_D_Auf] THEN
    ;Oeffen SZ1
    R1AusgleichFunktion=2
    $OUT[O_SZ_D_Auf]=FALSE
    SZ_Msg(32,#NotifyMsg)
  ENDIF
  IF $OUT[O_SZ_D_Zu] THEN
    ;schliessen SZ1 EIN
    R1AusgleichFunktion=3
    $OUT[O_SZ_D_Zu]=FALSE
    SZ_Msg(33,#NotifyMsg)
  ENDIF
ELSE
  IF $OUT[O_SZ_D_Teach] OR $OUT[O_SZ_D_Auf] OR $OUT[O_SZ_D_Zu] THEN
    SZ_Msg(35,#NotifyMsg); Zangenfunktion bereits aktiv
    $OUT[O_SZ_D_Teach]=FALSE
    $OUT[O_SZ_D_Auf]=FALSE
    $OUT[O_SZ_D_Zu]=FALSE
  ENDIF
ENDIF     
;
END
;
;***************************************************
DEF Zangenfunktion(SZNr :IN)
INT SZNr
;
;SZ Oeffnen in Hand
IF $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf] THEN	
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=TRUE
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu]=FALSE
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu_o_S]=FALSE
  B_SZ_AUF_ZU[SZNr]=TRUE
  IF $IN[SZ_BASE_MA[SZNr]+I_SZ_auf] THEN
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
  ENDIF
ENDIF
;SZ Schliessen in Hand
IF Mit_KE[SZNr] THEN
  IF $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu_o_S] THEN	
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=TRUE
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
    B_SZ_AUF_ZU[SZNr]=TRUE
    IF $IN[SZ_BASE_MA[SZNr]+I_SZ_zu] THEN
      $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu_o_S]=FALSE
    ENDIF
  ENDIF
ELSE
  IF $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu] THEN	
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=TRUE
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
    B_SZ_AUF_ZU[SZNr]=TRUE
    IF $IN[SZ_BASE_MA[SZNr]+I_SZ_zu] THEN
      $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu]=FALSE
    ENDIF
  ENDIF 
ENDIF
;SZ Fahrt auf Teachposition ausloesen
IF $OUT[SZ_BASE_MA[SZNr]+O_SZ_S_TPos] THEN
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_TPos_u]=FALSE
  TeachPos[SZNr]=FALSE
  WAIT SEC 0.4
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=TRUE
  IF $IN[SZ_BASE_MA[SZNr]+I_SZ_TPos_g] THEN
    TeachPos[SZNr]=TRUE
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_S_TPos]=FALSE
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_TPos_u]=TRUE
    WAIT FOR NOT($IN[SZ_BASE_MA[SZNr]+I_SZ_TPos_g])
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_TPos_u]=FALSE
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=FALSE
    WAIT SEC 0.24
    schleppfehler=TRUE
    sf_prog_status=#user_act
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_SPos_g]=FALSE
  ENDIF
ENDIF
;SZ Referenzieren
IF $OUT[SZ_BASE_MA[SZNr]+O_SZ_ref] THEN	
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=TRUE
  B_SZ_TEACH_REF[SZNr]=TRUE
  IF NOT $IN[SZ_BASE_MA[SZNr]+I_SZ_ref] THEN
    B_SZ_n_Ref[SZNr]=TRUE
  ENDIF	
  IF $IN[SZ_BASE_MA[SZNr]+I_SZ_ref] AND $IN[SZ_BASE_MA[SZNr]+I_SZ_IPos_g] AND B_SZ_n_Ref[SZNr] THEN
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_ref]=FALSE
    $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=FALSE
    B_SZ_TEACH_REF[SZNr]=FALSE
    B_SZ_n_Ref[SZNr]=FALSE
    SZ_Msg(1,#NotifyMsg)
  ENDIF
ENDIF
;SZ Tastend Auf
IF $OUT[SZ_BASE_MA[SZNr]+O_SZ_t_auf] THEN	
  B_SZ_Tastend[SZNr]=TRUE
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=TRUE
ENDIF
;SZ Tastend Zu
IF $OUT[SZ_BASE_MA[SZNr]+O_SZ_t_zu] THEN	
  B_SZ_Tastend[SZNr]=TRUE
  $OUT[SZ_BASE_MA[SZNr]+O_SZ_FRG]=TRUE
ENDIF
; 
END
;ENDFOLD (Zangenfunktion)
;
;***************************************************
;FOLD Lebensbit SZ
DEF L_Bit_SZ(SZNr :IN)
INT SZNr
BOOL LBitSZ, LBitFault
INT RobTimer
BOOL ErrLBit,bRet
;
ErrLBit=FALSE
LBitFault=FALSE
;
;Setzen - Rucksetzen des Lebensbit an Zangensteuerung
$OUT[SZ_BASE_MA[SZNr]+O_SZ_LBit] = NOT $IN[SZ_BASE_MA[SZNr]+I_SZ_LBit]
RobTimer = $ROB_TIMER	
IF $IN[SZ_BASE_MA[SZNr]+I_SZ_LBit]<>LBitState[SZNr] THEN
  LBitTimeCnt[SZNr] = RobTimer
ENDIF
IF ((RobTimer-LBitTimeCnt[SZNr])>5000) THEN
  ErrLBit=TRUE
  ErrSZNr=SZNr
  SZ_LBitFeh[SZNr]=TRUE
ENDIF
LBitState[SZNr]=$IN[SZ_BASE_MA[SZNr]+I_SZ_LBit]
IF ErrLBit THEN
  SZ_Msg(4,#StateMsg,ErrSZNr)
ELSE
  IF (n_SZS_Handle[4]>-1) THEN
    bRet=Clear_KrlMsg(n_SZS_Handle[4])
    n_SZS_Handle[4]=-1
    ErrSZNr=-1
  ENDIF
  SZ_LBitFeh[SZNr]=FALSE
ENDIF
;
END
;ENDFOLD
;
;***************************************************
;FOLD SZ_Meldungen
DEF SZ_Msg(msg_nr :IN, MsgTyp :IN, SZNr :IN )
INT msg_nr, SZNr, Answer
DECL SZS_MsgType MsgTyp
DECL KrlMsg_T USER_MSG
DECL KrlMsgPar_T Par[3]
DECL KrlMsgOpt_T Opt
;
USER_MSG = { Modul[] "SZ_S_Msg", Nr -1, Msg_txt[] " "}
Opt = { VL_Stop FALSE, Clear_P_Reset TRUE, Log_To_DB TRUE }
Par[1] = { Par_type #Value, Par_txt[] " " }
;
IF Varstate("SZNr")==#initialized THEN
  SWITCH SZNr
    CASE 1
      Par[1] = { Par_type #Value, Par_int 1 }
    CASE 2
      Par[1] = { Par_type #Value, Par_int 2 }
    CASE 3
      Par[1] = { Par_type #Value, Par_int 3 }
    CASE 4
      Par[1] = { Par_type #Value, Par_int 4 }
    CASE 5
      Par[1] = { Par_type #Value, Par_int 5 }
    CASE 6
      Par[1] = { Par_type #Value, Par_int 6 }
    DEFAULT
      Par[1] = { Par_type #Value, Par_txt[] " " }
  ENDSWITCH
ELSE
  Par[1] = { Par_type #Value, Par_txt[] " " }
ENDIF
;
IF ((n_SZS_Handle[msg_nr]<0) OR (MsgTyp==#NotifyMsg) OR (MsgTyp==#QuitMsg)) THEN
  USER_MSG.Nr = msg_nr
  SWITCH msg_nr
    CASE 1
	   USER_MSG.MSG_TXT[]="EZ/SP/KE1: Zange ist referenziert"
    CASE 2
	   USER_MSG.MSG_TXT[]="EZ/SP/KE2: Zange ist referenziert"
    CASE 3
	   USER_MSG.MSG_TXT[]="EZ/SP/KE3: Zange ist referenziert"
    CASE 4
	   USER_MSG.MSG_TXT[]="EZ/SP/KE%1: Keine Antwort auf Lebensbit"
    CASE 5
	   USER_MSG.MSG_TXT[]=" "
    CASE 6
	   USER_MSG.MSG_TXT[]="EZ/SP/KE1: Slave Startadresse ungueltig"
    CASE 7
	   USER_MSG.MSG_TXT[]="EZ/SP/KE2: Slave Startadresse ungueltig"
    CASE 8
	   USER_MSG.MSG_TXT[]="EZ/SP/KE3: Slave Startadresse ungueltig"
    CASE 9
	   USER_MSG.MSG_TXT[]=" "
    CASE 10
	   USER_MSG.MSG_TXT[]=" "
    CASE 11
	   USER_MSG.MSG_TXT[]=" "
    CASE 20
      USER_MSG.MSG_TXT[]="Ausgleich fuer Zangenfunktion abgebrochen, neu anwaehlen"
    CASE 21
      USER_MSG.MSG_TXT[]="Programmanwahl fuer Zangenfunktion erforderlich"  
    CASE 22
      USER_MSG.MSG_TXT[]="Init mit Start+ fuer Zangenfunktion erforderlich"  
    CASE 23
      USER_MSG.MSG_TXT[]="Teachfunktion nicht erlaubt, wenn kein SingleStep"  
    CASE 24
      USER_MSG.MSG_TXT[]="SAK fahrt durchfuehren vor Zangenfunktion"  
    CASE 31	
      USER_MSG.MSG_TXT[]="EZ/SP/KE1: Zange teachen, Start+ erforderlich"
    CASE 32
      USER_MSG.MSG_TXT[]="EZ/SP/KE1: Zange oeffnen, Start+ erforderlich"
    CASE 33
      USER_MSG.MSG_TXT[]="EZ/SP/KE1: Zange schliessen, Start+ erforderlich"
    CASE 34
      USER_MSG.MSG_TXT[]="EZ/SP/KE1: Zangenfunktion nicht zulaessig"
    CASE 35
      USER_MSG.MSG_TXT[]="EZ/SP/KE1: Zangenfunktion bereits aktiv, SAW fuer Abbruch"
    CASE 41
      USER_MSG.MSG_TXT[]="EZ/SP/KE2: Zange teachen, Start+ erforderlich"  
    CASE 42
      USER_MSG.MSG_TXT[]="EZ/SP/KE2: Zange oeffnen, Start+ erforderlich"  
    CASE 43
      USER_MSG.MSG_TXT[]="EZ/SP/KE2: Zange schliessen, Start+ erforderlich"  
    CASE 44
      USER_MSG.MSG_TXT[]="EZ/SP/KE2: Zangenfunktion nicht zulaessig"  
    CASE 45
      USER_MSG.MSG_TXT[]="EZ/SP/KE2: Zangenfunktion bereits aktiv, SAW fuer Abbruch"  
    CASE 51
      USER_MSG.MSG_TXT[]="EZ/SP/KE3: Zange teachen, Start+ erforderlich" 
    CASE 52
      USER_MSG.MSG_TXT[]="EZ/SP/KE3: Zange oeffnen, Start+ erforderlich"  
    CASE 53
      USER_MSG.MSG_TXT[]="EZ/SP/KE3: Zange schliessen, Start+ erforderlich" 
    CASE 54
      USER_MSG.MSG_TXT[]="EZ/SP/KE3: Zangenfunktion nicht zulaessig"    
    CASE 55
      USER_MSG.MSG_TXT[]="EZ/SP/KE3: Zangenfunktion bereits aktiv, SAW fuer Abbruch"
    CASE 56
      USER_MSG.MSG_TXT[]="EZ/SP/KE%1: Oeffnungsmass zu klein"
    DEFAULT
	   USER_MSG.MSG_TXT[]="unbekannte Meldung"
  ENDSWITCH
  SWITCH MsgTyp
    CASE #StateMsg
      n_SZS_Handle[msg_nr] = Set_KrlMsg (#State, USER_MSG, Par[], Opt) ;Ausgabe Statusmeldung
    CASE #QuitMsg
      n_SZS_Handle[msg_nr] = Set_KrlMsg (#Quit, USER_MSG, Par[], Opt) ;Ausgabe Quittierungsmeldung
    CASE #NotifyMsg
      n_SZS_Handle[msg_nr] = Set_KrlMsg (#Notify, USER_MSG, Par[], Opt) ;Ausgabe Hinweismeldung
    DEFAULT
      n_SZS_Handle[msg_nr] = Set_KrlMsg (#Quit, USER_MSG, Par[], Opt) ;Ausgabe Quittierungsmeldung
  ENDSWITCH
ENDIF
END
;
;ENDFOLD (SZ Meldungen)
