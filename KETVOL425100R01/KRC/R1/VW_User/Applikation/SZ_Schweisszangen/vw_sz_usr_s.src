;***************************************************
;FOLD Kuehlwasser in Single-Step vorhanden
GLOBAL DEF KW_vorhanden()
INT i
;
;RIP 1-3
IF $OUT[O_R_Hand] THEN
  FOR i=1 TO 3
    $FLAG[F_KW_Hand_iO[i]]=$IN[I_R_KW_vorh[i]] OR $FLAG[F_KW_Hand_iO[i]] 
  ENDFOR
