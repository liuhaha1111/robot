&ACCESS  R
&COMMENT KS26
&PARAM DISKPATH = VW_User/Applikation/SZ_Schweisszangen
&PARAM TPUSER_VERSION = 8.3.0
&REL 200
DEF VW_SZ_USR_R( )
;
;***************************************************
;*Technologiepaket SZ Schweisszangen               *
;*                                                 *
;*Konzernstandard                                  *
;*Bearbeiter: C. Eisenknappl AUDI AG I/PG-C61      *
;*                                                 *
;***************************************************
;
END
;
;FOLD SZ_Interface
GLOBAL DEF SZ_Interface(USER_CMD:IN,CMD_SEL:IN,PAR1:IN,PAR2:IN,PAR3:IN,PAR4:IN,PAR5:IN,PAR6:IN,PAR7:IN,PAR8:IN,PAR9:IN)
DECL VW_USER_CMD USER_CMD
INT  CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9
INT P[5], R[5]
INT i, N
INT RobTimerStart
BOOL bRet
;
SWITCH USER_CMD
;
;***************************************************
  CASE #USR_INIT
    ;FOLD Init
    ;
    ; Initialisierung Zangenfunktion
    R1AusgleichFunktion=0
    ; INTERRUPT fuer Zangenfunktionen
    GLOBAL INTERRUPT DECL 3 WHEN R1AusgleichFunktion>0 DO GunFunctionManual()
    INTERRUPT ON 3
    ;Reset Messung
    $SoftPlcInt[301]=0
    ;
    FOR i=1 TO 3
      $FLAG[F_WPS_FRG[i]]=FALSE
      $OUT[SZ_BASE_SL[i]+O_SZ_KF_akt]=FALSE
    ENDFOR
    ;
    ;Merker Init
    ;FOR i=1 TO 3
    ;  IF MIT_EZ[i] OR MIT_KE[i] THEN
    ;    SZ_MERKER_INIT(i)
    ;  ENDIF
    ;ENDFOR
    ;
    IF ((MIT_EZ[1]==TRUE) OR (MIT_KE[1]==TRUE)) AND (EZ1_Dock==FALSE) THEN
      SEL_RES=SELECT(#MAKRO,(EZ1_Konfig_Makro[1]),TRUE,,,,,FALSE)
    ENDIF
    IF ((MIT_EZ[2]==TRUE) OR (MIT_KE[2]==TRUE)) AND (EZ2_Dock==FALSE) THEN
      SEL_RES=SELECT(#MAKRO,(EZ2_Konfig_Makro),TRUE,,,,,FALSE)
    ENDIF
    IF ((MIT_EZ[3]==TRUE) OR (MIT_KE[3]==TRUE)) AND (EZ3_Dock==FALSE) THEN
      SEL_RES=SELECT(#MAKRO,(EZ3_Konfig_Makro),TRUE,,,,,FALSE)
    ENDIF
    ;
    ;ENDFOLD (Init)
;
;***************************************************
  CASE #USR_ADV
    ;FOLD Advance
;
    Offset=PAR3
;
    nActivePathVectormove=nActivePathDefault
    IF (Offset>=10) AND (Offset<=30) THEN
      nActivePathVectormove=(nActivePathVectormove-Offset)
    ENDIF
      SWITCH PAR1
        CASE 10,12 ;EZ1 Schweissen, EZ1 Fraesen
          IF (PAR1==12) THEN
            ;Anforderung Normalfraesen
            CONTINUE
            $FLAG[F_SZ_Anw_NF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[1]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[1]+I_SK_Stfr] AND $IN[SZ_BASE_SL[1]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR ((PAR2>=51) AND (PAR2<=54)) OR $FLAG[F_SZ_Anw_NF[1]]) 
            ;Anforderung Startfraesen
            CONTINUE
            $FLAG[F_SZ_Anw_SF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[1]]) OR ((PAR2>=41) AND (PAR2<=44)) OR $FLAG[F_SZ_Anw_SF[1]])
          ENDIF
          CONTINUE
          IF $IN[SK_BASE_SL[1]+I_SK_o_Proz] THEN
            $FLAG[F_o_Proz_BMS]=TRUE
          ELSE
            $FLAG[F_o_Proz_BMS]=FALSE
          ENDIF
          IF NOT Mit_KE[1] THEN
            CONTINUE
            SO_SZ1_Prg_Nr=PAR2
          ENDIF
          CONTINUE
          SO_SK1_Pkt_Nr=PAR5
          CONTINUE
          SO_SPS_Proz_Nr=PAR5
          IF Mit_KE[1] THEN
            CONTINUE
            IF (SO_SK1_Pkt_Nr>90) THEN   	
              CONTINUE	
              SO_SK1_Fzg_Typ=PAR6
            ELSE  
              CONTINUE
              SO_SK1_Fzg_Typ=0  
            ENDIF 
          ELSE
            CONTINUE
            IF (SO_SZ1_Prg_Nr>90) THEN   	
              CONTINUE	
              SO_SZ1_Fzg_Typ=PAR6
              CONTINUE	
              SO_SK1_Fzg_Typ=PAR6
              CONTINUE
              $OUT[O_RIP_SK_Sens]=FALSE
            ELSE  
              CONTINUE
              SO_SZ1_Fzg_Typ=0 
              CONTINUE
              SO_SK1_Fzg_Typ=0  
              CONTINUE
              $OUT[O_RIP_SK_Sens]=FALSE
            ENDIF
          ENDIF 
          CONTINUE
          $FLAG[F_Frg_Servo]=TRUE
          CONTINUE          
          WHILE USER_AKTIV
            SZ_Msg(1,#QuitMsg) ;mehr als 1 USER-Aufruf aktiv
          ENDWHILE
          USER_AKTIV=TRUE
          IF Mit_KE[1] THEN
            CONTINUE
            MyCorrVal_EK=GetEKVal(EZ1_EK_FBit)
            CONTINUE
            EZ1_EK_Wert=(MyCorrVal_EK*2)
            CONTINUE
            MyCorrVal_GEO=GetGEOVal(EZ1_GEO_FBit)
            CONTINUE
            MyCorrValue=(MyCorrVal_EK+MyCorrVal_GEO)    
          ELSE
            CONTINUE
            MyCorrValue=GetEKVal(EZ1_EK_FBit)
            CONTINUE
            EZ1_EK_Wert=(GetEKVal(EZ1_EK_FBit)*2)
          ENDIF
          CONTINUE
          MyCorrOFF=(Offset*0.1)
          CONTINUE
          WHILE ((MyCorrOFF<-10) OR (MyCorrOFF>10))
            SZ_Msg(3,#QuitMsg) ; MyCorrOFF nicht im zulaessigen Bereich
          ENDWHILE
          CONTINUE
          MyCorr=$NULLFRAME
          CONTINUE
          WHILE ((SO_SZ1_ZCode==0) OR (SO_SZ1_ZCode>4))
            SZ_Msg(2,#QuitMsg) ; Zangencode ungueltig
          ENDWHILE
          IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
            CONTINUE
            IF (SO_SZ1_ZCode==1) THEN
              MyCorr.X=-((MyCorrValue*EZ1_Z1_AHV)+MyCorrOff)
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==2) THEN
              MyCorr.X=-((MyCorrValue*EZ1_Z2_AHV)+MyCorrOff)
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==3) THEN
              MyCorr.X=-((MyCorrValue*EZ1_Z3_AHV)+MyCorrOff)
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==4) THEN
              MyCorr.X=-((MyCorrValue*EZ1_Z4_AHV)+MyCorrOff)
            ENDIF
          ELSE
            CONTINUE
            IF (SO_SZ1_ZCode==1) THEN          
              MyCorr.X=-(MyCorrValue*EZ1_Z1_AHV)
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==2) THEN              
              MyCorr.X=-(MyCorrValue*EZ1_Z2_AHV)
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==3) THEN              
              MyCorr.X=-(MyCorrValue*EZ1_Z3_AHV)
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==4) THEN              
              MyCorr.X=-(MyCorrValue*EZ1_Z4_AHV)
            ENDIF
          ENDIF      
          CONTINUE
          IF (VW_MPARA_ACT.BASE_NO>0) THEN
            CONTINUE
            SWITCH BASE_TYPE[VW_MPARA_ACT.BASE_NO]
              CASE #TCP
                CONTINUE
                $BASE=$BASE:MyCorr
              DEFAULT
                CONTINUE
                $TOOL=$TOOL:MyCorr
            ENDSWITCH
          ELSE
            CONTINUE
            $TOOL=$TOOL:MyCorr
          ENDIF
          IF ($PRO_MODE==#MSTEP) THEN
            CONTINUE
            $ADVANCE=0 ; Anfahren WPS-Punkt mit EK-Verschleiss in SingleStep
          ENDIF
          CONTINUE
          TRIGGER  WHEN DISTANCE=0 DELAY=0.0 DO $Flag[F_FRG_VMove]=FALSE
          CONTINUE
          TRIGGER  WHEN DISTANCE=1 DELAY=0.0 DO $Flag[F_FRG_VMove]=TRUE ;Freigabe VektorMove Schweissmakro
          CONTINUE
          TRIGGER  WHEN DISTANCE=1 DELAY=-100.0 DO T_B_Corr(MyCorr) PRIO=-1
          IF NOT DOCK_SZ THEN
            IF Mit_KE[1] THEN
              CONTINUE
              B_SZ1_VW_EK[1]=(((MyCorrVal_EK*2)>EZ1_Z1_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ1 Vorwarnung Kappenstandzeit
              CONTINUE
              B_SZ1_MAX_EK[1]=(((MyCorrVal_EK*2)>EZ1_Z1_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ1 Maximale Kappenstandzeit        
            ELSE
              CONTINUE
              B_SZ1_VW_EK[1]=(((MyCorrValue*2)>EZ1_Z1_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ1 Vorwarnung Kappenstandzeit
              CONTINUE
              B_SZ1_MAX_EK[1]=(((MyCorrValue*2)>EZ1_Z1_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ1 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF ($softplcint[EZ_PlcInt[1]]==7) THEN
              IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
                CONTINUE
	             act_P1.E1=(act_P1.E1-(MyCorrValue*2))
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	             CONTINUE
                PTP act_P1
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	             CONTINUE
                LIN act_P1
	           ENDIF
            ENDIF
            CONTINUE
            IF ($softplcint[EZ_PlcInt[1]]==8) THEN
              IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
                CONTINUE
	             act_P1.E2=(act_P1.E2-(MyCorrValue*2))
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	             CONTINUE
                PTP act_P1
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	             CONTINUE
                LIN act_P1
	           ENDIF
            ENDIF
            CONTINUE
            IF ($softplcint[EZ_PlcInt[1]]==9) THEN
              IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
                CONTINUE
	             act_P1.E3=(act_P1.E3-(MyCorrValue*2))
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	             CONTINUE
                PTP act_P1
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	             CONTINUE
                LIN act_P1
	           ENDIF
            ENDIF
            CONTINUE
            IF ($softplcint[EZ_PlcInt[1]]==10) THEN
              IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
                CONTINUE
	             act_P1.E4=(act_P1.E4-(MyCorrValue*2))
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	             CONTINUE
                PTP act_P1
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	             CONTINUE
                LIN act_P1
	           ENDIF
            ENDIF
            CONTINUE
            IF ($softplcint[EZ_PlcInt[1]]==11) THEN
              IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
                CONTINUE
	             act_P1.E5=(act_P1.E5-(MyCorrValue*2))
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	             CONTINUE
                PTP act_P1
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	             CONTINUE
                LIN act_P1
	           ENDIF
            ENDIF
            CONTINUE
            IF ($softplcint[EZ_PlcInt[1]]==12) THEN
              IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
                CONTINUE
	             act_P1.E6=(act_P1.E6-(MyCorrValue*2))
              ENDIF
              CONTINUE                
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	             CONTINUE
                PTP act_P1
              ENDIF
              CONTINUE
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	             CONTINUE
                LIN act_P1
	           ENDIF
            ENDIF
          ENDIF
          IF (EZ1_Dock==TRUE) THEN
          IF Mit_KE[1] THEN
            CONTINUE
            IF (SO_SZ1_ZCode==1) THEN
              CONTINUE
              B_SZ1_VW_EK[1]=(((MyCorrVal_EK*2)>EZ1_Z1_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ1 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[1]=(((MyCorrVal_EK*2)>EZ1_Z1_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ1 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==2) THEN
              CONTINUE
              B_SZ1_VW_EK[2]=(((MyCorrVal_EK*2)>EZ1_Z2_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ2 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[2]=(((MyCorrVal_EK*2)>EZ1_Z2_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ2 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==3) THEN
              CONTINUE
              B_SZ1_VW_EK[3]=(((MyCorrVal_EK*2)>EZ1_Z3_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ3 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[3]=(((MyCorrVal_EK*2)>EZ1_Z3_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ 3 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==4) THEN
              CONTINUE
              B_SZ1_VW_EK[4]=(((MyCorrVal_EK*2)>EZ1_Z4_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ4 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[4]=(((MyCorrVal_EK*2)>EZ1_Z4_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ4 Maximale Kappenstandzeit
            ENDIF
          ELSE
            CONTINUE
            IF (SO_SZ1_ZCode==1) THEN
                CONTINUE
              B_SZ1_VW_EK[1]=(((MyCorrValue*2)>EZ1_Z1_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ1 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[1]=(((MyCorrValue*2)>EZ1_Z1_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ1 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==2) THEN
                CONTINUE
              B_SZ1_VW_EK[2]=(((MyCorrValue*2)>EZ1_Z2_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ2 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[2]=(((MyCorrValue*2)>EZ1_Z2_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ2 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==3) THEN
                CONTINUE
              B_SZ1_VW_EK[3]=(((MyCorrValue*2)>EZ1_Z3_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ3 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[3]=(((MyCorrValue*2)>EZ1_Z3_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ3 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==4) THEN
                CONTINUE
              B_SZ1_VW_EK[4]=(((MyCorrValue*2)>EZ1_Z4_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ4 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[4]=(((MyCorrValue*2)>EZ1_Z4_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ4 Maximale Kappenstandzeit
            ENDIF
            ENDIF
            CONTINUE             
            IF ($softplcint[EZ_PlcInt[1]]==7) AND (SO_SZ1_ZCode==1) THEN
		        IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
                CONTINUE
	             act_P1.E1=(act_P1.E1-(MyCorrValue*2))
              ENDIF
              CONTINUE                
	           IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	             CONTINUE
                PTP act_P1
              ENDIF
	           CONTINUE
              IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	             CONTINUE
                LIN act_P1
	           ENDIF
            ENDIF
            CONTINUE
            IF ($softplcint[EZ_PlcInt[1]]==8) AND (SO_SZ1_ZCode==1) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E2=(act_P1.E2-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==9) AND (SO_SZ1_ZCode==1) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E3=(act_P1.E3-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==10) AND (SO_SZ1_ZCode==1) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E4=(act_P1.E4-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==11) AND (SO_SZ1_ZCode==1) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E5=(act_P1.E5-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==12) AND (SO_SZ1_ZCode==1) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E6=(act_P1.E6-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==7) AND (SO_SZ1_ZCode==2) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E1=(act_P1.E1-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==8) AND (SO_SZ1_ZCode==2) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E2=(act_P1.E2-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==9) AND (SO_SZ1_ZCode==2) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E3=(act_P1.E3-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==10) AND (SO_SZ1_ZCode==2) THEN
