            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
	         ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[1]]==10) AND (SO_SZ1_ZCode==3) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E4=(act_P1.E4-(MyCorrValue*2))
            ENDIF  
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
