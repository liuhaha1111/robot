;***************************************************
;FOLD VM_Interface
GLOBAL DEF VM_Interface(USER_CMD:IN,CMD_SEL:IN,PAR1:IN,PAR2:IN,PAR3:IN,PAR4:IN,PAR5:IN,PAR6:IN,PAR7:IN,PAR8:IN,PAR9:IN)
DECL VW_USER_CMD USER_CMD
INT  CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9
INT i
;
SWITCH USER_CMD
;
;***************************************************
  CASE #USR_INIT
    ;FOLD Init
    ;
    ;
    ;ENDFOLD (Init)
;
;***************************************************
  CASE #USR_ADV
    ;FOLD Advance
    ;
    SWITCH PAR1
      CASE 1  ;EZ
        ZangenAntrieb=#EZ
        SWITCH PAR2
          CASE 1  ;C-Zange
            ZangenTyp=#C_Zange
            IF (PAR3==0) THEN  ;Zeit fuer aktive Phase
              PARAMS_PROG.TIME_EXPECTED=(EZ_C_PRG_TimeDefault*0.001)
              PARAMS_MAN.TIME_EXPECTED=(EZ_C_MAN_TimeDefault*0.001)
            ELSE
              IF (PAR3>=250) AND (PAR3<=800) THEN
                PARAMS_PROG.TIME_EXPECTED=(PAR3*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
              ELSE
                PARAMS_PROG.TIME_EXPECTED=(EZ_C_PRG_TimeDefault*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
                IF (PAR3<>0) THEN
                  SZ_Msg(51,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
            IF (PAR4==0) THEN  ;Weg fuer aktive Phase
              PARAMS_PROG.PROZ_EXPECTED=EZ_C_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
              PARAMS_MAN.PROZ_EXPECTED=EZ_C_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
            ELSE
              IF (PAR4>=20) AND (PAR4<=100) THEN
                PARAMS_PROG.PROZ_EXPECTED=(PAR4/10.0)*(100/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(1.0 *100/Direction.Directioncart.X)) ;1mm Biegung
              ELSE
                PARAMS_PROG.PROZ_EXPECTED=EZ_C_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=EZ_C_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
                IF (PAR4<>0) THEN
                  SZ_Msg(52,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
            IF (PAR5==0) THEN ;Armdurchbiegung in 1/10mm
              C_ArmDurchbiegung=C_DefaultArmDurchbiegung
            ELSE
              IF (PAR5>0) AND (PAR5<25) THEN     
                C_ArmDurchbiegung=PAR5
              ELSE
                C_ArmDurchbiegung=C_DefaultArmDurchbiegung
                SZ_Msg(53,#QuitMsg)
              ENDIF
            ENDIF
          CASE 2  ;X-Zange
            ZangenTyp=#X_Zange
            IF (PAR3==0) THEN  ;Zeit fuer aktive Phase
              PARAMS_PROG.TIME_EXPECTED=(EZ_X_PRG_TimeDefault*0.001)
              PARAMS_MAN.TIME_EXPECTED=(EZ_X_MAN_TimeDefault*0.001)
            ELSE
              IF (PAR3>=250) AND (PAR3<=800) THEN
                PARAMS_PROG.TIME_EXPECTED=(PAR3*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
              ELSE
                PARAMS_PROG.TIME_EXPECTED=(EZ_X_PRG_TimeDefault*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
                IF (PAR3<>0) THEN
                  SZ_Msg(51,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
            IF (PAR4==0) THEN  ;Weg fuer aktive Phase
              PARAMS_PROG.PROZ_EXPECTED=EZ_X_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
              PARAMS_MAN.PROZ_EXPECTED=EZ_X_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
            ELSE
              IF (PAR4>=20) AND (PAR4<=100) THEN
                PARAMS_PROG.PROZ_EXPECTED=(PAR4/10.0)*(100/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(1.0 *100/Direction.Directioncart.X)) ;1mm Biegung
              ELSE
                PARAMS_PROG.PROZ_EXPECTED=EZ_X_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=EZ_X_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
                IF (PAR4<>0) THEN
                  SZ_Msg(52,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
            IF (PAR5==0) THEN ;Armdurchbiegung in 1/10mm
              X_ArmDurchbiegung=X_DefaultArmDurchbiegung 
            ELSE
              IF (PAR5>0) AND (PAR5<25) THEN     
                X_ArmDurchbiegung=PAR5
              ELSE
                X_ArmDurchbiegung=X_DefaultArmDurchbiegung
                SZ_Msg(53,#QuitMsg)
              ENDIF
            ENDIF
        ENDSWITCH
      CASE 2  ;SP
        ZangenAntrieb=#SP
        SWITCH PAR2
          CASE 1  ;C-Zange
            ZangenTyp=#C_Zange
            IF (PAR3==0) THEN  ;Zeit fuer aktive Phase
              PARAMS_PROG.TIME_EXPECTED=(SP_C_PRG_TimeDefault*0.001)
              PARAMS_MAN.TIME_EXPECTED=(SP_C_MAN_TimeDefault*0.001)
            ELSE
              IF (PAR3>=250) AND (PAR3<=800) THEN
                PARAMS_PROG.TIME_EXPECTED=(PAR3*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
              ELSE
                PARAMS_PROG.TIME_EXPECTED=(SP_C_PRG_TimeDefault*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
                IF (PAR3<>0) THEN
                  SZ_Msg(51,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
            IF (PAR4==0) THEN  ;Weg fuer aktive Phase
              PARAMS_PROG.PROZ_EXPECTED=SP_C_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
              PARAMS_MAN.PROZ_EXPECTED=SP_C_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
            ELSE
              IF (PAR4>=20) AND (PAR4<=100) THEN
                PARAMS_PROG.PROZ_EXPECTED=(PAR4/10.0)*(100/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(1.0 *100/Direction.Directioncart.X)) ;1mm Biegung
              ELSE
                PARAMS_PROG.PROZ_EXPECTED=SP_C_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=SP_C_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
                IF (PAR4<>0) THEN
                  SZ_Msg(52,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
          CASE 2  ;X-Zange
            ZangenTyp=#X_Zange
            IF (PAR3==0) THEN  ;Zeit fuer aktive Phase
              PARAMS_PROG.TIME_EXPECTED=(SP_X_PRG_TimeDefault*0.001)
              PARAMS_MAN.TIME_EXPECTED=(SP_X_MAN_TimeDefault*0.001)
            ELSE
              IF (PAR3>=250) AND (PAR3<=800) THEN
                PARAMS_PROG.TIME_EXPECTED=(PAR3*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
              ELSE
                PARAMS_PROG.TIME_EXPECTED=(SP_X_PRG_TimeDefault*0.001)
                PARAMS_MAN.TIME_EXPECTED=PARAMS_PROG.TIME_EXPECTED
                IF (PAR3<>0) THEN
                  SZ_Msg(51,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
            IF (PAR4==0) THEN  ;Weg fuer aktive Phase
              PARAMS_PROG.PROZ_EXPECTED=SP_X_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
              PARAMS_MAN.PROZ_EXPECTED=SP_X_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
            ELSE
              IF (PAR4>=20) AND (PAR4<=100) THEN
                PARAMS_PROG.PROZ_EXPECTED=(PAR4/10.0)*(100/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(1.0 *100/Direction.Directioncart.X)) ;1mm Biegung
              ELSE
                PARAMS_PROG.PROZ_EXPECTED=SP_X_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
                PARAMS_MAN.PROZ_EXPECTED=SP_X_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
                IF (PAR4<>0) THEN
                  SZ_Msg(52,#QuitMsg) 
                ENDIF
              ENDIF
            ENDIF
        ENDSWITCH
    ENDSWITCH
;
    ;ENDFOLD (Advance)
;
;***************************************************
  CASE #USR_TRIG
    ;FOLD Trig
    ;
    ;
    ;ENDFOLD (TRIG)    
;
;***************************************************
  CASE #USR_MAIN
    ;FOLD Main
    ;
     SWITCH PAR1
       CASE 1  ;EZ
         ZangenAntrieb=#EZ
         SWITCH PAR2
           CASE 1  ;C-Zange
             ZangenTyp=#C_Zange
             PARAMS_PROG.TIME_EXPECTED=(EZ_C_PRG_TimeDefault*0.001)
             PARAMS_MAN.TIME_EXPECTED=(EZ_C_MAN_TimeDefault*0.001)
             PARAMS_PROG.PROZ_EXPECTED=EZ_C_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
             PARAMS_MAN.PROZ_EXPECTED=EZ_C_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
           CASE 2  ;X-Zange
             ZangenTyp=#X_Zange
             PARAMS_PROG.TIME_EXPECTED=(EZ_X_PRG_TimeDefault*0.001)
             PARAMS_MAN.TIME_EXPECTED=(EZ_X_MAN_TimeDefault*0.001)
             PARAMS_PROG.PROZ_EXPECTED=EZ_X_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
             PARAMS_MAN.PROZ_EXPECTED=EZ_X_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
         ENDSWITCH
       CASE 2  ;SP
         ZangenAntrieb=#SP
         SWITCH PAR2
           CASE 1  ;C-Zange
             ZangenTyp=#C_Zange
             PARAMS_PROG.TIME_EXPECTED=(SP_C_PRG_TimeDefault*0.001)
             PARAMS_MAN.TIME_EXPECTED=(SP_C_MAN_TimeDefault*0.001)
             PARAMS_PROG.PROZ_EXPECTED=SP_C_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
             PARAMS_MAN.PROZ_EXPECTED=SP_C_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
           CASE 2  ;X-Zange
             ZangenTyp=#X_Zange
             PARAMS_PROG.TIME_EXPECTED=(SP_X_PRG_TimeDefault*0.001)
             PARAMS_MAN.TIME_EXPECTED=(SP_X_MAN_TimeDefault*0.001)
             PARAMS_PROG.PROZ_EXPECTED=SP_X_PRG_DistanceDefault*(10.0/Direction.Directioncart.X)
             PARAMS_MAN.PROZ_EXPECTED=SP_X_MAN_DistanceDefault*(10.0/Direction.Directioncart.X)
         ENDSWITCH
    ENDSWITCH 
    ;
    ;ENDFOLD (Main)
;
;***************************************************
  CASE #USR_MAKRO
    ;FOLD MAKRO
;
;
    ;ENDFOLD (Makro)
;
;***************************************************
ENDSWITCH ;(USER_CMD)
END
;
;ENDFOLD (S_Zangen Interface)
;
;***************************************************
;FOLD Tool-Base-Corr
GLOBAL DEF T_B_Corr(MyCorr_1 :IN)
FRAME MyCorr_1
IF (VW_MPARA_ACT.BASE_NO>0) THEN
  SWITCH BASE_TYPE[VW_MPARA_ACT.BASE_NO]
    CASE #TCP
      CONTINUE
      Base_Corr=$NULLFRAME
      Base_Corr=MyCorr_1
    DEFAULT
      CONTINUE
      Tool_Corr=$NULLFRAME
      Tool_Corr=MyCorr_1
    ENDSWITCH
ELSE
  CONTINUE
  Tool_Corr=$NULLFRAME
  Tool_Corr=MyCorr
ENDIF
END
;
;***************************************************
;FOLD Zangenfunktion
GLOBAL DEFFCT INT GunPosition(SZNr:IN)
INT SZNr
INT ActPosition
;
SWITCH SZNr
  CASE 1
    ActPosition=SI_SZ1_IstPos
    IF $IN[SZ_BASE_MA[1]+I_SZ_Vorz] THEN
      ActPosition=ActPosition*(-1)
    ENDIF
    RETURN(ActPosition)
  CASE 2
    ActPosition=SI_SZ2_IstPos
    IF $IN[SZ_BASE_MA[2]+I_SZ_Vorz] THEN
      ActPosition=ActPosition*(-1)
    ENDIF
    RETURN(ActPosition)
  CASE 3
    ActPosition=SI_SZ3_IstPos
    IF $IN[SZ_BASE_MA[3]+I_SZ_Vorz] THEN
      ActPosition=ActPosition*(-1)
    ENDIF
    RETURN(ActPosition)
  CASE 4
  CASE 5
  CASE 6
  CASE 7
ENDSWITCH
ENDFCT
;ENDFOLD
;
;***************************************************
;FOLD SZ EK-Wert auslesen
DEFFCT REAL GetEKVal(MyFirstBit:OUT)
INT MyFirstBit
INT MyValue
INT N
INT MyMask
MyValue=0
MyMask=1
IF ((MyFirstBit==EZ1_EK_FBit) AND MIT_EK_Vorz[1]==TRUE) OR ((MyFirstBit==EZ2_EK_FBit) AND MIT_EK_Vorz[2]==TRUE) OR ((MyFirstBit==EZ3_EK_FBit) AND MIT_EK_Vorz[3]==TRUE) THEN
  FOR N=MyFirstBit TO (MyFirstBit+6)
    CONTINUE
    IF $IN[N] THEN 
      MyValue=MyValue+MyMask
    ENDIF
    MyMask=MyMask*2
  ENDFOR
  CONTINUE
  IF $IN[MyFirstBit+7] THEN
    RETURN(MyValue*(-0.1))
  ELSE
    RETURN(MyValue*(0.1))
  ENDIF
ELSE
  FOR N=MyFirstBit TO (MyFirstBit+7)
    CONTINUE
    IF $IN[N] THEN
      MyValue=MyValue+MyMask
    ENDIF
    MyMask=MyMask*2
  ENDFOR
  RETURN(MyValue*0.1)
ENDIF
ENDFCT
;ENDFOLD
;
;***************************************************
;FOLD SZ Geometrie auslesen
DEFFCT REAL GetGEOVal(MyFirstBit:OUT)
INT MyFirstBit
INT MyValue
INT N
INT MyMask
MyValue=0
MyMask=1
IF ((MyFirstBit==EZ1_GEO_FBit) AND MIT_EK_Vorz[1]==TRUE) OR ((MyFirstBit==EZ2_GEO_FBit) AND MIT_EK_Vorz[2]==TRUE) OR ((MyFirstBit==EZ3_GEO_FBit) AND MIT_EK_Vorz[3]==TRUE) THEN
  FOR N=MyFirstBit TO (MyFirstBit+2)
    CONTINUE
    IF $IN[N] THEN
      MyValue=MyValue+MyMask
    ENDIF
    MyMask=MyMask*2
  ENDFOR
  CONTINUE
  IF $IN[MyFirstBit+3] THEN
    RETURN(MyValue*(-1.0))
  ELSE
    RETURN(MyValue*(1.0))
  ENDIF
ELSE
  FOR N=MyFirstBit TO (MyFirstBit+2)
    CONTINUE
    IF $IN[N] THEN
      MyValue=MyValue+MyMask
    ENDIF
    MyMask=MyMask*2
  ENDFOR
  CONTINUE
  RETURN(MyValue*(1.0))
ENDIF
ENDFCT
;ENDFOLD
;
;***************************************************
;FOLD SZ Armdurchbiegung auslesen
DEFFCT REAL GetGunVal(MyFirstBit:OUT)
INT MyFirstBit
INT MyValue
INT N
INT MyMask
MyValue=0
MyMask=1
FOR N=MyFirstBit TO (MyFirstBit+3)
  CONTINUE
  IF $IN[N] THEN
    MyValue=MyValue+MyMask
  ENDIF
  MyMask=MyMask*2
ENDFOR
CONTINUE
RETURN(MyValue)
ENDFCT
;ENDFOLD
;
;***************************************************
;FOLD SZ Armdurchbiegung berechnen
DEFFCT REAL CalcGunVal(MyFirstBit:OUT)
INT MyFirstBit
INT MyValue
INT N
INT MyMask
MyValue=0
MyMask=1
FOR N=MyFirstBit TO (MyFirstBit+7)
  CONTINUE
  IF $IN[N] THEN
    MyValue=MyValue+MyMask
  ENDIF
  MyMask=MyMask*2
ENDFOR
;
IF (ZangenTyp==#C_Zange) THEN
  MyValue=((MyValue/10)*C_ArmDurchbiegung)
ENDIF
IF (ZangenTyp==#X_Zange) THEN
  MyValue=((MyValue/10)*X_ArmDurchbiegung)
ENDIF
;
RETURN(MyValue*(1.0))
ENDFCT
;ENDFOLD
;
;***************************************************
;FOLD GunFunctionManual
GLOBAL DEF GunFunctionManual()
INT RobTimerStart
INT PrevLastPosition
INT LastPosition
INT ActPosition
INT StartPosGun
BOOL IsMovingBack
BOOL IsMovingForward
BOOL ZangeNIO
POS StartPos
POS ReturnPos
POS IstPos
INT SZNr
;
BRAKE
REPEAT
  SWITCH R1AusgleichFunktion
    CASE 1,2,3 ;Zange1
	   SZNr=1
    CASE 11,12,13 ;Zange2
	   SZNr=2
	 CASE 21,22,23 ;Zange3
	   SZNr=3  
  ENDSWITCH
  SWITCH R1AusgleichFunktion
    CASE 1,11,21 ;teachmode ein
      LIN $POS_ACT
      StartPos=$Pos_Act
      ReturnPos=$Pos_Act
      RobTimerStart=$ROB_TIMER
      WAIT FOR (($ASYNC_STATE==#IDLE) AND ($Brake_Sig>0)) OR (($ROB_TIMER-RobTimerStart)>2000)
      IF (($ROB_TIMER-RobTimerStart)>2000) THEN
        SZ_Msg(30,#QuitMsg)
      ENDIF  
      SZ_Msg(31,#NotifyMsg)
      StatModeOldOV=$OV_PRO
      $OV_PRO=100
      $VEL.CP=$VEL_MA.cp
      $ACC.CP=$ACC_MA.cp
      LIN StartPos:{x +3.0, y 0, z 0, a 0, b 0, c 0}
      $OV_PRO=StatModeOldOV
      StatModeOldOV=-1
      $OUT[SZ_BASE_MA[SZNr]+O_SZ_S_TPos]=TRUE
      RobTimerStart=$ROB_TIMER
      StartPosGun=GunPosition(SZNr)
      REPEAT
        ActPosition=GunPosition(SZNr)
        IF (ActPosition>StartPosGun) THEN
          StartPosGun=ActPosition
        ENDIF      
        ZangeNIO=NOT($IN[SZ_BASE_MA[SZNr]+I_SZ_bereit]) OR $IN[SZ_BASE_MA[SZNr]+I_SZ_Sammel] OR NOT ($IN[SZ_BASE_MA[SZNr]+I_SZ_Auto])
      UNTIL ($IN[SZ_BASE_MA[SZNr]+I_SZ_zu] OR ZangeNIO OR (($ROB_TIMER-RobTimerStart)>5000) OR (R1AusgleichFunktion==0))
	   IF (ZangeNIO OR (($ROB_TIMER-RobTimerStart)>5000))  THEN
	     IstPos=$pos_act_mes
        LIN IstPos
        IF ZangeNIO THEN
	       SZ_Msg(32,#NotifyMsg);Abbruch wegen Zangenstoerung
	     ENDIF
        IF (($ROB_TIMER-RobTimerStart)>5000) THEN
          SZ_Msg(40,#NotifyMsg);teach position nicht erreicht
        ENDIF
	     HALT
	   ELSE
        StartPosGun=GunPosition(SZNr)
        IstPos=$pos_act_mes
        LIN IstPos      
        REPEAT
          ActPosition=GunPosition(SZNr)
          ZangeNIO=NOT($IN[SZ_BASE_MA[SZNr]+I_SZ_bereit]) OR $IN[SZ_BASE_MA[SZNr]+I_SZ_Sammel] OR NOT ($IN[SZ_BASE_MA[SZNr]+I_SZ_Auto])
        UNTIL ($IN[SZ_BASE_MA[SZNr]+I_SZ_auf] OR ZangeNIO OR (($ROB_TIMER- RobTimerStart)>5000))
        ZangeNIO=ZangeNIO OR (($ROB_TIMER-RobTimerStart)>5000)
        StatModeOldOV=$OV_PRO
        $OV_PRO=100
        $VEL.CP=$VEL_MA.cp
        $ACC.CP=$ACC_MA.cp
        LIN ReturnPos
        $OV_PRO=StatModeOldOV
        StatModeOldOV=-1
        RobTimerStart=$ROB_TIMER
        REPEAT
        UNTIL (TeachPos[1] OR TeachPos[2] OR TeachPos[3] OR ZangeNIO OR (($ROB_TIMER-RobTimerStart)>5000))
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_S_TPos]=FALSE
        IF NOT ZangeNIO AND (TeachPos[1] OR TeachPos[2] OR TeachPos[3]) THEN
          SZ_Msg(41,#NotifyMsg);TeachMode abgeschlossen
        ELSE  
          SZ_Msg(35,#NotifyMsg);SZ hat TeachPos nicht gefunden 
        ENDIF  
        RobTimerStart=$ROB_TIMER
	     REPEAT
        UNTIL (NOT ($IN[SZ_BASE_MA[SZNr]+I_SZ_TPos_g]) OR (($ROB_TIMER-RobTimerStart)>5000) OR (R1AusgleichFunktion==0))
        IF (($ROB_TIMER-RobTimerStart)>5000) THEN
          SZ_Msg(36,#NotifyMsg);SZ TeachPos nicht zurueckgenommen 
        ENDIF
        R1AusgleichFunktion=0        
        HALT
      ENDIF
    CASE 2,12,22 ;Zange auf
      IF $IN[SZ_BASE_MA[SZNr]+I_SZ_auf] THEN
        ;Zange bereits offen
        SZ_Msg(42,#NotifyMsg)
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
      ELSE
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=TRUE
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu]=FALSE
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu_o_S]=FALSE
        RobTimerStart=$ROB_TIMER
        WAIT FOR ($IN[SZ_BASE_MA[SZNr]+I_SZ_auf] OR (($ROB_TIMER- RobTimerStart)>5000) OR (R1AusgleichFunktion==0))
        IF NOT $IN[SZ_BASE_MA[SZNr]+I_SZ_auf] THEN
          ;Fehler Zange oeffnen
          $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
          SZ_Msg(43,#NotifyMsg)
        ELSE
          ;Zange ok geoeffnet
          $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
          SZ_Msg(44,#NotifyMsg)
        ENDIF
      ENDIF
      GunBalanceOff(SZNr)
      SZ_Msg(37,#NotifyMsg)
      R1AusgleichFunktion=0
      HALT
    CASE 3,13,23 ;Zange zu
      GunBalanceOnManual()
      WAIT SEC 0.25
      $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
      $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu]=TRUE
      $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu_o_S]=TRUE      
      RobTimerStart=$ROB_TIMER
      REPEAT
      UNTIL ($IN[SZ_BASE_MA[SZNr]+I_SZ_zu] OR (($ROB_TIMER- RobTimerStart)>5000) OR (R1AusgleichFunktion==0))
      IF NOT $IN[SZ_BASE_MA[SZNr]+I_SZ_zu] THEN
        GunBalanceOff(SZNr)
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu]=FALSE 
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu_o_S]=FALSE
        R1AusgleichFunktion=0
        SZ_Msg(45,#NotifyMsg) ;Fehler Kraft erreicht, Zange schliessen
        HALT
      ELSE
        GunBalanceHold()
	     SZ_Msg(46,#NotifyMsg) ;Kraft erreicht, Zange schliessen
        WAIT SEC 0.5
	     $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=TRUE
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu]=FALSE
        $OUT[SZ_BASE_MA[SZNr]+O_SZ_zu_o_S]=FALSE
        RobTimerStart=$ROB_TIMER
        WAIT FOR ($IN[SZ_BASE_MA[SZNr]+I_SZ_auf] OR (($ROB_TIMER-RobTimerStart)>5000) OR (R1AusgleichFunktion==0))
	     $OUT[SZ_BASE_MA[SZNr]+O_SZ_auf]=FALSE
	     GunBalanceOff(SZNr)
        R1AusgleichFunktion=0
        SZ_Msg(30,#NotifyMsg)
        HALT
      ENDIF
      DEFAULT
      IF R1AusgleichFunktion==0 THEN
        SZ_Msg(38,#NotifyMsg) ;Zangenfunktion abgebrochen
        RETURN
      ENDIF
    ENDSWITCH
UNTIL (R1AusgleichFunktion==0)
END
;ENDFOLD (GunFunctionManual)
;
;***************************************************
;FOLD Zangenausgleich
GLOBAL DEF GunBalanceOnManual()
;Konfigurationsaenderungen ggf. an Antrieb schicken
CF_UPDATE_CONF()
ERROR=VECTORMOVEON( STRATEGY,  DIRECTION, PARAMS_MAN)
VMV_PRINT_ERROR(error)
END
;
;***************************************************
GLOBAL DEF GunBalanceOnProgram(GunCmd:IN)
INT GunCmd
;
SWITCH GunCmd
  CASE 1
    CONTINUE
    $softplcint[400]=SO_SK1_Pkt_Nr
    CONTINUE
    $softplcint[401]=SO_SK1_Fzg_Typ 
  CASE 2
    CONTINUE
    IF Mit_2SZ_an_SK1 THEN
      CONTINUE
      $softplcint[400]=SO_SK1_Pkt_Nr
      CONTINUE
      $softplcint[401]=SO_SK1_Fzg_Typ
    ELSE
      CONTINUE
      $softplcint[400]=SO_SK2_Pkt_Nr
      CONTINUE
      $softplcint[401]=SO_SK2_Fzg_Typ 
    ENDIF  
  CASE 3
    CONTINUE
    $softplcint[400]=SO_SK3_Pkt_Nr
    CONTINUE
    $softplcint[401]=SO_SK3_Fzg_Typ
ENDSWITCH    
;
;Start Messung
Startzeit=$ROB_TIMER
;Konfigurationsaenderungen ggf. an Antrieb schicken
CF_UPDATE_CONF()
ERROR=VECTORMOVEON( STRATEGY,  DIRECTION, PARAMS_PROG)
VMV_PRINT_ERROR(error)
END
;
;***************************************************
GLOBAL DEF GunBalanceHold()
DECL VMSTATE LocalVMState
REAL TimeAtKraftErreicht
REAL PosVM, TimeVM, CorrVal,CorrVal_1,CorrVal_2
INT PosAtKraftErreicht
LocalVMState=$VMState
QAusgleich=LocalVMState.currentPos
ZeitZangeZu=$ROB_TIMER-Startzeit
Startzeit=$ROB_TIMER
;
PosAtKraftErreicht=LocalVMState.currentPos
TimeAtKraftErreicht=$ROB_TIMER
TimeVM=0 ;ZeitDifferenz seit Kraft errreicht
PosVM=0 ;WegDifferenz seit Kraft errreicht
;Zeit zum Nivellieren abwarten, aber nicht mehr signifikant weiter ziehen lassen
WHILE ((TimeVM<300) AND  (PosVM<1))
  WAIT SEC 0.001
  LocalVMState=$VMState
  PosVM=LocalVMState.currentPos-PosAtKraftErreicht
  TimeVM=$ROB_TIMER-TimeAtKraftErreicht
ENDWHILE
VektorMoveLogging()
ERROR=VECTORMOVEOFF(#FIX_POSITION)
VMV_PRINT_ERROR(error)
;
IF Mit_KE[1] THEN
  IF $OUT[SZ_BASE_MA[1]+O_SZ_FRG] AND $OUT[SZ_BASE_MA[1]+O_SZ_zu] THEN
    CorrVal_1=GetEKVal(EZ1_EK_FBit)*10
    CorrVal_2=GetGEOVal(EZ1_GEO_FBit)*10
    CorrVal=(CorrVal_1+CorrVal_2)
    QDurchbiegung=SI_SZ1_IstPos-CorrVal
    IF $IN[SZ_BASE_MA[1]+I_SZ_Vorz] THEN
      QDurchbiegung=-QDurchbiegung
    ENDIF
  ENDIF
ELSE
  IF $OUT[SZ_BASE_MA[1]+O_SZ_FRG] AND $OUT[SZ_BASE_MA[1]+O_SZ_zu] THEN
    QDurchbiegung=SI_SZ1_IstPos-GetEKVal(EZ1_EK_FBit)*10
    IF $IN[SZ_BASE_MA[1]+I_SZ_Vorz] THEN
      QDurchbiegung=-QDurchbiegung
    ENDIF
  ENDIF  
ENDIF
;
IF Mit_KE[2] THEN
  IF $OUT[SZ_BASE_MA[2]+O_SZ_FRG] AND $OUT[SZ_BASE_MA[2]+O_SZ_zu] THEN
    CorrVal_1=GetEKVal(EZ2_EK_FBit)*10
    CorrVal_2=GetGEOVal(EZ2_GEO_FBit)*10
    CorrVal=(CorrVal_1 + CorrVal_2)
    QDurchbiegung=SI_SZ2_IstPos-CorrVal
    IF $IN[SZ_BASE_MA[2]+I_SZ_Vorz] THEN
      QDurchbiegung=-QDurchbiegung
    ENDIF
  ENDIF
ELSE
  IF $OUT[SZ_BASE_MA[2]+O_SZ_FRG] AND $OUT[SZ_BASE_MA[2]+O_SZ_zu] THEN
    QDurchbiegung=SI_SZ2_IstPos-GetEKVal(EZ2_EK_FBit)*10
    IF $IN[SZ_BASE_MA[2]+I_SZ_Vorz] THEN
      QDurchbiegung=-QDurchbiegung
    ENDIF
  ENDIF
ENDIF
;
IF Mit_KE[3] THEN
  IF $OUT[SZ_BASE_MA[3]+O_SZ_FRG] AND $OUT[SZ_BASE_MA[3]+O_SZ_zu] THEN
    CorrVal_1=GetEKVal(EZ3_EK_FBit)*10
    CorrVal_2=GetGEOVal(EZ3_GEO_FBit)*10
    CorrVal=(CorrVal_1 + CorrVal_2)
    QDurchbiegung=SI_SZ3_IstPos-CorrVal
    IF $IN[SZ_BASE_MA[3]+I_SZ_Vorz] THEN
      QDurchbiegung=-QDurchbiegung
    ENDIF
  ENDIF
ELSE  
  IF $OUT[SZ_BASE_MA[3]+O_SZ_FRG] AND $OUT[SZ_BASE_MA[3]+O_SZ_zu] THEN
    QDurchbiegung=SI_SZ3_IstPos-GetEKVal(EZ3_EK_FBit)*10
    IF $IN[SZ_BASE_MA[3]+I_SZ_Vorz] THEN
      QDurchbiegung=-QDurchbiegung
    ENDIF
  ENDIF
ENDIF  
END
;
;***************************************************
GLOBAL DEF GunBalanceOff(GunCmd:IN)
;Ende Schweissen
INT GunCmd, SZNr
INT ActPosition
INT StartPosGun
BOOL IsMovingBack
;
ZeitSchweissen=$ROB_TIMER-Startzeit
Startzeit=$ROB_TIMER
SWITCH GunCmd
  CASE 1
    SZNr=1
  CASE 2
    SZNr=2
  CASE 3
    SZNr=3    
ENDSWITCH 
StartPosGun=GunPosition(SZNr)
REPEAT
  ActPosition=GunPosition(SZNr)
  IsMovingBack=((ActPosition-StartPosGun)>2)
UNTIL  IsMovingBack OR (($ROB_TIMER- Startzeit)>500) 
ERROR=VECTORMOVEOFF(#MOVE_BACK_COMPLETE)
VMV_PRINT_ERROR(error)
END
;
;***************************************************
GLOBAL DEF GunBalanceImmediateOff()
ERROR=VECTORMOVEOFF(#IMMEDIATE_OFF)
VMV_PRINT_ERROR(error)
END
;
;***************************************************
DEF VMV_PRINT_ERROR(error:in)
DECL VMERROR error
;
SWITCH error
  CASE #VM_OK
    ;display_string ("Returnwert: VM_OK")
  CASE #VM_ILLEGAL_INTERPRETER
    display_string ("Returnwert: VM_ILLEGAL_INTERPRETER")
  CASE #VM_ROBOT_NOT_FREE
    display_string ("Returnwert: VM_ROBOT_NOT_FREE")
  CASE #VM_ALREADY_ACTIVE
    display_string ("Returnwert: VM_ALREADY_ACTIVE")
  CASE #VM_NOT_ACTIVE
    ;display_string ("Returnwert: VM_NOT_ACTIVE")
  CASE #VM_TOOL_INVALID
    display_string ("Returnwert: VM_TOOL_INVALID")
  CASE #VM_BASE_INVALID
    display_string ("Returnwert: VM_BASE_INVALID")
  CASE #VM_INCOMPLETE_INPUT
    display_string ("Returnwert: VM_INCOMPLETE_INPUT")
  CASE #VM_BRAKES_NOT_OPEN
    display_string ("Returnwert: VM_BRAKES_NOT_OPEN")
  CASE #VM_NOT_YET_IMPLEMENTED
    display_string ("Returnwert: VM_NOT_YET_IMPLEMENTED")
  CASE #VM_ILLEGAL_POS
    display_string ("Returnwert: VM_ILLEGAL_POS")
  CASE #VM_OTHER
    display_string ("Returnwert: VM_OTHER")
  DEFAULT
  display_string ("Returnwert: <unbekannt>")
ENDSWITCH
END
;
;***************************************************
DEF CF_UPDATE_CONF()
BOOL ret
;
ret=TRUE
IF VARSTATE("l_VelLagThresholdBegin")<>#initialized THEN
  ret=FALSE
ELSE
  IF l_VelLagThresholdBegin <> _VelLagThresholdBegin THEN
    ret=FALSE
  ENDIF
ENDIF
IF VARSTATE("l_VelLagThresholdEnd")<>#initialized THEN
  ret=FALSE
ELSE
  IF l_VelLagThresholdEnd <> _VelLagThresholdEnd THEN
    ret=FALSE
  ENDIF
ENDIF
IF VARSTATE("l_TrqPullTimeFactor")<>#initialized THEN
  ret=FALSE
ELSE
  IF l_TrqPullTimeFactor<>_TrqPullTimeFactor THEN
    ret=FALSE
  ENDIF
ENDIF
IF VARSTATE("l_TrqPullDeltaFactor")<>#initialized THEN
  ret=FALSE
ELSE
  IF l_TrqPullDeltaFactor <> _TrqPullDeltaFactor THEN
    ret=FALSE
  ENDIF
ENDIF
IF VARSTATE("l_VMVMasterDetectStart")<>#initialized THEN
  ret=FALSE
ELSE
  IF l_VMVMasterDetectStart<>_VMVMasterDetectStart THEN
    ret=FALSE
  ENDIF
ENDIF
l_VelLagThresholdBegin=_VelLagThresholdBegin
l_VelLagThresholdEnd=_VelLagThresholdEnd
l_TrqPullTimeFactor=_TrqPullTimeFactor
l_TrqPullDeltaFactor=_TrqPullDeltaFactor
l_VMVMasterDetectStart=_VMVMasterDetectStart
IF (ret==FALSE) THEN
  display_string("Konifiguration geaendert, wird an Antrieb geschickt")
  CF_WRITECONFIGALL()
ENDIF
END
;
;***************************************************
GLOBAL DEF CF_WRITECONFIGALL()
INT i
;
FOR i=1 to 6
  CF_WRITECONFIG(i)
ENDFOR
END
;
;***************************************************
DEF CF_WRITECONFIG(achse:in)
INT achse
CHAR achs_string[2]
;
SWITCH (achse)
  CASE 1
    achs_string[]="A1"
  CASE 2
    achs_string[]="A2"
  CASE 3
    achs_string[]="A3"
  CASE 4
    achs_string[]="A4" 
  CASE 5
    achs_string[]="A5"
  CASE 6
    achs_string[]="A6"
ENDSWITCH
SSD_DELAYED("DRIVE",achs_string[],"VMVMasterVelLagThresholdBegin",_VelLagThresholdBegin)
SSD_DELAYED("DRIVE",achs_string[],"VMVMasterVelLagThresholdEnd",_VelLagThresholdEnd)
SSD_DELAYED("DRIVE",achs_string[],"VMVMasterTrqPullTimeFactor",_TrqPullTimeFactor)
SSD_DELAYED("DRIVE",achs_string[],"VMVMasterTrqPullDeltaFactor",_TrqPullDeltaFactor)
SSD_DELAYED("DRIVE",achs_string[],"VMVMasterDetectStart",_VMVMasterDetectStart)
END
;
;***************************************************
DEF SSD(OWNER_NAME[]:IN, OWNER_AXNAME[]:IN, VAR_NAME[]:IN, VALUE:IN)
CHAR OWNER_NAME[]
CHAR OWNER_AXNAME[]
CHAR VAR_NAME[]
REAL VALUE
INT RET_STATUS
;
IF VMV_Office_Sim THEN
  RETURN
ENDIF
RET_STATUS=-1
RET_STATUS=SET_SYSTEM_DATA(OWNER_NAME[], OWNER_AXNAME[], VAR_NAME[], VALUE)
IF (RET_STATUS<>0) THEN
  SSD_ERROR(OWNER_NAME[], OWNER_AXNAME[], VAR_NAME[], VALUE, RET_STATUS)
ENDIF
END
;
;***************************************************
DEF SSD_DELAYED(OWNER_NAME[]:IN, OWNER_AXNAME[]:IN, VAR_NAME[]:IN, VALUE:IN)
CHAR OWNER_NAME[]
CHAR OWNER_AXNAME[]
CHAR VAR_NAME[]
REAL VALUE
INT RET_STATUS
;
IF VMV_Office_Sim THEN
  RETURN
ENDIF
RET_STATUS=-1
RET_STATUS=SET_SYSTEM_DATA_DELAYED(OWNER_NAME[], OWNER_AXNAME[], VAR_NAME[], VALUE)
IF (RET_STATUS<>0) THEN
  SSD_ERROR(OWNER_NAME[], OWNER_AXNAME[], VAR_NAME[], VALUE, RET_STATUS)
ENDIF
END
;
;***************************************************
DEF SSD_ERROR(OWNER_NAME[]:IN, OWNER_AXNAME[]:IN, VAR_NAME[]:IN, VALUE:IN, RET_STATUS: IN)
CHAR OWNER_NAME[]
CHAR OWNER_AXNAME[]
CHAR VAR_NAME[]
REAL VALUE
INT RET_STATUS
;
SWITCH RET_STATUS
  CASE -1
    display_string ("Fehler VAR_NAME: RET_STATUS wurde nicht belegt")
    display_string (VAR_NAME[])
  CASE 0 ;Wert wurde erfolgreich gelesen/geschrieben
  CASE 1
    display_string ("Fehler OWNER_NAME: nicht bekannt")
    display_string (OWNER_NAME[])
  CASE 2
    display_string ("Fehler OWNER_AXNAME: ungueltig")
    display_string (OWNER_AXNAME[])
  CASE 3
    display_string ("Fehler VAR_NAME: nicht bekannt")
    display_string (VAR_NAME[])
  CASE 4
    display_string ("Fehler VAR:  Variable schreibgeschuetzt")
    display_string (VAR_NAME[])
  CASE 5
    display_string ("Fehler VAR: Wertebereichsueberschreitung")
    display_string (VAR_NAME[])
ENDSWITCH
END
;
;***************************************************
DEF DISPLAY_STRING(Src[]:in)
CHAR src[]
DECL KrlMsg_T Msg
DECL KrlMsgPar_T Par[3]
DECL KrlMsgOpt_T Opt
DECL CHAR next[470]
INT nHandle, laenge, i
BOOL fortsetzen
;
fortsetzen=FALSE
laenge=StrLen(src[])
Msg.Modul[]="DISPLAY_STRING"
Msg.Nr=1
IF laenge<=60 THEN
  Msg.Msg_txt[]=src[]
ELSE
  ;erste 55 Zeichen ausdrucken, Rest rekursiv
  fortsetzen=TRUE
  FOR i=1 to 55
    ;ersten teil ausdrucken
    Msg.Msg_txt[i]=src[i]
  ENDFOR
  FOR i=56 to 60
    ;ersten teil ausdrucken mit .....
    Msg.Msg_txt[i]="."
  ENDFOR
  ;rest in next schreiben mit fortsetz-Prefix
  FOR i=1 to 5
    next[i]="."
  ENDFOR
  FOR i=56 to laenge
    next[i-50]=src[i]
  ENDFOR
ENDIF
Opt={ VL_Stop FALSE, Clear_P_Reset FALSE, Log_To_DB TRUE }
nHandle=Set_KrlMsg (#Notify, Msg, Par[], Opt)
;rekursiv den Rest raushauen
IF fortsetzen THEN
  display_string(next[])
ENDIF
END
;ENDFOLD (Zangenausgleich)
