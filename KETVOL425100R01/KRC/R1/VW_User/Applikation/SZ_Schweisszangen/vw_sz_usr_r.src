;
        CASE 11 ;EZ1 Service
          IF Mit_KE[1] THEN
            CONTINUE
            MyCorrVal_EK=GetEKVal(EZ1_EK_FBit)
            CONTINUE
            MyCorrVal_GEO=GetGEOVal(EZ1_GEO_FBit)
            CONTINUE
            MyCorrValue=(MyCorrVal_EK+MyCorrVal_GEO)    
          ELSE
            CONTINUE
            MyCorrValue=GetEKVal(EZ1_EK_FBit)
          ENDIF  
          IF (EZ1_Dock==TRUE) THEN
          IF Mit_KE[1] THEN
            CONTINUE
            IF (SO_SZ1_ZCode==1) THEN
              CONTINUE
              B_SZ1_VW_EK[1]=(((MyCorrVal_EK*2)>EZ1_Z1_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ1 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[1]=(((MyCorrVal_EK*2)>EZ1_Z1_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ1 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==2) THEN
              CONTINUE
              B_SZ1_VW_EK[2]=(((MyCorrVal_EK*2)>EZ1_Z2_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ2 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[2]=(((MyCorrVal_EK*2)>EZ1_Z2_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ2 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==3) THEN
              CONTINUE
              B_SZ1_VW_EK[3]=(((MyCorrVal_EK*2)>EZ1_Z3_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ3 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[3]=(((MyCorrVal_EK*2)>EZ1_Z3_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ3 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==4) THEN
              CONTINUE
              B_SZ1_VW_EK[4]=(((MyCorrVal_EK*2)>EZ1_Z4_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ4 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[4]=(((MyCorrVal_EK*2)>EZ1_Z4_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ4 Maximale Kappenstandzeit
            ENDIF
          ELSE
            CONTINUE
            IF (SO_SZ1_ZCode==1) THEN
                CONTINUE
              B_SZ1_VW_EK[1]=(((MyCorrValue*2)>EZ1_Z1_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ1 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[1]=(((MyCorrValue*2)>EZ1_Z1_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ1 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==2) THEN
                CONTINUE
              B_SZ1_VW_EK[2]=(((MyCorrValue*2)>EZ1_Z2_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ2 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[2]=(((MyCorrValue*2)>EZ1_Z2_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ2 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==3) THEN
              CONTINUE
              B_SZ1_VW_EK[3]=(((MyCorrValue*2)>EZ1_Z3_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ3 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[3]=(((MyCorrValue*2)>EZ1_Z3_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ3 Maximale Kappenstandzeit
            ENDIF
            CONTINUE
            IF (SO_SZ1_ZCode==4) THEN
              CONTINUE
              B_SZ1_VW_EK[4]=(((MyCorrValue*2)>EZ1_Z4_VW_EK) OR $IN[SK_BASE_MA[1]+I_SK_V_Stdm]) ;EZ1-SZ4 Vorwarnung Kappenstandzeit
                CONTINUE
              B_SZ1_MAX_EK[4]=(((MyCorrValue*2)>EZ1_Z4_MAX_EK) OR $IN[SZ_BASE_MA[1]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[1]+I_SK_M_Stdm]) ;EZ1-SZ4 Maximale Kappenstandzeit
            ENDIF
          ENDIF
          ENDIF
          ;Anforderung Normalfraesen
          CONTINUE
          $FLAG[F_SZ_Anw_NF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[1]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[1]+I_SK_Stfr] AND $IN[SZ_BASE_SL[1]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR ((PAR2>=51) AND (PAR2<=54)) OR $FLAG[F_SZ_Anw_NF[1]])
          ;Anforderung Startfraesen
          CONTINUE
          $FLAG[F_SZ_Anw_SF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[1]]) OR ((PAR2>=41) AND (PAR2<=44)) OR $FLAG[F_SZ_Anw_SF[1]])
;
        CASE 20,22 ;EZ2 Schweissen, EZ2 Fraesen
          IF (PAR1==22) THEN
            ;Anforderung Normalfraesen
            CONTINUE
            $FLAG[F_SZ_Anw_NF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[2]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[2]+I_SK_Stfr] AND $IN[SZ_BASE_SL[2]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[2]])
            ;Anforderung Startfraesen
            CONTINUE
            $FLAG[F_SZ_Anw_SF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[2]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[2]])
          ENDIF
          CONTINUE
          IF $IN[SK_BASE_SL[2]+I_SK_o_Proz] THEN
            $FLAG[F_o_Proz_BMS]=TRUE
          ELSE
            $FLAG[F_o_Proz_BMS]=FALSE
          ENDIF
          CONTINUE
          $OUT[O_RIP_SK_Sens]=FALSE
          IF Mit_KE[2] THEN
            CONTINUE
            SO_SK2_Pkt_Nr=PAR5
            CONTINUE
            SO_SPS_Proz_Nr=PAR5
            CONTINUE
            IF (SO_SK2_Pkt_Nr>90) THEN 
              CONTINUE
              SO_SK2_Fzg_Typ=PAR6
            ELSE
              CONTINUE
              SO_SK2_Fzg_Typ=0
            ENDIF 
          ELSE    
            IF NOT Mit_KE[2] THEN
              CONTINUE
              SO_SZ2_Prg_Nr=PAR2
            ENDIF
            CONTINUE
            SO_SPS_Proz_Nr=PAR5
            IF Mit_KE[2] THEN
              CONTINUE
              IF (SO_SK2_Pkt_Nr>90) THEN 
                CONTINUE	
                SO_SK2_Fzg_Typ=PAR6
              ELSE
                CONTINUE
                SO_SK2_Fzg_Typ=0
              ENDIF 
            ELSE
              CONTINUE            
              IF (SO_SZ2_Prg_Nr>90) THEN 
                CONTINUE	
                SO_SZ2_Fzg_Typ=PAR6
                IF NOT Mit_2SZ_an_SK1 THEN
                  CONTINUE
                  SO_SK2_Pkt_Nr=PAR5
                  CONTINUE	
                  SO_SK2_Fzg_Typ=PAR6
                  CONTINUE
                  $OUT[O_RIP_SK_Sens]=FALSE
                ELSE
                  CONTINUE
                  SO_SK1_Pkt_Nr=PAR5
                  CONTINUE
                  SO_SK1_Fzg_Typ=PAR6
                  CONTINUE
                  $OUT[O_RIP_SK_Sens]=TRUE
                ENDIF
              ELSE
                CONTINUE
                SO_SZ2_Fzg_Typ=0
                IF NOT Mit_2SZ_an_SK1 THEN
                  CONTINUE
                  SO_SK2_Pkt_Nr=PAR5
                  CONTINUE
                  SO_SK2_Fzg_Typ=0
                  CONTINUE
                  $OUT[O_RIP_SK_Sens]=FALSE
                ELSE
                  CONTINUE
                  SO_SK1_Pkt_Nr=PAR5
                  CONTINUE
                  SO_SK1_Fzg_Typ=0
                  CONTINUE
                  $OUT[O_RIP_SK_Sens]=TRUE
                ENDIF
              ENDIF  
            ENDIF 
          ENDIF  
          CONTINUE
          $FLAG[F_Frg_Servo]=TRUE
          CONTINUE
          WHILE USER_AKTIV
            SZ_Msg(1,#QuitMsg) ;mehr als 1 USER-Aufruf aktiv
          ENDWHILE
          USER_AKTIV=TRUE
          IF Mit_KE[2] THEN
            CONTINUE
            MyCorrVal_EK=GetEKVal(EZ2_EK_FBit)
            CONTINUE
            EZ2_EK_Wert=(MyCorrVal_EK*2)
            CONTINUE
            MyCorrVal_GEO=GetGEOVal(EZ2_GEO_FBit)
            CONTINUE
            MyCorrValue=(MyCorrVal_EK+MyCorrVal_GEO)
            CONTINUE
            B_SZ2_VW_EK[1]=(((MyCorrVal_EK*2)>EZ2_Z1_VW_EK) OR $IN[SK_BASE_MA[2]+I_SK_V_Stdm]) ;EZ2-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ2_MAX_EK[1]=(((MyCorrVal_EK*2)>EZ2_Z1_MAX_EK) OR $IN[SZ_BASE_MA[2]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[2]+I_SK_M_Stdm]) ;EZ2-SZ1 Maximale Kappenstandzeit
          ELSE
            CONTINUE
            MyCorrValue=GetEKVal(EZ2_EK_FBit)
            CONTINUE
            EZ2_EK_Wert=(MyCorrValue*2)
            CONTINUE
            B_SZ2_VW_EK[1]=(((MyCorrValue*2)>EZ2_Z1_VW_EK) OR $IN[SK_BASE_MA[2]+I_SK_V_Stdm]) ;EZ2-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ2_MAX_EK[1]=(((MyCorrValue*2)>EZ2_Z1_MAX_EK) OR $IN[SZ_BASE_MA[2]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[2]+I_SK_M_Stdm]) ;EZ2-SZ1 Maximale Kappenstandzeit
          ENDIF
          CONTINUE
          MyCorrOFF=(Offset*0.1)
          CONTINUE
          WHILE ((MyCorrOFF<-10) OR (MyCorrOFF>10))
            SZ_Msg(3,#QuitMsg) ; MyCorrOFF nicht im zulaessigen Bereich
          ENDWHILE
          CONTINUE
          MyCorr=$NULLFRAME
          IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
            MyCorr.X=-((MyCorrValue*EZ2_Z1_AHV)+MyCorrOff)
          ELSE	
            MyCorr.X=-(MyCorrValue*EZ2_Z1_AHV)
          ENDIF
          CONTINUE
          IF (VW_MPARA_ACT.BASE_NO>0) THEN
            CONTINUE
            SWITCH BASE_TYPE[VW_MPARA_ACT.BASE_NO]
              CASE #TCP
                CONTINUE
                $BASE=$BASE:MyCorr
              DEFAULT
                CONTINUE
                $TOOL=$TOOL:MyCorr
            ENDSWITCH
          ELSE
            CONTINUE
           $TOOL=$TOOL:MyCorr
          ENDIF
          IF ($PRO_MODE==#MSTEP) THEN
            CONTINUE
            $ADVANCE=0 ; Anfahren WPS-Punkt mit EK-Verschleiss in SingleStep
          ENDIF
          CONTINUE
          TRIGGER  WHEN DISTANCE=0 DELAY=0.0 DO $Flag[F_FRG_VMove]=FALSE
          CONTINUE
          TRIGGER  WHEN DISTANCE=1 DELAY=0.0 DO $Flag[F_FRG_VMove]=TRUE ;Freigabe VektorMove Schweissmakro
          CONTINUE
          TRIGGER  WHEN DISTANCE=1 DELAY=-100.0 DO T_B_Corr(MyCorr) PRIO=-1
          CONTINUE
          IF ($softplcint[EZ_PlcInt[2]]==7) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E1=(act_P1.E1-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[2]]==8) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E2=(act_P1.E2-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[2]]==9) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E3=(act_P1.E3-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[2]]==10) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E4=(act_P1.E4-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[2]]==11) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E5=(act_P1.E5-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[2]]==12) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E6=(act_P1.E6-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
;
        CASE 21 ;EZ2 Service
          IF Mit_KE[2] THEN
            CONTINUE
            MyCorrVal_EK=GetEKVal(EZ2_EK_FBit)
            CONTINUE
            MyCorrVal_GEO=GetGEOVal(EZ2_GEO_FBit)
            CONTINUE
            MyCorrValue=(MyCorrVal_EK+MyCorrVal_GEO) 
            CONTINUE
            B_SZ2_VW_EK[1]=(((MyCorrVal_EK*2)>EZ2_Z1_VW_EK) OR $IN[SK_BASE_MA[2]+I_SK_V_Stdm]) ;EZ2-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ2_MAX_EK[1]=(((MyCorrVal_EK*2)>EZ2_Z1_MAX_EK) OR $IN[SZ_BASE_MA[2]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[2]+I_SK_M_Stdm]) ;EZ2-SZ1 Maximale Kappenstandzeit
          ELSE
            CONTINUE
            MyCorrValue=GetEKVal(EZ2_EK_FBit)
            CONTINUE
            B_SZ2_VW_EK[1]=(((MyCorrValue*2)>EZ2_Z1_VW_EK) OR $IN[SK_BASE_MA[2]+I_SK_V_Stdm]) ;EZ2-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ2_MAX_EK[1]=(((MyCorrValue*2)>EZ2_Z1_MAX_EK) OR $IN[SZ_BASE_MA[2]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[2]+I_SK_M_Stdm]) ;EZ2-SZ1 Maximale Kappenstandzeit
          ENDIF
          ;Anforderung Normalfraesen
          CONTINUE
          $FLAG[F_SZ_Anw_NF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[2]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[2]+I_SK_Stfr] AND $IN[SZ_BASE_SL[2]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[2]])
          ;Anforderung Startfraesen
          CONTINUE
          $FLAG[F_SZ_Anw_SF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[2]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[2]])        
;
        CASE 30,32 ;EZ3 Schweissen, EZ3 Fraesen
          IF (PAR1==32) THEN
            ;Anforderung Normalfraesen
            CONTINUE
            $FLAG[F_SZ_Anw_NF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[3]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[3]+I_SK_Stfr] AND $IN[SZ_BASE_SL[3]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[3]]) 
            ;Anforderung Startfraesen
            CONTINUE
            $FLAG[F_SZ_Anw_SF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[3]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[3]])
          ENDIF
          CONTINUE
          IF $IN[SK_BASE_SL[3]+I_SK_o_Proz] THEN
            $FLAG[F_o_Proz_BMS]=TRUE
          ELSE
            $FLAG[F_o_Proz_BMS]=FALSE
          ENDIF
          IF NOT Mit_KE[3] THEN
            CONTINUE          
            SO_SZ3_Prg_Nr=PAR2
          ENDIF
          CONTINUE
          SO_SPS_Proz_Nr=PAR5
          IF Mit_KE[3] THEN
            CONTINUE
            IF (SO_SK3_Pkt_Nr>90) THEN
              CONTINUE
              SO_SK3_Fzg_Typ=PAR6
            ELSE
              CONTINUE
              SO_SK3_Fzg_Typ=0
            ENDIF 
          ELSE
            CONTINUE
            IF (SO_SZ3_Prg_Nr>90) THEN
              CONTINUE	 
              SO_SZ3_Fzg_Typ=PAR6
              CONTINUE
              SO_SK3_Pkt_Nr=PAR5
              CONTINUE
              SO_SK3_Fzg_Typ=PAR6
            ELSE
              CONTINUE
              SO_SZ3_Fzg_Typ=0
              CONTINUE    
              SO_SK3_Pkt_Nr=PAR5
              CONTINUE
              SO_SK3_Fzg_Typ=0
            ENDIF 
          ENDIF  
          CONTINUE
          $FLAG[F_Frg_Servo]=TRUE
          CONTINUE
          WHILE USER_AKTIV
            SZ_Msg(1,#QuitMsg) ;mehr als 1 USER-Aufruf aktiv
          ENDWHILE
          USER_AKTIV=TRUE
          IF Mit_KE[3] THEN
            CONTINUE
            MyCorrVal_EK=GetEKVal(EZ3_EK_FBit)
            CONTINUE
            EZ3_EK_Wert=(MyCorrVal_EK*2)
            CONTINUE
            MyCorrVal_GEO=GetGEOVal(EZ3_GEO_FBit)
            CONTINUE
            MyCorrValue=(MyCorrVal_EK+MyCorrVal_GEO)
            CONTINUE
            B_SZ3_VW_EK[1]=(((MyCorrVal_EK*2)>EZ3_Z1_VW_EK) OR $IN[SK_BASE_MA[3]+I_SK_V_Stdm]) ;EZ3-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ3_MAX_EK[1]=(((MyCorrVal_EK*2)>EZ3_Z1_MAX_EK) OR $IN[SZ_BASE_MA[3]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[3]+I_SK_M_Stdm]) ;EZ3-SZ1 Maximale Kappenstandzeit
          ELSE
            CONTINUE
            MyCorrValue=GetEKVal(EZ3_EK_FBit)
            CONTINUE
            EZ3_EK_Wert=(MyCorrValue*2)  
            CONTINUE
            B_SZ3_VW_EK[1]=(((MyCorrValue*2)>EZ3_Z1_VW_EK) OR $IN[SK_BASE_MA[3]+I_SK_V_Stdm]) ;EZ3-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ3_MAX_EK[1]=(((MyCorrValue*2)>EZ3_Z1_MAX_EK) OR $IN[SZ_BASE_MA[3]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[3]+I_SK_M_Stdm]) ;EZ3-SZ1 Maximale Kappenstandzeit
          ENDIF
          CONTINUE
          MyCorrOFF=(Offset*0.1)
          CONTINUE
          WHILE ((MyCorrOFF<-10) OR (MyCorrOFF>10))
            SZ_Msg(3,#QuitMsg) ; MyCorrOFF nicht im zulaessigen Bereich
          ENDWHILE
          CONTINUE
          MyCorr=$NULLFRAME
	       IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
            MyCorr.X=-((MyCorrValue*EZ3_Z1_AHV)+MyCorrOff)
          ELSE	
            MyCorr.X=-(MyCorrValue*EZ3_Z1_AHV)
          ENDIF
          CONTINUE
          IF (VW_MPARA_ACT.BASE_NO>0) THEN
            CONTINUE
            SWITCH BASE_TYPE[VW_MPARA_ACT.BASE_NO]
              CASE #TCP
                CONTINUE
                $BASE=$BASE:MyCorr
              DEFAULT
                CONTINUE
                $TOOL=$TOOL:MyCorr
            ENDSWITCH
          ELSE
            CONTINUE
            $TOOL=$TOOL:MyCorr
          ENDIF
          IF ($PRO_MODE==#MSTEP) THEN
            CONTINUE
            $ADVANCE=0 ; Anfahren WPS-Punkt mit EK-Verschleiss in SingleStep
          ENDIF
          CONTINUE
          TRIGGER  WHEN DISTANCE=0 DELAY=0.0 DO $Flag[F_FRG_VMove]=FALSE
          CONTINUE
          TRIGGER  WHEN DISTANCE=1 DELAY=0.0 DO $Flag[F_FRG_VMove]=TRUE ;Freigabe VektorMove Schweissmakro    
          CONTINUE
          TRIGGER  WHEN DISTANCE=1 DELAY=-100.0 DO T_B_Corr(MyCorr) PRIO=-1
          CONTINUE
          IF ($softplcint[EZ_PlcInt[3]]==7) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E1=(act_P1.E1-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[3]]==8) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E2=(act_P1.E2-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[3]]==9) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E3=(act_P1.E3-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[3]]==10) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E4=(act_P1.E4-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[3]]==11) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E5=(act_P1.E5-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
          CONTINUE
          IF ($softplcint[EZ_PlcInt[3]]==12) THEN
            IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
              CONTINUE
	           act_P1.E6=(act_P1.E6-(MyCorrValue*2))
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PTP_MOTION) THEN
	           CONTINUE
              PTP act_P1
            ENDIF
	         CONTINUE
            IF (VW_MPARA_ACT.MOVE_TYPE==#PATH_MOTION) THEN
	           CONTINUE
              LIN act_P1
            ENDIF
          ENDIF
;
        CASE 31 ;EZ3 Service
          IF Mit_KE[3] THEN
            CONTINUE
            MyCorrVal_EK=GetEKVal(EZ3_EK_FBit)
            CONTINUE
            MyCorrVal_GEO=GetGEOVal(EZ3_GEO_FBit)
            CONTINUE
            MyCorrValue=(MyCorrVal_EK+MyCorrVal_GEO)
            CONTINUE
            B_SZ3_VW_EK[1]=(((MyCorrVal_EK*2)>EZ3_Z1_VW_EK) OR $IN[SK_BASE_MA[3]+I_SK_V_Stdm]) ;EZ3-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ3_MAX_EK[1]=(((MyCorrVal_EK*2)>EZ3_Z1_MAX_EK) OR $IN[SZ_BASE_MA[3]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[3]+I_SK_M_Stdm]) ;EZ3-SZ1 Maximale Kappenstandzeit
          ELSE
            CONTINUE
            MyCorrValue=GetEKVal(EZ3_EK_FBit)
            CONTINUE
            B_SZ3_VW_EK[1]=(((MyCorrValue*2)>EZ3_Z1_VW_EK) OR $IN[SK_BASE_MA[3]+I_SK_V_Stdm]) ;EZ3-SZ1 Vorwarnung Kappenstandzeit
            CONTINUE
            B_SZ3_MAX_EK[1]=(((MyCorrValue*2)>EZ3_Z1_MAX_EK) OR $IN[SZ_BASE_MA[3]+I_SZ_F_Kapp] OR $IN[SK_BASE_MA[3]+I_SK_M_Stdm]) ;EZ3-SZ1 Maximale Kappenstandzeit
          ENDIF
          ;Anforderung Normalfraesen
          CONTINUE
          $FLAG[F_SZ_Anw_NF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[3]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[3]+I_SK_Stfr] AND $IN[SZ_BASE_SL[3]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[3]])
          ;Anforderung Startfraesen
          CONTINUE
          $FLAG[F_SZ_Anw_SF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[3]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[3]]) 
;
        CASE 13,14,15,16,23,33 ;nur Trigger
;
        DEFAULT
          SZ_Msg(20,#QuitMsg) ;Falsche Auswahl
;
      ENDSWITCH ;von PAR1
;
;
    ;ENDFOLD (Advance)
;
;***************************************************
  CASE #USR_TRIG
    ;FOLD Trig
;
    IF NOT $FLAG[F_Frg_Servo]==TRUE THEN
      $FLAG[F_Frg_Servo]=TRUE
    ENDIF
;
    SWITCH PAR1
      CASE 10,12 ;EZ1 Schweissen, EZ1 Fraesen
        IF $IN[SK_BASE_SL[1]+I_SK_o_Proz] THEN
          $FLAG[F_o_Proz_BMS]=TRUE
        ELSE
          $FLAG[F_o_Proz_BMS]=FALSE
        ENDIF
        ;Bauteilende(Q-Auswertung)
        $OUT[SK_BASE_MA[1]+O_SK_BTEnde]=FALSE
        IF ($PRO_MODE==#MSTEP) THEN
          WAIT SEC 1.0   ;Wartezeit Kontrolle Zangenoeffnung
        ENDIF
        IF (SO_SK1_Pkt_Nr<>PAR5) OR (SO_SK1_Fzg_Typ<>PAR6) THEN  
          IF NOT Mit_KE[1] THEN
            SO_SZ1_Prg_Nr=PAR2
            SO_SZ1_Fzg_Typ=PAR6
          ENDIF          
          SO_SK1_Pkt_Nr=PAR5
          SO_SK1_Fzg_Typ=PAR6   
          SO_SPS_Proz_Nr=PAR5
          $OUT[O_RIP_SK_Sens]=FALSE
	       WAIT SEC 0.1
        ENDIF
        ;VM Armdurchbiegung verrechnen
        IF Mit_KE[1] THEN
          MyGunValue=(GetGunVal(EZ1_GUN_FBit)/2)
          VISU_Gun=(MyGunValue*10)
          HM_PROZ_EXPECTED=PARAMS_PROG.PROZ_EXPECTED
          PARAMS_PROG.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(MyGunValue/Direction.Directioncart.X)*100)
          VISU_PROG_PROZ=(((Direction.Directioncart.X/100)*PARAMS_PROG.PROZ_EXPECTED)*10)
        ELSE
          MyGunValue=CalcGunVal(EZ1_FORCE_FBit)
          VISU_Gun=(MyGunValue*10)
          HM_PROZ_EXPECTED=PARAMS_PROG.PROZ_EXPECTED
          PARAMS_PROG.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(MyGunValue/Direction.Directioncart.X)*100)
          VISU_PROG_PROZ=(((Direction.Directioncart.X/100)*PARAMS_PROG.PROZ_EXPECTED)*10)
        ENDIF
        IF $IN[SZ_BASE_SL[1]+I_SZ_o_Kra] THEN
          SZ_Msg(47,#NotifyMsg)
        ENDIF
        WAIT FOR (NOT $IN[SZ_BASE_SL[1]+I_SZ_o_Kra] OR $IN[I_R_Quit_Wei])
        $FLAG[F_KW_Wart_AUS]=FALSE
        $FLAG[F_WA_EIN_VSP]=TRUE
        ;Abfrage Kuehlwasser i.O.
        ;FOLD WARTE BIS B_RIP_KW_iO[1] + E26;%{E}%MKUKATPVW %CVW_SPS %VWBOASG %P 2:WARTE BIS B_RIP_KW_iO[1] + E26,3:  WBOASG
        $LOOP_MSG[]="Warte bis Kuehlwasser i.O. + E26"
        $LOOP_CONT=TRUE
        WAIT FOR B_RIP_KW_iO[1] OR $IN[26] OR (NOT $LOOP_CONT AND ($MODE_OP<>#EX))
        $LOOP_MSG[]="                                                                                                                                "
        ;ENDFOLD  
        $FLAG[F_WPS_FRG[1]]=TRUE
        ;Anforderung Normalfraesen
        $FLAG[F_SZ_Anw_NF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[1]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[1]+I_SK_Stfr] AND $IN[SZ_BASE_SL[1]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR ((PAR2>=51) AND (PAR2<=54)) OR $FLAG[F_SZ_Anw_NF[1]]) 
        ;Anforderung Startfraesen
        $FLAG[F_SZ_Anw_SF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[1]]) OR ((PAR2>=41) AND (PAR2<=44)) OR $FLAG[F_SZ_Anw_SF[1]]) 
        IF (PAR5==31) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=TRUE
          $FLAG[F_SZ1_ANW_Z[2]]=FALSE 
          $FLAG[F_SZ1_ANW_Z[3]]=FALSE
          $FLAG[F_SZ1_ANW_Z[4]]=FALSE
        ENDIF   
        IF (PAR5==32) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=FALSE
          $FLAG[F_SZ1_ANW_Z[2]]=TRUE 
          $FLAG[F_SZ1_ANW_Z[3]]=FALSE
          $FLAG[F_SZ1_ANW_Z[4]]=FALSE
        ENDIF 
        IF (PAR5==33) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=FALSE
          $FLAG[F_SZ1_ANW_Z[2]]=FALSE 
          $FLAG[F_SZ1_ANW_Z[3]]=TRUE
          $FLAG[F_SZ1_ANW_Z[4]]=FALSE
        ENDIF 
        IF (PAR5==34) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=FALSE
          $FLAG[F_SZ1_ANW_Z[2]]=FALSE 
          $FLAG[F_SZ1_ANW_Z[3]]=FALSE
          $FLAG[F_SZ1_ANW_Z[4]]=TRUE
        ENDIF
;
      CASE 11 ;EZ1 Service
        IF NOT Mit_KE[1] THEN
          SO_SZ1_Prg_Nr=PAR2
          SO_SZ1_Fzg_Typ=0
        ENDIF
        SO_SK1_Pkt_Nr=PAR5
        SO_SK1_Fzg_Typ=0   
        WAIT SEC 0.1
        ;
        $OUT[SZ_BASE_MA[1]+O_SZ_MvFrae]=FALSE
        $OUT[SZ_BASE_MA[1]+O_SZ_MnFrae]=FALSE
        ;
        IF $IN[SK_BASE_MA[1]+I_SK_KF_erf] THEN
          WAIT SEC 0.1
        ENDIF
        ;
        $FLAG[F_WPS_FRG[1]]=TRUE
        ;
        ;Anforderung Normalfraesen
        $FLAG[F_SZ_Anw_NF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[1]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[1]+I_SK_Stfr] AND $IN[SZ_BASE_SL[1]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR ((PAR2>=51) AND (PAR2<=54)) OR $FLAG[F_SZ_Anw_NF[1]])
        ;Anforderung Startfraesen
        $FLAG[F_SZ_Anw_SF[1]]=(($IN[SK_BASE_MA[1]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[1]]) OR ((PAR2>=41) AND (PAR2<=44)) OR $FLAG[F_SZ_Anw_SF[1]]) 
        ;
        IF (PAR5==31) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=TRUE
          $FLAG[F_SZ1_ANW_Z[2]]=FALSE 
          $FLAG[F_SZ1_ANW_Z[3]]=FALSE
          $FLAG[F_SZ1_ANW_Z[4]]=FALSE
        ENDIF   
        IF (PAR5==32) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=FALSE
          $FLAG[F_SZ1_ANW_Z[2]]=TRUE 
          $FLAG[F_SZ1_ANW_Z[3]]=FALSE
          $FLAG[F_SZ1_ANW_Z[4]]=FALSE
        ENDIF 
        IF (PAR5==33) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=FALSE
          $FLAG[F_SZ1_ANW_Z[2]]=FALSE 
          $FLAG[F_SZ1_ANW_Z[3]]=TRUE
          $FLAG[F_SZ1_ANW_Z[4]]=FALSE
        ENDIF 
        IF (PAR5==34) THEN
          $FLAG[F_SZ1_ANW_Z[1]]=FALSE
          $FLAG[F_SZ1_ANW_Z[2]]=FALSE 
          $FLAG[F_SZ1_ANW_Z[3]]=FALSE
          $FLAG[F_SZ1_ANW_Z[4]]=TRUE
        ENDIF             
;
      CASE 13; EZ1/SZ1 KF-Umdrehung autom. Ermitteln
        IF MIT_Auto_KF AND KF1_Z_aktiv[1] AND ($COUNT_I[36]<>0) THEN
          KF1_Z_aktiv[1]=FALSE
          MyCorrValue=GetEKVal(EZ1_EK_FBit)
          KF_IST_1_1=MyCorrValue
          IF EZ1SZ1_EK_gew THEN
            KF_ALT_1_1=KF_IST_1_1
            EZ1SZ1_EK_gew=FALSE
          ENDIF
          IF (KF_IST_1_1<(KF_ALT_1_1+(KF_EK_Limit_1_1*($COUNT_I[36])))) AND ($COUNT_I[4]<=KF_Umd_Limit) THEN
            KF_COUNT_Pos_1_1=KF_COUNT_Pos_1_1+1
          ENDIF
          IF (KF_IST_1_1>(KF_ALT_1_1+(KF_EK_Limit_1_1*($COUNT_I[36])))) AND ($COUNT_I[4]>KF_Umd_min) THEN
            KF_COUNT_Neg_1_1=KF_COUNT_Neg_1_1+1
          ENDIF
          IF (KF_COUNT_Pos_1_1>=2) THEN
            $COUNT_I[4]=$COUNT_I[4]+1
            KF_COUNT_Pos_1_1=0
            KF_COUNT_Neg_1_1=0
          ENDIF
          IF (KF_COUNT_Neg_1_1>=2) THEN
            $COUNT_I[4]=$COUNT_I[4]-1
            KF_COUNT_Pos_1_1=0
            KF_COUNT_Neg_1_1=0
          ENDIF
          IF ($COUNT_I[4]>KF_Umd_Limit) THEN
            SZ_Msg(11,#NotifyMsg) ;Fraesmesser KF1 defekt
          ENDIF
          KF_ALT_1_1=KF_IST_1_1
          $COUNT_I[36]=0
        ENDIF
;
      CASE 14; EZ1/SZ2 KF-Umdrehung autom. Ermitteln
        IF MIT_Auto_KF AND KF1_Z_aktiv[2] AND ($COUNT_I[36]<>0) THEN
          KF1_Z_aktiv[2]=FALSE
          MyCorrValue=GetEKVal(EZ1_EK_FBit)
          KF_IST_1_2=MyCorrValue
          IF EZ1SZ2_EK_gew THEN
            KF_ALT_1_2=KF_IST_1_2
            EZ1SZ2_EK_gew=FALSE
          ENDIF
          IF (KF_IST_1_2<(KF_ALT_1_2+(KF_EK_Limit_1_2*($COUNT_I[36])))) AND ($COUNT_I[10]<=KF_Umd_Limit) THEN
            KF_COUNT_Pos_1_2=KF_COUNT_Pos_1_2+1
          ENDIF
          IF (KF_IST_1_2>(KF_ALT_1_2+(KF_EK_Limit_1_2*($COUNT_I[36])))) AND ($COUNT_I[10]>KF_Umd_min) THEN
            KF_COUNT_Neg_1_2=KF_COUNT_Neg_1_2+1
          ENDIF
          IF (KF_COUNT_Pos_1_2>=2) THEN
            $COUNT_I[10]=$COUNT_I[10]+1
            KF_COUNT_Pos_1_2=0
            KF_COUNT_Neg_1_2=0
          ENDIF
          IF (KF_COUNT_Neg_1_2>=2) THEN
            $COUNT_I[10]=$COUNT_I[10]-1
            KF_COUNT_Pos_1_2=0
            KF_COUNT_Neg_1_2=0
          ENDIF
          IF ($COUNT_I[10]>KF_Umd_Limit) THEN
            SZ_Msg(11,#NotifyMsg) ;Fraesmesser KF1 defekt
          ENDIF
          KF_ALT_1_2=KF_IST_1_2
          $COUNT_I[36]=0
        ENDIF
;
      CASE 15; EZ1/SZ3 KF-Umdrehung autom. Ermitteln
        IF MIT_Auto_KF AND KF1_Z_aktiv[3] AND ($COUNT_I[36]<>0) THEN
          KF1_Z_aktiv[3]=FALSE
          MyCorrValue=GetEKVal(EZ1_EK_FBit)
          KF_IST_1_3=MyCorrValue
          IF EZ1SZ3_EK_gew THEN
            KF_ALT_1_3=KF_IST_1_3
            EZ1SZ3_EK_gew=FALSE
          ENDIF
          IF (KF_IST_1_3<(KF_ALT_1_3+(KF_EK_Limit_1_3*($COUNT_I[36])))) AND ($COUNT_I[13]<=KF_Umd_Limit) THEN
            KF_COUNT_Pos_1_3=KF_COUNT_Pos_1_3+1
          ENDIF
          IF (KF_IST_1_3>(KF_ALT_1_3+(KF_EK_Limit_1_3*($COUNT_I[36])))) AND ($COUNT_I[13]>KF_Umd_min) THEN
            KF_COUNT_Neg_1_3=KF_COUNT_Neg_1_3+1
          ENDIF
          IF (KF_COUNT_Pos_1_3>=2) THEN
            $COUNT_I[13]=$COUNT_I[13]+1
            KF_COUNT_Pos_1_3=0
            KF_COUNT_Neg_1_3=0
          ENDIF
          IF (KF_COUNT_Neg_1_3>=2) THEN
            $COUNT_I[13]=$COUNT_I[13]-1
            KF_COUNT_Pos_1_3=0
            KF_COUNT_Neg_1_3=0
          ENDIF
          IF ($COUNT_I[13]>KF_Umd_Limit) THEN
            SZ_Msg(11,#NotifyMsg) ;Fraesmesser KF1 defekt
          ENDIF
          KF_ALT_1_3=KF_IST_1_3
          $COUNT_I[36]=0
        ENDIF
;
      CASE 16; EZ1/SZ4 KF-Umdrehung autom. Ermitteln
        IF MIT_Auto_KF AND KF1_Z_aktiv[4] AND ($COUNT_I[36]<>0) THEN
          KF1_Z_aktiv[4]=FALSE
          MyCorrValue=GetEKVal(EZ1_EK_FBit)
          KF_IST_1_4=MyCorrValue
          IF EZ1SZ4_EK_gew THEN
            KF_ALT_1_4=KF_IST_1_4
            EZ1SZ4_EK_gew=FALSE
          ENDIF
          IF (KF_IST_1_4<(KF_ALT_1_4+(KF_EK_Limit_1_4*($COUNT_I[36])))) AND ($COUNT_I[16]<=KF_Umd_Limit) THEN
            KF_COUNT_Pos_1_4=KF_COUNT_Pos_1_4+1
          ENDIF
          IF (KF_IST_1_4>(KF_ALT_1_4+(KF_EK_Limit_1_4*($COUNT_I[36])))) AND ($COUNT_I[16]>KF_Umd_min) THEN
            KF_COUNT_Neg_1_4=KF_COUNT_Neg_1_4+1
          ENDIF
          IF (KF_COUNT_Pos_1_4>=2) THEN
            $COUNT_I[16]=$COUNT_I[16]+1
            KF_COUNT_Pos_1_4=0
            KF_COUNT_Neg_1_4=0
          ENDIF
          IF (KF_COUNT_Neg_1_4>=2) THEN
            $COUNT_I[16]=$COUNT_I[16]-1
            KF_COUNT_Pos_1_4=0
            KF_COUNT_Neg_1_4=0
          ENDIF
          IF ($COUNT_I[16]>KF_Umd_Limit) THEN
            SZ_Msg(11,#NotifyMsg) ;Fraesmesser KF1 defekt
          ENDIF
          KF_ALT_1_4=KF_IST_1_4
          $COUNT_I[36]=0
        ENDIF
;
      CASE 20,22 ;EZ2 Schweissen, EZ2 Fraesen
        IF $IN[SK_BASE_SL[2]+I_SK_o_Proz] THEN
          $FLAG[F_o_Proz_BMS]=TRUE
        ELSE
          $FLAG[F_o_Proz_BMS]=FALSE
        ENDIF
        ;Bauteilende(Q-Auswertung)
        $OUT[SK_BASE_MA[2]+O_SK_BTEnde]=FALSE
        IF ($PRO_MODE==#MSTEP) THEN
          WAIT SEC 1.0   ;Wartezeit Kontrolle Zangenoeffnung
        ENDIF
	     IF NOT Mit_2SZ_an_SK1 THEN
	       IF (SO_SK2_Pkt_Nr<>PAR5) OR (SO_SK2_Fzg_Typ<>PAR6) THEN
            IF NOT Mit_KE[2] THEN
              SO_SZ2_Prg_Nr=PAR2
              SO_SZ2_Fzg_Typ=PAR6
            ENDIF
            SO_SK2_Pkt_Nr=PAR5
            SO_SK2_Fzg_Typ=PAR6  
		      SO_SPS_Proz_Nr=PAR5
            $OUT[O_RIP_SK_Sens]=FALSE
            WAIT SEC 0.1
	       ENDIF
        ELSE
          IF (SO_SK1_Pkt_Nr<>PAR5) OR (SO_SK1_Fzg_Typ<>PAR6) THEN
	         IF NOT Mit_KE[2] THEN
              SO_SZ2_Prg_Nr=PAR2
              SO_SZ2_Fzg_Typ=PAR6
            ENDIF
            SO_SK1_Pkt_Nr=PAR5
	         SO_SK1_Fzg_Typ=PAR6   
		      SO_SPS_Proz_Nr=PAR5
            $OUT[O_RIP_SK_Sens]=TRUE
		      WAIT SEC 0.1
          ENDIF
        ENDIF
        ;VM Armdurchbiegung verrechnen
        IF Mit_KE[2] THEN
          MyGunValue=(GetGunVal(EZ2_GUN_FBit)/2)
          VISU_Gun=(MyGunValue*10)
          HM_PROZ_EXPECTED=PARAMS_PROG.PROZ_EXPECTED
          PARAMS_PROG.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(MyGunValue/Direction.Directioncart.X)*100)
          VISU_PROG_PROZ=(((Direction.Directioncart.X/100)*PARAMS_PROG.PROZ_EXPECTED)*10)
        ELSE
          MyGunValue=CalcGunVal(EZ2_FORCE_FBit)
          VISU_Gun=(MyGunValue*10)
          HM_PROZ_EXPECTED=PARAMS_PROG.PROZ_EXPECTED
          PARAMS_PROG.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(MyGunValue/Direction.Directioncart.X)*100)
          VISU_PROG_PROZ=(((Direction.Directioncart.X/100)*PARAMS_PROG.PROZ_EXPECTED)*10)
        ENDIF
        IF $IN[SZ_BASE_SL[2]+I_SZ_o_Kra] THEN
          SZ_Msg(11,#NotifyMsg)
        ENDIF
        WAIT FOR (NOT $IN[SZ_BASE_SL[2]+I_SZ_o_Kra] OR $IN[I_R_Quit_Wei])
        $FLAG[F_KW_Wart_AUS]=FALSE
        $FLAG[F_WA_EIN_VSP]=TRUE
        ;Abfrage Kuehlwasser i.O.
        ;FOLD WARTE BIS B_RIP_KW_iO[2] + E26;%{E}%MKUKATPVW %CVW_SPS %VWBOASG %P 2:WARTE BIS B_RIP_KW_iO[2] + E26,3:  WBOASG
        $LOOP_MSG[]="Warte bis Kuehlwasser i.O. + E26"
        $LOOP_CONT=TRUE
        WAIT FOR B_RIP_KW_iO[2] OR $IN[26] OR (NOT $LOOP_CONT AND ($MODE_OP<>#EX))
        $LOOP_MSG[]="                                                                                                                                "
        ;ENDFOLD
        $FLAG[F_WPS_FRG[2]]=TRUE
        ;Anforderung Normalfraesen
        $FLAG[F_SZ_Anw_NF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[2]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[2]+I_SK_Stfr] AND $IN[SZ_BASE_SL[2]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[2]])
        ;Anforderung Startfraesen
        $FLAG[F_SZ_Anw_SF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[2]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[2]])        
        ;
        ;Vorwahl Zangen-Nr
        IF (PAR5==31) THEN
          $FLAG[F_SZ2_ANW_Z1]=TRUE
        ENDIF
        ;
      CASE 21 ;EZ2 Service
	     IF NOT Mit_2SZ_an_SK1 THEN
	       IF NOT Mit_KE[2] THEN
            SO_SZ2_Prg_Nr=PAR2
            SO_SZ2_Fzg_Typ=0
          ENDIF
          SO_SK2_Pkt_Nr=PAR5
          SO_SK2_Fzg_Typ=0
        ELSE
          IF NOT Mit_KE[2] THEN
            SO_SZ2_Prg_Nr=PAR2
            SO_SZ2_Fzg_Typ=0
          ENDIF
          SO_SK1_Pkt_Nr=PAR5
	       SO_SK1_Fzg_Typ=0  
        ENDIF   
        WAIT SEC 0.1
        ;
        $FLAG[F_WPS_FRG[2]]=TRUE
        ;
        $OUT[SZ_BASE_MA[2]+O_SZ_MvFrae]=FALSE
        $OUT[SZ_BASE_MA[2]+O_SZ_MnFrae]=FALSE
        ;
        IF $IN[SK_BASE_MA[2]+I_SK_KF_erf] THEN
          WAIT SEC 0.1
        ENDIF
        ;
        ;Anforderung Normalfraesen
        $FLAG[F_SZ_Anw_NF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[2]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[2]+I_SK_Stfr] AND $IN[SZ_BASE_SL[2]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[2]])
        ;Anforderung Startfraesen
        $FLAG[F_SZ_Anw_SF[2]]=(($IN[SK_BASE_MA[2]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[2]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[2]]) 
        ;
        ;Vorwahl Zangen-Nr
        IF (PAR5==31) THEN
          $FLAG[F_SZ2_ANW_Z1]=TRUE
        ENDIF        
;
      CASE 23 ;EZ2/SZ1 KF-Umdrehung autom. Ermitteln
        IF MIT_Auto_KF AND KF2_Z_aktiv AND ($COUNT_I[36]<>0) THEN
          KF2_Z_aktiv=FALSE
          MyCorrValue=GetEKVal(EZ2_EK_FBit)
          KF_IST_2_1=MyCorrValue
          IF EZ2SZ1_EK_gew THEN
            KF_ALT_2_1=KF_IST_2_1
            EZ2SZ1_EK_gew=FALSE
          ENDIF
          IF (KF_IST_2_1<(KF_ALT_2_1+(KF_EK_Limit_2_1*($COUNT_I[36])))) AND ($COUNT_I[7]<=KF_Umd_Limit) THEN
            KF_COUNT_Pos_2_1=KF_COUNT_Pos_2_1+1
          ENDIF
          IF (KF_IST_2_1>(KF_ALT_2_1+(KF_EK_Limit_2_1*($COUNT_I[36])))) AND ($COUNT_I[7]>KF_Umd_min) THEN
            KF_COUNT_Neg_2_1=KF_COUNT_Neg_2_1+1
          ENDIF
          IF (KF_COUNT_Pos_2_1>=2) THEN
            $COUNT_I[7]=$COUNT_I[7]+1
            KF_COUNT_Pos_2_1=0
            KF_COUNT_Neg_2_1=0
          ENDIF
          IF (KF_COUNT_Neg_2_1>=2) THEN
            $COUNT_I[7]=$COUNT_I[7]-1
            KF_COUNT_Pos_2_1=0
            KF_COUNT_Neg_2_1=0
          ENDIF
          IF ($COUNT_I[7]>KF_Umd_Limit) THEN
            SZ_Msg(12,#NotifyMsg) ;Fraesmesser KF2 defekt
          ENDIF
          KF_ALT_2_1=KF_IST_2_1
          $COUNT_I[36]=0
        ENDIF 
;
      CASE 30,32 ;EZ3 Schweissen, EZ3 Fraesen
        IF $IN[SK_BASE_SL[3]+I_SK_o_Proz] THEN
          $FLAG[F_o_Proz_BMS]=TRUE
        ELSE
          $FLAG[F_o_Proz_BMS]=FALSE
        ENDIF
        ;Bauteilende(Q-Auswertung)
        $OUT[SK_BASE_MA[3]+O_SK_BTEnde]=FALSE
        IF ($PRO_MODE==#MSTEP) THEN
          WAIT SEC 1.0   ;Wartezeit Kontrolle Zangenoeffnung
        ENDIF 
        IF (SO_SK3_Pkt_Nr<>PAR5) OR (SO_SK3_Fzg_Typ<>PAR6) THEN  
          IF NOT Mit_KE[3] THEN
            SO_SZ3_Prg_Nr=PAR2
            SO_SZ3_Fzg_Typ=PAR6  
          ENDIF
          SO_SK3_Pkt_Nr=PAR5
          SO_SK3_Fzg_Typ=PAR6   
          SO_SPS_Proz_Nr=PAR5
	       WAIT SEC 0.1
        ENDIF
        ;VM Armdurchbiegung verrechnen
        IF Mit_KE[3] THEN
          MyGunValue=(GetGunVal(EZ3_GUN_FBit)/2)
          VISU_Gun=(MyGunValue*10)
          HM_PROZ_EXPECTED=PARAMS_PROG.PROZ_EXPECTED
          PARAMS_PROG.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(MyGunValue/Direction.Directioncart.X)*100)
          VISU_PROG_PROZ=(((Direction.Directioncart.X/100)*PARAMS_PROG.PROZ_EXPECTED)*10)
        ELSE
          MyGunValue=CalcGunVal(EZ3_FORCE_FBit)
          VISU_Gun=(MyGunValue*10)
          HM_PROZ_EXPECTED=PARAMS_PROG.PROZ_EXPECTED
          PARAMS_PROG.PROZ_EXPECTED=(PARAMS_PROG.PROZ_EXPECTED+(MyGunValue/Direction.Directioncart.X)*100)
          VISU_PROG_PROZ=(((Direction.Directioncart.X/100)*PARAMS_PROG.PROZ_EXPECTED)*10)
        ENDIF
        IF $IN[SZ_BASE_SL[3]+I_SZ_o_Kra] THEN
          SZ_Msg(11,#NotifyMsg)
        ENDIF
        WAIT FOR (NOT $IN[SZ_BASE_SL[3]+I_SZ_o_Kra] OR $IN[I_R_Quit_Wei])
        $FLAG[F_KW_Wart_AUS]=FALSE
        $FLAG[F_WA_EIN_VSP]=TRUE
        ;Abfrage Kuehlwasser i.O.
        ;FOLD WARTE BIS B_RIP_KW_iO[3] + E26;%{E}%MKUKATPVW %CVW_SPS %VWBOASG %P 2:WARTE BIS B_RIP_KW_iO[3] + E26,3:  WBOASG
        $LOOP_MSG[]="Warte bis Kuehlwasser i.O. + E26"
        $LOOP_CONT=TRUE
        WAIT FOR B_RIP_KW_iO[3] OR $IN[26] OR (NOT $LOOP_CONT AND ($MODE_OP<>#EX))
        $LOOP_MSG[]="                                                                                                                                "
        ;ENDFOLD       
        $FLAG[F_WPS_FRG[3]]=TRUE
        ;Anforderung Normalfraesen
        $FLAG[F_SZ_Anw_NF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[3]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[3]+I_SK_Stfr] AND $IN[SZ_BASE_SL[3]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[3]]) 
        ;Anforderung Startfraesen
        $FLAG[F_SZ_Anw_SF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[3]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[3]])       
        ;
        ;Vorwahl Zangen-Nr
        IF (PAR5==31) THEN
          $FLAG[F_SZ3_ANW_Z1]=TRUE
        ENDIF
        ;
      CASE 31 ;EZ3 Service
        IF NOT Mit_KE[3] THEN
          SO_SZ3_Prg_Nr=PAR2
          SO_SZ3_Fzg_Typ=0 
        ENDIF
        SO_SK3_Pkt_Nr=PAR5
        SO_SK3_Fzg_Typ=0  
        WAIT SEC 0.1
        ;
        $OUT[SZ_BASE_MA[3]+O_SZ_MvFrae]=FALSE
        $OUT[SZ_BASE_MA[3]+O_SZ_MnFrae]=FALSE
        ;
        IF $IN[SK_BASE_MA[3]+I_SK_KF_erf] THEN
          WAIT SEC 0.1
        ENDIF
        ;
        $FLAG[F_WPS_FRG[3]]=TRUE
        ;
        ;Anforderung Normalfraesen
        $FLAG[F_SZ_Anw_NF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Normfr] AND NOT $IN[SK_BASE_MA[3]+I_SK_Stfr]) OR (NOT $IN[SK_BASE_MA[3]+I_SK_Stfr] AND $IN[SZ_BASE_SL[3]+I_SZ_Anw_Fra]) OR $FLAG[F_SZ_o_Wiedh] OR (PAR2==51) OR $FLAG[F_SZ_Anw_NF[3]])
        ;Anforderung Startfraesen
        $FLAG[F_SZ_Anw_SF[3]]=(($IN[SK_BASE_MA[3]+I_SK_Stfr] AND NOT $FLAG[F_SZ_Anw_NF[3]]) OR (PAR2==41) OR $FLAG[F_SZ_Anw_SF[3]])     
        ;
        ;Vorwahl Zangen-Nr
        IF (PAR5==31) THEN
          $FLAG[F_SZ3_ANW_Z1]=TRUE
        ENDIF  
;
      CASE 33 ;EZ3/SZ1 KF-Umdrehung autom. Ermitteln
        IF MIT_Auto_KF AND KF3_Z_aktiv AND ($COUNT_I[36]<>0) THEN
          KF3_Z_aktiv=FALSE
          MyCorrValue=GetEKVal(EZ3_EK_FBit)
          KF_IST_3_1=MyCorrValue
          IF EZ3SZ1_EK_gew THEN
            KF_ALT_3_1=KF_IST_3_1
            EZ3SZ1_EK_gew=FALSE
          ENDIF
          IF (KF_IST_3_1<(KF_ALT_3_1+(KF_EK_Limit_3_1*($COUNT_I[36])))) AND ($COUNT_I[19]<=KF_Umd_Limit) THEN
            KF_COUNT_Pos_3_1=KF_COUNT_Pos_3_1+1
          ENDIF
          IF (KF_IST_3_1>(KF_ALT_3_1+(KF_EK_Limit_3_1*($COUNT_I[36])))) AND ($COUNT_I[19]>KF_Umd_min) THEN
            KF_COUNT_Neg_3_1=KF_COUNT_Neg_3_1+1
          ENDIF
          IF (KF_COUNT_Pos_3_1>=2) THEN
            $COUNT_I[19]=$COUNT_I[19]+1
            KF_COUNT_Pos_3_1=0
            KF_COUNT_Neg_3_1=0
          ENDIF
          IF (KF_COUNT_Neg_3_1>=2) THEN
            $COUNT_I[19]=$COUNT_I[19]-1
            KF_COUNT_Pos_3_1=0
            KF_COUNT_Neg_3_1=0
          ENDIF
          IF ($COUNT_I[19]>KF_Umd_Limit) THEN
            SZ_Msg(13,#NotifyMsg) ;Fraesmesser KF3 defekt
          ENDIF
          KF_ALT_3_1=KF_IST_3_1
          $COUNT_I[36]=0
        ENDIF
;
      DEFAULT
        SZ_Msg(19,#QuitMsg) ;Falsche Auswahl
    ENDSWITCH ;von PAR1    
;
    ;ENDFOLD (TRIG)    
;
;***************************************************
  CASE #USR_MAIN
    ;FOLD Main
;
    VISU_Gun=0
    VISU_PROG_PROZ=0
    PARAMS_PROG.PROZ_EXPECTED=HM_PROZ_EXPECTED
    $FLAG[F_o_Proz_BMS]=FALSE
    FOR i=1 TO 3
      $FLAG[F_WPS_FRG[i]]=FALSE
    ENDFOR
;
    ;FOLD Rueckbewegung EZ1, EZ2, EZ3
    Weg=PAR4
    SWITCH PAR1
      CASE 10,20,30
        ;+X Rueckbewegung
        IF (($PRO_MODE==#GO) OR ($MODE_OP==#EX)) THEN
	       MyCorrWeg=$NULLFRAME
	       MyCorrWeg.X=-(Weg*0.1)
	       IF (Weg>9) THEN
	         PTP $Pos_act:MyCorrWeg C_PTP
	       ENDIF
        ENDIF
        ;
        ;Bauteilende(Q-Auswertung)
        IF (PAR7==1) THEN
          i=(PAR1/10)
          $OUT[SK_BASE_MA[i]+O_SK_BTEnde]=TRUE
        ENDIF
;
      CASE 11,12 ;EZ1 Service
      CASE 13,14,15,16,23,33 ;nur Trigger
      CASE 21,22 ;EZ2 Service
      CASE 31,32 ;EZ3 Service
;
      DEFAULT
        SZ_Msg(20,#QuitMsg) ;Falsche Auswahl
    ENDSWITCH ;von PAR1
    ;ENDFOLD
;

;
    ;ENDFOLD (Main)
;
;***************************************************
  CASE #USR_MAKRO
    ;FOLD MAKRO
;
    SWITCH PAR1
      CASE 10
        IF Mit_KE[1] THEN
          IF (b_Stoss_akt==FALSE) AND (((SO_SK1_Pkt_Nr>30) AND (SO_SK1_Pkt_Nr<41)) OR (SO_SK1_Pkt_Nr>98)) THEN
            SWITCH Par2
              CASE 1
                IF (varState("$VMState.active")<>#Initialized) THEN
                  GunBalanceOnProgram(1)
                  GunBal_Halt=FALSE
                ELSE  
                  IF ($VMState.active==FALSE) THEN
                    GunBalanceOnProgram(1)
                    GunBal_Halt=FALSE
                  ENDIF  
                ENDIF  
              CASE 2
                IF (GunBal_Halt==FALSE) THEN
                  GunBalanceHold()
                  GunBal_Halt=TRUE
                ENDIF  
              CASE 3
                GunBalanceOff(1)
                GunBal_Halt=FALSE
            ENDSWITCH
          ENDIF  
        ELSE
          IF (b_Stoss_akt==FALSE) AND (((SO_SZ1_Prg_Nr>30) AND (SO_SZ1_Prg_Nr<41)) OR (SO_SZ1_Prg_Nr>98)) THEN
            SWITCH Par2
              CASE 1
                IF (varState("$VMState.active")<>#Initialized) THEN
                  GunBalanceOnProgram(1)
                  GunBal_Halt=FALSE
                ELSE  
                  IF ($VMState.active==FALSE) THEN
                    GunBalanceOnProgram(1)
                    GunBal_Halt=FALSE
                  ENDIF  
                ENDIF  
              CASE 2
                IF (GunBal_Halt==FALSE) THEN
                  GunBalanceHold()
                  GunBal_Halt=TRUE
                ENDIF  
              CASE 3
                GunBalanceOff(1)
                GunBal_Halt=FALSE
            ENDSWITCH
          ENDIF	
        ENDIF
;
	   CASE 20
        IF Mit_KE[2] THEN
          IF (((SO_SK2_Pkt_Nr>30) AND (SO_SK2_Pkt_Nr<41)) OR (SO_SK2_Pkt_Nr>98)) THEN
            SWITCH Par2
              CASE 1
                IF (varState("$VMState.active")<>#Initialized) THEN
                  GunBalanceOnProgram(2)
                  GunBal_Halt=FALSE
                ELSE  
                  IF ($VMState.active==FALSE) THEN
                    GunBalanceOnProgram(2)
                    GunBal_Halt=FALSE
                  ENDIF  
                ENDIF              
              CASE 2
                IF (GunBal_Halt==FALSE) THEN
                  GunBalanceHold()
                  GunBal_Halt=TRUE
                ENDIF  
              CASE 3
                GunBalanceOff(2)
                GunBal_Halt=FALSE
            ENDSWITCH
	       ENDIF	
        ELSE  
          IF (((SO_SZ2_Prg_Nr>30) AND (SO_SZ2_Prg_Nr<41)) OR (SO_SZ2_Prg_Nr>98)) THEN
            SWITCH Par2
              CASE 1
                IF (varState("$VMState.active")<>#Initialized) THEN
                  GunBalanceOnProgram(2)
                  GunBal_Halt=FALSE
                ELSE  
                  IF ($VMState.active==FALSE) THEN
                    GunBalanceOnProgram(2)
                    GunBal_Halt=FALSE
                  ENDIF  
                ENDIF              
              CASE 2
                IF (GunBal_Halt==FALSE) THEN
                  GunBalanceHold()
                  GunBal_Halt=TRUE
                ENDIF  
              CASE 3
                GunBalanceOff(2)
                GunBal_Halt=FALSE
            ENDSWITCH
	       ENDIF	
        ENDIF
;
      CASE 30
        IF Mit_KE[3] THEN
          IF (((SO_SK3_Pkt_Nr>30) AND (SO_SK3_Pkt_Nr<41)) OR (SO_SK3_Pkt_Nr>98)) THEN
            SWITCH PAR2
              CASE 1
                IF (varState("$VMState.active")<>#Initialized) THEN
                  GunBalanceOnProgram(3)
                  GunBal_Halt=FALSE
                ELSE  
                  IF ($VMState.active==FALSE) THEN
                    GunBalanceOnProgram(3)
                    GunBal_Halt=FALSE
                  ENDIF  
                ENDIF              
              CASE 2
                IF (GunBal_Halt==FALSE) THEN
                  GunBalanceHold()
                  GunBal_Halt=TRUE
                ENDIF  
              CASE 3
                GunBalanceOff(3)
                GunBal_Halt=FALSE
            ENDSWITCH
	       ENDIF	
        ELSE  
          IF (((SO_SZ3_Prg_Nr>30) AND (SO_SZ3_Prg_Nr<41)) OR (SO_SZ3_Prg_Nr>98)) THEN
            SWITCH Par2
              CASE 1
                IF (varState("$VMState.active")<>#Initialized) THEN
                  GunBalanceOnProgram(3)
                  GunBal_Halt=FALSE
                ELSE  
                  IF ($VMState.active==FALSE) THEN
                    GunBalanceOnProgram(3)
                    GunBal_Halt=FALSE
                  ENDIF  
                ENDIF   
              CASE 2
                IF (GunBal_Halt==FALSE) THEN
                  GunBalanceHold()
                  GunBal_Halt=TRUE
                ENDIF  
              CASE 3
                GunBalanceOff(3)
                GunBal_Halt=FALSE
            ENDSWITCH
	       ENDIF
        ENDIF
    ENDSWITCH
;
    ;ENDFOLD  
  DEFAULT
;
ENDSWITCH ;(USER_CMD)
END
;
;ENDFOLD (S_Zangen Interface)
