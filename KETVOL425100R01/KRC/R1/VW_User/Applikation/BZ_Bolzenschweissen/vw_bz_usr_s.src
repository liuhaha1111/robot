;
END
;
;FOLD INIT BZ 
GLOBAL DEF BZ_INIT( )
INT i
;
;FOLD Version Techpaket
Tech_BZ.Name[]="KS26.01.001_20190612"
;ENDFOLD
;
;FOLD Vorbesetzung Meldungsausgabe
FOR i=1 TO 100
  n_BZS_Handle[i]=-1
  n_BZR_Handle[i]=-1
ENDFOR
;ENDFOLD
;
;FOLD BZ BASE ADRESSEN INITIALISIEREN
BZ_BASE_INIT( )
;ENDFOLD
;
END
;ENDFOLD
;
;***************************************************
;FOLD SAW BZ 
GLOBAL DEF BZ_SAW(BZNr: IN)
INT i,BZNr
;
;
END
