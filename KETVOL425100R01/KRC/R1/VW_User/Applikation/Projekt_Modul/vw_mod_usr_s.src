;***************************************************
;FOLD INIT MOD3
GLOBAL DEF MOD3_INIT( )
INT i
;
;Version Techpaket
Tech_MOD3.Name[]="KS26.01.001_20180122"
;
;Vorbesetzung Meldungsausgabe
FOR i=1 TO 100
  n_MOD3S_Handle[i]=-1
  n_MOD3R_Handle[i]=-1
ENDFOR
;DZ Init Spanngruppenrichtungsmerker
DZ_busy=TRUE
  DZ_fm=FALSE
  FOR i = 1 TO AnzSpnGr
    dzSpnGrYr[i]=0
    dzSpnGrKe[i]=0
  ENDFOR
DZ_busy=FALSE
;
;
END
;ENDFOLD
