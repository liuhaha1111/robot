;
;***************************************************
SWITCH USER_CMD
;
;***************************************************
  CASE #USR_INIT
    ;FOLD Init
    ;
    ;
    ;ENDFOLD (Init)
;
;***************************************************
  CASE #USR_ADV
    ;FOLD Advance
;
    SWITCH CMD_SEL
;
      CASE 104    
        SWITCH PAR1
          CASE 8  ;Auswahl MS1
            CONTINUE
            IF $IN[MS_BASE_SL[1]+I_MS_o_Proz] THEN
              CONTINUE
              $FLAG[F_o_Proz_BMS]=TRUE
            ELSE
              CONTINUE
              $FLAG[F_o_Proz_BMS]=FALSE
            ENDIF
            CONTINUE
            SO_SPS_Proz_Nr=PAR6
            SWITCH PAR2
              CASE 1
                WHILE ((PAR6<1) OR (PAR6>100))
                  MS_Msg(25,#QuitMsg) ; PAR6 Falscher Wert
                ENDWHILE
                IF (PAR3==2) THEN
                  FOR i=1 TO 100
                    MS_Naht_Nr_iO[i]=FALSE
                    MS_Naht_Nr_wied[i]=FALSE
                  ENDFOR
                ENDIF
                IF (PAR3==1) AND MS_Naht_Nr_wied[PAR6] THEN
                  MS_Naht_wied=TRUE ; Nahtwiederholung angewaehlt
                ENDIF
                IF (PAR3==0) THEN
                  MS_Naht_wied=FALSE
                ENDIF
                IF NOT MS_Naht_Nr_iO[PAR6] THEN
                  CONTINUE
                  $FLAG[F_FRG_LB_Ein]=TRUE ;Freigabe Lichtbogen Ein
                ELSE
                  CONTINUE
                  $FLAG[F_FRG_LB_Ein]=FALSE
                ENDIF
                IF MIT_MS_SUCH THEN
                  MS_HILF=PAR5
