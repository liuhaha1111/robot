     $out[RZ_6]=TRUE
   ENDSWITCH
   endif
  ;ENDFOLD
;
 else
  if $async_axis==0 then
  for i=1 to 6
    $out[RZ_1+((i-1)*32)]=true
  endfor
  if $ex_kin.et1<>#ersys then
	for b=1 to ($ex_ax_num)
	  if b==1 then
        a=1
	  else	
       a=a*2
      endif
      c=(a B_AND $async_axis)
	  if ((a B_AND $async_axis) > 0) then
       if b>3 then
       $out[RZ_4+b-1]=false
       else
	    $out[RZ_1+((b-1)*32)]=false
       endif
	  else
       if b>3 then
         $out[RZ_4+b-1]=true
       else
         $out[RZ_1+((b-1)*32)]=true
       endif
	  endif
    endfor
  else
   ; Roboter steht auf Verfahrachse
	for b=2 to ($ex_ax_num)
	  if b==2 then
        a=1
	  else	
       a=a*2
      endif
	c=(a B_AND $async_axis)
	  if ((a B_AND $async_axis) >0) then
       if b>4 then
         $out[RZ_4+b-2]=false
       else
	    $out[RZ_1+((b-2)*32)]=false
       endif
	  else
       if b>4 then
         $out[RZ_4+b-2]=true
       else
	    $out[RZ_1+((b-2)*32)]=true
       endif
	  endif
    endfor
  endif
 endif  
endif
;
ENDIF

;***************************************************
;KS schwenken
FOR i=1 TO 3
  IF $OUT[O_R_Hand] AND NOT $OUT[O_R_Proz_akt] AND $OUT[O_KS_Schw[i]] THEN
    IF $OUT[SG_RZ_Open[i]]==TRUE THEN
	 $OUT[KF_BASE_MA[i]+O_KF_versetzen]=TRUE
     $OUT[KF_BASE_MA[i]+O_KS_M_EIN]=($IN[KF_BASE_MA[i]+I_KF_INI] OR NOT KF_mit_VE[i])
    ENDIF
  ELSE
    $OUT[O_KS_Schw[i]]=FALSE
  ENDIF
ENDFOR
;***************************************************
;
;Ausgabe RSK Statusmeldungen an BMS
;
;Fehler KS Motor/Endlage
$OUT[O_RSK_F_KS]=$OUT[O_R_Auto] AND ($FLAG[F_RSK_KS_R] OR $FLAG[F_RSK_KS_A])
;Fehler KF Motor/Initiator
$OUT[O_RSK_F_KF]=$OUT[O_R_Auto] AND ($FLAG[F_F_Schwenker] OR $FLAG[F_RSK_KF] OR $FLAG[F_KF_MoS_nio] OR $FLAG[F_KW_MoS_nio] OR $FLAG[F_KL_MoS_nio])
;Fehler Kurzschlussschweissung
$OUT[O_RSK_F_Kurz]=$OUT[O_R_Auto] AND $FLAG[F_RSK_Kurz]
;Sammelstoerung
$OUT[O_RSK_F_Sammel]=$OUT[O_R_Auto] AND $OUT[O_R_PERI_RDY] AND ($FLAG[F_RSK_KF] OR $FLAG[F_RSK_KS_R] OR $FLAG[F_RSK_KS_A] OR $FLAG[F_RSK_Kraft] OR $FLAG[F_RSK_Mess] OR $FLAG[F_RSK_Kurz] OR $FLAG[F_RSK_Vers] OR $FLAG[F_RSK_Sammel] OR $FLAG[F_KF_KS_ZS_S])
;
;***************************************************
;
;Ausgabe KW Statusmeldungen an BMS
FOR i=1 TO 3
  IF MIT_KW[i] THEN
	;Prozess aktiv
	$OUT[KW_BASE_SL[i]+O_KW_Proz_akt]=$FLAG[F_KW_Proz_akt[i]]
	;Beim Kappenwechsel
	$OUT[KW_BASE_SL[i]+O_KW_b_Wechsel]=$FLAG[F_KW_Proz_akt[i]] AND $FLAG [F_KW_BMS_Anw[i]]
    ;Kappen Magazin oben/unten leer
    $OUT[KW_BASE_SL[i]+O_KW_Mag_leer]=NOT $IN[KW_BASE_MA[i]+I_KW_MZ1_leer] OR NOT $IN[KW_BASE_MA[i]+I_KW_MZ2_leer]
	;Fehler Kappe loesen
		;$OUT[KW_BASE_SL[i]+O_KW_Kap_loesen]=$OUT[O_R_Auto]
    ;Fehler Kappe setzen
    $OUT[KW_BASE_SL[i]+O_KW_Feh_setz]=$OUT[KW_BASE_SL[i]+O_KW_Proz_akt] AND $FLAG[F_KW_Sammel[i]]
	;Fehler KF Motor/Initiator
	$OUT[KW_BASE_SL[i]+O_KW_Feh_KF]=$OUT[O_R_Auto] AND $FLAG[F_RSK_KF]
	;KW Motorschutz hat ausgeloest!
	$OUT[KW_BASE_SL[i]+O_KW_Motorschutz]=NOT $IN[KW_BASE_MA[i]+I_KW_Motorschutz]
    ;Sammelstoerung
    $OUT[KW_BASE_SL[i]+O_KW_Sammel]=$OUT[O_R_Auto] AND $COULD_START_MOTION AND ($OUT[KW_BASE_SL[i]+O_KW_Feh_setz] OR $OUT[KW_BASE_SL[i]+O_KW_Mag_leer] OR $FLAG[F_KW_Sammel[i]])
		;$OUT[KW_BASE_SL[i]+O_KW_Proz_akt]=$FLAG[F_KW_Proz_akt[i]]
		;$OUT[KW_BASE_SL[i]+O_KW_b_Wechsel]=$FLAG[F_KW_Proz_akt[i]]
	
  ENDIF
  $FLAG[F_m_KW[i]]=MIT_KW[i]
  $FLAG[F_Braeuer]=KW_Braeuer
  $FLAG[F_Lutz]=KW_Lutz
  $FLAG[F_AEG]=KW_AEG
  $FLAG[F_Sintherleghe]=KW_Sintherleghe
ENDFOR
;
;
;
END
