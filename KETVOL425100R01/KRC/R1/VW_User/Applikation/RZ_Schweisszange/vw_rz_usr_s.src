;
;***************************************************
;FOLD KW_BASE_INIT
DEF KW_BASE_INIT()
BOOL bRet
INT BaseResult
;
;KW SLAVE ADRESSIERUNG
BaseResult=BaseCheck(CF_KW_BASE_SL[1])
IF (BaseResult<>0) THEN
  CF_KW_BASE_SL[1]=HM_BASE_SL
  KW_BASE_SL[1]=HM_BASE_SL
ELSE
  KW_BASE_SL[1]=CF_KW_BASE_SL[1]
ENDIF
;
BaseResult=BaseCheck(CF_KW_BASE_SL[2])
IF (BaseResult<>0) THEN
  CF_KW_BASE_SL[2]=HM_BASE_SL
  KW_BASE_SL[2]=HM_BASE_SL
ELSE
  KW_BASE_SL[2]=CF_KW_BASE_SL[2]
ENDIF
;
BaseResult=BaseCheck(CF_KW_BASE_SL[3])
IF (BaseResult<>0) THEN
  CF_KW_BASE_SL[3]=HM_BASE_SL
  KW_BASE_SL[3]=HM_BASE_SL
ELSE
  KW_BASE_SL[3]=CF_KW_BASE_SL[3]
ENDIF
;
;KW MASTER ADRESSIERUNG
KW_BASE_MA[1]=857                             
KW_BASE_MA[2]=1017
KW_BASE_MA[3]=1177
;
END
;ENDFOLD (KW_BASE_INIT)
