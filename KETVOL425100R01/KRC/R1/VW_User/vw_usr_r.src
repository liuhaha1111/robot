    VMT_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
    ;ENDFOLD (VMT GlueBead TRIG)
;
;***************************************************
  CASE 801 ; Hauptgruppe 8, Untergruppe 1
    ;FOLD KG-XML
    VIS_Intrface(#USR_TRIG, CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) ;EKI KUKA--COGNEX
    ;ENDFOLD
;
;***************************************************
  CASE 806 ; Hauptgruppe 8, Untergruppe 6
