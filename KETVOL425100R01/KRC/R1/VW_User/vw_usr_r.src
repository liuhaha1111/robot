;
;***************************************************
  CASE 308 ; Hauptgruppe 3, Untergruppe 8
    ;FOLD TraceCollector
    xStartPos=$AXIS_ACT
    xStartPosSave=xStartPos
    PTP xStartPos
    IF tcoTraceCollectionActive THEN
      $TRACE.MODE=#T_STOP
      WAIT FOR ($TRACE.STATE==#T_END)
      IF ($OV_PRO<>100) THEN
        MsgNotify("Trace wird nicht ausgefuhert: Override <> 100%","VW TraceCollector",,,5)
      ELSE
        IF ($MODE_OP<>#EX) THEN
          MsgNotify("Trace wird nicht ausgefuhert: $MODE_OP <> #EX","VW TraceCollector",,,5)
        ELSE
          $TRACE.NAME[]=TcoTraceFileName[]
          $TRACE.CONFIG[]=TcoTraceConfigName[]
          $TRACE.MODE=#T_START
          vw_logging("TrCollOn", $MOT_TEMP[1], $MOT_TEMP[2], $MOT_TEMP[3], $MOT_TEMP[4], $MOT_TEMP[5], $MOT_TEMP[6], , , , , , , , )
          MsgNotify("Traceaufzeichnung gestartet!","VW TraceCollector",,,5)
        ENDIF   
      ENDIF
    ENDIF
    NumberOfAxis=0
    NumberOfAxis=PAR1
    $OUT[O_R_Analyse_aktiv]=TRUE
    FOR i=1 TO NumberOfAxis
      SWITCH i
        CASE 1
          xStartPos.a1=xStartPosSave.a1-MyAxMove[NumberOfAxis].NegMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement 
          xStartPos.a1=xStartPosSave.a1+MyAxMove[NumberOfAxis].PosMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos=xStartPosSave
          PTP xStartPos ;Rueckpositionieren auf Ausgangsposition
          WAIT SEC WaitBetweenMovement
        CASE 2
          xStartPos.a2=xStartPosSave.a2-MyAxMove[NumberOfAxis].NegMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos.a2=xStartPosSave.a2+MyAxMove[NumberOfAxis].PosMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos=xStartPosSave
          PTP xStartPos ;Rueckpositionieren auf Ausgangsposition
          WAIT SEC WaitBetweenMovement
        CASE 3
          xStartPos.a3=xStartPosSave.a3-MyAxMove[NumberOfAxis].NegMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos.a3=xStartPosSave.a3+MyAxMove[NumberOfAxis].PosMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos=xStartPosSave
          PTP xStartPos ;Rueckpositionieren auf Ausgangsposition
          WAIT SEC WaitBetweenMovement
        CASE 4     
          xStartPos.a4=xStartPosSave.a4-MyAxMove[NumberOfAxis].NegMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos.a4=xStartPosSave.a4+MyAxMove[NumberOfAxis].PosMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos=xStartPosSave
          PTP xStartPos ;Rueckpositionieren auf Ausgangsposition
          WAIT SEC WaitBetweenMovement
        CASE 5
          xStartPos.a5=xStartPosSave.a5-MyAxMove[NumberOfAxis].NegMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos.a5=xStartPosSave.a5+MyAxMove[NumberOfAxis].PosMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement 
          xStartPos=xStartPosSave
          PTP xStartPos ;Rueckpositionieren auf Ausgangsposition
          WAIT SEC WaitBetweenMovement
        CASE 6
          xStartPos.a6=xStartPosSave.a6-MyAxMove[NumberOfAxis].NegMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos.a6=xStartPosSave.a6+MyAxMove[NumberOfAxis].PosMove
          PTP xStartPos
          WAIT SEC WaitBetweenMovement
          xStartPos=xStartPosSave
          PTP xStartPos ;Rueckpositionieren auf Ausgangsposition
          WAIT SEC WaitBetweenMovement
        ENDSWITCH          
      ENDFOR
      IF ($TRACE.MODE<>#T_STOP) THEN
        $TRACE.MODE=#T_STOP
        WAIT FOR ($TRACE.STATE==#T_END)
        vw_logging("TrCollOff", $MOT_TEMP[1], $MOT_TEMP[2], $MOT_TEMP[3], $MOT_TEMP[4], $MOT_TEMP[5], $MOT_TEMP[6], , , , , , , , )
        MsgNotify("Traceaufzeichnung beendet!","VW TraceCollector",,,5)
        WAIT SEC 10
      ENDIF 
      $OUT[O_R_Analyse_aktiv]=FALSE ;Start Archivierung
   ;ENDFOLD
