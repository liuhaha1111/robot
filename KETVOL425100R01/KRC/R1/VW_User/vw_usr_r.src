  CASE 1001 ; Hauptgruppe 10, Untergruppe 1
    ;FOLD Perceptron
    PRC_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)  
