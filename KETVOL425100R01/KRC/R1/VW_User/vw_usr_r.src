      SEL_RES=SELECT(#MAKRO,0,TRUE,,,,,FALSE)
    ENDIF
    IF (PAR1==2) THEN
      $TIMER_STOP[1]=TRUE
      $TIMER[2]= $TIMER[1]
      $TIMER_STOP[2]=TRUE
    ENDIF
    IF (PAR1==3) THEN
      $TIMER_STOP[3]=TRUE
      $TIMER[3]=0
      $TIMER_STOP[3]=FALSE
    ENDIF
    IF (PAR1==4) THEN
      $TIMER_STOP[3]=TRUE
      $TIMER[4]=$TIMER[3]
      $TIMER_STOP[4]=TRUE
    ENDIF
    ;ENDFOLD
