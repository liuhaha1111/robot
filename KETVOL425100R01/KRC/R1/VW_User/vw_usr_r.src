  CASE 701 ; Hauptgruppe 7, Untergruppe 1
    ;FOLD VMT
    VMT_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
    ;ENDFOLD (VMT BK TRIG)
;
;***************************************************
  CASE 702 ; Hauptgruppe 7, Untergruppe 2
    ;FOLD VMT  
    VMT_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)  
   ;ENDFOLD (VMT Toolbox TRIG)
;
;***************************************************
  CASE 703 ; Hauptgruppe 7, Untergruppe 3
