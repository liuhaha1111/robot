&ACCESS  R
&COMMENT KS_26_01_0083 VW (Tech_Basic)
&PARAM DISKPATH = VW_User
&PARAM TPUSER_VERSION = 8.3.0
&PARAM EDITMASK = vw_usr_r
&PARAM TEMPLATE = C:\KRC\Roboter\Template\vw_usr_rv
&PARAM SUPPRESS = LoosOfPrecision UnswitchedEnum UnusedFunctionParamete
&REL 437
DEF VW_USR_R(USER_CMD :IN,CMD_SEL:IN,PARA1:IN,PARA2:IN,PARA3:IN,PARA4:IN,PARA5:IN,PARA6:IN,PARA7:IN,PARA8:IN,PARA9:IN,PARA10:IN )
;
;FOLD ;%{H}%MKUKATPVW
;VW_USER Call
DECL VW_USER_CMD USER_CMD
REAL PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9
BOOL PARA10
INT CMD_SEL
SWITCH  USER_CMD
CASE #USR_INIT
USER_INIT ()
CASE #USR_ADV
USER_ADV (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_TRIG
USER_TRIG (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAIN
USER_MAIN (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
CASE #USR_MAKRO
USER_MAKRO (CMD_SEL,PARA1,PARA2,PARA3,PARA4,PARA5,PARA6,PARA7,PARA8,PARA9,PARA10)
DEFAULT
ENDSWITCH
END
;XENDFOLD hidden fold ueber ganzen user MUE 18.2
;***************************************************
;FOLD USER_INIT
DEF  USER_INIT ()
;Aufruf am Programmanfang
;
;***************************************************
;* Basis-Technologiepaket                          *
;*                                                 *
;*Konzernstandard                                  *
;*Bearbeiter: C. Eisenknappl AUDI AG I/PG-C61      *
;*                                                 *
;* Aenderungsjournal:                              *
;* 2018.11.08 KL Merker angepasst                  *
;*                                                 *
;***************************************************
;
INT I
BOOL bRet
;
;FOLD Folgenummer spiegeln in Hand
IF ($MODE_OP<>#EX) THEN
  PRG_NR_REFL=P_SELECT
ENDIF
;ENDFOLD
;
;FOLD Arbeitspunktzaehler ruecksetzen
IF ($COUNT_I[I_Arbpkt_Nr]<>0) THEN
  $COUNT_I[I_Arbpkt_Nr]=0
ENDIF 
;ENDFOLD
;
;FOLD Merker und Timer Initialisierung
SEL_RES=SELECT(#MAKRO,50,TRUE,,,,,FALSE)
SEL_RES=SELECT(#MAKRO,57,TRUE,,,,,FALSE)
IF (B_Anlauf==TRUE) THEN
  $TIMER_STOP[12]=TRUE
  $TIMER[12]=0
  $TIMER_STOP[12]=FALSE
  WAIT SEC 0.5
  B_Anlauf=FALSE
ENDIF   
;ENDFOLD
;
;FOLD Vorbesetzung POT Timer
IF (B_Anlauf==TRUE) THEN
  $TIMER_STOP[12]=TRUE
  $TIMER[12]=0
  $TIMER_STOP[12]=FALSE
ENDIF
;ENDFOLD
;
;FOLD Abfrage Tool_Corr und Base_Corr vorhanden
IF Varstate("TOOL_CORR")<>#Initialized THEN
  USR_Msg(2,#QuitMsg) ; Tool_Corr nicht vorhanden
ENDIF
IF Varstate("BASE_CORR")<>#Initialized THEN
  USR_Msg(3,#QuitMsg) ; BASE_Corr nicht vorhanden
ENDIF
Tool_Corr=$NULLFRAME
Base_Corr=$NULLFRAME
;ENDFOLD
;
;Externe Achsen asynchron schalten
IF MIT_1ExtAchse THEN
  $ASYNC_AXIS= 'B0001'
ENDIF
IF MIT_2ExtAchse THEN
  $ASYNC_AXIS= 'B0011'
ENDIF
IF MIT_2ExtAchse_A7 THEN
  $ASYNC_AXIS= 'B0110'
ENDIF
;
;Merker-Init (Workarround)
INTERRUPT OFF 28
GLOBAL INTERRUPT DECL 28 WHEN B_Merker_Init DO Merker_Init_R()
INTERRUPT ON 28
;
Merker_Init_R()
;
;***************************************************
;
;USER_INIT Module
;BM
IF MIT_BM[1] OR MIT_BM[2] OR MIT_BM[3] THEN
  BM_Interface(#USR_INIT,,,,,,,)
ENDIF
;BU
IF MIT_BU THEN
  BU_M_Interface(#USR_INIT,,,,,,,)
  BU_ACF_Interface(#USR_INIT,,,,,,,)
ENDIF
;BZ
IF MIT_BZ[1] OR MIT_BZ[2] THEN
  BZ_Interface(#USR_INIT,,,,,,,)
ENDIF
;LR
IF MIT_LR THEN
  LR_Interface(#USR_INIT,,,,,,,)
ENDIF
;CZ
IF MIT_CZS[1] OR MIT_CZS[2] OR MIT_CZP[1] OR MIT_CZP[2] OR MIT_CZF[1] THEN
  CZ_Interface(#USR_INIT,,,,,,,)
ENDIF
;DS
IF MIT_DS THEN
  DS_Interface(#USR_INIT,,,,,,,)
ENDIF
;EKI
IF MIT_EKI THEN
  EKI_Interface(#USR_INIT,,,,,,,)
ENDIF
;Kamerasystemschnittstelle
IF B_MIT_VIS THEN
  VIS_Intrface(#USR_INIT,,,,,,,)
ENDIF
;FD
IF MIT_FD[1] OR MIT_FD[2] THEN
  FD_Interface(#USR_INIT,,,,,,,)
ENDIF
;G
G_Interface(#USR_INIT,,,,,,,)
;G
G_Koll_Interface(#USR_INIT,,,,,,,)
;Zeiss
IF B_MIT_ZAI THEN
  ZAI_Interface(#USR_INIT,,,,,,,)
ENDIF
;ScanGun
IF B_MIT_ScanGun THEN
ScanGun_Interface(#USR_INIT,,,,,,,,,,)
ENDIF
;TechBase
IF B_MIT_TechBase THEN
TechBase_Interface(#USR_INIT,,,,,,,,,,)
ENDIF
;INOS
IF B_MIT_INOS THEN
  INOS_ResetSignals()
  INOS_Interface(#USR_INIT,,,,,,,)
ENDIF
;ISRA INIT
IF B_MIT_ISR THEN
  ISRA_PG_INIT()
ENDIF
;KL
IF MIT_KL[1] OR MIT_KL[2] OR MIT_KL[3] THEN
  KL_Interface(#USR_INIT,,,,,,,)
ENDIF
;MS
IF MIT_MS[1] OR MIT_MS[2] THEN
  MS_Interface(#USR_INIT,,,,,,,)
ENDIF
;NK
IF MIT_NK THEN
  NK_Interface(#USR_INIT,,,,,,,)
ENDIF
;NZ
IF MIT_NZS[1] OR MIT_NZS[2] OR MIT_NZH[1] OR MIT_NZH[2] THEN
  NZ_Interface(#USR_INIT,,,,,,,)
ENDIF
;OE
IF MIT_OE[1] OR MIT_OE[2] THEN
  OE_Interface(#USR_INIT,,,,,,,)
ENDIF
;PGR
PGR_Interface(#USR_INIT,,,,,,,)
;POT
POT_Interface(#USR_INIT,,,,,,,)
;PRC
IF B_MIT_PRC THEN
  PRC_Interface(#USR_INIT,,,,,,,)
ENDIF
;RE
IF MIT_RE THEN
  RE_Interface(#USR_INIT,,,,,,,)
ENDIF
;RW
IF MIT_RW[1] OR MIT_RW[2] THEN
  RW_Interface(#USR_INIT,,,,,,,)
ENDIF
;SRF
IF $SR_SAFEMON_ACTIVE THEN 
  SFR_Interface(#USR_INIT,,,,,,,)
ENDIF
;SM
IF MIT_SM[1] OR MIT_SM[2] THEN
  SM_Interface(#USR_INIT,,,,,,,)
ENDIF
;SR
IF MIT_SR THEN
  SR_Interface(#USR_INIT,,,,,,,)
ENDIF
;STP
IF MIT_STP THEN
  STP_Interface(#USR_INIT,,,,,,,)
ENDIF
;SZ+VM
IF MIT_EZ[1] OR MIT_EZ[2] OR MIT_EZ[3] OR MIT_KE[1] OR MIT_KE[2] OR MIT_KE[3] THEN
  SZ_Interface(#USR_INIT,,,,,,,)
  VM_Interface(#USR_INIT,,,,,,,)
ENDIF
;VMT
IF B_MIT_VMT THEN
  VMT_Interface(#USR_INIT,,,,,,,)
ENDIF
;VA+IPO
IF MIT_VA THEN
  VA_Interface(#USR_INIT,,,,,,,)
  IPO_Interface(#USR_INIT,,,,,,,)
ENDIF
;Projekt-Modul
MOD1_Interface(#USR_INIT,,,,,,,)
MOD2_Interface(#USR_INIT,,,,,,,)
MOD3_Interface(#USR_INIT,,,,,,,)
;Conveyor
IF B_MIT_CONV THEN
  vw_conv_usr_r(#USR_INIT,,,,,,,)
ENDIF
;
END
;ENDFOLD
;
;***************************************************
;FOLD USER_ADV
;
DEF  USER_ADV (CMD_SEL:IN,PAR1:IN,PAR2:IN,PAR3:IN,PAR4:IN,PAR5:IN,PAR6:IN,PAR7:IN,PAR8:IN,PAR9:IN,PAR10:IN)
;Aufruf im Vorlauf
;
INT CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9
BOOL PAR10, bRet
;
IF (PAR10==FALSE) THEN
  RETURN
ENDIF  
;
SWITCH CMD_SEL
  CASE 101 ; Hauptgruppe 1, Untergruppe 1
    ;FOLD EZSP
    ;Meldungsausgabe, falls mit WZ 0 geteacht wurde
    CONTINUE
    IF (VW_MPARA_ACT.TOOL_NO<1) THEN
      USR_Msg(1,#QuitMsg)
    ENDIF
    SZ_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD    
;
;***************************************************
  CASE 102 ; Hauptgruppe 1, Untergruppe 2 
    ;FOLD Roboter-Ausgleich
    VM_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 103 ; Hauptgruppe 1, Untergruppe 3
    ;FOLD CZ
    CZ_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)    
    ;ENDFOLD
;
;***************************************************
  CASE 104 ; Hauptgruppe 1, Untergruppe 4
    ;FOLD  MIG/MAG
    MS_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 105 ; Hauptgruppe 1, Untergruppe 5
    ;FOLD Baseverschiebung
    SWITCH PAR1
      CASE 1
        CONTINUE
        Base_Data[31]=BASE_DATA[VW_MPARA_ACT.BASE_NO]
      CASE 11
        CONTINUE
        WHILE ($CYCFLAG[PAR6]==TRUE)
          USR_Msg(7,#QuitMsg) ;Suchlauf Nahsensor defekt
        ENDWHILE
      DEFAULT
      USR_Msg(20,#QuitMsg) ;P1 Falschr Wert
    ENDSWITCH ;von PAR1
    ;ENDFOLD
;
;***************************************************
  CASE 106 ; Hauptgruppe 1, Untergruppe 6
    ;FOLD SFR
    SFR_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) 
    ;ENDFOLD
;
;***************************************************
  CASE 107 ; Hauptgruppe 1, Untergruppe 7
    ;FOLD Teile-Speicher
    IF (PAR5>0) THEN
      IF NOT $IN[PAR5] THEN
        CONTINUE
        $OUT[PAR5]=TRUE
        CONTINUE
        WHILE NOT $IN[PAR5]
          IF (n_USRR_Handle[8]<0) THEN
            USR_Msg(8,#StateMsg) ;Teilespeicher-Nr. von SPS fehlt
          ENDIF  
        ENDWHILE 
        bRet=Clear_KrlMsg(n_USRR_Handle[8])
        n_USRR_Handle[8]=-1   ;Zustandsmeldung zuruecknehmen
      ENDIF
    ENDIF  
    CONTINUE
    $COUNT_I[i_T_SpeicherNr]=$B_IN[BI_T_SpeicherNr]
    CONTINUE
    WHILE ($COUNT_I[i_T_SpeicherNr]<1) OR ($COUNT_I[i_T_SpeicherNr]>254)
      USR_Msg(9,#QuitMsg) ;SPS Speicherposition ungueltig
      CONTINUE
	   $COUNT_I[i_T_SpeicherNr]=$B_IN[BI_T_SpeicherNr]
    ENDWHILE
    CONTINUE
    $B_OUT[BO_T_SpeicherNr]=$B_IN[BI_T_SpeicherNr]
    ;Teile-Speicher-Position 1-254 setzen
    CONTINUE
    IF (BASE_TYPE[VW_MPARA_ACT.BASE_NO]==#BASE) THEN
      CONTINUE
      WHILE (T_Speicher[$COUNT_I[i_T_SpeicherNr]].Z==0.0)
        USR_Msg(10,#QuitMsg) ;Koordinaten fuer Speicherposition ungueltig
      ENDWHILE
	   SWITCH Par1
	     CASE 1
          CONTINUE
          BASE_DATA[31]=T_Speicher[$COUNT_I[i_T_SpeicherNr]]
	     CASE 2
          CONTINUE
          BASE_DATA[31]=BASE_DATA[VW_MPARA_ACT.BASE_NO]:T_Speicher[$COUNT_I[i_T_SpeicherNr]]
	     DEFAULT
          USR_Msg(20,#QuitMsg) ;P1 Falschr Wert
	   ENDSWITCH
    ELSE
      USR_Msg(11,#QuitMsg) ;Base-Type ungueltig
    ENDIF
  ;ENDFOLD
;
;***************************************************
  CASE 108 ; Hauptgruppe 1, Untergruppe 8
;
;***************************************************
  CASE 109 ; Hauptgruppe 1, Untergruppe 9
;
;***************************************************
  CASE 110 ; Hauptgruppe 1, Untergruppe 10
    ;FOLD SR
    SR_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) 
    ;ENDFOLD
;
;***************************************************
  CASE 201 ; Hauptgruppe 2, Untergruppe 1
;
;***************************************************
  CASE 202 ; Hauptgruppe 2, Untergruppe 2
    ;FOLD BZ
    BZ_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) 
    ;ENDFOLD
;
;***************************************************
  CASE 203 ; Hauptgruppe 2, Untergruppe 3  
    ;FOLD NZ
    NZ_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) 
    ;ENDFOLD
;
;***************************************************
  CASE 204 ; Hauptgruppe 2, Untergruppe 4
    ;FOLD Kollisionsueberwachung
      G_Koll_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) 
    ;ENDFOLD
;
;***************************************************
  CASE 205 ; Hauptgruppe 2, Untergruppe 5
    ;FOLD MIG/MAG
    MS_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 206 ; Hauptgruppe 2, Untergruppe 6
    ;FOLD SM
    SM_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)  
    ;ENDFOLD
;
;***************************************************
  CASE 207 ; Hauptgruppe 2, Untergruppe 7
    ;FOLD RE
    RE_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 208 ; Hauptgruppe 2, Untergruppe 8
    ;FOLD STP
    STP_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 209 ; Hauptgruppe 2, Untergruppe 9
    ;FOLD BM
    BM_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 210 ; Hauptgruppe 2, Untergruppe 10 
    ;FOLD RW
    RW_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 301 ; Hauptgruppe 3, Untergruppe 1
    ;FOLD PN-Teilnehmer
    DS_PN_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) 
    ;ENDFOLD
;
;***************************************************
  CASE 302 ; Hauptgruppe 3, Untergruppe 2 
;
;***************************************************
  CASE 303 ; Hauptgruppe 3, Untergruppe 3 
    ;FOLD KL
    KL_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
    ;ENDFOLD
;
;***************************************************
  CASE 304 ; Hauptgruppe 3, Untergruppe 4 
    ;FOLD FD
    FD_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 305 ; Hauptgruppe 3, Untergruppe 5 
    ;FOLD BU  
    BU_M_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
    ;ENDFOLD 
;
;***************************************************
  CASE 306 ; Hauptgruppe 3, Untergruppe 6
    ;FOLD ACF  
    BU_ACF_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
    ;ENDFOLD
;
;***************************************************
  CASE 307 ; Hauptgruppe 3, Untergruppe 7
;
;***************************************************
  CASE 308 ; Hauptgruppe 3, Untergruppe 8
;
;***************************************************
  CASE 309 ; Hauptgruppe 3, Untergruppe 9
;
;***************************************************
  CASE 310 ; Hauptgruppe 3, Untergruppe 10
    ;FOLD MS Naht
    MS_Naht_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 401 ; Hauptgruppe 4, Untergruppe 1
    ;FOLD LR
    LR_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 402 ; Hauptgruppe 4, Untergruppe 2
    ;FOLD NK
    NK_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) 
    ;ENDFOLD
;
;***************************************************
  CASE 403 ; Hauptgruppe 4, Untergruppe 3
;
;***************************************************
  CASE 404 ; Hauptgruppe 4, Untergruppe 4
    ;FOLD OE
    OE_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)  
    ;ENDFOLD
;
;***************************************************
  CASE 405 ; Hauptgruppe 4, Untergruppe 5
    ;FOLD Dehnfugensensor
    CONTINUE
    WHILE (VW_MPARA_ACT.BASE_NO<1)
      USR_Msg(15,#QuitMsg) ; Base-Nr falsch
    ENDWHILE
    ;Sensor 1
    CONTINUE
    WHILE (($ANIN[8]*10)<1.0)
      USR_Msg(5,#QuitMsg) ;Sensor 1 defekt
    ENDWHILE
    CONTINUE
    WHILE (($ANIN[8]*10)>9.5)
      USR_Msg(5,#QuitMsg) ;Sensor 1 defekt
    ENDWHILE
    ;Sensor 2
    CONTINUE
    WHILE (($ANIN[7]*10)<1.0)
      USR_Msg(6,#QuitMsg) ;Sensor 2 defekt
    ENDWHILE
    CONTINUE
    WHILE (($ANIN[7]*10)>9.5)
      USR_Msg(6,#QuitMsg) ;Sensor 2 defekt
    ENDWHILE
    ;Initialisierung
    Dehnfuge=$NULLFRAME
    IF (PAR3>0) THEN
      HM_DF_Steigung=PAR3
      HM_DF_Offset=PAR4
      HM_DF1_Wert=(($ANIN[8]*10)*(HM_DF_Steigung/100)-(HM_DF_Offset/10))
      HM_DF2_Wert=(($ANIN[7]*10)*(HM_DF_Steigung/100)-(HM_DF_Offset/10))
    ELSE
      HM_DF1_Wert=(($ANIN[8]*10)-(HM_DF_Offset/10))
      HM_DF2_Wert=(($ANIN[7]*10)-(HM_DF_Offset/10))
    ENDIF
    ;Korrektur Sensor 1
    IF (PAR1==1) THEN
      IF (PAR2==1) THEN
        Dehnfuge.X=-HM_DF1_Wert
      ENDIF
      IF (PAR2==2) THEN
        Dehnfuge.Y=-HM_DF1_Wert
      ENDIF
      IF (PAR2==3) THEN
        Dehnfuge.Z=-HM_DF1_Wert
      ENDIF
      IF (PAR2==11) THEN
        Dehnfuge.X=HM_DF1_Wert
      ENDIF
      IF (PAR2==12) THEN
        Dehnfuge.Y=HM_DF1_Wert
      ENDIF
      IF (PAR2==13) THEN
        Dehnfuge.Z=HM_DF1_Wert
      ENDIF
    ENDIF
    ;Korrektur Sensor 2
    IF (PAR1==2) THEN
      IF (PAR2==1) THEN
        Dehnfuge.X=-HM_DF2_Wert
      ENDIF
      IF (PAR2==2) THEN
        Dehnfuge.Y=-HM_DF2_Wert
      ENDIF
      IF (PAR2==3) THEN
        Dehnfuge.Z=-HM_DF2_Wert
      ENDIF
      IF (PAR2==11) THEN
        Dehnfuge.X=HM_DF2_Wert
      ENDIF
      IF (PAR2==12) THEN
        Dehnfuge.Y=HM_DF2_Wert
      ENDIF
      IF (PAR2==13) THEN
        Dehnfuge.Z=HM_DF2_Wert
      ENDIF
    ENDIF
      CONTINUE
      BASE_DATA[31]=BASE_DATA[VW_MPARA_ACT.BASE_NO]:Dehnfuge
    ;ENDFOLD
;
;***************************************************


















  CASE 410 ; Hauptgruppe 4, Untergruppe 10
    ;FOLD TR
    TR_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 501 ; Hauptgruppe 5, Untergruppe 1
    ;FOLD MOD1
    MOD1_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 502 ; Hauptgruppe 5, Untergruppe 2
    ;FOLD MOD2
    MOD2_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 503 ; Hauptgruppe 5, Untergruppe 3
    ;FOLD MOD3
    MOD3_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 504 ; Hauptgruppe 5, Untergruppe 4
    ;FOLD CONV
    vw_conv_usr_r(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
   CASE 601 ; Hauptgruppe 6, Untergruppe 1
   

;***************************************************
  CASE 701 ; Hauptgruppe 7, Untergruppe 1
    ;FOLD VMT   
    VMT_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
    ;ENDFOLD
;
;***************************************************
  CASE 702 ; Hauptgruppe 7, Untergruppe 2
  ;FOLD VMT  
  VMT_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
  ;ENDFOLD
;
;***************************************************
  CASE 703 ; Hauptgruppe 7, Untergruppe 3
  ;FOLD VMT  
  VMT_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)  
  ;ENDFOLD
;
;***************************************************
  CASE 704 ; Hauptgruppe 7, Untergruppe 4
  ;FOLD VMT   
  VMT_Interface(#USR_ADV,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)   
  ;ENDFOLD
;
;***************************************************
  CASE 801 ; Hauptgruppe 8, Untergruppe 1
    ;FOLD KG-XML
    VIS_Intrface(#USR_ADV, CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9) ;EKI KUKA--COGNEX
    ;ENDFOLD
;
;***************************************************
  CASE 806 ; Hauptgruppe 8, Untergruppe 6
    ;FOLD INOS
