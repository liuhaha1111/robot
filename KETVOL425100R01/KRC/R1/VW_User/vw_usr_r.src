;***************************************************
  CASE 405 ; Hauptgruppe 4, Untergruppe 5
;
;***************************************************
  CASE 406 ; Hauptgruppe 4, Untergruppe 6
    ;FOLD Spreizmagnet
    WHILE ((PAR1<0) OR (PAR1>80))
      USR_Msg(14,#QuitMsg) ; Spreizmagnete Stromwert zu hoch, Soll 0-80 
    ENDWHILE
    r_SPM_S_Vorg=(PAR1*0.1)
    $ANOUT[12]=r_SPM_S_Vorg ;Stromvorgabe fuer Spreizmagnet
    r_SPM_Z_Vorg=(PAR2*0.1) ;Pulszeitvorgabe
    ;ENDFOLD
;
;***************************************************


















  CASE 410 ; Hauptgruppe 4, Untergruppe 10
    ;FOLD TR
    TR_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
;***************************************************
  CASE 501 ; Hauptgruppe 5, Untergruppe 1
    ;FOLD MOD1
    MOD1_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ;ENDFOLD
;
