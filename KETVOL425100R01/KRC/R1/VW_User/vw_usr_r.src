;***************************************************
  CASE 807 ; Hauptgruppe 8, Untergruppe 7
    ;FOLD INOS
    INOS_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)  
    ;ENDFOLD
;
;***************************************************
  CASE 901,902,903,906,907,908,909,910 ;Hauptgruppe 9, Untergruppe 1-10 
    ;FOLD ZAI
    IF (PAR10==TRUE) THEN
      ZAI_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ENDIF
    ;ENDFOLD   

;
;***************************************************
  CASE 904 ;Hauptgruppe 9, Untergruppe 4 
    ;FOLD ScanGun
    IF (PAR10==TRUE) THEN
      ScanGun_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ENDIF
    ;ENDFOLD 

;
;***************************************************
  CASE 905 ;Hauptgruppe 9, Untergruppe 5 
    ;FOLD TechBase
    IF (PAR10==TRUE) THEN
      TechBase_Interface(#USR_TRIG,CMD_SEL,PAR1,PAR2,PAR3,PAR4,PAR5,PAR6,PAR7,PAR8,PAR9)
    ENDIF
    ;ENDFOLD 

;
