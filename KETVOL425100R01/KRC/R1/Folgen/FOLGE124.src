         Act_P1 = P3
         Act_P2 = P3
         VW(#MPARA,TRUE)
         SPS_FERTIG=FALSE
         TRIGGER WHEN DISTANCE=1 DELAY=0 DO SPS_TRIG(4) PRIO=-1
         VW_USER(#USR_ADV,307,2,0,0,0,0,0,0,0,0,TRUE)
         VW_USR_R(#USR_ADV,307,2,0,0,0,0,0,0,0,0,TRUE)
         PTP P3
         $ADVANCE=1
         WAIT FOR SPS_FERTIG
         VW_USER(#USR_MAIN,307,2,0,0,0,0,0,0,0,0,TRUE)
         VW_USR_R(#USR_MAIN,307,2,0,0,0,0,0,0,0,0,TRUE)
      ;ENDFOLD
   ;ENDFOLD
   ; FOLD ;%{H}
   VW (#VW_AUE_END,TRUE)
   GOTO PENTER
   PEXIT:
END
DEF SPS_TRIG(NO :IN)
   INT NO
   INT VW_STOP
   BOOL UES
   BOOL ANA_UES
   BOOL ANA_TRIG
   VW_STOP=$VW_PSPS_STOP
   UES=FALSE
   ANA_UES=FALSE
   ANA_TRIG=FALSE
   IF ((NO>10000) AND (NO<20000)) THEN
      NO=NO-10000
      UES=TRUE
   ENDIF
   IF ((NO>20000) AND (NO<30000)) THEN
      NO=NO-20000
      ANA_TRIG=TRUE
   ENDIF
   IF NO>30000 THEN
      NO=NO-30000
      ANA_UES=TRUE
      ANA_TRIG=TRUE
   ENDIF
   ; FOLD ;%{H}
   IF ((VW_STOP B_AND 'B0001') > 0) THEN
      ;-- Trigger vorzeitig geschaltet (delay < 0) oder MStep
      IF (((VW_STOP B_AND 'B0110') > 0) AND ($MODE_OP<>#EX)) THEN
         ;-- MStep oder BCO Bewegung
         HALT
      ENDIF
   ENDIF
   ; ENDFOLD
   IF (SEARCH_END) THEN
      SEARCH_END = FALSE
      INTERRUPT OFF 39
   ENDIF
   SWITCH NO
      CASE 1
         ;FOLD SPS_TRIG1 {H}
            VALCYCFL30=$CYCFLAG[254]
            $CYCFLAG[254]=(TRUE) AND $CYCFLAG[255] OR ($TIMER[61]<0)
            VW(#FB_CHECK,TRUE)
            VW_USER(#USR_TRIG,307,1,0,0,0,0,0,0,0,0,TRUE)
            VW_USR_R(#USR_TRIG,307,1,0,0,0,0,0,0,0,0,TRUE)
         ;ENDFOLD
      CASE 2
         ;FOLD SPS_TRIG2 {H}
            VALCYCFL30=$CYCFLAG[254]
            $CYCFLAG[254]=(TRUE) AND $CYCFLAG[255] OR ($TIMER[61]<0)
            VW(#FB_CHECK,TRUE)
            SEL_RES=SELECT(#MAKRO,50,TRUE,,,,,FALSE)
            SEL_RES=SELECT(#MAKRO,46,TRUE,,,,,FALSE)
            SEL_RES=SELECT(#MAKRO,45,TRUE,,,,,FALSE)
            $OUT[15] = FALSE
            $LOOP_MSG[]="E23"
            $LOOP_CONT=TRUE
            WAIT FOR ($IN[23]) OR (NOT $LOOP_CONT AND ($MODE_OP<>#EX))
            $LOOP_MSG[]="                                                                                                                                "
            VALCYCFL30=$CYCFLAG[254]
            $CYCFLAG[254]=($CYCFLAG[30]) AND $CYCFLAG[255] OR ($TIMER[61]<0)
            VW(#FB_CHECK,TRUE)
         ;ENDFOLD
      CASE 3
         ;FOLD SPS_TRIG3 {H}
            VALCYCFL30=$CYCFLAG[254]
            $CYCFLAG[254]=(TRUE) AND $CYCFLAG[255] OR ($TIMER[61]<0)
            VW(#FB_CHECK,TRUE)
            $FLAG[944] = FALSE
            $FLAG[945] = FALSE
            $FLAG[946] = FALSE
            $FLAG[947] = FALSE
            $FLAG[948] = FALSE
            $FLAG[949] = FALSE
            $FLAG[950] = FALSE
            $FLAG[951] = FALSE
            $FLAG[952] = FALSE
            $FLAG[944] = NOT $IN[20] AND NOT $IN[21] AND $IN[121] AND NOT $IN[122] AND NOT $IN[123]
            $FLAG[945] = $IN[20] AND NOT $IN[21] AND $IN[121] AND NOT $IN[122] AND NOT $IN[123]
            $FLAG[946] = NOT $IN[20] AND $IN[21] AND $IN[121] AND NOT $IN[122] AND NOT $IN[123]
            $FLAG[947] = NOT $IN[20] AND NOT $IN[21] AND NOT $IN[121] AND $IN[122] AND NOT $IN[123]
            $FLAG[948] = $IN[20] AND NOT $IN[21] AND NOT $IN[121] AND $IN[122] AND NOT $IN[123]
            $FLAG[949] = NOT $IN[20] AND $IN[21] AND NOT $IN[121] AND $IN[122] AND NOT $IN[123]
            $FLAG[950] = NOT $IN[20] AND NOT $IN[21] AND NOT $IN[121] AND NOT $IN[122] AND $IN[123]
            $FLAG[951] = $IN[20] AND NOT $IN[21] AND NOT $IN[121] AND NOT $IN[122] AND $IN[123]
            $FLAG[952] = NOT $IN[20] AND $IN[21] AND NOT $IN[121] AND NOT $IN[122] AND $IN[123]
            $LOOP_MSG[]="E23"
            $LOOP_CONT=TRUE
            WAIT FOR ($IN[23]) OR (NOT $LOOP_CONT AND ($MODE_OP<>#EX))
            $LOOP_MSG[]="                                                                                                                                "
            VALCYCFL30=$CYCFLAG[254]
            $CYCFLAG[254]=($CYCFLAG[30]) AND $CYCFLAG[255] OR ($TIMER[61]<0)
            VW(#FB_CHECK,TRUE)
         ;ENDFOLD
      CASE 4
         ;FOLD SPS_TRIG4 {H}
            VALCYCFL30=$CYCFLAG[254]
            $CYCFLAG[254]=(TRUE) AND $CYCFLAG[255] OR ($TIMER[61]<0)
            VW(#FB_CHECK,TRUE)
