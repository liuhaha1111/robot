      ;FOLD 13: F944 = !E20 & !E21 & E121 & !E122 & ! E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F944 = !E20 & !E21 & E121 & !E122 & ! E123,3:BOASG
      ;ENDFOLD
