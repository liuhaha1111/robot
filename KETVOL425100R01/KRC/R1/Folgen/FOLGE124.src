      ;FOLD 15: F945 = E20 & !E21 & E121 & !E122 & ! E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F945 = E20 & !E21 & E121 & !E122 & ! E123,3:BOASG
      ;ENDFOLD
      ;FOLD 16: -- TCP-Pruefen G1 -- ;%{SE}%MKUKATPVW %CVW_COM %VCOMMENT %P 2:-- TCP-Pruefen G1 --,3:VW_COMMENT
      ;ENDFOLD
      ;FOLD 17: F946 = !E20 & E21 & E121 & !E122 & ! E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F946 = !E20 & E21 & E121 & !E122 & ! E123,3:BOASG
      ;ENDFOLD
      ;FOLD 18: -- Wartugsstellung G2 -- ;%{SE}%MKUKATPVW %CVW_COM %VCOMMENT %P 2:-- Wartugsstellung G2 --,3:VW_COMMENT
      ;ENDFOLD
      ;FOLD 19: F947 = !E20 & !E21 & !E121 & E122 & ! E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F947 = !E20 & !E21 & !E121 & E122 & ! E123,3:BOASG
      ;ENDFOLD
