      ;FOLD 21: F948 = E20 & !E21 & !E121 & E122 & ! E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F948 = E20 & !E21 & !E121 & E122 & ! E123,3:BOASG
      ;ENDFOLD
      ;FOLD 22: -- TCP-Pruefen G2 -- ;%{SE}%MKUKATPVW %CVW_COM %VCOMMENT %P 2:-- TCP-Pruefen G2 --,3:VW_COMMENT
      ;ENDFOLD
      ;FOLD 23: F949 = !E20 & E21 & !E121 & E122 & ! E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F949 = !E20 & E21 & !E121 & E122 & ! E123,3:BOASG
      ;ENDFOLD
      ;FOLD 24: -- Wartugsstellung G3 -- ;%{SE}%MKUKATPVW %CVW_COM %VCOMMENT %P 2:-- Wartugsstellung G3 --,3:VW_COMMENT
      ;ENDFOLD
      ;FOLD 25: F950 = !E20 & !E21 & !E121 & !E122 & E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F950 = !E20 & !E21 & !E121 & !E122 & E123,3:BOASG
      ;ENDFOLD
      ;FOLD 26: -- Werkzeugwechsel G3 -- ;%{SE}%MKUKATPVW %CVW_COM %VCOMMENT %P 2:-- Werkzeugwechsel G3 --,3:VW_COMMENT
      ;ENDFOLD
      ;FOLD 27: F951 = E20 & !E21 & !E121 & !E122 & E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F951 = E20 & !E21 & !E121 & !E122 & E123,3:BOASG
      ;ENDFOLD
      ;FOLD 28: -- TCP-Pruefen G3 -- ;%{SE}%MKUKATPVW %CVW_COM %VCOMMENT %P 2:-- TCP-Pruefen G3 --,3:VW_COMMENT
      ;ENDFOLD
      ;FOLD 29: F952 = !E20 & E21 & !E121 & !E122 & E123 ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F952 = !E20 & E21 & !E121 & !E122 & E123,3:BOASG
      ;ENDFOLD
      ;FOLD 30: WARTE BIS E23 ;%{SE}%MKUKATPVW %CVW_SPS %VWBOASG %P 2:WARTE BIS E23,3:WBOASG
      ;ENDFOLD
      ;FOLD 31: FB PSPS = M30 ;%{SE}%MKUKATPVW %CVW_SPS %VFBPSPS %P 2:FB PSPS = M30,3:FBPSPS
      ;ENDFOLD
      ;FOLD UP81 = (F944 + F948) & M174 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP81 = (F944 + F948) & M174,3:UP
      ;ENDFOLD
      ;FOLD UP82 = (F945 + F947) & M173 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP82 = (F945 + F947) & M173,3:UP
      ;ENDFOLD
      ;FOLD UP83 = (F950) & M173 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP83 = (F950) & M173,3:UP
      ;ENDFOLD
      ;FOLD UP84 = (F950) & M174 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP84 = (F950) & M174,3:UP
      ;ENDFOLD
      ;FOLD UP85 = (F944 + F951) & M175 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP85 = (F944 + F951) & M175,3:UP
      ;ENDFOLD
      ;FOLD UP86 = (F947) & M175 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP86 = (F947) & M175,3:UP
      ;ENDFOLD
      ;FOLD UP112 = F944 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP112 = F944,3:UP
      ;ENDFOLD
      ;FOLD UP201 = F945 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP201 = F945,3:UP
      ;ENDFOLD
      ;FOLD UP113 = F947 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP113 = F947,3:UP
      ;ENDFOLD
      ;FOLD UP202 = F948 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP202 = F948,3:UP
      ;ENDFOLD
      ;FOLD UP114 = F950 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP114 = F950,3:UP
      ;ENDFOLD
      ;FOLD UP203 = F951 ;%{SE}%MKUKATPVW %CVW_SPS %VUP %P 2:UP203 = F951,3:UP
      ;ENDFOLD
      ;FOLD {H}
         VW_MPARA_ACT=P2_D
         Act_P1 = P2
         Act_P2 = P2
         VW(#MPARA,TRUE)
         SPS_FERTIG=FALSE
         TRIGGER WHEN DISTANCE=1 DELAY=-50 DO SPS_TRIG(3) PRIO=-1
         PTP P2
         $ADVANCE=1
         WAIT FOR SPS_FERTIG
         SEL_RES=SELECT(#UP,81,($FLAG[944] OR $FLAG[948]) AND $CYCFLAG[174])
         SEL_RES=SELECT(#UP,82,($FLAG[945] OR $FLAG[947]) AND $CYCFLAG[173])
         SEL_RES=SELECT(#UP,83,($FLAG[950]) AND $CYCFLAG[173])
         SEL_RES=SELECT(#UP,84,($FLAG[950]) AND $CYCFLAG[174])
         SEL_RES=SELECT(#UP,85,($FLAG[944] OR $FLAG[951]) AND $CYCFLAG[175])
         SEL_RES=SELECT(#UP,86,($FLAG[947]) AND $CYCFLAG[175])
         SEL_RES=SELECT(#UP,112,$FLAG[944])
         SEL_RES=SELECT(#UP,201,$FLAG[945])
         SEL_RES=SELECT(#UP,113,$FLAG[947])
         SEL_RES=SELECT(#UP,202,$FLAG[948])
         SEL_RES=SELECT(#UP,114,$FLAG[950])
         SEL_RES=SELECT(#UP,203,$FLAG[951])
      ;ENDFOLD
   ;ENDFOLD
   ;FOLD PTP VB=100% VE=0% ACC=100% RobWzg=1 Base=0 SPSTrig=0[1/100s] P ;%{P}%MKUKATPVW,%CMOVE8,%VPTP,%P 1:1, 2: VB=, 3:100, 4:%, 5: VE=, 6:0, 7:%, 8: ACC=, 9:100, 10:%, 11: RobWzg=, 12:1, 13: Base=, 14:0, 15: SPSTrig=, 16:0, 17:[1/100s], 18: P, 19:3, 20:-1, 21:4
      ;FOLD 1: FB PSPS = EIN ;%{SE}%MKUKATPVW %CVW_SPS %VFBPSPS %P 2:FB PSPS = EIN,3:FBPSPS
      ;ENDFOLD
      ;FOLD 2: TECH3 Roboter LPTK-Folge Techaufruf=EIN ;%{SE}%MKUKATPVW %CVW_SPS %VUSER %P 2:TECH3.Roboter CN=307 P1=2 P2=0 P3=0 P4=0 P5=0 P6=0 P7=0 P8=0 P9=0 P10=EIN,3:USER
      ;ENDFOLD
      ;FOLD {H}
