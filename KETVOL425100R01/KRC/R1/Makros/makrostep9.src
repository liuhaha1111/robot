      ;FOLD T8 ( !F334 ) = -2[1/10Sek] ;%{SE}%MKUKATPVW %CVW_SPS %VTASG %P 2:T8 ( !F334 ) = -2[1/10Sek], 3: TASG
         VW(#SET_TIME,NOT $FLAG[334],8,0,-2)
      ;ENDFOLD
      ;FOLD -- Hilfsflag SK Programmwechsel -- ;%{SE}%MKUKATPVW %CVW_COM %VCOMMENT %P 2:-- Hilfsflag SK Programmwechsel --, 3: VW_COMMENT
      ;ENDFOLD
      ;FOLD F334 = EIN ;%{SE}%MKUKATPVW %CVW_SPS %VBOASG %P 2:F334 = EIN, 3: BOASG
         $FLAG[334] = TRUE
      ;ENDFOLD
      ;FOLD t9 ( EIN ) = STOP ;%{SE}%MKUKATPVW %CVW_SPS %VTSTOP %P 2:t9 ( EIN ) = STOP, 3: TSTOP
         VW(#SET_TIME,TRUE,9,1,0)
      ;ENDFOLD
      ;FOLD Schritt 1 = T8 & A4039 & A3506 & A3505 ;%{SE}%MKUKATPVW %CVW_SPS %VST_CON %P 2:Schritt 1 = T8 & A4039 & A3506 & A3505, 3: ST_CON
         IF $TIMER_FLAG[8] AND $OUT[4039] AND $OUT[3506] AND $OUT[3505] THEN
            PREV_STEP[9] = APP_INT_STEP[9]
            APP_INT_STEP[9] = 1
         ENDIF
      ;ENDFOLD
   ;ENDFOLD
   ; FOLD ;%{H}
   DEFAULT
   HMeldung ("StepNotAvailableInModul")
   APP_INT_STEP[9]=1
   ENDSWITCH
   END
   DEF HMeldung (Meld[]:IN)
     CHAR Meld[]
     DECL KrlMsg_T Msg
     DECL KrlMsgPar_T Par[3]
     DECL KrlMsgOpt_T Opt
     INT nHandle
     BOOL dummy
     dummy=STRCOPY(Msg.Msg_txt[],Meld[])
     Msg.Modul[]="MAKROSTEP"
     Msg.Nr=111
     Par[1].Par_type=#Value
     Par[1].Par_Txt[] = "9"
     Par[2].Par_type=#Value
     Par[2].Par_Int = PREV_STEP[9]
     Opt = {VL_Stop TRUE, Clear_P_Reset TRUE, Log_To_DB FALSE}
     nHandle = Set_KrlMsg (#Notify, Msg, Par[], Opt)
     WAIT SEC 0.2
END
; ENDFOLD